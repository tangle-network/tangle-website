{
  "schema_version": "2026-06-16",
  "name": "Tangle",
  "description": "AI service infrastructure: model routing, sandboxed agent runtime, browser automation, Blueprint services, and x402 payment rails.",
  "homepage": "https://tangle.tools/",
  "llms": "https://tangle.tools/llms.txt",
  "openapi": "https://router.tangle.tools/openapi.json",
  "docs": "https://docs.tangle.tools/",
  "support": "mailto:hello@tangle.tools",
  "npm_packages": [
    {
      "name": "@tangle-network/tcloud",
      "purpose": "Router SDK and CLI for model routing, billing headers, and agent service calls.",
      "install": "npm install @tangle-network/tcloud",
      "bin": "tcloud"
    },
    {
      "name": "@tangle-network/sandbox",
      "purpose": "TypeScript SDK for creating and driving isolated agent sandboxes.",
      "install": "npm install @tangle-network/sandbox"
    },
    {
      "name": "@tangle-network/browser-agent-driver",
      "purpose": "Browser automation driver and CLI for agentic web tasks.",
      "install": "npm install -g @tangle-network/browser-agent-driver",
      "bin": "bad"
    }
  ],
  "safe_discovery_calls": [
    "GET https://router.tangle.tools/api/health",
    "GET https://router.tangle.tools/v1/models",
    "GET https://tangle.tools/.well-known/tangle-browser-agent.json",
    "GET https://sandbox.tangle.tools/health",
    "GET https://sandbox.tangle.tools/.well-known/tangle-agent.json",
    "GET https://sandbox.tangle.tools/v1/public-templates",
    "GET https://sandbox.tangle.tools/v1/public-templates/featured"
  ],
  "products": [
    {
      "name": "Tangle Router",
      "url": "https://router.tangle.tools/",
      "manifest": "https://router.tangle.tools/.well-known/tangle-agent.json",
      "openapi": "https://router.tangle.tools/openapi.json",
      "npm": "@tangle-network/tcloud"
    },
    {
      "name": "Tangle Sandbox",
      "url": "https://sandbox.tangle.tools/",
      "manifest": "https://sandbox.tangle.tools/.well-known/tangle-agent.json",
      "npm": "@tangle-network/sandbox"
    },
    {
      "name": "Browser Agent",
      "url": "https://tangle.tools/services/browser-agent",
      "manifest": "https://tangle.tools/.well-known/tangle-browser-agent.json",
      "npm": "@tangle-network/browser-agent-driver",
      "cli": "bad"
    },
    {
      "name": "Agent Builder",
      "url": "https://agents.tangle.tools/",
      "manifest": "https://agents.tangle.tools/.well-known/tangle-agent.json",
      "openapi": "https://agents.tangle.tools/openapi.json"
    }
  ],
  "install": [
    "npm install @tangle-network/tcloud",
    "npm install @tangle-network/sandbox",
    "npm install -g @tangle-network/browser-agent-driver"
  ],
  "environment": {
    "api_key": "TANGLE_API_KEY"
  }
}

  <script is:inline>
    function createGridReveal(sectionId) {
      new p5((p) => {
        const CELL_SIZE = 40;
        const STARTING_STROKE_ALPHA = 1;
        const STARTING_FILL_ALPHA = 0.5;
        const AMT_FADE_PER_FRAME = 5;
        const MAX_CELLS = 150;
        const REVEAL_INTERVAL = 1000;
        const DYNAMIC_FADE_THRESHOLD = 100;

        let numRows, numCols, allNeighbors = [], revealInterval, lastRevealTime = 0, dynamicFadeRate = AMT_FADE_PER_FRAME;

        p.setup = function() {
          let section = document.getElementById(sectionId);
          if (!section) return;
          let cnv = p.createCanvas(section.offsetWidth, section.offsetHeight);
          cnv.parent(sectionId);
          cnv.style("position", "absolute");
          cnv.style("top", "0");
          cnv.style("left", "0");
          cnv.style("width", section.offsetWidth + "px");
          cnv.style("height", section.offsetHeight + "px");
          cnv.style("z-index", "-1");
          cnv.style("pointer-events", "none");
          p.strokeWeight(1);
          numRows = Math.ceil(section.offsetHeight / CELL_SIZE);
          numCols = Math.ceil(section.offsetWidth / CELL_SIZE);
          revealInterval = setInterval(attemptReveal, REVEAL_INTERVAL);
        };

        p.draw = function() {
          p.clear();
          if (allNeighbors.length > DYNAMIC_FADE_THRESHOLD) {
            dynamicFadeRate = AMT_FADE_PER_FRAME * (1 + (allNeighbors.length - DYNAMIC_FADE_THRESHOLD) / 50);
          } else {
            dynamicFadeRate = AMT_FADE_PER_FRAME;
          }
          for (let neighbor of allNeighbors) {
            let nx = neighbor.col * CELL_SIZE;
            let ny = neighbor.row * CELL_SIZE;
            neighbor.opacity = Math.max(0, neighbor.opacity - dynamicFadeRate);
            p.stroke(255, 255, 255, neighbor.opacity * (STARTING_STROKE_ALPHA / 100));
            p.fill(255, 255, 255, neighbor.opacity * (STARTING_FILL_ALPHA / 100));
            p.rect(nx, ny, CELL_SIZE, CELL_SIZE);
          }
          allNeighbors = allNeighbors.filter(n => n.opacity > 0);
        };

        function attemptReveal() {
          if (allNeighbors.length < MAX_CELLS) {
            let row = Math.floor(p.random(numRows));
            let col = Math.floor(p.random(numCols));
            let capacityRatio = allNeighbors.length / MAX_CELLS;
            let maxNew = Math.max(1, Math.floor(8 * (1 - capacityRatio)));
            allNeighbors.push(...getRandomNeighbors(row, col, maxNew));
          }
        }

        function getRandomNeighbors(row, col, maxN) {
          let pot = [];
          for (let dr = -1; dr <= 1; dr++) {
            for (let dc = -1; dc <= 1; dc++) {
              let nr = row + dr, nc = col + dc;
              if ((dr !== 0 || dc !== 0) && nr >= 0 && nr < numRows && nc >= 0 && nc < numCols) {
                pot.push({ row: nr, col: nc, opacity: 100 });
              }
            }
          }
          for (let i = pot.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [pot[i], pot[j]] = [pot[j], pot[i]];
          }
          return pot.slice(0, Math.min(maxN, pot.length));
        }

        p.windowResized = function() {
          let section = document.getElementById(sectionId);
          if (!section) return;
          p.resizeCanvas(section.offsetWidth, section.offsetHeight);
          numRows = Math.ceil(section.offsetHeight / CELL_SIZE);
          numCols = Math.ceil(section.offsetWidth / CELL_SIZE);
        };
      });
    }

    document.addEventListener("DOMContentLoaded", function() {
      createGridReveal('section_wrapper_1');
      createGridReveal('section_wrapper_2');
    });
  </script>


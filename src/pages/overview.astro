      <div class="wf-container-large hero-container">
        <div class="wf-hero-text wf-container-large">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Tangle Protocol</div>
            </div>
          </div>
          <h1 class="wf-h1">The Decentralized Cloud<br/>for AI Services</h1>

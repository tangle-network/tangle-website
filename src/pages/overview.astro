            <stop offset="50%" stop-color="rgba(79,70,229,0.7)"/>
            <stop offset="100%" stop-color="rgba(79,70,229,0.18)"/>
          </linearGradient>
          <linearGradient id="ov-life-node" x1="0" y1="0" x2="0" y2="1">

---
import BaseLayout from '../layouts/BaseLayout.astro';

const controls = [
  {
    title: 'Access control',
    body: 'Production access is limited to approved personnel with MFA, role-based access, and documented onboarding and offboarding.',
  },
  {
    title: 'Change management',
    body: 'Code and infrastructure changes are reviewed before release, tracked in source control, and covered by automated checks where applicable.',
  },
  {
    title: 'Data protection',
    body: 'Tangle uses TLS for data in transit, encryption at rest where supported by the underlying storage service, and scoped secrets for hosted runtimes.',
  },
  {
    title: 'Sandbox isolation',
    body: 'Agent workloads run in isolated execution environments with bounded filesystem, process, and network access based on the product configuration.',
  },
  {
    title: 'Vulnerability management',
    body: 'We use dependency review, secret scanning, security testing, penetration-test remediation tracking, and targeted code review for sensitive changes.',
  },
  {
    title: 'Logging and monitoring',
    body: 'Security-relevant events are logged, reviewed, and retained according to internal policy so incidents can be investigated and remediated.',
  },
  {
    title: 'Vendor management',
    body: 'Sub-processors are reviewed for business purpose, data processed, region, and contract basis before handling customer data.',
  },
  {
    title: 'Incident response',
    body: 'Security events are triaged by severity, assigned an owner, and tracked through containment, remediation, customer communication, and review.',
  },
];

const productSurfaces = [
  { label: 'Blueprint Agent', href: 'https://ai.tangle.tools' },
  { label: 'Sandbox infrastructure', href: 'https://sandbox.tangle.tools' },
  { label: 'Router infrastructure', href: 'https://router.tangle.tools' },
  { label: 'Browser Agent', href: 'https://browser.tangle.tools' },
  { label: 'Audit Agent', href: 'https://audits.tangle.tools' },
];
---

<BaseLayout
  title="Security"
  description="Public security practices for Tangle Technologies, Inc. products, infrastructure, and hosted agent services."
>
  <div class="security-page">
    <section class="security-hero">
      <div class="security-hero-copy">
        <p class="security-eyebrow">Security</p>
        <h1>Security practices for Tangle products</h1>
        <p>
          Tangle Technologies, Inc. maintains a security program for hosted SaaS products, agent infrastructure, sandbox execution, model routing, and customer data handling.
        </p>
        <div class="security-actions" aria-label="Security links">
          <a href="mailto:security@tangle.tools" class="security-primary">Contact security</a>
          <a href="/sub-processors" class="security-secondary">Sub-processors</a>
          <a href="/status" class="security-secondary">Status</a>
        </div>
      </div>

      <aside class="security-summary" aria-label="Security program summary">
        <div>
          <span>Program owner</span>
          <strong>Tangle Technologies, Inc.</strong>
        </div>
        <div>
          <span>Security contact</span>
          <a href="mailto:security@tangle.tools">security@tangle.tools</a>
        </div>
        <div>
          <span>Compliance program</span>
          <strong>SOC 2 Type II audit program in progress</strong>
        </div>
        <div>
          <span>Last updated</span>
          <strong>June 29, 2026</strong>
        </div>
      </aside>
    </section>

    <section class="security-section security-section--light">
      <div class="security-section-head">
        <p class="security-eyebrow">Coverage</p>
        <h2>Products covered by this page</h2>
      </div>
      <div class="security-surface-list">
        {productSurfaces.map((surface) => (
          <a href={surface.href} target="_blank" rel="noopener noreferrer">
            <span>{surface.label}</span>
            <small>{surface.href.replace('https://', '')}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="security-section">
      <div class="security-section-head">
        <p class="security-eyebrow">Controls</p>
        <h2>How we protect customer data and hosted services</h2>
      </div>
      <div class="security-control-grid">
        {controls.map((control) => (
          <article class="security-control">
            <h3>{control.title}</h3>
            <p>{control.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="security-section security-section--split">
      <div>
        <p class="security-eyebrow">Data handling</p>
        <h2>Sandbox and model-vendor data handling</h2>
        <p>
          Customer workloads may include prompts, files, command output, screenshots, environment variables, and agent traces.
          Tangle limits processing to the services customers request and uses product-level controls to reduce accidental exposure.
        </p>
        <p>
          Before outbound model-vendor calls, Tangle redaction controls are designed to remove authentication credentials, payment-card numbers, and government identifiers where detected.
          Customers choose the model vendor used by their workflow.
        </p>
      </div>
      <div>
        <p class="security-eyebrow">Compliance</p>
        <h2>Reports and questionnaires</h2>
        <p>
          Tangle is maintaining SOC 2 Type II readiness materials and audit evidence.
          Formal reports, customer questionnaires, and additional security documentation may be shared under NDA when appropriate.
        </p>
        <p>
          Email <a href="mailto:security@tangle.tools">security@tangle.tools</a> for report requests, responsible disclosure, vendor review, or security questionnaire routing.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .security-page {
    min-height: 100vh;
    background: #f4f4f9;
    color: #111827;
  }

  .security-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 27rem);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
    max-width: 74rem;
    margin: 0 auto;
    padding: clamp(7rem, 12vw, 9rem) 5% clamp(3rem, 6vw, 5rem);
  }

  .security-hero-copy h1,
  .security-section-head h2,
  .security-section--split h2 {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0;
    color: #111827;
  }

  .security-hero-copy h1 {
    max-width: 48rem;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.97;
    font-weight: 800;
  }

  .security-hero-copy p {
    max-width: 43rem;
    margin: 1.25rem 0 0;
    color: #3a3a50;
    font-size: clamp(1rem, 1.45vw, 1.2rem);
    line-height: 1.65;
  }

  .security-eyebrow {
    margin: 0 0 0.85rem;
    color: #4338CA;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .security-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .security-primary,
  .security-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.7rem 1rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
  }

  .security-primary {
    background: #4F46E5;
    color: #ffffff;
  }

  .security-secondary {
    background: #ffffff;
    color: #3730A3;
    border: 1px solid rgba(79, 70, 229, 0.18);
  }

  .security-summary {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 60px rgba(15, 23, 42, 0.08);
  }

  .security-summary div {
    display: grid;
    gap: 0.25rem;
    padding: 0.9rem;
    border-radius: 6px;
    background: #f7f7fb;
  }

  .security-summary span {
    color: #5e5e7a;
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .security-summary strong,
  .security-summary a {
    color: #111827;
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .security-section {
    max-width: 74rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) 5%;
  }

  .security-section--light {
    max-width: none;
    border-block: 1px solid rgba(25, 28, 36, 0.08);
    background: #ffffff;
  }

  .security-section--light > * {
    max-width: 74rem;
    margin-inline: auto;
  }

  .security-section-head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .security-section-head h2,
  .security-section--split h2 {
    max-width: 48rem;
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    line-height: 1.08;
    font-weight: 800;
  }

  .security-surface-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .security-surface-list a,
  .security-control {
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
  }

  .security-surface-list a {
    display: grid;
    gap: 0.35rem;
    min-height: 6.5rem;
    padding: 1rem;
    color: #111827;
    text-decoration: none;
  }

  .security-surface-list span {
    font-weight: 800;
  }

  .security-surface-list small {
    color: #5e5e7a;
    overflow-wrap: anywhere;
  }

  .security-control-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .security-control {
    min-height: 14rem;
    padding: 1.1rem;
  }

  .security-control h3 {
    margin: 0 0 0.65rem;
    color: #111827;
    font-size: 1rem;
    line-height: 1.25;
  }

  .security-control p,
  .security-section--split p {
    margin: 0;
    color: #3a3a50;
    line-height: 1.62;
  }

  .security-section--split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .security-section--split > div {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
  }

  .security-section--split a {
    color: #3730A3;
    font-weight: 700;
  }

  @media (max-width: 960px) {
    .security-hero,
    .security-section--split {
      grid-template-columns: 1fr;
    }

    .security-surface-list,
    .security-control-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .security-hero,
    .security-section {
      padding-inline: 1rem;
    }

    .security-surface-list,
    .security-control-grid {
      grid-template-columns: 1fr;
    }

    .security-control {
      min-height: auto;
    }
  }
</style>


---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get only drafts
const drafts = await getCollection('blog', ({ data }) => data.draft === true);
const sortedDrafts = drafts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Draft Previews" description="Internal draft previews">
  <section class="max-w-5xl mx-auto px-4 py-16">
    <!-- Preview Banner -->
    <div class="mb-8 rounded-xl border-2 border-amber-500/50 bg-amber-500/10 px-6 py-4">
      <div class="flex items-center gap-3">
        <span class="text-2xl">🔒</span>
        <div>
          <p class="font-semibold text-amber-400">Internal Only</p>
          <p class="text-sm text-amber-300/80">These drafts are not visible on the public blog.</p>
        </div>
      </div>
    </div>

    <div class="mb-12">
      <p class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-2">Drafts</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">Draft Previews</h1>
      <p class="text-text-secondary">
        {sortedDrafts.length} draft{sortedDrafts.length !== 1 ? 's' : ''} pending review.
      </p>
    </div>

    {sortedDrafts.length === 0 ? (
      <div class="rounded-xl border border-white/5 bg-[#141430] p-8 text-center">
        <p class="text-text-secondary mb-4">No drafts pending.</p>
        <a href="/blog" class="text-brand-cool hover:underline">← Back to published posts</a>
      </div>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {sortedDrafts.map((post) => (
          <a href={`/preview/${post.data.slug}`} class="group block relative">
            <div class="absolute right-3 top-3 z-10 rounded-full bg-amber-500 px-2 py-0.5 text-xs font-bold text-black">
              DRAFT
            </div>
            <article class="rounded-xl border border-amber-500/30 bg-[#141430] overflow-hidden transition-all hover:border-amber-500/50 hover:shadow-lg hover:shadow-amber-500/5">
              {post.data.coverImage && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.data.coverImage}
                    alt={post.data.imageAlt || post.data.title}
                    class="w-full h-full object-cover transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                {post.data.series && (
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-brand-primary/15 text-brand-cool">
                      {post.data.series}
                    </span>
                  </div>
                )}
                <h2 class="text-lg font-semibold mb-2 group-hover:text-amber-400 transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-sm text-text-secondary mb-4 line-clamp-3">{post.data.summary}</p>
                <time datetime={post.data.date} class="text-xs text-text-muted">
                  {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </article>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

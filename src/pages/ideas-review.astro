---
// Internal interaction-ideas gallery. Unlinked, noindex. Ten motion/graphic
// ideas as live prototypes, numbered by my ranking (story-value / effort).
// Real model IDs for #08 come from the router catalog snapshot.
import catalog from '../data/router-models.json';
const orbitModels = catalog.ids.filter((id) => id.length < 26).slice(40, 52);

const ideas = [
  { n: 1, title: 'Harness rail emits traces', effort: 'M', wow: 'high', cred: 'high', verdict: 'shipped on homepage', note: 'Tiles light RUNNING with scroll; each emits a filament that converges to one trace node. Below: auto-looping miniature.' },
  { n: 2, title: 'Convergence handoff', effort: 'S', wow: 'med', cred: 'high', verdict: 'shipped on homepage', note: 'The moment sandbox output becomes intelligence input. One node, one label. Part of the same loop below.' },
  { n: 3, title: 'Real component echoes', effort: 'M', wow: 'med', cred: 'highest', verdict: 'build next', note: 'Schematic twins of actual Intelligence components (ConfidenceBar, OptimizationLineage from products/intelligence/web). Marketing speaks the product’s visual language.' },
  { n: 4, title: 'Cutout knot object', effort: 'M', wow: 'med', cred: 'med', verdict: 'candidate', note: 'A background-free knot drawn in SVG, rotating slowly. No raster, no sticker: an object, not an image.' },
  { n: 5, title: 'Trace spine across sections', effort: 'M', wow: 'high', cred: 'high', verdict: 'candidate', note: 'One filament runs down the page edge, crossing section boundaries, drawn by scroll. The whole page becomes one diagram. Scroll inside the frame.' },
  { n: 6, title: 'TraceTree, real', effort: 'L', wow: 'high', cred: 'highest', verdict: 'blocked on demo workspace', note: 'The actual 54KB TraceTree component screenshotted from a live workspace. Below is only the schematic shape; the real thing needs a populated demo.' },
  { n: 7, title: 'Interactive loop machine', effort: 'L (Rive) / M (code)', wow: 'high', cred: 'med', verdict: 'candidate', note: 'The run→trace→analyze→propose→prove→ship cycle reacting to hover. Code stand-in below; Rive would add physics and state.' },
  { n: 8, title: 'Model constellation on hover', effort: 'S', wow: 'med', cred: 'high', verdict: 'candidate', note: 'Hover the card: real model IDs from the live catalog orbit in. Uses the 477-model snapshot, nothing invented.' },
  { n: 9, title: 'Terminal typing moment', effort: 'S', wow: 'low', cred: 'med', verdict: 'only if a section feels thin', note: 'One command types itself. Charming, but borders on step-theater.' },
  { n: 10, title: 'Cursor-reactive filament field', effort: 'M', wow: 'highest', cred: 'low', verdict: 'hero-only, use with restraint', note: 'Threads bend away from your cursor. Move your mouse through the frame.' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Tangle interaction ideas — ranked prototypes</title>
  </head>
  <body>
    <main>
      <h1>Ten ideas, ranked, live</h1>
      <p class="hint">
        Each is a working prototype, numbered by my ranking (story-value over effort).
        Columns: effort S/M/L, wow, credibility. Disagree by number.
      </p>

      {ideas.map((idea) => (
        <section id={`idea-${idea.n}`}>
          <header>
            <span class="num">{String(idea.n).padStart(2, '0')}</span>
            <h2>{idea.title}</h2>
            <span class="badges mono">
              <b>effort {idea.effort}</b>
              <b>wow {idea.wow}</b>
              <b>cred {idea.cred}</b>
              <b class="verdict">{idea.verdict}</b>
            </span>
          </header>
          <p class="note">{idea.note}</p>

          {idea.n === 1 && (
            <div class="demo demo-dark" id="demo-pipeline">
              <div class="mini-rail">
                {['claude', 'codex', 'hermes', 'kimi'].map((c) => (
                  <div class="mini-tile mono" data-tile>{'$ ' + c}<span class="mini-run">RUNNING</span></div>
                ))}
              </div>
              <svg viewBox="0 0 640 150" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="mg" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#22D3EE" /><stop offset="1" stop-color="#6366F1" />
                  </linearGradient>
                </defs>
                {[0, 1, 2, 3].map((i) => (
                  <path data-line d={`M ${80 + i * 160} 0 C ${80 + i * 160} 75, 320 85, 320 134`} fill="none" stroke="url(#mg)" stroke-width="2" pathLength="1" />
                ))}
                <circle data-node cx="320" cy="138" r="5" fill="#6366F1" />
              </svg>
              <p class="mono handoff" data-handoff>traces → intelligence</p>
            </div>
          )}

          {idea.n === 3 && (
            <div class="demo demo-paper">
              <div class="echo-row">
                <div class="echo-card">
                  <span class="mono echo-label">confidence</span>
                  <div class="conf-track"><div class="conf-fill" style="width: 74%"></div></div>
                  <span class="mono echo-sub">proposal confidence, from held-out agreement</span>
                </div>
                <div class="echo-card">
                  <span class="mono echo-label">optimization lineage</span>
                  <div class="lineage">
                    <span class="gen mono">v1</span><i></i><span class="gen mono">v2</span><i></i><span class="gen gen-hot mono">v3</span>
                  </div>
                  <span class="mono echo-sub">each generation gated by evals before promotion</span>
                </div>
              </div>
            </div>
          )}

          {idea.n === 4 && (
            <div class="demo demo-dark demo-center">
              <svg class="knot-obj" viewBox="0 0 200 200" width="180" height="180">
                <defs>
                  <linearGradient id="kg" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#67E8F9" /><stop offset="0.5" stop-color="#6366F1" /><stop offset="1" stop-color="#F0ABFC" />
                  </linearGradient>
                </defs>
                <g class="knot-spin">
                  <path d="M100,30 C150,30 170,80 140,110 C110,140 60,130 55,95 C50,60 90,50 115,70 C140,90 145,140 100,165 C55,140 60,90 85,70 C110,50 150,60 145,95 C140,130 90,140 60,110 C30,80 50,30 100,30 Z" fill="none" stroke="url(#kg)" stroke-width="2.5" stroke-linecap="round" opacity="0.9" />
                </g>
              </svg>
            </div>
          )}

          {idea.n === 5 && (
            <div class="demo demo-scrollframe" id="demo-spine">
              <div class="spine-inner">
                <svg class="spine-svg" viewBox="0 0 40 1000" preserveAspectRatio="none" aria-hidden="true">
                  <defs>
                    <linearGradient id="sg" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#22D3EE" /><stop offset="0.55" stop-color="#6366F1" /><stop offset="1" stop-color="#BE185D" />
                    </linearGradient>
                  </defs>
                  <path data-spine d="M 20 0 L 20 1000" stroke="url(#sg)" stroke-width="3" pathLength="1" />
                </svg>
                <div class="spine-sec spine-dark"><span>the run</span></div>
                <div class="spine-sec spine-light"><span>the trace</span></div>
                <div class="spine-sec spine-dark"><span>the fix</span></div>
              </div>
            </div>
          )}

          {idea.n === 6 && (
            <div class="demo demo-paper">
              <div class="tree mono">
                <div class="tr"><span class="tw" style="--w:96%; --c:#22D3EE"></span>run · fix flaky checkout test<em>38.2s</em></div>
                <div class="tr ind1"><span class="tw" style="--w:14%; --c:#6366F1"></span>model · plan<em>2.1s</em></div>
                <div class="tr ind1"><span class="tw" style="--w:52%; --c:#818CF8"></span>tool · run tests<em>19.8s</em></div>
                <div class="tr ind2"><span class="tw" style="--w:47%; --c:#A855F7"></span>shell · pnpm test<em>18.1s</em></div>
                <div class="tr ind1"><span class="tw" style="--w:22%; --c:#E879F9"></span>edit · batch-writer.ts<em>3.4s</em></div>
              </div>
              <p class="mono echo-sub" style="padding: 0 1.4rem 1.1rem">schematic echo. the real TraceTree ships when a demo workspace exists.</p>
            </div>
          )}

          {idea.n === 7 && (
            <div class="demo demo-paper demo-center">
              <svg id="loop-machine" viewBox="0 0 460 220" width="460">
                {['run', 'trace', 'analyze', 'propose', 'prove', 'ship'].map((label, i) => {
                  const cx = 60 + i * 68;
                  const cy = i % 2 === 0 ? 70 : 150;
                  return (
                    <g class="lm-node" data-i={i} style={`--cx:${cx}px; --cy:${cy}px`}>
                      <circle cx={cx} cy={cy} r="24" />
                      <text x={cx} y={cy + 4} text-anchor="middle">{label}</text>
                    </g>
                  );
                })}
                <path id="lm-path" d="M 60 70 L 128 150 L 196 70 L 264 150 L 332 70 L 400 150" fill="none" stroke="#C7C9EE" stroke-width="1.5" />
                <circle id="lm-pulse" r="4" fill="#6366F1" />
              </svg>
            </div>
          )}

          {idea.n === 8 && (
            <div class="demo demo-dark demo-center">
              <div class="const-card" id="const-card">
                <span class="const-core mono">router.tangle.tools</span>
                {orbitModels.map((id, i) => (
                  <span class="const-id mono" style={`--a:${(i / orbitModels.length) * 360}deg; --r:${9 + (i % 3) * 2.4}rem; --d:${i * 40}ms`}>{id}</span>
                ))}
              </div>
              <p class="mono echo-sub" style="color: #8b8db0">hover the card. IDs are from the live catalog snapshot.</p>
            </div>
          )}

          {idea.n === 9 && (
            <div class="demo demo-dark demo-center">
              <div class="term mono"><span class="t-prompt">$</span> <span id="type-target"></span><span class="caret"></span></div>
            </div>
          )}

          {idea.n === 10 && (
            <div class="demo demo-dark demo-tall">
              <canvas id="field-canvas"></canvas>
            </div>
          )}
        </section>
      ))}
    </main>

    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // 01/02: looping mini pipeline
      const pipe = document.getElementById('demo-pipeline');
      if (pipe && !reduced) {
        const tiles = [...pipe.querySelectorAll('[data-tile]')];
        const lines = [...pipe.querySelectorAll('[data-line]')];
        const node = pipe.querySelector('[data-node]');
        const handoff = pipe.querySelector('[data-handoff]');
        let t = 0;
        setInterval(() => {
          t = (t + 1) % 90;
          const p = t / 90;
          tiles.forEach((el, i) => el.classList.toggle('on', p > 0.08 + i * 0.1 && p < 0.94));
          lines.forEach((el, i) => {
            const lp = Math.min(1, Math.max(0, (p - (0.16 + i * 0.1)) / 0.3));
            el.style.strokeDashoffset = String(1 - (p < 0.94 ? lp : 0));
          });
          const done = p > 0.72 && p < 0.94;
          node.style.opacity = done ? '1' : '0.25';
          handoff.style.opacity = done ? '1' : '0.2';
        }, 66);
      }

      // 05: spine draws with inner scroll
      const spineFrame = document.getElementById('demo-spine');
      if (spineFrame) {
        const path = spineFrame.querySelector('[data-spine]');
        const update = () => {
          const max = spineFrame.scrollHeight - spineFrame.clientHeight;
          const p = max > 0 ? spineFrame.scrollTop / max : 1;
          path.style.strokeDashoffset = String(1 - p);
        };
        spineFrame.addEventListener('scroll', update, { passive: true });
        update();
      }

      // 07: pulse walks the loop; hover highlights
      const lm = document.getElementById('loop-machine');
      if (lm && !reduced) {
        const path = lm.querySelector('#lm-path');
        const pulse = lm.querySelector('#lm-pulse');
        const len = path.getTotalLength();
        let start = performance.now();
        const step = (now) => {
          const p = ((now - start) / 6000) % 1;
          const pt = path.getPointAtLength(p * len);
          pulse.setAttribute('cx', pt.x);
          pulse.setAttribute('cy', pt.y);
          const idx = Math.min(5, Math.floor(p * 6 + 0.08));
          lm.querySelectorAll('.lm-node').forEach((n, i) => n.classList.toggle('lit', i === idx));
          requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }

      // 09: typing loop
      const target = document.getElementById('type-target');
      if (target && !reduced) {
        const line = 'claude -p "fix the flaky checkout test"';
        let i = 0, dir = 1;
        setInterval(() => {
          i += dir;
          if (i >= line.length + 14) dir = -1;
          if (i <= 0) dir = 1;
          target.textContent = line.slice(0, Math.min(line.length, Math.max(0, i)));
        }, 55);
      } else if (target) {
        target.textContent = 'claude -p "fix the flaky checkout test"';
      }

      // 10: cursor-reactive filament field
      const canvas = document.getElementById('field-canvas');
      if (canvas && !reduced) {
        const ctx = canvas.getContext('2d');
        const dpr = Math.min(2, window.devicePixelRatio || 1);
        let W, H;
        const fit = () => {
          W = canvas.clientWidth; H = canvas.clientHeight;
          canvas.width = W * dpr; canvas.height = H * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };
        fit();
        window.addEventListener('resize', fit);
        const mouse = { x: -999, y: -999 };
        canvas.addEventListener('pointermove', (e) => {
          const r = canvas.getBoundingClientRect();
          mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
        });
        canvas.addEventListener('pointerleave', () => { mouse.x = -999; mouse.y = -999; });
        const N = 26;
        const hues = ['#22D3EE', '#67E8F9', '#6366F1', '#818CF8', '#A5AAFC', '#A855F7', '#F0ABFC'];
        const draw = (now) => {
          ctx.clearRect(0, 0, W, H);
          for (let i = 0; i < N; i++) {
            const y0 = (H / (N + 1)) * (i + 1);
            const drift = Math.sin(now / 3000 + i) * 6;
            ctx.beginPath();
            ctx.moveTo(0, y0 + drift);
            for (let x = 0; x <= W; x += 16) {
              let y = y0 + drift + Math.sin(x / 140 + i * 1.7 + now / 2400) * 5;
              const dx = x - mouse.x, dy = y - mouse.y;
              const d2 = dx * dx + dy * dy;
              if (d2 < 22500) {
                const f = (1 - Math.sqrt(d2) / 150) * 46;
                y += (dy >= 0 ? 1 : -1) * f;
              }
              ctx.lineTo(x, y);
            }
            ctx.strokeStyle = hues[i % hues.length];
            ctx.globalAlpha = 0.5;
            ctx.lineWidth = 1.1;
            ctx.stroke();
          }
          ctx.globalAlpha = 1;
          requestAnimationFrame(draw);
        };
        requestAnimationFrame(draw);
      }
    </script>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #0c0b1d;
    color: #ededf4;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

  main {
    max-width: 68rem;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  h1 { font-size: 2.2rem; font-weight: 600; letter-spacing: -0.03em; }
  .hint { color: #9b9bbf; font-size: 1.05rem; line-height: 1.6; max-width: 46rem; }

  section { margin-top: 3.5rem; }

  header { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .num { color: #6366f1; font-size: 1.6rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
  h2 { margin: 0; font-size: 1.45rem; font-weight: 600; letter-spacing: -0.02em; }

  .badges { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .badges b {
    padding: 0.2rem 0.6rem;
    border: 1px solid rgba(199, 201, 238, 0.2);
    border-radius: 999px;
    color: #9b9bbf;
    font-size: 0.72rem;
    font-weight: 500;
  }
  .badges .verdict { color: #a5aafc; border-color: rgba(165, 170, 252, 0.4); }

  .note { color: #c5c5dc; font-size: 1.02rem; line-height: 1.6; max-width: 52rem; }

  .demo {
    margin-top: 1rem;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(199, 201, 238, 0.16);
  }

  .demo-dark { background: #080814; padding: 2rem; }
  .demo-paper { background: #f5f5fb; color: #191c24; }
  .demo-center { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
  .demo-tall { padding: 0; height: 20rem; }

  /* 01 */
  .mini-rail { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem; }
  .mini-tile {
    position: relative;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(199, 201, 238, 0.14);
    border-radius: 9px;
    background: #12112a;
    color: #ededf4;
    font-size: 0.95rem;
    opacity: 0.4;
    transition: opacity 0.3s, border-color 0.3s;
  }
  .mini-tile.on { opacity: 1; border-color: rgba(103, 232, 249, 0.45); }
  .mini-run { position: absolute; right: 0.8rem; color: #67e8f9; font-size: 0.65rem; opacity: 0; transition: opacity 0.3s; }
  .mini-tile.on .mini-run { opacity: 1; }
  #demo-pipeline svg { display: block; width: 100%; height: 9rem; margin-top: 0.4rem; }
  #demo-pipeline [data-line] { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .handoff { margin: 0.4rem 0 0; text-align: center; color: #a5aafc; font-size: 0.85rem; opacity: 0.2; transition: opacity 0.4s; }

  /* 03 */
  .echo-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 1.4rem; }
  .echo-card { background: #ffffff; border: 1px solid #d8d8ea; border-radius: 12px; padding: 1.2rem 1.4rem; }
  .echo-label { display: block; color: #7c3aed; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; }
  .conf-track { height: 0.7rem; margin-top: 0.9rem; border-radius: 999px; background: #ececf6; overflow: hidden; }
  .conf-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, #7C3AED, #BE185D); animation: confIn 1.4s cubic-bezier(0.2,0.6,0.2,1) both; }
  @keyframes confIn { from { width: 0 !important; } }
  .echo-sub { display: block; margin-top: 0.7rem; color: #5e5e7a; font-size: 0.82rem; }
  .lineage { display: flex; align-items: center; gap: 0.6rem; margin-top: 0.9rem; }
  .gen { padding: 0.45rem 0.9rem; border: 1px solid #d8d8ea; border-radius: 9px; background: #f5f5fb; color: #191c24; font-size: 0.95rem; }
  .gen-hot { background: linear-gradient(92deg, rgba(124,58,237,0.1), rgba(190,24,93,0.1)); border-color: #c4b5fd; color: #7c3aed; font-weight: 700; }
  .lineage i { flex: 1; height: 2px; background: linear-gradient(90deg, #C7C9EE, #A855F7); border-radius: 2px; }

  /* 04 */
  .knot-spin { transform-origin: 100px 100px; animation: spin 26s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* 05 */
  .demo-scrollframe { height: 22rem; overflow-y: auto; background: #080814; position: relative; }
  .spine-inner { position: relative; }
  .spine-svg { position: absolute; top: 0; left: 1.4rem; width: 40px; height: 100%; }
  .spine-svg path { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .spine-sec { min-height: 16rem; display: flex; align-items: center; padding-left: 6rem; font-size: 1.4rem; font-weight: 600; letter-spacing: -0.02em; }
  .spine-dark { background: #0c0b1d; color: #ededf4; }
  .spine-light { background: #f5f5fb; color: #191c24; }

  /* 06 */
  .tree { padding: 1.4rem 1.4rem 0.8rem; }
  .tr { position: relative; display: flex; align-items: center; gap: 0.8rem; padding: 0.55rem 0.4rem; color: #191c24; font-size: 0.95rem; }
  .tr em { margin-left: auto; font-style: normal; color: #5e5e7a; font-size: 0.85rem; }
  .tr .tw { display: block; width: 8rem; height: 0.55rem; border-radius: 4px; background: #ececf6; position: relative; overflow: hidden; flex: 0 0 auto; }
  .tr .tw::after { content: ''; position: absolute; inset: 0; width: var(--w); background: var(--c); border-radius: 4px; }
  .ind1 { padding-left: 1.8rem; }
  .ind2 { padding-left: 3.4rem; }

  /* 07 */
  #loop-machine { max-width: 100%; padding: 1.6rem 0; }
  .lm-node circle { fill: #ffffff; stroke: #d8d8ea; stroke-width: 1.5; transition: stroke 0.3s, filter 0.3s; }
  .lm-node text { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600; fill: #191c24; }
  .lm-node.lit circle { stroke: #7c3aed; filter: drop-shadow(0 0 8px rgba(124, 58, 237, 0.5)); }
  .lm-node:hover circle { stroke: #be185d; }

  /* 08 */
  .const-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22rem;
    height: 14rem;
    margin: 2.5rem 0 0.5rem;
    border: 1px solid rgba(199, 201, 238, 0.2);
    border-radius: 14px;
    background:
      radial-gradient(120% 90% at 70% 10%, rgba(165, 170, 252, 0.28), transparent 55%),
      linear-gradient(170deg, #101336 0%, #0c0b1d 100%);
  }
  .const-core { color: #ededf4; font-size: 1rem; }
  .const-id {
    position: absolute;
    left: 50%;
    top: 50%;
    color: #8b8db0;
    font-size: 0.68rem;
    opacity: 0;
    transform: translate(-50%, -50%) rotate(var(--a)) translateX(var(--r)) rotate(calc(-1 * var(--a)));
    transition: opacity 0.5s ease var(--d);
    white-space: nowrap;
  }
  .const-card:hover .const-id { opacity: 1; }

  /* 09 */
  .term {
    width: min(34rem, 100%);
    padding: 1.1rem 1.3rem;
    border: 1px solid rgba(199, 201, 238, 0.16);
    border-radius: 10px;
    background: #12112a;
    color: #ededf4;
    font-size: 1rem;
  }
  .t-prompt { color: #67e8f9; }
  .caret { display: inline-block; width: 8px; height: 1.1em; margin-left: 2px; vertical-align: text-bottom; background: #a5aafc; animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  /* 10 */
  #field-canvas { display: block; width: 100%; height: 100%; }

  @media (max-width: 720px) {
    .echo-row { grid-template-columns: 1fr; }
    .mini-rail { grid-template-columns: repeat(2, 1fr); }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const colors = [
  { name: 'Primary', hex: '#6172F3', desc: 'Buttons, links, accents' },
  { name: 'Primary Light', hex: '#818CF8', desc: 'Gradient endpoints, hover' },
  { name: 'Primary Soft', hex: '#A78BFA', desc: 'Subtle highlights' },
  { name: 'Background', hex: '#000000', desc: 'Page background' },
  { name: 'Card', hex: '#141428', desc: 'Elevated surfaces' },
  { name: 'Border', hex: '#211A41', desc: 'Section wrapper borders' },
  { name: 'Card Border', hex: '#2A2B39', desc: 'Card borders (rgb(42,43,57))' },
  { name: 'Text Primary', hex: '#FFFFFF', desc: 'Headings' },
  { name: 'Text Secondary', hex: '#AAB0BC', desc: 'Body text' },
  { name: 'Text Muted', hex: '#6B7094', desc: 'Labels, captions' },
];
---

<BaseLayout title="Brand Kit" description="Tangle Network brand assets, logos, colors, and usage guidelines.">

  <!-- Hero -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 12rem 5% 4rem; justify-content: flex-start;">
      <div class="wf-container-large hero-container" style="width: 100%; text-align: center; align-items: center;">
        <div class="wf-glowing-wrapper">
          <div class="wf-glowing-wrapper-button">
            <div class="wf-button-text-pill">Brand</div>
          </div>
        </div>
        <h1 class="wf-h1" style="width: auto;">Brand Kit</h1>
        <div class="wf-body-01 align-center" style="max-width: 500px;">Download official Tangle Network assets for press, partnerships, and integrations.</div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/abstract-objects-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.3;">
          <source src="/videos/abstract-objects.webm" type="video/webm" />
          <source src="/videos/abstract-objects.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- Logos -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Logos</div>
          <div class="wf-body-02 align-center">Use the dark version on light backgrounds, light version on dark backgrounds. Maintain clear space around the logo.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 1000px; margin: 0 auto;">
          <!-- Logo on dark -->
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; background: #000;">
            <img src="/images/webflow/Tangle Logo_topnav_dark.svg" alt="Tangle Logo (dark bg)" style="height: 32px;" />
            <span style="font-family: 'Satoshi', sans-serif; font-size: 13px; color: rgba(255,255,255,0.4);">On dark background</span>
          </div>
          <!-- Logo on light -->
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; background: #f0f0f4;">
            <img src="/images/webflow/Tangle Logo_topnav_light.svg" alt="Tangle Logo (light bg)" style="height: 32px;" />
            <span style="font-family: 'Satoshi', sans-serif; font-size: 13px; color: rgba(0,0,0,0.4);">On light background</span>
          </div>
          <!-- Logomark -->
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem;">
            <img src="/images/webflow/Tangle Webclip_256px.png" alt="Tangle Logomark" style="width: 64px; height: 64px; border-radius: 16px;" />
            <span style="font-family: 'Satoshi', sans-serif; font-size: 13px; color: rgba(255,255,255,0.4);">Logomark / App Icon</span>
          </div>
        </div>
        <div style="text-align: center; margin-top: 2rem;">
          <a href="/images/webflow/Tnt Logo.png" download class="wf-btn-secondary" style="padding: 12px 24px;">Download Logo Pack</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Colors -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Colors</div>
          <div class="wf-body-02 align-center">The Tangle palette. Purple is the primary accent. Everything else is dark with subtle contrast.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; max-width: 1000px; margin: 0 auto;">
          {colors.map(c => (
            <div style="border: 2px solid rgb(42,43,57); border-radius: 20px; overflow: hidden;">
              <div style={`background: ${c.hex}; height: 80px; ${c.hex === '#000000' ? 'border-bottom: 1px solid rgba(255,255,255,0.1);' : ''}`}></div>
              <div style="padding: 12px 14px;">
                <div style="font-family: 'Satoshi', sans-serif; font-size: 13px; font-weight: 700; color: white; margin-bottom: 2px;">{c.name}</div>
                <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 4px;">{c.hex}</div>
                <div style="font-family: 'Satoshi', sans-serif; font-size: 11px; color: rgba(255,255,255,0.3);">{c.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Typography</div>
          <div class="wf-body-02 align-center">Two typefaces. Satoshi for all UI and marketing. JetBrains Mono for code.</div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 1000px; margin: 0 auto;">
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2.5rem;">
            <div style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: white; line-height: 1.1; margin-bottom: 1rem;">Satoshi Variable</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 1.5rem;">Primary typeface for headings, body text, buttons, and all UI elements.</div>
            <div style="display: flex; flex-direction: column; gap: 4px;">
              {[{ w: 400, l: 'Regular' }, { w: 500, l: 'Medium' }, { w: 600, l: 'Semibold' }, { w: 700, l: 'Bold' }, { w: 800, l: 'Extra Bold' }].map(f => (
                <div style={`font-family: 'Satoshi', sans-serif; font-weight: ${f.w}; font-size: 14px; color: rgba(255,255,255,0.6);`}>
                  <span style="color: rgba(255,255,255,0.25); font-size: 11px; font-family: 'JetBrains Mono', monospace; width: 40px; display: inline-block;">{f.w}</span> {f.l} — The quick brown fox jumps
                </div>
              ))}
            </div>
          </div>
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2.5rem;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 700; color: white; line-height: 1.1; margin-bottom: 1rem;">JetBrains Mono</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 1.5rem;">Code blocks, terminal output, technical labels, and monospace UI elements.</div>
            <div style="background: #0a0a14; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 1.25rem; font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.7; color: rgba(255,255,255,0.7);">
              <span style="color: #c084fc;">const</span> <span style="color: #e2e8f0;">agent</span> = <span style="color: #c084fc;">new</span> <span style="color: #60a5fa;">BrowserAgent</span>();<br/><span style="color: #c084fc;">await</span> agent.<span style="color: #60a5fa;">run</span>(<span style="color: #fbbf24;">"test the signup flow"</span>);
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Usage Guidelines -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Usage Guidelines</div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 1000px; margin: 0 auto;">
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2.5rem;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 700; color: #4ade80; margin-bottom: 1.25rem;">Do</div>
            <ul style="font-family: 'Satoshi', sans-serif; font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.8; padding-left: 1.25rem;">
              <li>Use official logo files from this page</li>
              <li>Maintain clear space equal to the icon height</li>
              <li>Use on solid dark or light backgrounds</li>
              <li>Use the purple accent palette for brand alignment</li>
              <li>Reference "Tangle Network" or "Tangle" in text</li>
            </ul>
          </div>
          <div style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2.5rem;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 700; color: #f87171; margin-bottom: 1.25rem;">Don't</div>
            <ul style="font-family: 'Satoshi', sans-serif; font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.8; padding-left: 1.25rem;">
              <li>Modify, distort, or rotate the logo</li>
              <li>Change the logo colors</li>
              <li>Place on busy or patterned backgrounds</li>
              <li>Add effects like drop shadows or outlines</li>
              <li>Use the logo at sizes smaller than 24px height</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Downloads -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Downloads</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 1000px; margin: 0 auto;">
          <a href="/images/webflow/Tangle Logo_topnav_dark.svg" download style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2rem; text-align: center; text-decoration: none; transition: border-color 0.3s;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; color: white; margin-bottom: 4px;">Logo SVG (dark)</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.3);">SVG · 9.5 KB</div>
          </a>
          <a href="/images/webflow/Tangle Logo_topnav_light.svg" download style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2rem; text-align: center; text-decoration: none; transition: border-color 0.3s;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; color: white; margin-bottom: 4px;">Logo SVG (light)</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.3);">SVG · 9.5 KB</div>
          </a>
          <a href="/images/webflow/Tangle Webclip_256px.png" download style="border: 2px solid rgb(42,43,57); border-radius: 32px; padding: 2rem; text-align: center; text-decoration: none; transition: border-color 0.3s;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; color: white; margin-bottom: 4px;">Logomark PNG</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.3);">PNG · 256×256 · 28 KB</div>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

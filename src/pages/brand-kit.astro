---
import BaseLayout from '../layouts/BaseLayout.astro';

const palette = {
  accent: [
    { name: 'brand', hex: '#6366F1', use: 'Primary accent. Actions, links, focus rings.' },
    { name: 'brand-cool', hex: '#818CF8', use: 'Hover, emphasis, gradient pair.' },
    { name: 'brand-glow', hex: '#A5AAFC', use: 'Highlights, text gradients, subtle fills.' },
    { name: 'brand-dim', hex: '#4F46E5', use: 'Pressed / visited states.' },
  ],
  depth: [
    { name: 'depth-1', hex: '#0C0B1D', use: 'Page background.' },
    { name: 'depth-2', hex: '#141328', use: 'Section / subtle elevation.' },
    { name: 'depth-3', hex: '#1D1B38', use: 'Card / panel.' },
    { name: 'depth-4', hex: '#262448', use: 'Elevated card, modal.' },
  ],
  status: [
    { name: 'running', hex: '#10B981', use: 'Active, healthy, online.' },
    { name: 'creating', hex: '#9B93F0', use: 'Transient / in-flight.' },
    { name: 'stopped', hex: '#FFB800', use: 'Paused, idle, warning.' },
    { name: 'error', hex: '#FF4D6D', use: 'Failed, destructive.' },
  ],
};

const typography = [
  { name: 'Geist', role: 'UI text (sans)', css: '"Geist", system-ui, sans-serif', weights: '300 / 400 / 500 / 600 / 700', sample: 'Infrastructure for AI services.' },
  { name: 'Outfit', role: 'Display (dark)', css: '"Outfit", "Geist", sans-serif', weights: '400 / 500 / 600 / 700', sample: 'Sandboxed runtime, unified routing.' },
  { name: 'Manrope', role: 'Display (light / vault)', css: '"Manrope", "Inter", sans-serif', weights: '400 / 500 / 600 / 700 / 800', sample: 'Deploy agents with SLA-backed runtime.' },
  { name: 'Inter', role: 'Body (light / vault)', css: '"Inter", "Geist", sans-serif', weights: '400 / 500 / 600 / 700', sample: 'A clean, professional body face.' },
  { name: 'Geist Mono', role: 'Code, terminal, readouts', css: '"Geist Mono", ui-monospace, monospace', weights: '400 / 500 / 600', sample: 'pnpm add @tangle-network/brand' },
];

const radii = [
  { name: 'sm', px: '6px', use: 'Chips, small inputs.' },
  { name: 'md', px: '8px', use: 'Buttons, inputs.' },
  { name: 'lg', px: '12px', use: 'Cards, dropdowns.' },
  { name: 'xl', px: '16px', use: 'Sections, modals.' },
  { name: 'full', px: '999px', use: 'Pills, badges.' },
];
---

<BaseLayout title="Brand system" description="Single source of truth for the Tangle brand — tokens, fonts, logo, and Tailwind v4 theme.">
  <div class="brand-system">
    <!-- Hero -->
    <section class="relative overflow-hidden" style="background-color: var(--depth-1);">
      <div class="absolute inset-0 z-0" style="background: radial-gradient(ellipse 70% 50% at 20% 0%, rgba(99, 102, 241, 0.10), transparent), radial-gradient(ellipse 50% 40% at 80% 10%, rgba(129, 140, 248, 0.08), transparent);"></div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 pt-32 pb-20">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 mb-8" style="background-color: rgba(99, 102, 241, 0.08);">
          <span class="status-dot status-dot-running" style="width: 8px; height: 8px;"></span>
          <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);">@tangle-network/brand · v0.1.0</span>
        </div>
        <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.05; color: var(--text-primary); margin-bottom: 1.25rem;">
          The Tangle brand system.
        </h1>
        <p style="font-family: var(--font-sans); font-size: 1.125rem; line-height: 1.6; color: var(--text-secondary); max-width: 36rem;">
          Design tokens, fonts, logo, and a Tailwind v4 theme — one package shared across every Tangle app. Single source of truth; components and consumers extend, never fork.
        </p>
        <div class="flex gap-3 mt-8" style="font-family: var(--font-mono); font-size: 13px;">
          <code style="background-color: var(--depth-3); color: var(--text-primary); border: 1px solid var(--border-default); padding: 0.5rem 0.875rem; border-radius: 8px;">pnpm add @tangle-network/brand</code>
          <a href="https://github.com/tangle-network/brand" target="_blank" rel="noopener noreferrer" style="background-color: var(--brand-dim); color: white; padding: 0.5rem 0.875rem; border-radius: 8px; text-decoration: none; font-family: var(--font-sans); font-weight: 500; font-size: 13px;">GitHub &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Logo -->
    <section class="max-w-5xl mx-auto px-6 py-20">
      <h2 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 0.5rem;">Logo</h2>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); max-width: 36rem; margin-bottom: 2rem;">The Tangle Knot. Two overlapping paths, indigo-to-violet gradient. Use the full lockup where space permits; the knot alone for avatars, favicons, and constrained surfaces.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 16px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 220px;">
          <svg width="80" height="80" viewBox="20 45 156 140" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom: 1rem;">
            <defs>
              <linearGradient id="bk-a" x1="36.79" y1="58.78" x2="145.99" y2="183.59" gradientUnits="userSpaceOnUse"><stop stop-color="#8E59FF" /><stop offset="1" stop-color="#6888F9" /></linearGradient>
              <linearGradient id="bk-b" x1="36.78" y1="169.38" x2="145.99" y2="44.57" gradientUnits="userSpaceOnUse"><stop stop-color="#8E59FF" /><stop offset="1" stop-color="#6888F9" /></linearGradient>

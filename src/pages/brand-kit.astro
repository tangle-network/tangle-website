---
import BaseLayout from '../layouts/BaseLayout.astro';

const colors = [
  { name: 'Primary', hex: '#605DBA', rgb: '96, 93, 186', usage: 'Brand primary, buttons, accents' },
  { name: 'Cool', hex: '#6172F3', rgb: '97, 114, 243', usage: 'Links, interactive elements, highlights' },
  { name: 'Indigo', hex: '#6172F3', rgb: '97, 114, 243', usage: 'Gradient start, badges' },
  { name: 'Purple', hex: '#7F56D9', rgb: '127, 86, 217', usage: 'Gradient end, emphasis' },
  { name: 'Background', hex: '#0A0A14', rgb: '10, 10, 20', usage: 'Page background, code blocks' },
  { name: 'Card', hex: '#141430', rgb: '20, 20, 48', usage: 'Card backgrounds, elevated surfaces' },
  { name: 'Border', hex: '#2A2B39', rgb: '42, 43, 57', usage: 'Card borders, dividers' },
  { name: 'Text Primary', hex: '#FFFFFF', rgb: '255, 255, 255', usage: 'Headings, primary text' },
  { name: 'Text Secondary', hex: 'rgba(255,255,255,0.55)', rgb: '—', usage: 'Body text, descriptions' },
  { name: 'Text Muted', hex: 'rgba(255,255,255,0.35)', rgb: '—', usage: 'Metadata, captions' },
  { name: 'Code Highlight', hex: '#C4B5FD', rgb: '196, 181, 253', usage: 'Inline code text' },
];
---

<BaseLayout title="Brand Kit" description="Tangle brand guidelines: logos, colors, typography, gradients, and usage rules.">

  <!-- Hero -->
  <section style="position: relative; padding: 10rem 5% 3rem;">
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 20%, rgba(130, 99, 255, 0.12) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(97, 114, 243, 0.08) 0%, transparent 50%); pointer-events: none;"></div>
    <div style="position: relative; z-index: 1; max-width: 80rem; margin: 0 auto;">
      <p style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6172f3; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;">Brand Guidelines</p>
      <h1 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 800; color: white; line-height: 1.1; margin-bottom: 1rem;">Tangle Brand Kit</h1>
      <p style="font-family: 'Satoshi', sans-serif; font-size: 1.1rem; color: rgba(255,255,255,0.45); max-width: 500px; line-height: 1.5;">Everything you need to accurately represent Tangle. Logos, colors, typography, and usage guidelines.</p>
    </div>
  </section>

  <!-- Main layout -->
  <div style="max-width: 80rem; margin: 0 auto; padding: 0 5% 6rem; display: flex; gap: 4rem;">

    <!-- Sidebar -->
    <nav class="bk-sidebar">
      {[
        { text: 'Logos', href: '#logos' },
        { text: 'Logomark', href: '#logomark' },
        { text: 'Colors', href: '#colors' },
        { text: 'Gradients', href: '#gradients' },
        { text: 'Typography', href: '#typography' },
        { text: 'Usage', href: '#usage' },
        { text: 'Partners', href: '#partners' },
      ].map(item => (
        <a href={item.href} style="display: block; padding: 8px 0; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; border-left: 2px solid transparent; padding-left: 16px;">{item.text}</a>
      ))}
    </nav>

    <!-- Content -->
    <div style="flex: 1; min-width: 0;">

      <!-- Logotype -->
      <section id="logos" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Logotype</h2>
        <p class="bk-desc">The primary Tangle wordmark. Use the dark version on light backgrounds and the light version on dark backgrounds.</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 1.5rem;">
          <div class="bk-preview" style="background: #0a0a14;">
            <img src="/images/webflow/Tangle Logo_topnav_dark.svg" alt="Tangle Logo on dark" style="height: 40px;" />
            <span class="bk-label">Dark background</span>
          </div>
          <div class="bk-preview" style="background: #f0f0f4;">
            <img src="/images/webflow/Tangle Logo_topnav_light.svg" alt="Tangle Logo on light" style="height: 40px;" />
            <span class="bk-label" style="color: rgba(0,0,0,0.4);">Light background</span>
          </div>
        </div>
        <a href="https://drive.google.com/drive/folders/1txth-wQ1s_GpRcTVMcZ7ncL9uslq-7bK" target="_blank" rel="noopener noreferrer" class="bk-download">
          Download Logos (SVG, PNG)
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Logomark -->
      <section id="logomark" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Logomark</h2>
        <p class="bk-desc">The standalone Tangle icon. Use in favicons, app icons, social avatars, and compact spaces where the full wordmark doesn't fit.</p>
        <div class="bk-preview" style="max-width: 400px; margin-bottom: 1.5rem;">
          <img src="/images/webflow/Tangle Webclip_256px.png" alt="Tangle Logomark" style="width: 120px; height: 120px;" />
        </div>
        <a href="https://drive.google.com/drive/folders/1X97dbnHYYGDXw0HQ74Qs4zbaWXC6Ot_V" target="_blank" rel="noopener noreferrer" class="bk-download">
          Download Icon (PNG, SVG)
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Colors -->
      <section id="colors" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Color Palette</h2>
        <p class="bk-desc">Click any swatch to copy the hex code.</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin-bottom: 2rem;">
          {colors.map(c => (
            <button
              class="bk-swatch"
              data-hex={c.hex}
              onclick={`navigator.clipboard.writeText('${c.hex}');this.querySelector('.bk-copied').style.opacity='1';setTimeout(()=>this.querySelector('.bk-copied').style.opacity='0',1000)`}
              style="cursor: pointer; background: none; border: none; text-align: left; padding: 0;"
            >
              <div style={`width: 100%; height: 80px; border-radius: 16px 16px 0 0; background: ${c.hex}; border: 1px solid rgba(255,255,255,0.08);`}></div>
              <div style="padding: 12px; border: 1px solid rgb(42,43,57); border-top: none; border-radius: 0 0 16px 16px; background: #141430;">
                <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; color: white; margin-bottom: 2px;">{c.name}</div>
                <div style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: rgba(255,255,255,0.5);">{c.hex}</div>
                <div style="font-family: 'Satoshi', sans-serif; font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 4px;">{c.usage}</div>
                <span class="bk-copied" style="font-size: 11px; color: #6172f3; opacity: 0; transition: opacity 0.2s;">Copied!</span>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- Gradients -->
      <section id="gradients" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Gradients</h2>
        <p class="bk-desc">Brand gradients used in hero sections, CTAs, and accent backgrounds.</p>

        <div style="display: grid; gap: 16px; margin-bottom: 1.5rem;">
          <div style="border-radius: 24px; overflow: hidden; border: 2px solid rgb(42,43,57);">
            <div style="height: 120px; background: linear-gradient(135deg, #605DBA 0%, #6172F3 50%, #7F56D9 100%);"></div>
            <div style="padding: 16px; background: #141430;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; color: white;">Primary Gradient</div>
              <code style="font-size: 12px; color: rgba(255,255,255,0.4);">linear-gradient(135deg, #605DBA, #6172F3, #7F56D9)</code>
            </div>
          </div>

          <div style="border-radius: 24px; overflow: hidden; border: 2px solid rgb(42,43,57);">
            <div style="height: 120px; background: radial-gradient(ellipse at 30% 50%, rgba(130, 99, 255, 0.6) 0%, transparent 50%), radial-gradient(ellipse at 70% 50%, rgba(74, 58, 255, 0.8) 0%, transparent 60%); background-color: #0a0a14;"></div>
            <div style="padding: 16px; background: #141430;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; color: white;">Glow Background</div>
              <code style="font-size: 12px; color: rgba(255,255,255,0.4);">radial-gradient(ellipse, rgba(130,99,255,0.6), transparent)</code>
            </div>
          </div>

          <div style="border-radius: 24px; overflow: hidden; border: 2px solid rgb(42,43,57);">
            <div style="height: 120px; background: linear-gradient(45deg, #5f5bee, #465cd2);"></div>
            <div style="padding: 16px; background: #141430;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; color: white;">Text Gradient</div>
              <code style="font-size: 12px; color: rgba(255,255,255,0.4);">linear-gradient(45deg, #5f5bee, #465cd2) — for gradient text</code>
            </div>
          </div>
        </div>

        <a href="https://drive.google.com/drive/folders/1rBwYcFx4bjIp88doqv9DRVr9Vv-dU6mW" target="_blank" rel="noopener noreferrer" class="bk-download">
          Download Gradient Assets
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Typography -->
      <section id="typography" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Typography</h2>
        <p class="bk-desc">Satoshi is Tangle's primary typeface. JetBrains Mono for code and monospace elements.</p>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 2rem;">
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 2.5rem;">
            <div style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 4rem; font-weight: 800; color: white; line-height: 1; margin-bottom: 1.5rem;">Satoshi</div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              {[
                { weight: 300, name: 'Light' },
                { weight: 400, name: 'Regular' },
                { weight: 500, name: 'Medium' },
                { weight: 600, name: 'SemiBold' },
                { weight: 700, name: 'Bold' },
                { weight: 900, name: 'Black' },
              ].map(f => (
                <div style={`font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-weight: ${f.weight}; font-size: 15px; color: rgba(255,255,255,0.6); display: flex; justify-content: space-between;`}>
                  <span>Satoshi {f.name}</span>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: rgba(255,255,255,0.3);">{f.weight}</span>
                </div>
              ))}
            </div>
          </div>
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 2.5rem;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 700; color: white; line-height: 1; margin-bottom: 1.5rem;">JetBrains Mono</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.8;">
              <div>Used for: code blocks, inline code,</div>
              <div>tags, badges, monospace labels</div>
              <div style="margin-top: 1rem; color: #C4B5FD;">const tangle = await deploy();</div>
              <div style="color: rgba(255,255,255,0.3);">// 0123456789 !@#$%^&*()</div>
            </div>
          </div>
        </div>

        <div style="display: flex; gap: 12px;">
          <a href="https://www.fontshare.com/fonts/satoshi" target="_blank" rel="noopener noreferrer" class="bk-download">
            Download Satoshi
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://www.jetbrains.com/lp/mono/" target="_blank" rel="noopener noreferrer" class="bk-download">
            Download JetBrains Mono
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </section>

      <!-- Usage Guidelines -->
      <section id="usage" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Usage Guidelines</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 2rem;">
          <div style="border: 2px solid rgba(52, 211, 153, 0.2); border-radius: 24px; padding: 2rem;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 700; color: #34D399; margin-bottom: 1rem;">Do</div>
            <ul style="font-family: 'Satoshi', sans-serif; font-size: 14px; color: rgba(255,255,255,0.6); list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
              <li>Use the logo on dark backgrounds with sufficient contrast</li>
              <li>Maintain clear space around the logo (min 1x logo height)</li>
              <li>Use the provided color palette consistently</li>
              <li>Use Satoshi for all headings and body text</li>
              <li>Use JetBrains Mono for code and technical labels</li>
            </ul>
          </div>
          <div style="border: 2px solid rgba(248, 113, 113, 0.2); border-radius: 24px; padding: 2rem;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 700; color: #F87171; margin-bottom: 1rem;">Don't</div>
            <ul style="font-family: 'Satoshi', sans-serif; font-size: 14px; color: rgba(255,255,255,0.6); list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
              <li>Stretch, rotate, or distort the logo</li>
              <li>Place the logo on busy or low-contrast backgrounds</li>
              <li>Change the logo colors outside the provided variants</li>
              <li>Add effects (shadows, glows, outlines) to the logo</li>
              <li>Use the logomark as a pattern or background element</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Partnerships -->
      <section id="partners" style="margin-bottom: 5rem;">
        <h2 class="bk-heading">Partnership Template</h2>
        <p class="bk-desc">Co-branding template for partnership announcements. Available as SVG for easy customization.</p>
        <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; overflow: hidden; margin-bottom: 1.5rem;">
          <img src="/images/webflow/Tangle Partnership Template.svg" alt="Tangle Partnership Template" style="width: 100%; display: block;" />
        </div>
        <a href="https://github.com/webb-tools/webb-dapp/tree/d747566fe86a6f44eee9aeed45c8e7f5688" target="_blank" rel="noopener noreferrer" class="bk-download">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View Template on GitHub
        </a>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  .bk-sidebar {
    position: sticky;
    top: 8rem;
    width: 140px;
    flex-shrink: 0;
  }
  .bk-sidebar a:hover {
    color: rgba(255,255,255,0.8) !important;
    border-left-color: #6172f3 !important;
  }
  .bk-heading {
    font-family: 'Satoshi Variable', 'Satoshi', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }
  .bk-desc {
    font-family: 'Satoshi', sans-serif;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
    max-width: 500px;
  }
  .bk-preview {
    border: 2px solid rgb(42,43,57);
    border-radius: 24px;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: relative;
  }
  .bk-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.3);
  }
  .bk-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: white;
    font-family: 'Satoshi', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .bk-download:hover {
    border-color: #6172f3;
    background: rgba(97, 114, 243, 0.05);
  }
  @media (max-width: 768px) {
    .bk-sidebar { display: none; }
  }
</style>

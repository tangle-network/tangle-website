---
import BaseLayout from '../layouts/BaseLayout.astro'

// 2026-07 indigo-material system. Two exposure poles of one hue family:
// dark pole (homepage/product) and cool indigo paper (editorial). Warm
// paper is retired — see gtm/execution-plans/tangle-tools-website-
// creative-direction.md for the ruling and the contrast-checked ladder.
const poles = [
  {
    name: 'Dark pole',
    use: 'Homepage, product surfaces',
    file: '/images/brand/atmospheres/tangle-atmosphere-indigo-01.webp',
    colors: ['#080814', '#0C0B1D', '#141328', '#1D1B38', '#262448', '#2E2C56'],
    logo: '/brand/tangle-logo-light.svg',
    className: 'dark',
  },
  {
    name: 'Paper pole',
    use: 'Blog, benchmarks, docs, research',
    file: '/images/brand/atmospheres/tangle-paper-indigo-01.webp',
    colors: ['#F5F5FB', '#ECECF6', '#E7E7F0', '#DBDBEA', '#4F46E5', '#191C24'],
    logo: '/brand/tangle-logo.svg',
    className: 'light',
  },
]

const ladder = [
  { name: 'Depth 0', hex: '#080814', note: 'wells, hero edges' },
  { name: 'Depth 1', hex: '#0C0B1D', note: 'dark canvas' },
  { name: 'Depth 3', hex: '#1D1B38', note: 'cards, code panes' },
  { name: 'Indigo 600', hex: '#4F46E5', note: 'buttons, links on paper' },
  { name: 'Indigo 500', hex: '#6366F1', note: 'brand, large display only' },
  { name: 'Indigo 400', hex: '#818CF8', note: 'accent text on dark' },
  { name: 'Indigo 300', hex: '#A5AAFC', note: 'glow, emphasis on dark' },
  { name: 'Paper 0', hex: '#F5F5FB', note: 'light canvas' },
  { name: 'Paper 1', hex: '#ECECF6', note: 'panels, tables' },
  { name: 'Ink', hex: '#191C24', note: 'text on paper' },
]

const semantic = [
  { name: 'Pass', dark: '#6EE7B7', light: '#047857' },
  { name: 'Warn', dark: '#FCD34D', light: '#B45309' },
  { name: 'Fail', dark: '#FB7185', light: '#BE123C' },
]

const rules = [
  'Indigo is the material, not the accent. The dark canvas glows indigo; chromatic accent appears in at most one CTA and the artifact highlights per screen.',
  'Every number is data: costs, latencies, span IDs, dates, and versions are set in mono with tabular figures. Mono is never decoration.',
  'Display type stays at weight 600 or below with tight tracking. No weight-800 headlines.',
  'Warm paper is retired. Light surfaces come only from the cool indigo paper ladder.',
  'Semantic color carries real state — eval pass/fail, gate results, diff add/remove — never mood.',
  'Filament artwork must derive from real trace geometry and resolve into a real artifact. If it cannot map to a run, it does not ship.',
]
---

<BaseLayout
  title="Brand kit"
  description="Tangle brand system: the indigo-material ladder, dark and paper poles, logo files, and usage rules."
>
  <script is:inline>
    document.body.classList.add('brand-kit-page')
  </script>

  <main class="brand-kit" aria-labelledby="brand-kit-title">
    <section class="brand-hero">
      <div class="brand-hero-inner">
        <img src="/brand/tangle-logo-light.svg" alt="Tangle" />
        <h1 id="brand-kit-title">Brand kit</h1>
        <p class="brand-hero-sub">
          One indigo material at two exposures: a dark pole for product and a cool paper pole for
          reading. The thread motif is the product's own physics — tangled runs resolving into a
          reviewable artifact.
        </p>
      </div>
    </section>

    <section class="brand-section" aria-labelledby="poles-title">
      <div class="section-head">
        <h2 id="poles-title">Two poles, one hue</h2>
      </div>
      <div class="theme-grid">
        {poles.map((pole) => (
          <article class={`theme-card theme-card-${pole.className}`}>
            <div class="theme-media">
              <img src={pole.file} alt={`Tangle ${pole.name} atmosphere`} />
              <img class="theme-logo" src={pole.logo} alt={`Tangle logo on the ${pole.name}`} />
            </div>
            <div class="theme-body">
              <h3>{pole.name}</h3>
              <p class="theme-use mono">{pole.use}</p>
              <div class="theme-colors" aria-label={`${pole.name} colors`}>
                {pole.colors.map((color) => (
                  <span style={`background: ${color};`} title={color}></span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="brand-section logo-section" aria-labelledby="logo-title">
      <div class="section-head">
        <h2 id="logo-title">Logo</h2>
      </div>
      <div class="logo-grid">
        <a class="logo-tile logo-tile-dark" href="/brand/tangle-logo-light.svg" download>
          <img src="/brand/tangle-logo-light.svg" alt="Tangle light logo" />
          <span>Light lockup</span>
        </a>
        <a class="logo-tile logo-tile-light" href="/brand/tangle-logo.svg" download>
          <img src="/brand/tangle-logo.svg" alt="Tangle dark logo" />
          <span>Dark lockup</span>
        </a>
        <a class="logo-tile logo-tile-icon" href="/brand/tangle-icon-filled.svg" download>
          <img src="/brand/tangle-icon-filled.svg" alt="Tangle knot icon" />
          <span>Knot icon</span>
        </a>
      </div>
    </section>

    <section class="brand-section palette-section" aria-labelledby="ladder-title">
      <div class="section-head">
        <h2 id="ladder-title">The ladder</h2>
      </div>
      <div class="palette-row">
        {ladder.map((color) => (
          <div class="swatch">
            <span style={`background: ${color.hex};`}></span>
            <strong>{color.name}</strong>
            <code class="mono">{color.hex}</code>
            <em>{color.note}</em>
          </div>
        ))}
      </div>

      <div class="semantic-row" aria-label="Semantic state colors">
        {semantic.map((s) => (
          <div class="semantic-pair">
            <strong>{s.name}</strong>
            <div>
              <span class="chip chip-dark" style={`color: ${s.dark};`}>{s.dark}</span>
              <span class="chip chip-light" style={`color: ${s.light};`}>{s.light}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="brand-section rules-section" aria-labelledby="rules-title">
      <div class="section-head">
        <h2 id="rules-title">Usage rules</h2>
      </div>
      <ol class="rules-list">
        {rules.map((rule) => (
          <li>{rule}</li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>

<style>
  :global(.brand-kit-page .wf-nav) {
    background: rgba(12, 11, 29, 0.86);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
  }

  .mono {
    font-family: var(--font-mono);
    font-feature-settings: 'tnum';
  }

  .brand-kit {
    min-height: 100vh;
    background: var(--paper-0);
    color: var(--ink);
  }

  .brand-hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 6% 4.5rem;
    background: #080814;
    color: #f7f7ff;
  }

  .brand-hero::before {
    position: absolute;
    inset: -10% -6% -20% 30%;
    content: '';
    background: url('/images/brand/atmospheres/tangle-filament-hero-01.webp') center / cover no-repeat;
    opacity: 0.85;
  }

  .brand-hero::after {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(90deg, rgba(8, 8, 20, 0.96) 0%, rgba(8, 8, 20, 0.7) 48%, rgba(8, 8, 20, 0.22) 100%),
      linear-gradient(180deg, rgba(8, 8, 20, 0.05), rgba(8, 8, 20, 0.72) 100%);
  }

  .brand-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 76rem;
    margin: 0 auto;
  }

  .brand-hero-inner > img {
    width: 10.5rem;
    max-height: 3rem;
    margin-bottom: 2rem;
    object-fit: contain;
    object-position: left center;
  }

  .brand-hero h1,
  .brand-section h2,
  .theme-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.032em;
    text-wrap: balance;
  }

  .brand-hero h1 {
    max-width: 10ch;
    font-size: clamp(3.8rem, 7.5vw, 7rem);
    line-height: 0.96;
  }

  .brand-hero-sub {
    max-width: 40rem;
    margin: 1.4rem 0 0;
    color: rgba(240, 240, 250, 0.78);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .brand-section {
    padding: 5rem 6%;
  }

  .section-head,
  .theme-grid,
  .logo-grid,
  .palette-row,
  .semantic-row,
  .rules-list {
    max-width: 76rem;
    margin-right: auto;
    margin-left: auto;
  }

  .brand-section h2 {
    color: var(--ink);
    font-size: clamp(2rem, 3.6vw, 3.4rem);
    line-height: 1.02;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .theme-card {
    overflow: hidden;
    border: 1px solid var(--hairline-light);
    border-radius: 10px;
    background: #ffffff;
  }

  .theme-media {
    position: relative;
    min-height: 24rem;
    overflow: hidden;
  }

  .theme-media > img:first-child {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .theme-card-light .theme-media {
    border-bottom: 1px solid var(--hairline-light);
  }

  .theme-logo {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 1;
    width: 10.5rem;
    max-height: 2.8rem;
    object-fit: contain;
    object-position: left center;
  }

  .theme-body {
    padding: 1.2rem 1.2rem 1.35rem;
  }

  .theme-card h3 {
    color: var(--ink);
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    line-height: 1.05;
  }

  .theme-use {
    margin: 0.5rem 0 0;
    color: var(--ink-muted);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .theme-colors {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.5rem;
    margin-top: 1.1rem;
  }

  .theme-colors span {
    display: block;
    height: 2.6rem;
    border-radius: 6px;
    box-shadow: inset 0 0 0 1px rgba(25, 28, 36, 0.1);
  }

  .logo-section {
    background: #ffffff;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .logo-tile {
    display: flex;
    min-height: 14rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.3rem;
    border-radius: 10px;
    text-decoration: none;
  }

  .logo-tile img {
    width: min(13rem, 60%);
    max-height: 4rem;
  }

  .logo-tile span {
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .logo-tile-dark {
    background: #0c0b1d;
    color: #f7f7ff;
  }

  .logo-tile-light,
  .logo-tile-icon {
    border: 1px solid var(--hairline-light);
    background: var(--paper-1);
    color: var(--ink);
  }

  .logo-tile-icon img {
    width: 4rem;
  }

  .palette-section {
    background: var(--paper-0);
  }

  .palette-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .swatch span {
    display: block;
    aspect-ratio: 5 / 3;
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px rgba(25, 28, 36, 0.1);
  }

  .swatch strong,
  .swatch code,
  .swatch em {
    display: block;
    color: var(--ink);
  }

  .swatch strong {
    margin-top: 0.6rem;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .swatch code {
    margin-top: 0.15rem;
    font-size: 0.76rem;
    color: var(--ink-secondary);
  }

  .swatch em {
    margin-top: 0.15rem;
    font-size: 0.78rem;
    font-style: normal;
    color: var(--ink-muted);
  }

  .semantic-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .semantic-pair strong {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink);
  }

  .chip {
    display: inline-block;
    margin-right: 0.5rem;
    padding: 0.32rem 0.6rem;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .chip-dark {
    background: #1d1b38;
  }

  .chip-light {
    background: #ffffff;
    box-shadow: inset 0 0 0 1px var(--hairline-light);
  }

  .rules-section {
    background: var(--paper-1);
  }

  .rules-list {
    margin: 2rem auto 0;
    padding: 0 0 0 1.4rem;
    max-width: 56rem;
    margin-left: 0;
  }

  .rules-list li {
    padding: 0.55rem 0;
    color: var(--ink-secondary);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .rules-list li::marker {
    color: #4f46e5;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  @media (max-width: 820px) {
    .brand-hero {
      padding: 6rem 1rem 2.75rem;
    }

    .brand-hero::before {
      inset: -10% -40% -10% -5%;
      opacity: 0.5;
    }

    .brand-hero::after {
      background: linear-gradient(180deg, rgba(8, 8, 20, 0.55) 0%, rgba(8, 8, 20, 0.92) 70%, #080814 100%);
    }

    .brand-hero h1 {
      font-size: clamp(3.2rem, 15vw, 5rem);
    }

    .brand-section {
      padding: 3.5rem 1rem;
    }

    .theme-grid,
    .logo-grid,
    .semantic-row {
      grid-template-columns: 1fr;
    }

    .theme-media {
      min-height: 18rem;
    }

    .palette-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

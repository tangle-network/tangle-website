          </svg>
          <div style="display: flex; align-items: baseline; gap: 6px;">
            <span style="font-family: var(--font-display); font-weight: 700; font-size: 1.5rem; letter-spacing: -0.01em; color: var(--text-primary);">Tangle</span>
          </div>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 0.75rem;">Full lockup · md</span>
        </div>

        <div style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 16px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 220px;">
          <svg width="80" height="80" viewBox="20 45 156 140" fill="none" xmlns="http://www.w3.org/2000/svg">

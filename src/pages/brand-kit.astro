          </svg>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 0.75rem;">Icon only · md</span>
        </div>
      </div>
      <p style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); margin-top: 1rem;">{`import { Logo, TangleKnot } from "@tangle-network/brand";`}</p>
    </section>

    <!-- Color -->
    <section class="max-w-5xl mx-auto px-6 py-20">
      <h2 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 0.5rem;">Color</h2>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); max-width: 36rem; margin-bottom: 2rem;">One accent (indigo), a four-stop depth stack, and semantic status colors. No gradients in surfaces — use the depth stack for hierarchy.</p>

      <h3 style="font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 1rem;">Accent</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
        {palette.accent.map((c) => (
          <div style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 12px; overflow: hidden;">
            <div style={`background-color: ${c.hex}; height: 96px;`}></div>
            <div style="padding: 0.875rem;">
              <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); margin-bottom: 0.125rem;">{c.name}</div>
              <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-bottom: 0.5rem;">{c.hex}</div>
              <div style="font-family: var(--font-sans); font-size: 12px; color: var(--text-secondary); line-height: 1.4;">{c.use}</div>
            </div>
          </div>
        ))}
      </div>

      <h3 style="font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 1rem;">Depth stack</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
        {palette.depth.map((c) => (
          <div style={`background-color: ${c.hex}; border: 1px solid var(--border-default); border-radius: 12px; padding: 1.5rem 1rem;`}>
            <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-primary); margin-bottom: 0.125rem;">{c.name}</div>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-bottom: 0.5rem;">{c.hex}</div>
            <div style="font-family: var(--font-sans); font-size: 12px; color: var(--text-secondary); line-height: 1.4;">{c.use}</div>
          </div>
        ))}
      </div>

      <h3 style="font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 1rem;">Status</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {palette.status.map((c) => (
          <div style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 12px; padding: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
              <span style={`width: 10px; height: 10px; border-radius: 50%; background-color: ${c.hex}; box-shadow: 0 0 8px ${c.hex}66;`}></span>
              <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-primary);">{c.name}</span>
            </div>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-bottom: 0.5rem;">{c.hex}</div>
            <div style="font-family: var(--font-sans); font-size: 12px; color: var(--text-secondary); line-height: 1.4;">{c.use}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Typography -->
    <section class="max-w-5xl mx-auto px-6 py-20">
      <h2 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 0.5rem;">Typography</h2>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); max-width: 36rem; margin-bottom: 2rem;">Geist for UI, Outfit for display on dark, Manrope + Inter for light/vault surfaces, Geist Mono for code and terminal readouts. Loaded once via `@tangle-network/brand/styles/fonts`.</p>
      <div class="space-y-3">
        {typography.map((t) => (
          <div style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 12px; padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem; gap: 1rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: baseline; gap: 0.75rem;">
                <span style={`font-family: ${t.css}; font-size: 1.25rem; font-weight: 600; color: var(--text-primary);`}>{t.name}</span>
                <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;">{t.role}</span>
              </div>
              <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">{t.weights}</span>
            </div>
            <div style={`font-family: ${t.css}; font-size: 1.5rem; line-height: 1.3; color: var(--text-primary); letter-spacing: -0.01em;`}>{t.sample}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Radii -->
    <section class="max-w-5xl mx-auto px-6 py-20">
      <h2 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 0.5rem;">Radii</h2>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); max-width: 36rem; margin-bottom: 2rem;">Tight radii for precision. Light/vault theme uses even tighter values (2/4/6/8px) for enterprise surfaces.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {radii.map((r) => (
          <div class="bk-radius-card" style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 12px; padding: 1.25rem; text-align: center; transition: border-color 0.2s ease, transform 0.2s ease;">
            <div class="bk-radius-swatch" style={`background-color: var(--brand-primary); height: 64px; border-radius: ${r.px === '999px' ? '999px' : r.px}; margin-bottom: 0.75rem; transition: border-radius 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);`}></div>
            <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-primary);">{r.name}</div>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">{r.px}</div>
            <div style="font-family: var(--font-sans); font-size: 11px; color: var(--text-secondary); line-height: 1.3; margin-top: 0.5rem;">{r.use}</div>
          </div>
        ))}
      </div>
      <style>
        .bk-radius-card:hover { border-color: var(--border-accent); transform: translateY(-2px); }
        .bk-radius-card:hover .bk-radius-swatch { border-radius: 999px !important; }
        @media (prefers-reduced-motion: reduce) {
          .bk-radius-card, .bk-radius-swatch { transition: none !important; }
          .bk-radius-card:hover .bk-radius-swatch { border-radius: inherit !important; }
        }
      </style>
    </section>

    <!-- Usage -->
    <section class="max-w-5xl mx-auto px-6 py-20 pb-32">
      <h2 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text-primary); margin-bottom: 0.5rem;">Usage</h2>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); max-width: 36rem; margin-bottom: 2rem;">One import wires fonts, tokens, Tailwind v4 theme, and base utilities.</p>
      <pre style="background-color: var(--depth-3); border: 1px solid var(--border-default); border-radius: 12px; padding: 1.25rem; font-family: var(--font-mono); font-size: 13px; line-height: 1.6; color: var(--text-primary); overflow-x: auto;"><code>{`/* app.css */
@import "@tangle-network/brand/styles";
@import "tailwindcss";`}</code></pre>
      <p style="font-family: var(--font-sans); color: var(--text-secondary); margin-top: 1.5rem; font-size: 14px;">
        For finer control, import fonts, tokens, theme, and globals independently. See the repo README for the full exports table.
      </p>
    </section>
  </div>
</BaseLayout>


              <linearGradient id="bk-c" x1="36.79" y1="58.78" x2="145.99" y2="183.59" gradientUnits="userSpaceOnUse"><stop stop-color="#8E59FF" /><stop offset="1" stop-color="#6888F9" /></linearGradient>
              <linearGradient id="bk-d" x1="36.78" y1="169.38" x2="145.99" y2="44.57" gradientUnits="userSpaceOnUse"><stop stop-color="#8E59FF" /><stop offset="1" stop-color="#6888F9" /></linearGradient>

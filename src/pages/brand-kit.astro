---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Logos',
    description: 'The Tangle Network logo in dark and light variants. Use the dark version on light backgrounds and the light version on dark backgrounds. Maintain clear space around the logo equal to the height of the "T" in the wordmark.',
    downloadUrl: 'https://drive.google.com/drive/folders/tangle-logos',
    downloadLabel: 'Download Logos',
    variants: ['Dark Version', 'Light Version'],
  },
  {
    title: 'Logomark / Icon',
    description: 'The Tangle Network logomark for use as app icons, favicons, and social media avatars. Available as a 256×256px webclip. Use this when the full wordmark is not necessary or space is limited.',
    downloadUrl: 'https://drive.google.com/drive/folders/tangle-icons',
    downloadLabel: 'Download Icon',
    variants: ['256px Webclip'],
  },
  {
    title: 'Partnerships',
    description: 'Co-branding templates for partnership announcements, joint marketing materials, and integration showcases. Includes lockup guidelines and spacing requirements for dual-logo usage.',
    downloadUrl: 'https://drive.google.com/drive/folders/tangle-partnerships',
    downloadLabel: 'Download Template',
    variants: ['Partnership Template'],
  },
  {
    title: 'Typeface',
    description: 'Tangle Network uses Space Grotesk as its primary typeface and Space Mono for code and technical content. Both are open-source fonts available from Google Fonts.',
    downloadUrl: 'https://fonts.google.com/specimen/Space+Grotesk',
    downloadLabel: 'Download Typeface',
    variants: ['Space Grotesk', 'Space Mono'],
  },
];
---

<BaseLayout title="Media Kit" description="Essential tools and guidelines to accurately and creatively represent Tangle Network.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-brand-primary/10 blur-[160px]"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32 pb-20 text-center">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight tracking-tight mb-6">
        Media Kit
      </h1>
      <p class="text-lg text-text-secondary max-w-xl mx-auto">
        Essential tools and guidelines to accurately and creatively represent Tangle Network.
      </p>
    </div>
  </section>

  <!-- Brand Sections -->
  <section class="pb-24">
    <div class="max-w-5xl mx-auto px-6 space-y-16">
      {sections.map((section) => (
        <div class="rounded-3xl border border-white/5 bg-bg-section p-8 md:p-12">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-3">{section.title}</h2>
          <p class="text-text-secondary text-sm leading-relaxed mb-8 max-w-2xl">{section.description}</p>

          <!-- Asset Previews -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {section.variants.map((variant) => (
              <div class="rounded-2xl border border-white/5 bg-bg-card p-8 flex flex-col items-center justify-center min-h-[160px]">
                <div class="w-24 h-24 rounded-2xl bg-bg-elevated border border-white/10 flex items-center justify-center mb-4">
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                    <rect x="4" y="4" width="32" height="32" rx="8" stroke="#7B61FF" stroke-width="2"/>
                    <circle cx="20" cy="20" r="6" stroke="#7B61FF" stroke-width="2"/>
                  </svg>
                </div>
                <span class="text-sm text-text-muted">{variant}</span>
              </div>
            ))}
          </div>

          <a
            href={section.downloadUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-6 py-3 bg-brand-primary text-white font-medium rounded-full hover:bg-brand-strong transition-colors text-sm"
          >
            {section.downloadLabel}
            <svg class="ml-2 w-4 h-4" viewBox="0 0 16 16" fill="none">
              <path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

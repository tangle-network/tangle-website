---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Media Kit" description="Essential tools and guidelines to accurately and creatively represent Tangle Network.">

  <!-- Hero -->
  <section style="position: relative; padding: 10rem 5% 2rem;">
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(97,114,243,0.08), transparent 60%); pointer-events: none;"></div>
    <div style="position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; display: flex; align-items: flex-start; gap: 2rem;">
      <div>
        <img src="/images/webflow/Tnt Logo.png" alt="Tangle" style="width: 50px; height: 50px; margin-bottom: 0.5rem;" />
        <h1 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Media Kit</h1>
        <p style="font-family: 'Satoshi', sans-serif; font-size: 0.9rem; color: rgba(255,255,255,0.45); max-width: 400px;">Essential tools and guidelines to accurately and creatively represent Tangle Network.</p>
      </div>
    </div>
  </section>

  <!-- Main layout: sidebar + content -->
  <div style="max-width: 80rem; margin: 0 auto; padding: 0 5% 6rem; display: flex; gap: 4rem;">

    <!-- Sidebar nav -->
    <nav class="bk-sidebar">
      {[
        { text: 'Logos', href: '#logos' },
        { text: 'Network', href: '#symbol' },
        { text: 'Partners', href: '#partnerships' },
        { text: 'Colors', href: '#colors' },
        { text: 'Typeface', href: '#typeface' },
      ].map(item => (
        <a href={item.href} style="display: block; padding: 8px 0; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; border-left: 2px solid transparent; padding-left: 16px;">{item.text}</a>
      ))}
    </nav>

    <!-- Content -->
    <div style="flex: 1; min-width: 0;">

      <!-- Logotype -->
      <section id="logos" style="margin-bottom: 4rem;">
        <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 2rem; font-weight: 700; color: white; margin-bottom: 2rem;">Logotype</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 1.5rem;">
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 3rem; display: flex; align-items: center; justify-content: center; background: #0a0a14;">
            <img src="/images/webflow/Tangle Logo_topnav_dark.svg" alt="Tangle Logo on dark" style="height: 40px;" />
          </div>
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 3rem; display: flex; align-items: center; justify-content: center; background: #f0f0f4;">
            <img src="/images/webflow/Tangle Logo_topnav_light.svg" alt="Tangle Logo on light" style="height: 40px;" />
          </div>
        </div>
        <a href="https://drive.google.com/drive/folders/1txth-wQ1s_GpRcTVMcZ7ncL9uslq-7bK" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none;">
          Download
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Logomark / Icon -->
      <section id="symbol" style="margin-bottom: 4rem;">
        <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 2rem; font-weight: 700; color: white; margin-bottom: 2rem;">Logomark / Icon</h2>
        <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 4rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
          <img src="/images/webflow/Tangle Webclip_256px.png" alt="Tangle Logomark" style="width: 200px; height: 200px;" />
        </div>
        <a href="https://drive.google.com/drive/folders/1X97dbnHYYGDXw0HQ74Qs4zbaWXC6Ot_V" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none;">
          Download
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Partnerships -->
      <section id="partnerships" style="margin-bottom: 4rem;">
        <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 2rem; font-weight: 700; color: white; margin-bottom: 2rem;">Partnerships</h2>
        <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; overflow: hidden; margin-bottom: 1.5rem;">
          <img src="/images/webflow/Tangle Partnership Template.svg" alt="Tangle Partnership Template" style="width: 100%; display: block;" />
        </div>
        <a href="https://github.com/webb-tools/webb-dapp/tree/d747566fe86a6f44eee9aeed45c8e7f5688" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
        </a>
      </section>

      <!-- Colors -->
      <section id="colors" style="margin-bottom: 4rem;">
        <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 2rem; font-weight: 700; color: white; margin-bottom: 2rem;">Colors</h2>
        <h3 style="font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 1rem;">Tangle Gradient:</h3>
        <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; overflow: hidden; margin-bottom: 2rem;">
          <img src="/images/webflow/Tangle Gradient.png" alt="Tangle Gradient" style="width: 100%; height: 250px; object-fit: cover; display: block;" />
        </div>
        <a href="https://drive.google.com/drive/folders/1rBwYcFx4bjIp88doqv9DRVr9Vv-dU6mW" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none;">
          Download
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>

      <!-- Typeface -->
      <section id="typeface" style="margin-bottom: 4rem;">
        <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 2rem; font-weight: 700; color: white; margin-bottom: 2rem;">Typeface</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 1.5rem;">
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 2.5rem;">
            <div style="display: flex; flex-direction: column; gap: 2px; margin-bottom: 1.5rem;">
              {['Satoshi Light', 'Satoshi Regular', 'Satoshi Medium', 'Satoshi Bold', 'Satoshi Black'].map((name, i) => (
                <div style={`font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-weight: ${[300,400,500,700,900][i]}; font-size: 14px; color: rgba(255,255,255,0.6);`}>{name}</div>
              ))}
            </div>
            <div style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 5rem; font-weight: 800; color: white; line-height: 1;">Satoshi</div>
          </div>
          <div style="border: 2px solid rgb(42,43,57); border-radius: 24px; padding: 2.5rem; display: flex; align-items: center; justify-content: center;">
            <div style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 10rem; font-weight: 900; color: white; line-height: 1; opacity: 0.1;">Aa</div>
          </div>
        </div>
        <a href="https://www.fontshare.com/fonts/satoshi" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: white; font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; text-decoration: none;">
          Download
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </section>
    </div>
  </div>

</BaseLayout>

<style>
  .bk-sidebar {
    position: sticky;
    top: 8rem;
    width: 140px;
    flex-shrink: 0;
  }
  .bk-sidebar a:hover {
    color: rgba(255,255,255,0.8) !important;
    border-left-color: #6172f3 !important;
  }
  @media (max-width: 768px) {
    .bk-sidebar { display: none; }
  }
</style>

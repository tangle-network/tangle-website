---
import BaseLayout from '../layouts/BaseLayout.astro';
import statusHistory from '../../public/status/history.json';

const statusById = new Map(statusHistory.services.map((service) => [service.id, service]));
const dayMs = 24 * 60 * 60 * 1000;
const today = new Date();
const days = Array.from({ length: statusHistory.windowDays }, (_, index) => {
  const date = new Date(today.getTime() - (statusHistory.windowDays - 1 - index) * dayMs);
  return date.toISOString().slice(0, 10);
});

const statusLabel = {
  operational: 'Operational',
  degraded: 'Degraded',
  down: 'Down',
  unknown: 'No data',
};

const measuredUptime = (history) => {
  const measured = history.filter((day) => day.checks > 0);
  if (!measured.length) return null;
  const ok = measured.reduce((sum, day) => sum + day.ok, 0);
  const checks = measured.reduce((sum, day) => sum + day.checks, 0);
  return Number(((ok / checks) * 100).toFixed(2));
};

const services = [
  {
    id: 'blueprint-agent',
    name: 'Blueprint Agent',
    domain: 'ai.tangle.tools',
    href: 'https://ai.tangle.tools',
    description: 'Hosted workbench for Blueprint agent workflows.',
  },
  {
    id: 'sandbox',
    name: 'Sandbox Infrastructure',
    domain: 'sandbox.tangle.tools',
    href: 'https://sandbox.tangle.tools',
    description: 'Isolated execution infrastructure for agent and dev-container workloads.',
  },
  {
    id: 'router',
    name: 'Router Infrastructure',
    domain: 'router.tangle.tools',
    href: 'https://router.tangle.tools',
    description: 'Hosted routing layer for model and agent traffic.',
  },
  {
    id: 'browser-agent',
    name: 'Browser Agent',
    domain: 'browser.tangle.tools',
    href: 'https://browser.tangle.tools',
    description: 'Browser automation surface for QA, workflows, and screenshots.',
  },
  {
    id: 'audit-agent',
    name: 'Audit Agent',
    domain: 'audits.tangle.tools',
    href: 'https://audits.tangle.tools',
    description: 'Security audit workflows and audit report generation.',
  },
  {
    id: 'docs',
    name: 'Docs',
    domain: 'docs.tangle.tools',
    href: 'https://docs.tangle.tools',
    description: 'Documentation, release notes, and developer reference material.',
  },
].map((service) => {
  const collected = statusById.get(service.id);
  const history = collected?.history ?? [];
  const historyByDate = new Map(history.map((day) => [day.date, day]));
  const measuredDays = history.filter((day) => day.checks > 0).length;
  const uptimePct = measuredUptime(history);
  const current = collected?.current ?? null;
  const currentStatus = current?.status ?? 'unknown';

  return {
    ...service,
    current,
    currentStatus,
    currentLabel: statusLabel[currentStatus],
    measuredDays,
    uptimePct,
    days: days.map((date) => historyByDate.get(date) ?? { date, status: 'unknown', checks: 0, ok: 0 }),
  };
});

const incidents = statusHistory.incidents ?? [];
const generatedAt = new Date(statusHistory.generatedAt);
---

<BaseLayout
  title="Status"
  description="Public reachability status for Tangle Blueprint Agent, sandbox infrastructure, router infrastructure, browser agents, audit agents, and docs."
>
  <div class="status-page">
    <section class="status-hero">
      <div>
        <p class="status-eyebrow">Status</p>
        <h1>Public service reachability</h1>
        <p>
          This page shows collected reachability checks for public Tangle product and infrastructure surfaces.
          Reloading the page shows the latest published status snapshot.
        </p>
      </div>
      <aside class="status-note">
        <span>Check type</span>
        <strong>Server-collected reachability</strong>
        <p>History is collected every six hours and displayed as daily bars. Older days stay gray until monitoring data exists.</p>
      </aside>
    </section>

    <section class="status-section">
      <div class="status-toolbar">
        <div>
          <p class="status-eyebrow">Services</p>
          <h2>Applications and infrastructure</h2>
        </div>
        <button type="button" class="status-refresh" data-status-refresh>Refresh page</button>
      </div>

      <div class="status-grid" aria-live="polite">
        {services.map((service) => (
          <article
            class="status-card"
            data-service-name={service.name}
          >
            <div class="status-card-head">
              <div>
                <h3>{service.name}</h3>
                <a href={service.href} target="_blank" rel="noopener noreferrer">{service.domain}</a>
              </div>
              <span class={`status-pill status-pill--${service.currentStatus === 'operational' ? 'ok' : service.currentStatus}`}>
                <span class="status-dot" aria-hidden="true"></span>
                <span>{service.currentLabel}</span>
              </span>
            </div>
            <p>{service.description}</p>
            {service.note && <p class="status-card-note">{service.note}</p>}
            <div class="status-history">
              <div class="status-history-head">
                <span>90-day history</span>
                <strong>{service.uptimePct === null ? 'No measured uptime yet' : `${service.uptimePct}% measured uptime`}</strong>
              </div>
              <div class="status-bars" aria-label={`${service.name} 90-day reachability history`}>
                {service.days.map((day) => (
                  <span
                    class={`status-bar status-bar--${day.status}`}
                    title={`${day.date}: ${statusLabel[day.status] ?? day.status}${day.checks ? ` (${day.ok}/${day.checks} checks)` : ''}`}
                  />
                ))}
              </div>
              <div class="status-window">
                <span>90 days ago</span>
                <span>{service.measuredDays}/90 days measured</span>
                <span>Today</span>
              </div>
            </div>
            <div class="status-meta">
              <span>Last checked</span>
              <strong data-status-time>
                {service.current?.checkedAt ? new Date(service.current.checkedAt).toLocaleString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  hour: 'numeric',
                  minute: '2-digit',
                }) : 'No data'}
              </strong>
            </div>
          </article>
        ))}
      </div>

      <div class="status-legend" aria-label="Status legend">
        <span><i class="status-bar status-bar--operational"></i> Operational</span>
        <span><i class="status-bar status-bar--degraded"></i> Degraded</span>
        <span><i class="status-bar status-bar--down"></i> Down</span>
        <span><i class="status-bar status-bar--unknown"></i> No monitor data</span>
      </div>
    </section>

    <section class="status-section">
      <div class="status-toolbar">
        <div>
          <p class="status-eyebrow">History</p>
          <h2>Incidents</h2>
        </div>
        <p class="status-generated">Collected {generatedAt.toLocaleString('en-US', {
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
        })}</p>
      </div>

      <div class="status-incidents">
        {incidents.length ? incidents.map((incident) => (
          <article class="status-incident">
            <strong>{incident.title}</strong>
            <span>{incident.date}</span>
            <p>{incident.summary}</p>
          </article>
        )) : (
          <article class="status-incident status-incident--empty">
            <strong>No incidents recorded in public status history.</strong>
            <p>Public history starts when the collector begins writing monitor data. Internal incident records remain available through the security process.</p>
          </article>
        )}
      </div>
    </section>

    <section class="status-contact">
      <div>
        <p class="status-eyebrow">Support</p>
        <h2>Need an incident update?</h2>
        <p>
          For a customer-impacting issue, email <a href="mailto:security@tangle.tools">security@tangle.tools</a> or <a href="mailto:hello@tangle.tools">hello@tangle.tools</a>.
        </p>
      </div>
      <a href="https://docs.tangle.tools/release-notes" target="_blank" rel="noopener noreferrer">Release notes</a>
    </section>
  </div>
</BaseLayout>

<script>
  const refreshButton = document.querySelector('[data-status-refresh]');
  refreshButton?.addEventListener('click', () => window.location.reload());
</script>

<style>
  .status-page {
    min-height: 100vh;
    background: #f4f4f9;
    color: #111827;
  }

  .status-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 26rem);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
    max-width: 76rem;
    margin: 0 auto;
    padding: clamp(7rem, 12vw, 9rem) 5% clamp(3rem, 6vw, 5rem);
  }

  .status-eyebrow {
    margin: 0 0 0.85rem;
    color: #047857;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .status-hero h1,
  .status-toolbar h2,
  .status-contact h2 {
    margin: 0;
    font-family: var(--font-display);
    color: #111827;
    letter-spacing: 0;
  }

  .status-hero h1 {
    max-width: 52rem;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.97;
    font-weight: 800;
  }

  .status-hero p {
    max-width: 44rem;
    margin: 1.25rem 0 0;
    color: #3a3a50;
    font-size: clamp(1rem, 1.45vw, 1.2rem);
    line-height: 1.65;
  }

  .status-note {
    display: grid;
    gap: 0.55rem;
    padding: 1.25rem;
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 60px rgba(15, 23, 42, 0.08);
  }

  .status-note span {
    color: #5e5e7a;
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .status-note strong {
    color: #111827;
    font-size: 1.1rem;
  }

  .status-note p {
    margin: 0;
    color: #3a3a50;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .status-section,
  .status-contact {
    max-width: 76rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) 5%;
  }

  .status-section {
    border-top: 1px solid rgba(25, 28, 36, 0.08);
  }

  .status-toolbar {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .status-toolbar h2,
  .status-contact h2 {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    line-height: 1.08;
    font-weight: 800;
  }

  .status-refresh,
  .status-contact > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.7rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(4, 120, 87, 0.22);
    background: #ffffff;
    color: #065F46;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .status-card {
    display: grid;
    gap: 1rem;
    min-height: 20rem;
    padding: 1rem;
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
  }

  .status-card-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
  }

  .status-card h3 {
    margin: 0 0 0.25rem;
    color: #111827;
    font-size: 1rem;
    line-height: 1.25;
  }

  .status-card a {
    color: #3730A3;
    font-size: 0.88rem;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .status-card p {
    margin: 0;
    color: #3a3a50;
    line-height: 1.58;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 1.9rem;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .status-dot {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: currentColor;
  }

  .status-pill--checking {
    background: #EEF2FF;
    color: #3730A3;
  }

  .status-pill--ok {
    background: #D1FAE5;
    color: #047857;
  }

  .status-pill--down {
    background: #FEE2E2;
    color: #B91C1C;
  }

  .status-pill--degraded {
    background: #FEF3C7;
    color: #92400E;
  }

  .status-pill--unknown {
    background: #E5E7EB;
    color: #4B5563;
  }

  .status-card-note {
    padding: 0.75rem;
    border-radius: 6px;
    background: #FFFBEB;
    color: #78350F !important;
    font-size: 0.88rem;
  }

  .status-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(25, 28, 36, 0.08);
    color: #5e5e7a;
    font-size: 0.82rem;
  }

  .status-meta strong {
    color: #111827;
    text-align: right;
  }

  .status-history {
    display: grid;
    gap: 0.55rem;
    align-self: end;
  }

  .status-history-head,
  .status-window,
  .status-legend,
  .status-generated {
    color: #5e5e7a;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .status-history-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .status-history-head strong {
    color: #111827;
    text-align: right;
  }

  .status-bars {
    display: grid;
    grid-template-columns: repeat(90, minmax(1px, 1fr));
    gap: 1px;
    min-width: 0;
  }

  .status-bar {
    display: block;
    width: 100%;
    min-width: 2px;
    height: 1.65rem;
    border-radius: 2px;
    background: #D1D5DB;
  }

  .status-bar--operational {
    background: #10B981;
  }

  .status-bar--degraded {
    background: #F59E0B;
  }

  .status-bar--down {
    background: #EF4444;
  }

  .status-bar--unknown {
    background: #D1D5DB;
  }

  .status-window {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
  }

  .status-window span:nth-child(2) {
    text-align: center;
  }

  .status-window span:last-child {
    text-align: right;
  }

  .status-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.1rem;
    margin-top: 1rem;
  }

  .status-legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .status-legend .status-bar {
    width: 0.75rem;
    min-width: 0.75rem;
    height: 0.75rem;
    border-radius: 2px;
  }

  .status-generated {
    margin: 0;
  }

  .status-incidents {
    display: grid;
    gap: 0.75rem;
  }

  .status-incident {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
  }

  .status-incident strong {
    color: #111827;
  }

  .status-incident span,
  .status-incident p {
    margin: 0;
    color: #5e5e7a;
  }

  .status-incident--empty {
    background: #F9FAFB;
  }

  .status-contact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 1px solid rgba(25, 28, 36, 0.08);
  }

  .status-contact p {
    max-width: 46rem;
    margin: 1rem 0 0;
    color: #3a3a50;
    line-height: 1.62;
  }

  .status-contact a {
    color: #065F46;
    font-weight: 800;
  }

  @media (max-width: 980px) {
    .status-hero,
    .status-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .status-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .status-hero,
    .status-section,
    .status-contact {
      padding-inline: 1rem;
    }

    .status-grid {
      grid-template-columns: 1fr;
    }

    .status-toolbar,
    .status-contact {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>

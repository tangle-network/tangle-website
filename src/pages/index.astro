---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import SectionHead from '../components/ui/SectionHead.astro';

const sdkCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">TangleClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/tcloud"</span>;

<span class="cw-k">const</span> <span class="cw-v">tangle</span> = <span class="cw-k">new</span> <span class="cw-f">TangleClient</span>({
  apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span>,
});

<span class="cw-c">// Sandboxed runtime, model routing, billing in one SDK</span>
<span class="cw-k">const</span> <span class="cw-v">box</span> = <span class="cw-k">await</span> tangle.sandbox.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-k">const</span> <span class="cw-v">result</span> = <span class="cw-k">await</span> tangle.<span class="cw-f">chat</span>({
  model: <span class="cw-s">"anthropic/claude-sonnet-4-6"</span>,
  messages: [{ role: <span class="cw-s">"user"</span>, content: <span class="cw-s">"Refactor src/ to TS"</span> }],
  sandbox: box.id,
});

<span class="cw-sh">✓</span> <span class="cw-v">12 files converted</span>  <span class="cw-c">· 47 tests passing</span>`;

const cliCode = `<span class="cw-c"># Install the Tangle CLI</span>
<span class="cw-sh">$</span> <span class="cw-v">npm install -g</span> <span class="cw-s">@tangle-network/tcloud</span>

<span class="cw-c"># Authenticate with your API key</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle auth login</span> <span class="cw-k">--api-key</span> <span class="cw-s">sk_...</span>

<span class="cw-c"># Route a model call through the unified router</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle chat</span> <span class="cw-k">--model</span> <span class="cw-s">"anthropic/claude-sonnet-4-6"</span> \\
<span class="cw-k">  --prompt</span> <span class="cw-s">"Summarize this PR"</span>

<span class="cw-c"># Spin up a sandbox, run an agent, stream output</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
<span class="cw-k">  --goal</span> <span class="cw-s">"Fix failing tests"</span>

<span class="cw-sh">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 4 turns · 9.2s</span>`;
---

<BaseLayout title="Infrastructure for AI services" description="Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.">

  <!-- Hero Section -->
  <section class="wf-section-hero" id="hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section">
      <div class="home-hero-grid">
        <div class="wf-hero-text">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Infrastructure for AI
              </div>
            </div>
          </div>
          <h1 class="wf-h1">Infrastructure<br/>for AI services.</h1>
          <div class="wf-body-01">
            Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.
          </div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Try Blueprint Agent</a>
            <a href="#products" class="wf-btn-secondary">Explore the stack</a>
          </div>
        </div>
        <div class="home-hero-code">
          <CodeWindow
            tabs={[
              { id: 'sdk', label: 'SDK', icon: 'code', html: sdkCode },
              { id: 'cli', label: 'CLI', icon: 'terminal', html: cliCode },
            ]}
          />
        </div>
      </div>
      <div class="wf-video-mask">
        <video
          autoplay
          loop
          muted
          playsinline
          poster="/images/hero/glass-cylinders-poster.jpg"
          class="wf-hero-video-poster"
        >
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <style>
    .home-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3rem;
      align-items: center;
      width: 100%;
      max-width: 84rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .home-hero-code {
      min-width: 0;
    }
    @media (max-width: 991px) {
      .home-hero-grid {
        grid-template-columns: minmax(0, 1fr);
        gap: 2rem;
      }
    }
  </style>

  <!-- Metrics strip (sandbox-ui pattern) -->
  <div class="wf-metrics-strip">
    <div class="wf-metrics-strip-inner">
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        &lt;1s provisioning
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        mTLS-isolated runtime
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        671 models, 14 providers
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        x402 machine payments
      </span>
    </div>
  </div>

  <!-- Products — VAULT/LIGHT surface for visual break -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper" id="products">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #059669;">The stack</span>
          <div class="wf-h3">AI-powered tools for every workflow.</div>
          <div class="wf-body-02">From code generation to browser automation to secure sandboxes — one stack, composable primitives.</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">

          <!-- Blueprint Agent -->
          <a href="/services/blueprint-agent" class="wf-builder-feature-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgba(99,102,241,0.3), rgba(99,102,241,0.1)); display: flex; align-items: center; justify-content: center;">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(99,102,241,1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Blueprint Agent</div>
              <div class="wf-body-02" style="margin-top: 8px;">AI development platform. 40+ ecosystems, multi-model, live preview. Ship production code faster with an AI pair programmer that understands your stack.</div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: auto;">
              <span style="color: rgba(99,102,241,1); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 6px;">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </div>
          </a>

          <!-- Browser Agent -->
          <a href="/services/browser-agent" class="wf-builder-feature-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgba(59,130,246,0.3), rgba(59,130,246,0.1)); display: flex; align-items: center; justify-content: center;">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(59,130,246,1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Browser Agent</div>
              <div class="wf-body-02" style="margin-top: 8px;">AI-powered browser automation. Describe what to test in plain English — the agent navigates, clicks, and verifies like a real user.</div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: auto;">
              <span style="color: rgba(59,130,246,1); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 6px;">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </div>
          </a>

          <!-- Sandbox SDK -->
          <a href="/services/sandbox" class="wf-builder-feature-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgba(16,185,129,0.3), rgba(16,185,129,0.1)); display: flex; align-items: center; justify-content: center;">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(16,185,129,1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                    <line x1="8" y1="21" x2="16" y2="21"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Sandbox SDK</div>
              <div class="wf-body-02" style="margin-top: 8px;">Cloud in a command. Spin up isolated environments for AI agents with full filesystem, networking, and process control.</div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: auto;">
              <span style="color: rgba(16,185,129,1); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 6px;">
                Learn more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <div class="wf-cta-card">
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <h2 class="wf-h4-2">Build with AI-Powered Infrastructure</h2>
        <div class="wf-body-02 align-center">From development to testing to deployment — Tangle's AI services accelerate every stage of your workflow.</div>
        <div class="wf-cta-button-row">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Try Blueprint Agent</a>
        </div>
      </div>
    </div>
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
  </div>

</BaseLayout>

    }
    .t-infra-ba-dot:first-child { background: #ff5f57; }
    .t-infra-ba-dot:nth-child(2) { background: #febc2e; }
    .t-infra-ba-dot:nth-child(3) { background: #28c840; }
    .t-infra-ba-url {

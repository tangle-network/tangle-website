---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import SectionHead from '../components/ui/SectionHead.astro';

const sdkCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">TangleClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/tcloud"</span>;

<span class="cw-k">const</span> <span class="cw-v">tangle</span> = <span class="cw-k">new</span> <span class="cw-f">TangleClient</span>({
  apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span>,
});

<span class="cw-c">// Sandboxed runtime, model routing, billing in one SDK</span>
<span class="cw-k">const</span> <span class="cw-v">box</span> = <span class="cw-k">await</span> tangle.sandbox.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-k">const</span> <span class="cw-v">result</span> = <span class="cw-k">await</span> tangle.<span class="cw-f">chat</span>({
  model: <span class="cw-s">"anthropic/claude-sonnet-4-6"</span>,
  messages: [{ role: <span class="cw-s">"user"</span>, content: <span class="cw-s">"Refactor src/ to TS"</span> }],
  sandbox: box.id,
});

<span class="cw-sh">✓</span> <span class="cw-v">12 files converted</span>  <span class="cw-c">· 47 tests passing</span>`;

const cliCode = `<span class="cw-c"># Install the Tangle CLI</span>
<span class="cw-sh">$</span> <span class="cw-v">npm install -g</span> <span class="cw-s">@tangle-network/tcloud</span>

<span class="cw-c"># Authenticate with your API key</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle auth login</span> <span class="cw-k">--api-key</span> <span class="cw-s">sk_...</span>

<span class="cw-c"># Route a model call through the unified router</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle chat</span> <span class="cw-k">--model</span> <span class="cw-s">"anthropic/claude-sonnet-4-6"</span> \\
<span class="cw-k">  --prompt</span> <span class="cw-s">"Summarize this PR"</span>

<span class="cw-c"># Spin up a sandbox, run an agent, stream output</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
<span class="cw-k">  --goal</span> <span class="cw-s">"Fix failing tests"</span>

<span class="cw-sh">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 4 turns · 9.2s</span>`;
---

<BaseLayout title="Infrastructure for AI services" description="Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.">

  <!-- Hero Section -->
  <section class="wf-section-hero" id="hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section">
      <div class="home-hero-grid">
        <div class="wf-hero-text">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Infrastructure for AI
              </div>
            </div>
          </div>
          <h1 class="wf-h1">Infrastructure<br/>for AI services.</h1>
          <div class="wf-body-01">
            Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.
          </div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Try Blueprint Agent</a>
            <a href="#products" class="wf-btn-secondary">Explore the stack</a>
          </div>
        </div>
        <div class="home-hero-code">
          <CodeWindow
            tabs={[
              { id: 'sdk', label: 'SDK', icon: 'code', html: sdkCode },
              { id: 'cli', label: 'CLI', icon: 'terminal', html: cliCode },
            ]}
          />
        </div>
      </div>
      <div class="wf-video-mask">
        <video
          autoplay
          loop
          muted
          playsinline
          poster="/images/hero/glass-cylinders-poster.jpg"
          class="wf-hero-video-poster"
        >
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <style>
    .home-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3rem;
      align-items: center;
      width: 100%;
      max-width: 84rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .home-hero-code {
      min-width: 0;
    }
    @media (max-width: 991px) {
      .home-hero-grid {
        grid-template-columns: minmax(0, 1fr);
        gap: 2rem;
      }
    }
  </style>

  <!-- Metrics strip (sandbox-ui pattern) -->
  <div class="wf-metrics-strip">
    <div class="wf-metrics-strip-inner">
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        &lt;1s provisioning
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        mTLS-isolated runtime
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        671 models, 14 providers
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        x402 machine payments
      </span>
    </div>
  </div>

  <!-- AUTORESEARCH — optimization loop diagram -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #10B981;">THE LOOP</span>
          <h2 class="wf-h3">We automate <span class="wf-gradient-text">autoresearch</span>.</h2>
          <p class="wf-body-01">
            Every Tangle agent runs on the same four-step loop: <strong style="color: var(--text-primary); font-weight: 600;">identify</strong> opportunities, <strong style="color: var(--text-primary); font-weight: 600;">contextualize</strong> them with data and domain, <strong style="color: var(--text-primary); font-weight: 600;">build</strong> the agent in a sandbox, <strong style="color: var(--text-primary); font-weight: 600;">evaluate</strong> against ground truth. Converge or iterate. Agents that build agents.
          </p>
        </div>

        <div class="autoresearch-diagram">
        <!-- Four phase cards in a 2x2 grid with a looping flow indicator -->
        <div class="ar-grid">
          <div class="ar-phase" data-step="01">
            <div class="ar-phase-head">
              <span class="ar-num">01</span>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div class="ar-phase-title">Identify</div>
            <div class="ar-phase-body">Scan market signals, user tasks, and failure modes. Pick the opportunity with the clearest gap.</div>
          </div>

          <div class="ar-phase" data-step="02">
            <div class="ar-phase-head">
              <span class="ar-num">02</span>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            </div>
            <div class="ar-phase-title">Contextualize</div>
            <div class="ar-phase-body">Assemble domain knowledge, tool access, and the Four Surfaces: Profile, Sandbox, Data, Evals.</div>
          </div>

          <div class="ar-phase" data-step="04">
            <div class="ar-phase-head">
              <span class="ar-num">04</span>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="ar-phase-title">Evaluate</div>
            <div class="ar-phase-body">Run agent-eval against ground truth. Score rubrics, judges, failure-mode coverage. Converge or iterate.</div>
          </div>

          <div class="ar-phase" data-step="03">
            <div class="ar-phase-head">
              <span class="ar-num">03</span>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <div class="ar-phase-title">Build</div>
            <div class="ar-phase-body">Agent Builder spins the workspace. Sandbox SDK isolates the runtime. Router routes every model call.</div>
          </div>

          <!-- SVG loop arrows overlayed -->
          <svg class="ar-arrows" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <marker id="ar-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#818CF8"/>
              </marker>
            </defs>
            <!-- top edge: 01 → 02 -->
            <path d="M 28 22 L 72 22" stroke="#818CF8" stroke-width="0.35" stroke-dasharray="1.5 1" fill="none" marker-end="url(#ar-arrow)" />
            <!-- right edge: 02 → 04 (down) -->
            <path d="M 85 34 L 85 66" stroke="#818CF8" stroke-width="0.35" stroke-dasharray="1.5 1" fill="none" marker-end="url(#ar-arrow)" />
            <!-- bottom edge: 04 → 03 (right-to-left) -->
            <path d="M 72 78 L 28 78" stroke="#818CF8" stroke-width="0.35" stroke-dasharray="1.5 1" fill="none" marker-end="url(#ar-arrow)" />
            <!-- left edge: 03 → 01 (up, closing the loop) -->
            <path d="M 15 66 L 15 34" stroke="#A5AAFC" stroke-width="0.5" stroke-dasharray="none" fill="none" marker-end="url(#ar-arrow)" />
          </svg>
        </div>

        <!-- Supporting infra row -->
        <div class="ar-infra">
          <div class="ar-infra-item">
            <div class="ar-infra-icon" style="background: rgba(99,102,241,0.14); color: #818CF8;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div class="ar-infra-text">
              <div class="ar-infra-label">Sandbox SDK</div>
              <div class="ar-infra-sub">Isolated compute per run</div>
            </div>
          </div>
          <div class="ar-infra-item">
            <div class="ar-infra-icon" style="background: rgba(16,185,129,0.14); color: #34D399;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div class="ar-infra-text">
              <div class="ar-infra-label">Tangle Router</div>
              <div class="ar-infra-sub">671 models · one API key</div>
            </div>
          </div>
          <div class="ar-infra-item">
            <div class="ar-infra-icon" style="background: rgba(255,184,0,0.14); color: #FFB800;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </div>
            <div class="ar-infra-text">
              <div class="ar-infra-label">Data</div>
              <div class="ar-infra-sub">Public · personal · licensed</div>
            </div>
          </div>
          <div class="ar-infra-item">
            <div class="ar-infra-icon" style="background: rgba(77,155,255,0.14); color: #4AABFF;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="ar-infra-text">
              <div class="ar-infra-label">Agent Eval</div>
              <div class="ar-infra-sub">Rubrics · judges · failure modes</div>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <style>
    .autoresearch-diagram {
      position: relative;
      margin-top: 2rem;
    }

    .ar-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 1rem;
      position: relative;
      padding: 2rem 0;
      background: radial-gradient(ellipse at center, rgba(99, 102, 241, 0.08), transparent 70%);
    }

    .ar-phase {
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      padding: 1.75rem 1.5rem;
      position: relative;
      z-index: 2;
      transition: border-color 0.16s ease, background-color 0.16s ease;
    }

    .ar-phase:hover {
      border-color: var(--border-accent);
      background-color: var(--depth-4);
    }

    .ar-phase-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
      color: var(--brand-cool);
    }

    .ar-num {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--brand-cool);
    }

    .ar-phase-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .ar-phase-body {
      font-family: var(--font-sans);
      font-size: 0.9375rem;
      line-height: 1.5;
      color: var(--text-secondary);
    }

    .ar-arrows {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: none;
    }

    .ar-infra {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
      padding: 1.5rem;
      background: var(--depth-2);
      border: 1px solid var(--border-subtle);
    }

    .ar-infra-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .ar-infra-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .ar-infra-label {
      font-family: var(--font-display);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .ar-infra-sub {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }

    @media (max-width: 768px) {
      .ar-grid { grid-template-columns: 1fr; grid-template-rows: auto; padding: 1rem; }
      .ar-arrows { display: none; }
      .ar-infra { grid-template-columns: 1fr 1fr; }
    }

    /* Home product cards — tokenized */
    .home-product-icon-wrap { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .home-product-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--brand-cool);
    }
    .home-product-card:hover .home-product-icon {
      border-color: var(--border-accent);
      background: var(--depth-4);
    }
    .home-product-cta {
      padding: 0 24px 24px;
      margin-top: auto;
      color: var(--brand-cool);
      font-size: 0.875rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
    }
  </style>

  <!-- Products — VAULT/LIGHT surface for visual break -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper" id="products">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #059669;">The stack</span>
          <div class="wf-h3">AI-powered tools for every workflow.</div>
          <div class="wf-body-02">From code generation to browser automation to secure sandboxes — one stack, composable primitives.</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">

          <!-- Blueprint Agent -->
          <a href="/services/blueprint-agent" class="wf-builder-feature-card home-product-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div class="home-product-icon-wrap">
                <div class="home-product-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Blueprint Agent</div>
              <div class="wf-body-02" style="margin-top: 8px;">AI pair programmer that ships real services. 40+ ecosystem templates, multi-model routing, live preview from prompt to deploy.</div>
            </div>
            <div class="home-product-cta">
              <span>Open Blueprint Agent</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>

          <!-- Browser Agent -->
          <a href="/services/browser-agent" class="wf-builder-feature-card home-product-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div class="home-product-icon-wrap">
                <div class="home-product-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Browser Agent</div>
              <div class="wf-body-02" style="margin-top: 8px;">Plain-English goals, real Chromium runs, screenshot + DOM evidence per turn. CLI for one-offs, SDK for CI.</div>
            </div>
            <div class="home-product-cta">
              <span>See it run</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>

          <!-- Sandbox SDK -->
          <a href="/services/sandbox" class="wf-builder-feature-card home-product-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column;">
            <div class="wf-builder-feature-top" style="flex: 1;">
              <div class="home-product-icon-wrap">
                <div class="home-product-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                    <line x1="8" y1="21" x2="16" y2="21"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                  </svg>
                </div>
              </div>
              <div class="wf-h4">Sandbox SDK</div>
              <div class="wf-body-02" style="margin-top: 8px;">Sub-second isolated containers for agent code. Any Docker image, mTLS sidecar, snapshot and restore.</div>
            </div>
            <div class="home-product-cta">
              <span>Read the SDK</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <div class="wf-cta-card">
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <h2 class="wf-h4-2">Build with AI-Powered Infrastructure</h2>
        <div class="wf-body-02 align-center">From development to testing to deployment — Tangle's AI services accelerate every stage of your workflow.</div>
        <div class="wf-cta-button-row">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Try Blueprint Agent</a>
        </div>
      </div>
    </div>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import ExamplePanel from '../components/ui/ExamplePanel.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import SectionHead from '../components/ui/SectionHead.astro';
import Section from '../components/ui/Section.astro';
import BentoCell from '../components/ui/BentoCell.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';

// ─── tcloud (the unified SDK: sandbox + router + evals in one client) ───
const tcloudSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">TangleClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/tcloud"</span>;

<span class="cw-k">const</span> <span class="cw-v">tangle</span> = <span class="cw-k">new</span> <span class="cw-f">TangleClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });

<span class="cw-c">// One client, every surface — sandbox, router, evals, billing.</span>
<span class="cw-k">const</span> <span class="cw-v">box</span>    = <span class="cw-k">await</span> tangle.sandbox.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });
<span class="cw-k">const</span> <span class="cw-v">reply</span>  = <span class="cw-k">await</span> tangle.<span class="cw-f">chat</span>({
  model: <span class="cw-s">"anthropic/claude-sonnet-4-6"</span>,
  messages: [{ role: <span class="cw-s">"user"</span>, content: <span class="cw-s">"Refactor src/ to TS"</span> }],
  sandbox: box.id,
});
<span class="cw-k">const</span> <span class="cw-v">score</span>  = <span class="cw-k">await</span> tangle.evals.<span class="cw-f">grade</span>({ run: reply.runId, rubric: <span class="cw-s">"refactor-correctness"</span> });

<span class="cw-ok">✓</span> <span class="cw-v">12 files converted</span>  <span class="cw-c">· 47 tests passing · score 0.92</span>`;

const tcloudCli = `<span class="cw-c"># One CLI — sandbox, router, evals.</span>
<span class="cw-sh">$</span> <span class="cw-v">npm i -g</span> <span class="cw-s">@tangle-network/tcloud</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle auth login</span> <span class="cw-k">--api-key</span> <span class="cw-s">sk_tan_…</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span>
<span class="cw-p">→</span> <span class="cw-v">sbx_a8f3c2d1</span>  <span class="cw-c">· ready in 0.6s</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle chat</span> <span class="cw-k">--model</span> <span class="cw-s">"anthropic/claude-sonnet-4-6"</span> \\
<span class="cw-k">  --prompt</span> <span class="cw-s">"Refactor src/ to TypeScript"</span> <span class="cw-k">--sandbox</span> <span class="cw-s">sbx_a8f3c2d1</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle evals grade</span> <span class="cw-k">--run</span> <span class="cw-s">run_7fx…</span> <span class="cw-k">--rubric</span> <span class="cw-s">refactor-correctness</span>
<span class="cw-p">→</span> <span class="cw-v">score 0.92</span>  <span class="cw-c">· judges=3 · 4 failure modes covered</span>`;

// ─── Sandbox SDK (the agent runtime) ───
const sandboxSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> <span class="cw-v">box</span>    = <span class="cw-k">await</span> client.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-c">// Stream a coding agent inside the sandbox</span>
<span class="cw-k">for await</span> (<span class="cw-k">const</span> <span class="cw-v">event</span> <span class="cw-k">of</span> box.<span class="cw-f">streamTask</span>(<span class="cw-s">"Refactor src/ to TypeScript and add tests"</span>)) {
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"tool_call"</span>)   console.<span class="cw-f">log</span>(<span class="cw-s">\`tool: \${event.tool}\`</span>);
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"message"</span>)     process.stdout.<span class="cw-f">write</span>(event.content);
}

<span class="cw-ok">✓</span> <span class="cw-v">PR #18 created</span>  <span class="cw-c">· src/ → TypeScript · 0 errors</span>`;

const sandboxCli = `<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span> <span class="cw-k">--name</span> <span class="cw-s">my-project</span>
<span class="cw-p">→</span> <span class="cw-v">sbx_a8f3c2d1</span>  <span class="cw-c">· ready in 0.6s · SSH ready</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle ssh</span> <span class="cw-s">sbx_a8f3c2d1</span>        <span class="cw-c"># drop into the box</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox snapshot</span> <span class="cw-s">sbx_a8f3c2d1</span> <span class="cw-k">--to</span> <span class="cw-s">s3://my-snaps/pre-migrate</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
<span class="cw-k">  --goal</span> <span class="cw-s">"Fix failing tests"</span> <span class="cw-k">--stream</span>
<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 4 turns · 18s · 0 errors</span>`;

// ─── Router (OpenAI-compatible, 671 models) ───
const routerSdk = `<span class="cw-k">import</span> <span class="cw-v">OpenAI</span> <span class="cw-k">from</span> <span class="cw-s">"openai"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">OpenAI</span>({
  baseURL: <span class="cw-s">"https://router.tangle.tools/v1"</span>,
  apiKey:  process.env.<span class="cw-v">TANGLE_API_KEY</span>,
});

<span class="cw-c">// Any of 671 models, one API key, one billing rail.</span>
<span class="cw-k">const</span> <span class="cw-v">reply</span> = <span class="cw-k">await</span> client.chat.completions.<span class="cw-f">create</span>({
  model: <span class="cw-s">"anthropic/claude-sonnet-4-6"</span>,
  messages: [{ role: <span class="cw-s">"user"</span>, content: <span class="cw-s">"Summarize this PR"</span> }],
});

<span class="cw-ok">✓</span> <span class="cw-v">Usage: 1,240 tokens</span>  <span class="cw-c">· $0.003 · via anthropic</span>`;

const routerCurl = `<span class="cw-sh">$</span> <span class="cw-v">curl</span> https://router.tangle.tools/v1/chat/completions \\
  <span class="cw-k">-H</span> <span class="cw-s">"Authorization: Bearer $TANGLE_API_KEY"</span> \\
  <span class="cw-k">-H</span> <span class="cw-s">"Content-Type: application/json"</span> \\
  <span class="cw-k">-d</span> <span class="cw-s">'{"model":"openai/gpt-5","messages":[{"role":"user","content":"hi"}]}'</span>

<span class="cw-c"># Same shape as OpenAI. Drop-in replacement.</span>
<span class="cw-c"># Fall over between providers automatically. 671 models, one URL.</span>`;

const routerPy = `<span class="cw-k">from</span> <span class="cw-v">openai</span> <span class="cw-k">import</span> <span class="cw-f">OpenAI</span>

client = <span class="cw-f">OpenAI</span>(
    base_url=<span class="cw-s">"https://router.tangle.tools/v1"</span>,
    api_key=os.environ[<span class="cw-s">"TANGLE_API_KEY"</span>],
)

reply = client.chat.completions.<span class="cw-f">create</span>(
    model=<span class="cw-s">"google/gemini-3.1-pro"</span>,
    messages=[{<span class="cw-s">"role"</span>: <span class="cw-s">"user"</span>, <span class="cw-s">"content"</span>: <span class="cw-s">"Why is my build red?"</span>}],
)
<span class="cw-f">print</span>(reply.choices[<span class="cw-n">0</span>].message.content)`;
---

<BaseLayout title="Secure Infrastructure for AI" description="Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.">

  <Hero
    layout="one-col"
    align="center"
    title='Secure Infrastructure for <span class="wf-gradient-text">AI</span>.'
    subtitle="Sandboxed runtime. Unified model routing. Programmable billing. The stack underneath every agent you ship — DSPy, Mastra, LangChain, your own."
    lede="Spawn a sandbox in under a second. Route across 671 models with one key. Bill per call, not per seat. Bring your framework — DSPy, Mastra, LangChain, your own."
    primaryCta={{ label: 'Try Blueprint Agent', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'Explore the stack', href: '#products' }}
    videoBg={{
      poster: '/images/hero/glass-cylinders-poster.jpg',
      webm: '/videos/glass-cylinders.webm',
      mp4: '/videos/glass-cylinders.mp4',
    }}
  />

  <!-- frameworks "RUNS WITH" text strip removed 2026-04-25 — Drew: 'no
       logos no banners.' Without real framework logos, a plain text list
       isn't social proof. Re-add when we have the SVGs.
       'See it work' ExamplePanel moved BELOW the vault optimization-loop
       section so the page alternates dark → light → dark → light → dark. -->

  <!-- Metrics strip — real, landed numbers, not adjectives -->
  <div class="wf-metrics-strip">
    <div class="wf-metrics-strip-inner">
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        0.6s p50 cold-start
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        671 models, 14 providers
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
        90% WebBench-50 pass rate
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        $0.06 / vCPU-hr
      </span>
    </div>
  </div>

  <!-- The optimization loop — vault-light section moved from /overview per
       Drew's call. Tight summary above the dark surfaces-scroller deep
       dive. Vault white surface gives the page a real rhythm break
       between dark hero/metrics and dark scroller. -->
  <Section variant="vault" pad="default" maxWidth="wide">
    <div class="hl-loop-wrap">
      <div class="hl-loop-meta">
        <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: #4F46E5; text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 1rem;">THE LOOP</div>
        <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: #191c24; margin: 0 0 1.5rem;">The optimization loop, <span style="background: linear-gradient(135deg, #4F46E5, #818CF8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">productized.</span></h2>
        <p style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.6; color: #3a3a50; margin: 0 0 1.25rem;">Profile, Sandbox, Data, Evals. Four surfaces, optimized in a loop. Every variant scored against ground truth. Ship what passes.</p>
        <p style="font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.65; color: #5e5e7a; margin: 0;">Same loop runs whether you're tuning a customer-support agent, a trading strategy, or a data extractor. Independently versioned. Independently optimizable. The protocol settles SLAs and routes payouts so the loop converges on economics, not vibes.</p>
      </div>
      <!-- Orbital animated loop diagram. Particle traces a closed path
           through 4 nodes (Profile / Sandbox / Data / Evals) in 6s; each
           node ring pulses when the particle passes; center "CONVERGES"
           label breathes on a 4.5s pulse. Pure SVG + SMIL + CSS, no JS. -->
      <div class="hl-orbit" aria-hidden="true">
        <svg viewBox="-160 -160 320 320" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="hl-grad-cool" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#A5AAFC"/>
              <stop offset="100%" stop-color="#4F46E5"/>
            </linearGradient>
            <radialGradient id="hl-particle-glow" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#A5AAFC" stop-opacity="0.95"/>
              <stop offset="55%" stop-color="#818CF8" stop-opacity="0.4"/>
              <stop offset="100%" stop-color="#818CF8" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="hl-center-pulse" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#4F46E5" stop-opacity="0.32"/>
              <stop offset="60%" stop-color="#4F46E5" stop-opacity="0.06"/>
              <stop offset="100%" stop-color="#4F46E5" stop-opacity="0"/>
            </radialGradient>
            <path id="hl-loop-path" d="M 0 -110 C 60 -110, 110 -60, 110 0 S 60 110, 0 110 S -110 60, -110 0 S -60 -110, 0 -110 Z" fill="none"/>
          </defs>
          <circle cx="0" cy="0" r="58" fill="url(#hl-center-pulse)">
            <animate attributeName="r" values="48;78;48" dur="4.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.85;0.35;0.85" dur="4.5s" repeatCount="indefinite"/>
          </circle>
          <text x="0" y="-3" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" letter-spacing="0.16em" fill="#4F46E5">CONVERGES</text>
          <text x="0" y="13" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" letter-spacing="0.16em" fill="#4F46E5">ON GOAL</text>
          <use href="#hl-loop-path" stroke="rgba(79, 70, 229, 0.22)" stroke-width="1.2" stroke-dasharray="3 4"/>
          <g fill="#4F46E5">
            <polygon points="-3,-3 5,0 -3,3" transform="translate(110, 0)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(0, 110) rotate(90)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(-110, 0) rotate(180)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(0, -110) rotate(-90)"/>
          </g>
          <circle r="14" fill="url(#hl-particle-glow)">
            <animateMotion dur="6s" repeatCount="indefinite" rotate="auto"><mpath href="#hl-loop-path"/></animateMotion>
          </circle>
          <circle r="3.5" fill="#A5AAFC">
            <animateMotion dur="6s" repeatCount="indefinite" rotate="auto"><mpath href="#hl-loop-path"/></animateMotion>
          </circle>
          <g class="hl-orbit-node hl-orbit-node--profile">
            <circle cx="0" cy="-110" r="22" fill="#ffffff" stroke="url(#hl-grad-cool)" stroke-width="1.5"/>
            <circle cx="0" cy="-110" r="22" fill="none" stroke="rgba(79, 70, 229, 0.45)" stroke-width="2" class="hl-orbit-pulse"/>
            <text x="0" y="-114" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#4F46E5" letter-spacing="0.12em">01</text>
            <text x="0" y="-101" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#191c24">Profile</text>
          </g>
          <g class="hl-orbit-node hl-orbit-node--sandbox">
            <circle cx="110" cy="0" r="22" fill="#ffffff" stroke="url(#hl-grad-cool)" stroke-width="1.5"/>
            <circle cx="110" cy="0" r="22" fill="none" stroke="rgba(79, 70, 229, 0.45)" stroke-width="2" class="hl-orbit-pulse"/>
            <text x="110" y="-4" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#4F46E5" letter-spacing="0.12em">02</text>
            <text x="110" y="9" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#191c24">Sandbox</text>
          </g>
          <g class="hl-orbit-node hl-orbit-node--data">
            <circle cx="0" cy="110" r="22" fill="#ffffff" stroke="url(#hl-grad-cool)" stroke-width="1.5"/>
            <circle cx="0" cy="110" r="22" fill="none" stroke="rgba(79, 70, 229, 0.45)" stroke-width="2" class="hl-orbit-pulse"/>
            <text x="0" y="106" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#4F46E5" letter-spacing="0.12em">03</text>
            <text x="0" y="119" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#191c24">Data</text>
          </g>
          <g class="hl-orbit-node hl-orbit-node--evals">
            <circle cx="-110" cy="0" r="22" fill="#ffffff" stroke="url(#hl-grad-cool)" stroke-width="1.5"/>
            <circle cx="-110" cy="0" r="22" fill="none" stroke="rgba(79, 70, 229, 0.45)" stroke-width="2" class="hl-orbit-pulse"/>
            <text x="-110" y="-4" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#4F46E5" letter-spacing="0.12em">04</text>
            <text x="-110" y="9" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#191c24">Evals</text>
          </g>
        </svg>
      </div>
    </div>
  </Section>

  <!-- '5 lines, real agent' — replaced 'One SDK. Three primitives.' tabbed
       ExamplePanel per Drew's 'totally different direction' note. Single
       60-second-to-first-agent demo: 5 lines of code (left) drive a live
       streaming output (right). No tabs, no widgetry. Cinematic, not
       generic. -->
  <section class="hl-build-section" id="see-it">
    <div class="hl-build">
      <div class="hl-build-inner">
        <div class="hl-build-meta">
          <div class="hl-build-eyebrow"><span class="hl-build-dot"></span> 60 SECONDS · LIVE</div>
          <h2 class="hl-build-title">Spawn a box. Hand it a goal. <span class="wf-gradient-text">Stream the result.</span></h2>
          <p class="hl-build-lede">Every agent shipped on Tangle starts here. Spawn an isolated box, hand it a goal, stream the result. The runtime, the routing, the billing — all behind one API key.</p>
          <div class="hl-build-stack">
            <span class="hl-build-pill"><strong>Sandbox</strong> isolated runtime</span>
            <span class="hl-build-pill"><strong>Router</strong> 671 models</span>
            <span class="hl-build-pill"><strong>Evals</strong> auto-scored</span>
          </div>
          <a class="hl-build-cta" href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer">
            Read the SDK docs
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hl-build-frame">
          <div class="hl-build-tabs">
            <span class="hl-build-tab--filename">agent.ts</span>
            <span class="hl-build-tab-spacer"></span>
            <span class="hl-build-tab-status"><span class="hl-build-status-dot"></span> live</span>
          </div>
          <div class="hl-build-split">
            <pre class="hl-build-code"><code><span class="cw-k">import</span> &#123; <span class="cw-f">TangleClient</span> &#125; <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/tcloud"</span>;

<span class="cw-k">const</span> tangle = <span class="cw-k">new</span> <span class="cw-f">TangleClient</span>(&#123; apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> &#125;);
<span class="cw-k">const</span> box    = <span class="cw-k">await</span> tangle.sandbox.<span class="cw-f">create</span>(&#123; image: <span class="cw-s">"node:22"</span> &#125;);

<span class="cw-k">for await</span> (<span class="cw-k">const</span> ev <span class="cw-k">of</span> tangle.<span class="cw-f">agent</span>(box).<span class="cw-f">run</span>(<span class="cw-s">"Refactor src/ to TypeScript"</span>)) &#123;
  process.stdout.<span class="cw-f">write</span>(ev.delta);
&#125;</code></pre>
            <div class="hl-build-stream" aria-live="polite">
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--sandbox">sandbox</span><span>spawned <code>sbx_a8f3c2d1</code> · <strong>0.6s</strong></span></div>
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--router">router</span><span>routed → <code>anthropic/claude-sonnet-4-6</code></span></div>
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--agent">agent</span><span>read <code>src/index.js</code></span></div>
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--agent">agent</span><span>wrote <code>src/index.ts</code> · <strong>+87 / -14</strong></span></div>
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--sandbox">sandbox</span><span><code>tsc --noEmit</code> · <strong style="color: #34D399;">0 errors</strong></span></div>
              <div class="hl-build-stream-line"><span class="hl-build-tag hl-build-tag--evals">evals</span><span>refactor-correctness · <strong style="color: #34D399;">0.94</strong></span></div>

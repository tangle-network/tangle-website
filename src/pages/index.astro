      letter-spacing: 0.08em;
    }

    /* Sandbox. live spawn rows */
    .t-infra-sb-visual {
      margin-top: auto;
      display: flex; flex-direction: column; gap: 0.35rem;
      padding: 0.875rem;
      background: linear-gradient(180deg, #f7fbf9 0%, #ecf6f0 100%);
      border: 1px solid rgba(5, 150, 105, 0.14);
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .t-infra-sb-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.225rem 0;
      border-bottom: 1px dashed rgba(5,150,105,0.12);
    }
    .t-infra-sb-row:last-child { border-bottom: 0; }
    .t-infra-sb-img { color: #4F46E5; font-weight: 600; }
    .t-infra-sb-ms  { color: #047857; font-weight: 700; }

    /* Router. number + auto-failover indicator + animated route line +
       cycling provider highlight (one provider lights up at a time on
       a 7s cycle to suggest "auto-failover routing live"). */
    .t-infra-rt-visual {
      margin-top: auto;
      display: flex; flex-direction: column; gap: 0.55rem;
      padding: 0.875rem;
      background: linear-gradient(180deg, #f7faff 0%, #edf2fc 100%);
      border: 1px solid rgba(37, 99, 235, 0.14);
      border-radius: 8px;
    }
    .t-infra-rt-headline {
      display: flex; justify-content: space-between; align-items: flex-start;
    }
    .t-infra-rt-num {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1;
      color: #2563EB;
    }
    .t-infra-rt-label {
      font-family: var(--font-mono);
      font-size: 0.625rem;
      letter-spacing: 0.12em;
      color: #5e5e7a;
      text-transform: uppercase;
      margin-top: 0.125rem;
    }
    .t-infra-rt-failover {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.18rem 0.5rem;
      background: rgba(5, 150, 105, 0.10);
      border: 1px solid rgba(5, 150, 105, 0.32);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: #047857;
    }
    .t-infra-rt-fov-dot {
      width: 6px; height: 6px; border-radius: 999px; background: #059669;
      box-shadow: 0 0 8px rgba(5, 150, 105, 0.55);
      animation: t-infra-pulse 1.6s ease-in-out infinite;
    }
    .t-infra-rt-route {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.4rem 0.55rem;
      background: rgba(37, 99, 235, 0.08);
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 0.7rem;
    }
    .t-infra-rt-route-from { color: #5e5e7a; }
    .t-infra-rt-route-arrow {
      color: #2563EB; font-weight: 700;
      animation: t-infra-rt-arrow 7s ease-in-out infinite;
    }
    @keyframes t-infra-rt-arrow {
      0%, 100% { transform: translateX(0); opacity: 0.7; }
      50%      { transform: translateX(3px); opacity: 1; }
    }
    .t-infra-rt-route-target { color: #1d4ed8; font-weight: 700; }
    .t-infra-rt-providers {
      display: flex; flex-wrap: wrap; gap: 0.3rem;
    }
    .t-infra-rt-prov, .t-infra-rt-providers span {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      padding: 0.18rem 0.45rem;
      background: rgba(37, 99, 235, 0.08);
      color: #1d4ed8;
      border-radius: 3px;
      transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
    }
    /* Cycling highlight. each numbered provider gets a 1s active phase
       on a 7s loop. -1s offset between siblings staggers them. */
    .t-infra-rt-prov { animation: t-infra-rt-prov 7s ease-in-out infinite; }
    .t-infra-rt-prov--1 { animation-delay: 0s; }
    .t-infra-rt-prov--2 { animation-delay: -1s; }
    .t-infra-rt-prov--3 { animation-delay: -2s; }
    .t-infra-rt-prov--4 { animation-delay: -3s; }
    .t-infra-rt-prov--5 { animation-delay: -4s; }
    .t-infra-rt-prov--6 { animation-delay: -5s; }
    .t-infra-rt-prov--7 { animation-delay: -6s; }
    @keyframes t-infra-rt-prov {
      0%, 14%, 100% { background: rgba(37, 99, 235, 0.08); color: #1d4ed8; transform: translateY(0); }
      4%, 10%       { background: rgba(37, 99, 235, 0.32); color: #1e40af; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(37, 99, 235, 0.18); }
    }
    @keyframes t-infra-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.42; }
    }

    /* Browser Agent. chrome bar with status pill + animated stage with
       cursor sweeping to a CTA on a 7s loop + cycling trace pills synced
       to the cursor phase. */
    .t-infra-ba-visual {
      margin-top: auto;
      display: flex; flex-direction: column; gap: 0.5rem;
      padding: 0.875rem;
      background: linear-gradient(180deg, #fff8ee 0%, #fcf0d9 100%);
      border: 1px solid rgba(217, 119, 6, 0.18);
      border-radius: 8px;
    }
    .t-infra-ba-chrome {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.45rem 0.625rem;
      background: #ffffff;
      border: 1px solid rgba(217, 119, 6, 0.14);
      border-radius: 6px;
    }
    .t-infra-ba-dot {
      width: 8px; height: 8px; border-radius: 999px; background: rgba(217, 119, 6, 0.42);
    }
    .t-infra-ba-dot:first-child { background: #ff5f57; }
    .t-infra-ba-dot:nth-child(2) { background: #febc2e; }
    .t-infra-ba-dot:nth-child(3) { background: #28c840; }
    .t-infra-ba-url {
      flex: 1;
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      color: #5e5e7a;
      padding-left: 0.45rem;
    }
    .t-infra-ba-status {
      flex-shrink: 0;
      display: inline-flex; align-items: center;
      padding: 0.1rem 0.4rem;
      background: rgba(5, 150, 105, 0.14);
      border: 1px solid rgba(5, 150, 105, 0.32);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 700;
      color: #047857;
    }
    /* Stage. page-mock with skeleton lines + a CTA + cursor that sweeps
       in from off-canvas, taps the CTA, retreats. 7s loop. */
    .t-infra-ba-stage {
      position: relative;
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 0.75rem 0.875rem 1.4rem;
      background: #ffffff;
      border: 1px solid rgba(217, 119, 6, 0.14);
      border-radius: 6px;
      overflow: hidden;
    }
    .t-infra-ba-line {
      height: 5px; border-radius: 3px;
      background: rgba(217, 119, 6, 0.14);
    }
    .t-infra-ba-line--1 { width: 64%; background: linear-gradient(90deg, rgba(217,119,6,0.32), rgba(217,119,6,0.10)); }
    .t-infra-ba-line--2 { width: 48%; }
    .t-infra-ba-line--3 { width: 72%; }
    .t-infra-ba-cta {
      align-self: flex-start;
      margin-top: 0.25rem;
      padding: 0.35rem 0.875rem;
      background: #4F46E5;
      color: #ffffff;
      border: 0;
      border-radius: 5px;
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      cursor: default;
      box-shadow: 0 4px 12px rgba(79, 70, 229, 0.32);
      position: relative;
    }
    .t-infra-ba-cta::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow: 0 0 0 0 rgba(165, 170, 252, 0);
      animation: t-infra-ba-tap 7s linear infinite;
      pointer-events: none;
    }
    @keyframes t-infra-ba-tap {
      0%, 30%, 100% { box-shadow: 0 0 0 0 rgba(165, 170, 252, 0); }
      32%           { box-shadow: 0 0 0 0 rgba(165, 170, 252, 0.7); }
      40%           { box-shadow: 0 0 0 14px rgba(165, 170, 252, 0); }
    }
    .t-infra-ba-cursor {
      position: absolute;
      right: 0.875rem;
      bottom: 0.625rem;
      color: #1f2937;
      filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.32));
      animation: t-infra-ba-sweep 7s cubic-bezier(0.33, 0.16, 0.45, 1) infinite;
      transform-origin: 0 0;
    }
    @keyframes t-infra-ba-sweep {
      0%, 5%   { transform: translate(40px, 30px) scale(1); opacity: 0; }
      14%      { transform: translate(40px, 30px) scale(1); opacity: 1; }
      28%      { transform: translate(0, 0) scale(1); opacity: 1; }
      32%      { transform: translate(0, 0) scale(0.85); opacity: 1; }
      36%      { transform: translate(0, 0) scale(1); opacity: 1; }
      55%      { transform: translate(-90px, -40px) scale(1); opacity: 1; }
      72%      { transform: translate(40px, 30px) scale(1); opacity: 0.6; }
      80%, 100% { transform: translate(40px, 30px) scale(1); opacity: 0; }
    }
    .t-infra-ba-trace {
      display: flex; flex-wrap: wrap; gap: 0.35rem;
    }
    .t-infra-ba-step {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      padding: 0.25rem 0.5rem;
      background: rgba(217, 119, 6, 0.08);
      border: 1px solid rgba(217, 119, 6, 0.14);
      border-radius: 4px;
      color: #92400e;
      transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
    }
    .t-infra-ba-step--ok {
      background: rgba(5, 150, 105, 0.14);
      border-color: rgba(5, 150, 105, 0.45);
      color: #047857;
      font-weight: 700;
    }
    /* Cycle the active state through the 4 trace steps. synced to cursor
       sweep timing (7s loop). nth-child(1)=goto, (2)=click, (3)=verify,
       (4)=ok. Goal step gets the green highlight when active. */
    .t-infra-ba-trace .t-infra-ba-step:nth-child(1) { animation: t-infra-ba-fade 7s linear infinite; animation-delay: 0s; }
    .t-infra-ba-trace .t-infra-ba-step:nth-child(2) { animation: t-infra-ba-fade 7s linear infinite; animation-delay: -5.25s; }
    .t-infra-ba-trace .t-infra-ba-step:nth-child(3) { animation: t-infra-ba-fade 7s linear infinite; animation-delay: -3.5s; }
    .t-infra-ba-trace .t-infra-ba-step:nth-child(4) { animation: t-infra-ba-fade-ok 7s linear infinite; animation-delay: -1.75s; }
    @keyframes t-infra-ba-fade {
      0%, 25%   { background: rgba(217, 119, 6, 0.32); border-color: rgba(217,119,6,0.55); color: #92400e; box-shadow: 0 0 12px rgba(217, 119, 6, 0.22); font-weight: 700; }
      26%, 100% { background: rgba(217, 119, 6, 0.08); border-color: rgba(217,119,6,0.14); color: #92400e; box-shadow: none; font-weight: 400; }
    }
    @keyframes t-infra-ba-fade-ok {
      0%, 25%   { background: rgba(5, 150, 105, 0.28); border-color: rgba(5, 150, 105, 0.55); color: #047857; box-shadow: 0 0 14px rgba(5, 150, 105, 0.22); }
      26%, 100% { background: rgba(5, 150, 105, 0.14); border-color: rgba(5, 150, 105, 0.45); color: #047857; box-shadow: none; }
    }

    /* Agent Builder. chip stack with model-cycler + animated eval bar
       implying live tuning. */
    .t-infra-ab-visual {
      margin-top: auto;
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 0.875rem;
      background: linear-gradient(180deg, #fbf8ff 0%, #f1ebfa 100%);
      border: 1px solid rgba(124, 58, 237, 0.14);
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .t-infra-ab-chip {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.275rem 0;
      border-bottom: 1px dashed rgba(124, 58, 237, 0.12);
    }
    .t-infra-ab-key {
      color: #7C3AED; font-weight: 700; min-width: 3rem;
    }
    .t-infra-ab-val { color: #3a3a50; }
    /* Model swap. vertical scroll cycle through 4 models. ~2s per
       model, 8s loop. Single visible row at a time. */
    .t-infra-ab-swap {
      position: relative;
      display: block;
      height: 1.05rem;
      overflow: hidden;
      flex: 1;
      min-width: 0;
    }
    .t-infra-ab-swap-item {
      position: absolute;
      inset: 0;
      color: #3a3a50;
      white-space: nowrap;
      animation: t-infra-ab-cycle 8s ease-in-out infinite;
      opacity: 0;
    }
    .t-infra-ab-swap-item:nth-child(1) { animation-delay: 0s; }
    .t-infra-ab-swap-item:nth-child(2) { animation-delay: -6s; }
    .t-infra-ab-swap-item:nth-child(3) { animation-delay: -4s; }
    .t-infra-ab-swap-item:nth-child(4) { animation-delay: -2s; }
    @keyframes t-infra-ab-cycle {
      0%        { opacity: 0; transform: translateY(8px); }
      4%, 24%   { opacity: 1; transform: translateY(0); }
      28%, 100% { opacity: 0; transform: translateY(-8px); }
    }
    /* Eval row. bar fills from 60% to 94% on a 4s pulse + score number
     ticks 8.6 → 9.4 in sync. Implies live auto-iterate. */
    .t-infra-ab-eval {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.4rem 0;
      margin-top: 0.125rem;
    }
    .t-infra-ab-eval-bar {
      flex: 1;
      height: 5px;
      background: rgba(124, 58, 237, 0.10);
      border-radius: 3px;
      overflow: hidden;
      position: relative;
    }
    .t-infra-ab-eval-fill {
      display: block;
      height: 100%;
      background: linear-gradient(90deg, #7C3AED, #34D399);
      border-radius: 3px;
      animation: t-infra-ab-bar 4s ease-in-out infinite;
      width: 94%;
    }
    @keyframes t-infra-ab-bar {
      0%, 100% { width: 86%; }
      50%      { width: 94%; }
    }
    .t-infra-ab-eval-num {
      color: #047857;
      font-weight: 700;
      min-width: 1.75rem;
      text-align: right;
      animation: t-infra-ab-num 4s ease-in-out infinite;
    }
    .t-infra-ab-eval-num::before { content: '9.4'; }
    @keyframes t-infra-ab-num {
      /* keyframes that swap content via counter-style trick are messy;
         we just toggle opacity to imply ticking instead. */
      0%, 100% { opacity: 0.7; }
      50%      { opacity: 1; }
    }

    /* Open Source Libraries. internal 2x2 sub-grid */
    .t-infra-oss-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      margin-top: 0.75rem;
    }
    .t-infra-oss-cell {
      padding: 1rem 1.125rem;
      background: #fafbff;
      border: 1px solid rgba(99, 102, 241, 0.14);
      border-radius: 10px;
      transition: border-color 0.18s ease, background 0.18s ease;
    }
    .t-infra-tile--oss:hover .t-infra-oss-cell {
      border-color: rgba(99, 102, 241, 0.28);
      background: #ffffff;
    }
    .t-infra-oss-name {
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      font-weight: 700;
      color: #4F46E5;
      margin-bottom: 0.5rem;
    }
    .t-infra-oss-import {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      color: #3a3a50;
      background: rgba(99, 102, 241, 0.06);
      border: 1px solid rgba(99, 102, 241, 0.14);
      border-radius: 5px;
      padding: 0.32rem 0.5rem;
      margin-bottom: 0.5rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .t-infra-oss-import span {
      color: #4F46E5; font-weight: 700; margin-right: 0.4rem;
    }
    .t-infra-oss-desc {
      font-family: var(--font-sans);
      font-size: 0.875rem;
      line-height: 1.45;
      color: #3a3a50;
      margin-bottom: 0.6rem;
    }
    .t-infra-oss-stats {
      display: flex; flex-wrap: wrap; gap: 0.4rem;
    }
    .t-infra-oss-stat {
      display: inline-flex; align-items: center; gap: 0.3rem;
      font-family: var(--font-mono);
      font-size: 0.625rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      padding: 0.18rem 0.45rem;
      background: rgba(99, 102, 241, 0.08);
      color: #4F46E5;
      border-radius: 3px;
    }
    .t-infra-oss-stat-icon {
      color: #d97706;
      font-size: 0.7rem;
    }

    /* Responsive. collapse the bento at narrower widths */
    @media (max-width: 1100px) {
      .t-infra-tile--bp,
      .t-infra-tile--sandbox,
      .t-infra-tile--router,
      .t-infra-tile--browser,
      .t-infra-tile--builder { grid-column: span 12; }
      .t-infra-oss-grid { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      .t-infra-bp-cursor,
      .t-infra-rt-fov-dot,
      .t-infra-rt-route-arrow,
      .t-infra-rt-prov,
      .t-infra-ba-cursor,
      .t-infra-ba-cta::after,
      .t-infra-ba-trace .t-infra-ba-step,
      .t-infra-ab-swap-item,
      .t-infra-ab-eval-fill,
      .t-infra-ab-eval-num { animation: none !important; opacity: 1; transform: none; }
      .t-infra-ab-swap-item:not(:first-child) { display: none; }
    }

    /* ─── Trust strip (vault) ─── */
    .t-trust-head {
      text-align: center;
      max-width: 56rem;
      margin: 0 auto 3rem;
    }
    .t-trust-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: #4F46E5;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .t-trust-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 2.4vw + 0.5rem, 2rem);
      font-weight: 700;
      letter-spacing: -0.018em;
      line-height: 1.2;
      color: #191c24;
      margin: 0;
      text-wrap: balance;
    }
    .t-trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(110, 108, 148, 0.22);
      border: 1px solid rgba(110, 108, 148, 0.22);
      border-radius: 12px;
      overflow: hidden;
    }
    .t-trust-cell {
      background: #ffffff;
      padding: 1.5rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      transition: background 0.18s ease;
    }
    .t-trust-cell:hover { background: #fafbfc; }
    .t-trust-name {
      font-family: var(--font-display);
      font-size: 1.0625rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      color: #191c24;
    }
    .t-trust-out {
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      line-height: 1.4;
      color: #5e5e7a;
    }
    @media (max-width: 991px) {
      .t-trust-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .t-trust-grid { grid-template-columns: 1fr; }
    }

    /* ─── Lifecycle (dark) ─── */
    .t-life {
      background: var(--depth-1);
      border-bottom: 1px solid var(--border-subtle);
      position: relative;
      overflow: hidden;
    }
    .t-life::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 12% 20%, rgba(99, 102, 241, 0.12) 0%, transparent 55%),
        radial-gradient(ellipse at 88% 80%, rgba(165, 170, 252, 0.08) 0%, transparent 55%);
      pointer-events: none;
    }
    .t-life-inner {
      position: relative;
      z-index: 1;
      max-width: 84rem;
      margin: 0 auto;
      padding: 6rem 6%;
    }
    .t-life-head {
      text-align: center;
      max-width: 52rem;
      margin: 0 auto 3rem;
    }
    .t-life-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--brand-cool);
      text-transform: uppercase;
      margin-bottom: 0.875rem;
    }
    .t-life-title {
      font-family: var(--font-display);
      font-size: var(--type-h2);
      font-weight: var(--type-h2-weight);
      line-height: var(--type-h2-line);
      letter-spacing: var(--type-h2-track);
      color: var(--text-primary);
      margin: 0 0 1rem;
      text-wrap: balance;
    }
    .t-life-lede {
      font-family: var(--font-sans);
      font-size: 1.0625rem;
      line-height: 1.6;
      color: var(--text-secondary);
      max-width: 44rem;
      margin: 0 auto;
    }
    .t-life-stage {
      background: var(--depth-2);
      border: 1px solid var(--border-default);
      border-radius: 16px;
      padding: 2rem 2rem 1.5rem;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    }
    .t-life-svg {
      width: 100%;
      height: auto;
      display: block;
    }
    .t-life-legend {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 0.75rem;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-subtle);
    }
    .t-life-leg {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      line-height: 1.35;
      color: var(--text-secondary);
    }
    .t-life-leg strong {
      color: var(--text-primary);
      font-weight: 600;
    }
    .t-life-leg code {
      background: rgba(165, 170, 252, 0.12);
      color: var(--text-primary);

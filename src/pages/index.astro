---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import BentoCell from '../components/ui/BentoCell.astro';
import StoryScroller from '../components/ui/StoryScroller.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
---

<BaseLayout
  title="Infrastructure for AI services"
  description="Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship."
>

  <!-- ─────────────── 1 · HERO (dark, full-viewport, centered) ─────────────── -->
  <Hero
    layout="one-col"
    align="center"
    title='Infrastructure for <span class="wf-gradient-text">AI services</span>.'
    subtitle="Sandboxed runtime. Unified model routing. Programmable billing. The stack underneath every agent you ship."
    lede="Spawn an isolated box in 0.6 seconds. Route across 671 models with one key. Bill per call, not per seat. DSPy, Mastra, LangChain, your own — bring whatever framework you've already chosen."
    primaryCta={{ label: 'Try Blueprint Agent', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'Read the docs', href: 'https://docs.tangle.tools', external: true }}
    videoBg={{
      poster: '/images/hero/glass-cylinders-poster.jpg',
      webm: '/videos/glass-cylinders.webm',
      mp4: '/videos/glass-cylinders.mp4',
    }}
  />

  <!-- ─────────────── 2 · TRUST STRIP (vault, framework partners + outcomes) ─────────────── -->
  <Section variant="vault" pad="tight" maxWidth="wide" class="t-trust">
    <div class="t-trust-head">
      <div class="t-trust-eyebrow">DESIGNED FOR TEAMS SHIPPING AT SCALE</div>
      <h2 class="t-trust-title">The frameworks your team already uses, on the runtime you've been waiting for.</h2>
    </div>
    <div class="t-trust-grid">
      <div class="t-trust-cell">
        <div class="t-trust-name">DSPy</div>
        <div class="t-trust-out">→ optimize prompts against ground truth, not vibes</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">Mastra</div>
        <div class="t-trust-out">→ deploy agents to a real sandbox in one call</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">LangChain</div>
        <div class="t-trust-out">→ swap providers without changing a line</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">LlamaIndex</div>
        <div class="t-trust-out">→ index, retrieve, run — all behind one key</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">CrewAI</div>
        <div class="t-trust-out">→ multi-agent crews, isolated per task</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">OpenAI</div>
        <div class="t-trust-out">→ drop-in compatible, 671 models routed</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">Anthropic</div>
        <div class="t-trust-out">→ Sonnet, Opus, Haiku — same billing rail</div>
      </div>
      <div class="t-trust-cell">
        <div class="t-trust-name">Coinbase</div>
        <div class="t-trust-out">→ x402 payments wired to the protocol</div>
      </div>
    </div>
  </Section>

  <!-- ─────────────── 3 · METRICS STRIP (dark, horizontal, mono) ─────────────── -->
  <div class="wf-metrics-strip">
    <div class="wf-metrics-strip-inner">
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        0.6s p50 cold-start
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        671 models · 14 providers
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
        90% WebBench-50
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        $0.06 / vCPU-hr
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        SOC 2 · 55 / 57
      </span>
      <span class="wf-metrics-strip-divider">|</span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09a1.65 1.65 0 00-1-1.51 1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09a1.65 1.65 0 001.51-1 1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 110 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        60+ ecosystem partners
      </span>
    </div>
  </div>

  <!-- ─────────────── 4 · ANIMATED LIFECYCLE DIAGRAM (dark, the "moment") ─────────────── -->
  <section class="t-life">
    <div class="t-life-inner">
      <div class="t-life-head">
        <div class="t-life-eyebrow">THE LIFECYCLE</div>
        <h2 class="t-life-title">One request. Five hops. <span class="wf-gradient-text">Settled in seconds.</span></h2>
        <p class="t-life-lede">A request arrives. We spawn an isolated box, route the model call, run the agent, snapshot the result, and meter the spend — all behind one API key. Watch the packet move.</p>
      </div>

      <div class="t-life-stage" aria-hidden="true">
        <svg viewBox="0 0 1280 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" class="t-life-svg">
          <defs>
            <linearGradient id="t-life-edge" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(165,170,252,0.10)"/>
              <stop offset="50%" stop-color="rgba(165,170,252,0.55)"/>
              <stop offset="100%" stop-color="rgba(165,170,252,0.10)"/>
            </linearGradient>
            <linearGradient id="t-life-node" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#1D1B38"/>
              <stop offset="100%" stop-color="#141328"/>
            </linearGradient>
            <radialGradient id="t-life-packet" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#A5AAFC" stop-opacity="1"/>
              <stop offset="50%" stop-color="#818CF8" stop-opacity="0.55"/>
              <stop offset="100%" stop-color="#818CF8" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="t-life-packet-ok" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#34D399" stop-opacity="1"/>
              <stop offset="55%" stop-color="#34D399" stop-opacity="0.45"/>
              <stop offset="100%" stop-color="#34D399" stop-opacity="0"/>
            </radialGradient>
            <path id="t-life-path"
              d="M 60 120 L 240 120 L 460 120 L 680 120 L 900 120 L 1120 120 L 1240 120"
              fill="none"/>
          </defs>

          <use href="#t-life-path" stroke="rgba(99,102,241,0.18)" stroke-width="1" stroke-dasharray="2 6"/>
          <use href="#t-life-path" stroke="url(#t-life-edge)" stroke-width="2"/>

          <g class="t-life-node">
            <rect x="14" y="92" width="92" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(165,170,252,0.35)" stroke-width="1"/>
            <text x="60" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#A5AAFC" letter-spacing="0.14em">INPUT</text>
            <text x="60" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">request</text>
          </g>

          <g class="t-life-node">
            <rect x="186" y="92" width="108" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(165,170,252,0.35)" stroke-width="1"/>
            <text x="240" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#A5AAFC" letter-spacing="0.14em">SPAWN</text>
            <text x="240" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">sandbox · 0.6s</text>
          </g>

          <g class="t-life-node">
            <rect x="406" y="92" width="108" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(165,170,252,0.35)" stroke-width="1"/>
            <text x="460" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#A5AAFC" letter-spacing="0.14em">ROUTE</text>
            <text x="460" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">671 models</text>
          </g>

          <g class="t-life-node">
            <rect x="626" y="92" width="108" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(165,170,252,0.35)" stroke-width="1"/>
            <text x="680" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#A5AAFC" letter-spacing="0.14em">RUN</text>
            <text x="680" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">tools · streaming</text>
          </g>

          <g class="t-life-node">
            <rect x="846" y="92" width="108" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(165,170,252,0.35)" stroke-width="1"/>
            <text x="900" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#A5AAFC" letter-spacing="0.14em">SNAPSHOT</text>
            <text x="900" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">save · restore</text>
          </g>

          <g class="t-life-node">
            <rect x="1066" y="92" width="108" height="56" rx="10" fill="url(#t-life-node)" stroke="rgba(52,211,153,0.45)" stroke-width="1"/>
            <text x="1120" y="118" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" fill="#34D399" letter-spacing="0.14em">BILL</text>
            <text x="1120" y="134" text-anchor="middle" font-family="Outfit, sans-serif" font-size="10" fill="#C5C5DC">$0.04 · settled</text>
          </g>

          <g fill="rgba(165,170,252,0.55)">
            <polygon points="-4,-3 5,0 -4,3" transform="translate(180,120)"/>
            <polygon points="-4,-3 5,0 -4,3" transform="translate(400,120)"/>
            <polygon points="-4,-3 5,0 -4,3" transform="translate(620,120)"/>
            <polygon points="-4,-3 5,0 -4,3" transform="translate(840,120)"/>
            <polygon points="-4,-3 5,0 -4,3" transform="translate(1060,120)"/>
          </g>

          <circle r="14" fill="url(#t-life-packet)">
            <animateMotion dur="7s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>
          <circle r="3.5" fill="#A5AAFC">
            <animateMotion dur="7s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>

          <circle r="12" fill="url(#t-life-packet)" opacity="0.85">
            <animateMotion dur="7s" begin="-2.3s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>
          <circle r="3" fill="#818CF8">
            <animateMotion dur="7s" begin="-2.3s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>

          <circle r="12" fill="url(#t-life-packet-ok)" opacity="0.8">
            <animateMotion dur="7s" begin="-4.6s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>
          <circle r="3" fill="#34D399">
            <animateMotion dur="7s" begin="-4.6s" repeatCount="indefinite" rotate="auto"><mpath href="#t-life-path"/></animateMotion>
          </circle>
        </svg>

        <div class="t-life-legend">
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--in"></span><strong>Input</strong> arrives at <code>router.tangle.tools</code></div>
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--sandbox"></span><strong>Spawn</strong> isolated box · sub-second</div>
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--router"></span><strong>Route</strong> to the right model · auto-failover</div>
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--agent"></span><strong>Run</strong> the agent · stream tool calls</div>
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--snap"></span><strong>Snapshot</strong> · resume any time</div>
          <div class="t-life-leg"><span class="t-life-leg-dot t-life-leg-dot--ok"></span><strong>Bill</strong> per call · USD-direct</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────── 5 · STICKY-SCROLL NARRATIVE (vault, 3 stages, 1.5x track) ─────────────── -->
  <div class="t-story-wrap">
    <StoryScroller
      eyebrow="THE FOUR SURFACES, IN MOTION"
      title="Profile, Sandbox, Data."
      titleAccent="Optimized in a loop."
      lede="Every agent on Tangle is the composition of a profile, a sandbox, and the data it touches. We make all three independently versionable — and continuously optimizable against the goal you actually care about."
      stages={[
        { id: 'profile', num: '01', title: 'Profile.', body: "The agent's identity — model, tools, prompts, policies. Versioned per release. Swap providers without rewriting the agent. <strong>Same loop, different brain.</strong>" },
        { id: 'sandbox', num: '02', title: 'Sandbox.',  body: 'An isolated container the agent runs inside. Any Docker image, sub-second start, snapshot and restore. <strong>Ship the agent the same way you ship code.</strong>' },
        { id: 'data',    num: '03', title: 'Data.',     body: 'Public, personal, licensed — split into prior-known and emergent. The agent reads from one channel and writes back to another. <strong>Data lineage you can audit.</strong>' },
      ]}
    >
      <Fragment slot="visual-0">
        <div class="t-story-card">
          <div class="t-story-card-eyebrow">PROFILE</div>
          <pre class="t-story-card-code"><code><span class="cw-c"># profile.yaml</span>
<span class="cw-k">model:</span>   <span class="cw-s">anthropic/claude-sonnet-4-6</span>
<span class="cw-k">tools:</span>   [<span class="cw-s">shell</span>, <span class="cw-s">edit</span>, <span class="cw-s">grep</span>]
<span class="cw-k">policy:</span>  <span class="cw-s">no-egress</span>
<span class="cw-k">budget:</span>  <span class="cw-n">$0.50</span> / run</code></pre>
          <div class="t-story-card-foot">v0.4.2 · pinned</div>
        </div>
      </Fragment>
      <Fragment slot="visual-1">
        <div class="t-story-card">
          <div class="t-story-card-eyebrow">SANDBOX</div>
          <div class="t-story-card-rows">
            <div class="t-story-row"><span class="t-story-tag t-story-tag--ok">spawned</span><code>sbx_a8f3c2d1</code><span class="t-story-row-x">0.6s</span></div>
            <div class="t-story-row"><span class="t-story-tag t-story-tag--mut">wrote</span><code>src/index.ts</code><span class="t-story-row-x">+87 / -14</span></div>
            <div class="t-story-row"><span class="t-story-tag t-story-tag--ok">tsc</span><code>--noEmit</code><span class="t-story-row-x">0 errors</span></div>
            <div class="t-story-row"><span class="t-story-tag t-story-tag--snap">snapshot</span><code>s3://snaps/run-7fx</code><span class="t-story-row-x">12 MB</span></div>
          </div>
          <div class="t-story-card-foot">node:22 · 4 vCPU · 8 GiB</div>
        </div>
      </Fragment>
      <Fragment slot="visual-2">
        <div class="t-story-card">
          <div class="t-story-card-eyebrow">DATA</div>
          <div class="t-story-data-grid">
            <div class="t-story-data-cell">
              <div class="t-story-data-l">PUBLIC</div>
              <div class="t-story-data-v">prior</div>
              <div class="t-story-data-c">web · code · arxiv</div>
            </div>
            <div class="t-story-data-cell">
              <div class="t-story-data-l">PUBLIC</div>
              <div class="t-story-data-v">emergent</div>
              <div class="t-story-data-c">eval traces</div>
            </div>
            <div class="t-story-data-cell">
              <div class="t-story-data-l">PERSONAL</div>
              <div class="t-story-data-v">prior</div>
              <div class="t-story-data-c">repo · docs</div>
            </div>
            <div class="t-story-data-cell t-story-data-cell--accent">
              <div class="t-story-data-l">PERSONAL</div>
              <div class="t-story-data-v">emergent</div>
              <div class="t-story-data-c">run output</div>
            </div>
          </div>
          <div class="t-story-card-foot">lineage · fully audited</div>
        </div>
      </Fragment>
    </StoryScroller>
  </div>

  <!-- ─────────────── 6 · THREE PRODUCTS (vault) ─────────────── -->
  <Section variant="vault" pad="default" id="products">
    <div class="t-prod-head">
      <div class="t-prod-eyebrow">THE STACK</div>
      <h2 class="t-prod-title">Build with one. <span class="t-prod-grad">Compose all three.</span></h2>
      <p class="t-prod-lede">Same auth, same billing, same observability. Pick the surface that matches the problem.</p>
    </div>

    <div class="t-prod-grid">
      <a href="/services/blueprint-agent" class="home-product-card" style="text-decoration: none; color: inherit; display: block;">
        <BentoCell variant="vault">
          <Fragment slot="title">
            <span style="display: flex; align-items: center; gap: 12px;">
              <span class="home-product-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="16 18 22 12 16 6"></polyline>
                  <polyline points="8 6 2 12 8 18"></polyline>
                </svg>
              </span>
              <span>Blueprint Agent</span>
            </span>
          </Fragment>
          <Fragment slot="body">Describe the service in English. Watch four models build it. Merge the PR.</Fragment>
          <div class="home-product-cta">
            <span>Open Blueprint Agent</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </BentoCell>
      </a>

      <a href="/services/browser-agent" class="home-product-card" style="text-decoration: none; color: inherit; display: block;">
        <BentoCell variant="vault">
          <Fragment slot="title">
            <span style="display: flex; align-items: center; gap: 12px;">
              <span class="home-product-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </span>
              <span>Browser Agent</span>
            </span>
          </Fragment>
          <Fragment slot="body">Plain-English goals. Real Chromium. Screenshot + DOM evidence on every turn.</Fragment>
          <div class="home-product-cta">
            <span>See it run</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </BentoCell>
      </a>

      <a href="/services/sandbox" class="home-product-card" style="text-decoration: none; color: inherit; display: block;">
        <BentoCell variant="vault">
          <Fragment slot="title">
            <span style="display: flex; align-items: center; gap: 12px;">
              <span class="home-product-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              </span>
              <span>Sandbox SDK</span>
            </span>
          </Fragment>
          <Fragment slot="body">Isolated containers for agent code. Sub-second start. Any Docker image. Snapshot and restore.</Fragment>
          <div class="home-product-cta">
            <span>Read the SDK</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </BentoCell>
      </a>
    </div>
  </Section>

  <!-- ─────────────── 7 · CODE + LIVE OUTPUT (dark) ─────────────── -->
  <section class="hl-build-section" id="see-it">
    <div class="hl-build">
      <div class="hl-build-inner">

    .t-oss-card-prompt {
      color: #A5AAFC; font-weight: 700; margin-right: 0.4rem;
    }
    .t-oss-card-badge {
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-size: 0.625rem;
      font-weight: 700;
      letter-spacing: 0.08em;

---
import BaseLayout from '../layouts/BaseLayout.astro';

const canonicalUrl = 'https://tangle.tools/';
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${canonicalUrl}#organization`,
      name: 'Tangle',
      legalName: 'Tangle Technologies, Inc.',
      url: canonicalUrl,
      logo: 'https://tangle.tools/icons/tangle-icon-512.png',
      description:
        'Tangle builds infrastructure for self-improving AI systems: sandboxes for agent work, one API key for every model, and automatic trace analysis that turns runs into improvements.',
      sameAs: [
        'https://twitter.com/tangle_network',
        'https://github.com/tangle-network',
        'https://www.youtube.com/@TangleNetwork',
        'https://discord.com/invite/cv8EfJu3Tn',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${canonicalUrl}#website`,
      name: 'Tangle',
      url: canonicalUrl,
      publisher: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: 'Run agents, intelligently. Make them better.',
      description:
        'Build agents in Tangle sandboxes with any coding harness. Every run is traced and analyzed; improvements ship for approval or autonomously.',
      isPartOf: { '@id': `${canonicalUrl}#website` },
      about: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
  ],
};

// Session-trace waterfall (illustrative run, internally consistent: the three
// full-suite spans total 33.1s of the 38.2s run).
const spans = [
  { name: 'run · fix flaky checkout test', kind: 'run', l: 0, w: 100, d: '38.2s', ind: 0 },
  { name: 'claude-opus-4-8 · plan', kind: 'llm', l: 1, w: 5.5, d: '2.1s', ind: 1 },
  { name: 'read · checkout.test.ts', kind: 'tool', l: 7, w: 1.6, d: '0.5s', ind: 1 },
  { name: 'pnpm test · full suite', kind: 'shell', l: 9, w: 33.5, d: '12.8s', ind: 1, waste: true },
  { name: 'edit · retry-policy.ts', kind: 'edit', l: 43.5, w: 5, d: '1.9s', ind: 1 },
  { name: 'pnpm test · full suite', kind: 'shell', l: 49.5, w: 29.8, d: '11.4s', ind: 1, waste: true },
  { name: 'edit · checkout.test.ts', kind: 'edit', l: 80.5, w: 2.3, d: '0.9s', ind: 1 },
  { name: 'pnpm test · full suite', kind: 'shell', l: 84, w: 15.2, d: '8.9s', ind: 1, waste: true },
];

// Real SDK usage, verified against products/sandbox/sdk/README.md in
// agent-dev-container. Do not invent APIs.
const sandboxSnippet = `import { Sandbox } from '@tangle-network/sandbox'

const box = await new Sandbox({
  apiKey: process.env.TANGLE_API_KEY,
}).create({ image: 'universal' })

await box.exec('claude -p "fix the flaky checkout test"')`;

const products = [
  {
    name: 'Sandboxes',
    line: 'Isolated computers for agents: shell, files, browser, any coding harness.',
    href: 'https://sandbox.tangle.tools',
    domain: 'sandbox.tangle.tools',
    hue: 'cyan',
  },
  {
    name: 'Intelligence',
    line: 'Analyst agents mine your traces, propose changes, and prove them on held-out runs.',
    href: 'https://intelligence.tangle.tools',
    domain: 'intelligence.tangle.tools',
    hue: 'magenta',
  },
  {
    name: 'Inference',
    line: '477+ models behind one OpenAI-compatible key.',
    href: 'https://router.tangle.tools',
    domain: 'router.tangle.tools',
    hue: 'indigo',
  },
];

// Coding harnesses preinstalled in every sandbox image. Marks are the
// canonical org avatars (GitHub); pi ships a designed monogram.
const harnesses = [
  { cmd: 'claude', name: 'Claude Code', logo: '/images/harness/claude-code.svg' },
  { cmd: 'codex', name: 'Codex', logo: '/images/harness/codex.png' },
  { cmd: 'opencode', name: 'OpenCode', logo: '/images/harness/opencode.svg' },
  { cmd: 'hermes', name: 'Hermes', logo: '/images/harness/hermes.png' },
  { cmd: 'openclaw', name: 'OpenClaw', logo: '/images/harness/openclaw.png' },
  { cmd: 'nanoclaw', name: 'NanoClaw', logo: '/images/harness/nanoclaw.png' },
  { cmd: 'kimi', name: 'Kimi Code', logo: '/images/harness/kimi-code.png' },
  { cmd: 'pi', name: 'Pi', logo: '/images/harness/pi.svg' },
];

---

<BaseLayout
  title="Run agents, intelligently. Make them better."
  description="Build agents in Tangle sandboxes with any coding harness. Every run is traced and analyzed automatically. Improvements ship for your approval, or autonomously."
  image="/images/og-self-improving-agents.png"
  imageAlt="Tangle: infrastructure for self-improving AI systems"
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

  <!-- ============================ HERO (dark, video) ============================ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-art" aria-hidden="true">
      <canvas id="hero-knot"></canvas>
      <img class="hero-poster" src="/images/brand/knot-poster.webp" alt="" loading="eager" />
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="shell">
      <div class="hero-copy">
        <h1 id="hero-title">
          Run agents, intelligently.
          <span class="grad-text">Make them better.</span>
        </h1>
        <p>
          Tangle runs your agents in isolated sandboxes and turns every trace into proven
          improvements.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer">Open the workbench</a>
          <a class="btn btn-ghost" href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer">Read the docs</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PROOF STRIP (paper) ==================== -->
  <section class="proof-strip" aria-label="Platform facts">
    <div class="shell proof-grid">
      <div class="proof"><strong>477+</strong><span>models on the router</span></div>
      <div class="proof"><strong>61+</strong><span>providers, one key</span></div>
      <div class="proof"><strong>8</strong><span>harnesses preinstalled</span></div>
      <div class="proof"><strong>OSS</strong><span>runtime and evals on GitHub</span></div>
    </div>
  </section>

  <!-- ========= SANDBOX (dark): harnesses run, traces emit ========= -->
  <section class="sb-section" aria-labelledby="sb-title">
    <div class="sb-flow">
      <div class="sb-sticky">
        <div class="shell">
          <div class="sb-head">
            <h2 id="sb-title">We optimize agents while they run.</h2>
            <p>
              Coding harnesses, tool-calling agents, long-running workflows: each gets a real
              computer in a Tangle Sandbox, and every run generates traces.
            </p>
          </div>

          <div class="sb-rail" aria-label="Coding harnesses preinstalled in every sandbox">
            {harnesses.map((h, i) => (
              <div class="sb-tile" data-i={i}>
                <img class="sb-logo" src={h.logo} alt={`${h.name} mark`} width="48" height="48" loading="lazy" />
                <span class="sb-name">{h.name}</span>
                <code class="mono sb-cmd">$ {h.cmd}</code>
                <span class="sb-run mono">running</span>
              </div>
            ))}
          </div>

          <svg class="sb-lines" viewBox="0 0 1160 300" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="sb-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#A5AAFC" />
                <stop offset="100%" stop-color="#4F46E5" />
              </linearGradient>
            </defs>
            {harnesses.map((_, i) => (
              <path
                class="sb-line"
                d={`M ${73 + i * 145} 0 C ${73 + i * 145} 150, 580 170, 580 268`}
                fill="none"
                stroke="url(#sb-grad)"
                stroke-width="2"
                stroke-linecap="round"
                pathLength="1"

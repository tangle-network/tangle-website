      box-shadow: 0 0 0 0 rgba(165, 170, 252, 0);
      animation: t-infra-ba-tap 7s linear infinite;
      pointer-events: none;
    }
    @keyframes t-infra-ba-tap {
      0%, 30%, 100% { box-shadow: 0 0 0 0 rgba(165, 170, 252, 0); }

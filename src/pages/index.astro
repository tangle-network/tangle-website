    }
    .hl-build-frame {
      background: var(--depth-2);
      border: 1px solid var(--border-default);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    }
    .hl-build-frame {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;

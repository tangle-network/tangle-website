      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .t-trust-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 2.4vw + 0.5rem, 2rem);
      font-weight: 700;
      letter-spacing: -0.018em;
      line-height: 1.2;
      color: #191c24;
      margin: 0;
      text-wrap: balance;
    }
    .t-trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(110, 108, 148, 0.22);
      border: 1px solid rgba(110, 108, 148, 0.22);
      border-radius: 12px;
      overflow: hidden;
    }
    .t-trust-cell {
      background: #ffffff;
      padding: 1.5rem 1.25rem;

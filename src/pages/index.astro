      flex-direction: column;
      gap: 0.4rem;
      transition: background 0.18s ease;
    }
    .t-trust-cell:hover { background: #fafbfc; }
    .t-trust-name {
      font-family: var(--font-display);
      font-size: 1.0625rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      color: #191c24;
    }
    .t-trust-out {
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      line-height: 1.4;
      color: #5e5e7a;
    }
    @media (max-width: 1024px) {
      .t-trust-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .t-trust-grid { grid-template-columns: 1fr; }
    }

    /* ─── Lifecycle (dark) ─── */
    .t-life {
      background: var(--depth-1);
      border-bottom: 1px solid var(--border-subtle);
      position: relative;
      overflow: hidden;
    }
    .t-life::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 12% 20%, rgba(99, 102, 241, 0.12) 0%, transparent 55%),
        radial-gradient(ellipse at 88% 80%, rgba(165, 170, 252, 0.08) 0%, transparent 55%);
      pointer-events: none;
    }
    .t-life-inner {
      position: relative;
      z-index: 1;
      max-width: 84rem;
      margin: 0 auto;
      padding: 6rem 6%;
    }
    .t-life-head {
      text-align: center;
      max-width: 52rem;
      margin: 0 auto 3rem;
    }
    .t-life-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--brand-cool);
      text-transform: uppercase;
      margin-bottom: 0.875rem;
    }
    .t-life-title {
      font-family: var(--font-display);
      font-size: var(--type-h2);
      font-weight: var(--type-h2-weight);
      line-height: var(--type-h2-line);
      letter-spacing: var(--type-h2-track);
      color: var(--text-primary);
      margin: 0 0 1rem;
      text-wrap: balance;
    }
    .t-life-lede {
      font-family: var(--font-sans);
      font-size: 1.0625rem;

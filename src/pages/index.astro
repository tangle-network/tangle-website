    .hl-build-inner {
      display: grid;
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.3fr);
      gap: 5rem;
      align-items: start;
    }
    .hl-build-meta { max-width: 32rem; }
    .hl-build-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      color: #34D399;
      margin-bottom: 0.875rem;
    }
    .hl-build-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;

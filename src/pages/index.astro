  <script>
    // Four Surfaces sticky-scroll: as the user scrolls, mark exactly one
    // .surfaces-stage and one .surfaces-panel as .is-active based on which
    // stage is closest to the viewport center. Stage cards are stacked
    // vertically inside the sticky pin, so we can't observe them directly
    // (they don't move). Instead we slice the outer .surfaces-track height
    // into 4 segments and use a single scroll handler keyed by the track's
    // bounding rect.
    (() => {
      const track = document.querySelector<HTMLElement>('.surfaces-track');
      if (!track) return;
      const stages = Array.from(document.querySelectorAll<HTMLElement>('.surfaces-stage'));
      const panels = Array.from(document.querySelectorAll<HTMLElement>('.surfaces-panel'));
      if (stages.length === 0 || panels.length === 0) return;

      const setActive = (idx: number) => {
        const i = Math.max(0, Math.min(stages.length - 1, idx));
        stages.forEach((s, k) => s.classList.toggle('is-active', k === i));
        panels.forEach((p, k) => p.classList.toggle('is-active', k === i));
      };

      // Default: first stage active before scroll
      setActive(0);

      const onScroll = () => {
        const rect = track.getBoundingClientRect();
        const vh = window.innerHeight;
        // Scroll progress through the track: 0 at start, 1 at end.
        // Track is taller than viewport — the pin sticks while we scroll past it.
        const total = rect.height - vh;
        if (total <= 0) return;
        const progress = Math.max(0, Math.min(1, -rect.top / total));
        // Quantize into N stages with deadbands so the active stage feels stable.
        const idx = Math.min(stages.length - 1, Math.floor(progress * stages.length));
        setActive(idx);
      };

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) {
        // Reduced motion: just light up all stages, no scroll-driven swap.
        stages.forEach((s) => s.classList.add('is-active'));
        panels.forEach((p) => p.classList.add('is-active'));
        return;
      }

      let raf = 0;
      const scheduled = () => {
        if (raf) return;
        raf = requestAnimationFrame(() => { raf = 0; onScroll(); });
      };
      window.addEventListener('scroll', scheduled, { passive: true });
      window.addEventListener('resize', scheduled);
      onScroll();
    })();
  </script>


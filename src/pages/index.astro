            <text class="sb-node-label" x="596" y="277">traces</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ========= INTELLIGENCE (paper): split scroll story ========= -->
  <section class="intel-section" aria-labelledby="intel-title">
    <div class="intel-flow" data-stage="0">
      <div class="intel-sticky">
        <div class="shell">
          <h2 id="intel-title" class="intel-h2">Every run makes your agents better.</h2>

          <div class="istage-area">
            <!-- stage 0: the trace -->
            <div class="istage istage-0" aria-label="Stage one: agents generate session traces">
              <div class="icopy">
                <h3>Your agents generate traces</h3>
                <p>
                  Every sandbox run and every routed model call produces a full session trace:
                  each span, tool call, token, and cost.
                </p>
              </div>
              <div class="ipane">
                <div class="wf-card">
                  <div class="wf-head mono"><span>checkout-agent · claude</span><span>38.2s</span></div>
                  {spans.map((sp) => (
                    <div class={`wf-row ind-${sp.ind}`}>
                      <span class="wf-name mono">{sp.name}</span>
                      <span class="wf-track"><i class={`wf-bar k-${sp.kind}`} style={`--l:${sp.l}%; --w:${sp.w}%`}></i></span>
                      <span class="wf-dur mono">{sp.d}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- stage 1: the analysis -->
            <div class="istage istage-1" aria-label="Stage two: analyst agents find the repeating waste">
              <div class="icopy">
                <h3>Analysts find what repeats</h3>
                <p>
                  Analyst agents and RLMs read every trace and cluster the waste and failures

    .t-oss-all {
      display: inline-flex; align-items: center; gap: 0.5rem;
      margin-top: 2rem;
      padding: 0.625rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.04em;

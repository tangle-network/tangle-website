  }

  .ship-card:nth-child(1) { top: 0; left: 2%; }
  .ship-card:nth-child(2) { top: 8%; right: 0; }
  .ship-card:nth-child(3) { bottom: 6%; left: 8%; }
  .ship-card:nth-child(4) { bottom: 0; right: 5%; }

  .intel-flow.static .ship-fan { height: auto; display: grid; gap: 1rem; }
  .intel-flow.static .ship-card { position: static; width: auto; opacity: 1; transform: none; }

  .ship-card header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .ship-card header img {
    width: 22px;
    height: 22px;
    border-radius: 5px;
  }

  /* dark marks need a dark chip behind them on white cards */
  .ship-card header img[src*="github"],
  .ship-card header img[src*="slack"] {
    padding: 3px;
    background: #11122d;
  }

  .ship-card header b {
    color: var(--ink);
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .chip {
    margin-left: auto;
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .chip-merged { background: rgba(99, 102, 241, 0.12); color: #4338CA; font-weight: 700; }
  .chip-done { background: rgba(4, 120, 87, 0.1); color: #047857; font-weight: 600; }
  .chip-live { background: rgba(129, 140, 248, 0.14); color: #4F46E5; font-weight: 600; }
  .chip-note { background: var(--paper-1); color: var(--ink-muted); }

  .ship-ref { margin: 0.55rem 0 0; color: var(--ink-muted); font-size: 0.82rem; }

  .ship-card > p:last-child {
    margin: 0.4rem 0 0;
    color: var(--ink-secondary);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  /* ---------- products (paper, gradient cards) ---------- */
  .products-section {
    background: var(--paper-0);
    color: var(--ink);
    padding: 5.5rem 0 5rem;
  }

  .statement {
    max-width: 56rem;
    color: var(--ink);
    font-size: clamp(2.2rem, 3.6vw, 3.3rem);
    line-height: 1.1;
  }

  .statement-grad {
    background-image: linear-gradient(92deg, #818CF8 0%, #6366F1 50%, #4F46E5 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: #4F46E5; /* fallback */
  }

  @supports not (background-clip: text) {
    .statement-grad { color: #4F46E5; -webkit-text-fill-color: currentColor; }
  }

  .product-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
    margin-top: 2.6rem;
  }

  .p-card {
    position: relative;
    display: flex;
    min-height: 22rem;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid rgba(25, 28, 60, 0.14);
    text-decoration: none;
    box-shadow: 0 22px 60px rgba(25, 28, 60, 0.14);
    transition: transform 0.25s cubic-bezier(0.2, 0.6, 0.2, 1), box-shadow 0.25s ease;
  }

  .p-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 32px 80px rgba(25, 28, 60, 0.22);
  }

  /* Layered chromatic fields, replaced by generated card art when it lands
     (background-image on .p-card-art). The gradient stack is the fallback
     and the loading state. */
  .p-card-art {
    position: absolute;
    inset: 0;
    background-color: #0c0b1d;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .p-card:hover .p-card-art { transform: scale(1.04); }

  /* Generated dispersion card art (Gemini 3 Pro, briefs in gtm assets).
     background-color stays as the loading/fallback state. */
  .p-card-cyan .p-card-art {
    background-image: url('/images/brand/cards/card-sandbox.webp');
  }

  .p-card-magenta .p-card-art {
    background-image: url('/images/brand/cards/card-intelligence.webp');
  }

  .p-card-indigo .p-card-art {
    background-image: url('/images/brand/cards/card-inference.webp');
  }

  .p-card-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.45rem;
    width: 100%;
    padding: 1.4rem 1.4rem 1.3rem;
    background: linear-gradient(180deg, transparent 0%, rgba(8, 8, 20, 0.32) 42%, rgba(8, 8, 20, 0.78) 100%);
  }

  .p-card-body h3 {
    color: #ffffff;
    font-size: 1.8rem;
    letter-spacing: -0.022em;
  }

  .p-card-body p {
    margin: 0;
    max-width: 24rem;
    color: rgba(240, 240, 250, 0.9);
    font-size: 1.18rem;
    line-height: 1.55;
  }

  .p-card-link {
    margin-top: 0.6rem;
    color: rgba(240, 240, 250, 0.66);
    font-size: 0.92rem;
  }

  .p-card:hover .p-card-link { color: #ffffff; }

  /* ---------- sandbox chapter (dark, scroll-driven) ---------- */
  .sb-section {
    background: linear-gradient(180deg, #0c0b1d 0%, #11122d 100%);
    border-top: 1px solid rgba(199, 201, 238, 0.08);
  }

  .sb-flow {
    position: relative;
    height: 240vh;
  }

  .sb-sticky {
    position: sticky;
    top: 0;
    display: flex;
    align-items: center;
    height: 100vh;
    overflow: hidden;
  }

  .sb-head {
    display: grid;
    grid-template-columns: minmax(14rem, 0.55fr) minmax(0, 1.45fr);
    gap: 2.5rem;
    align-items: start;
  }

  .sb-head h2 {
    color: #ffffff;
    font-size: clamp(2.3rem, 3.6vw, 3.5rem);
    letter-spacing: -0.032em;
  }

  .sb-head p {
    margin: 0;
    color: rgba(237, 237, 244, 0.8);
    font-size: clamp(1.2rem, 1.5vw, 1.45rem);
    line-height: 1.6;
    max-width: 46rem;
  }

  .sb-rail {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 2.6rem;
  }

  .sb-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    padding: 1.1rem 0.6rem 0.9rem;
    border: 1px solid rgba(199, 201, 238, 0.12);
    border-radius: 12px;
    background: #12112a;
    text-align: center;
    opacity: 0.38;
    transition: opacity 0.45s ease, border-color 0.45s ease, box-shadow 0.45s ease, transform 0.45s ease;
  }

  .sb-tile.on {
    opacity: 1;
    border-color: rgba(129, 140, 248, 0.45);
    box-shadow: 0 10px 40px rgba(99, 102, 241, 0.16);
    transform: translateY(-3px);
  }

  .sb-logo {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: inset 0 0 0 1px rgba(199, 201, 238, 0.14);
  }

  .sb-name {
    color: #ededf4;
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .sb-cmd {
    color: rgba(198, 200, 226, 0.66);
    font-size: 0.85rem;
  }

  .sb-run {
    color: #A5AAFC;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .sb-tile.on .sb-run { opacity: 1; }

  .sb-lines {
    display: block;
    width: 100%;
    height: clamp(11rem, 24vh, 15rem);
    margin-top: 0.4rem;
  }

  .sb-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  .sb-node {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .sb-flow.done .sb-node {
    opacity: 1;
    filter: drop-shadow(0 0 10px rgba(99, 102, 241, 0.9));
  }

  .sb-node-label {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: rgba(198, 200, 226, 0.7);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .sb-flow.done .sb-node-label { opacity: 1; }

  /* static fallback */
  .sb-flow.static { height: auto; }
  .sb-flow.static .sb-sticky { position: static; height: auto; padding: 4.5rem 0; }
  .sb-flow.static .sb-tile { opacity: 1; }
  .sb-flow.static .sb-tile .sb-run { opacity: 0; }
  .sb-flow.static .sb-line { stroke-dashoffset: 0; }
  .sb-flow.static .sb-node, .sb-flow.static .sb-node-label { opacity: 1; }

  /* ---------- intelligence scroll flow (paper) ---------- */
  .intel-section {
    background: var(--paper-0);
    color: var(--ink);
    padding: 6.5rem 0 0;
  }

  .intel-head {
    max-width: 46rem;
    margin: 0 auto;
    text-align: center;
  }

  .intel-head h2 {
    color: var(--ink);
    font-size: clamp(2.3rem, 3.6vw, 3.5rem);
    letter-spacing: -0.032em;
  }

  .intel-head p {
    margin: 1.2rem 0 0;
    color: var(--ink-secondary);
    font-size: clamp(1.2rem, 1.5vw, 1.45rem);
    line-height: 1.6;
  }

  .intel-flow {
    position: relative;
    height: 340vh;
  }

  .intel-sticky {
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    overflow: hidden;
  }

  .intel-step {
    position: absolute;
    width: 1px;
    height: 33.4%;
    left: 0;
  }

  .intel-step[data-step="0"] { top: 0; }
  .intel-step[data-step="1"] { top: 27%; }
  .intel-step[data-step="2"] { top: 54%; }

  .stage-nav {
    display: flex;
    gap: 2.2rem;
    margin-bottom: 2.4rem;
    padding: 0;
    list-style: none;
  }

  .stage-nav li {
    position: relative;
    padding-bottom: 0.5rem;
    color: var(--ink-muted);
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .stage-nav li::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 2px;
    background: linear-gradient(90deg, #7C3AED, #BE185D);
    transition: right 0.45s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .intel-flow[data-stage="0"] .stage-nav li[data-for="0"],
  .intel-flow[data-stage="1"] .stage-nav li[data-for="1"],
  .intel-flow[data-stage="2"] .stage-nav li[data-for="2"] {
    color: var(--ink);
  }

  .intel-flow[data-stage="0"] .stage-nav li[data-for="0"]::after,
  .intel-flow[data-stage="1"] .stage-nav li[data-for="1"]::after,
  .intel-flow[data-stage="2"] .stage-nav li[data-for="2"]::after {
    right: 0;
  }

  .stage-area {
    position: relative;
    width: min(56rem, 92vw);
    min-height: 30rem;
  }

  .stage {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    opacity: 0;
    transform: translateY(56px);
    transition: opacity 0.55s cubic-bezier(0.2, 0.6, 0.2, 1), transform 0.55s cubic-bezier(0.2, 0.6, 0.2, 1);
    pointer-events: none;
  }

  .intel-flow[data-stage="0"] .stage-0,
  .intel-flow[data-stage="1"] .stage-1,
  .intel-flow[data-stage="2"] .stage-2 {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .intel-flow[data-stage="1"] .stage-0,
  .intel-flow[data-stage="2"] .stage-1 {
    opacity: 0;
    transform: translateY(-44px);
  }

  /* static fallback: no JS, reduced motion, or narrow screens */
  .intel-flow.static { height: auto; padding-bottom: 4rem; }
  .intel-flow.static .intel-sticky { position: static; height: auto; overflow: visible; padding: 2.5rem 0 0; }
  .intel-flow.static .stage-area { min-height: 0; width: min(56rem, 92vw); }
  .intel-flow.static .stage { position: static; opacity: 1; transform: none; pointer-events: auto; margin-bottom: 2.5rem; }
  .intel-flow.static .stage-nav { display: none; }
  .intel-flow.static .intel-step { display: none; }

  .sim-card {
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #d8d8ea;
    border-radius: 14px;
    box-shadow: 0 24px 70px rgba(79, 70, 229, 0.09);
  }

  .sim-card-dim .trace-list li { color: var(--ink-muted); }

  .sim-head {
    padding: 0.85rem 1.4rem;
    border-bottom: 1px solid #ececf6;
    color: var(--ink-muted);
    font-size: 0.88rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .trace-list {
    margin: 0;
    padding: 0.4rem 0;
    list-style: none;
  }

  .trace-list li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.75rem 1.4rem;
    color: var(--ink);
    font-size: 1.02rem;
  }

  .trace-list li + li { border-top: 1px solid var(--paper-1); }

  .t-logo {
    width: 1.5rem;
    height: 1.5rem;
    flex: 0 0 auto;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: inset 0 0 0 1px rgba(25, 28, 60, 0.12);
  }

  .trace-list em {
    margin-left: auto;
    font-style: normal;
    color: var(--ink-muted);
    font-size: 0.92rem;
    white-space: nowrap;
  }

  .trace-list em.hot {
    color: #be123c;
    background: rgba(190, 18, 60, 0.08);
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
  }

  .sim-note {
    margin: 0;
    padding: 0.8rem 1.4rem;
    border-top: 1px solid #ececf6;
    color: var(--ink-muted);
    font-size: 0.88rem;
  }

  .analyst-card {
    align-self: center;
    width: min(40rem, 100%);
    padding: 1.3rem 1.6rem;
    background: #ffffff;
    border: 1px solid #d8d8ea;
    border-left: 3px solid #4F46E5;
    border-radius: 12px;
    box-shadow: 0 18px 50px rgba(124, 58, 237, 0.12);
  }

  .analyst-label {
    color: #7C3AED;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .analyst-card p {
    margin: 0.6rem 0 0;
    color: var(--ink);
    font-size: 1.18rem;
    line-height: 1.6;
  }

  /* ---- the PR card (pierre-register diff) ---- */
  .pr-card {
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #d8d8ea;
    border-radius: 14px;
    box-shadow: 0 28px 80px rgba(79, 70, 229, 0.11);
  }

  .pr-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.4rem;
    border-bottom: 1px solid #ececf6;
  }

  .pr-file {
    color: var(--ink);
    font-size: 1rem;
    font-weight: 600;
  }

  .pr-branch {
    color: var(--ink-muted);
    font-size: 0.88rem;
  }

  .pr-status {
    margin-left: auto;
    font-size: 0.85rem;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
  }

  .pr-card[data-verdict=""] .pr-status::before {
    content: 'open';
    color: #047857;
  }

  .pr-card[data-verdict="approved"] .pr-status {
    background: linear-gradient(92deg, rgba(124, 58, 237, 0.12), rgba(190, 24, 93, 0.12));
  }

  .pr-card[data-verdict="approved"] .pr-status::before {
    content: 'merged';
    background-image: linear-gradient(92deg, #7C3AED, #BE185D);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 700;
  }

  .pr-card[data-verdict="rejected"] .pr-status::before {
    content: 'closed';
    color: var(--ink-muted);
  }

  .pr-diff {
    padding: 0.6rem 0;
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .d-row { display: flex; }

  .d-gut {
    flex: 0 0 3.2rem;
    padding-right: 1rem;
    color: var(--ink-muted);
    font-size: 0.85rem;
    text-align: right;
    user-select: none;
    line-height: inherit;
  }

  .d-code {
    flex: 1;
    padding-right: 1.4rem;
    white-space: pre-wrap;
  }

  .d-hunk .d-code { color: var(--ink-muted); }
  .d-del { background: #FDF0F3; }
  .d-del .d-code { color: #9F1239; }
  .d-add { background: #EBF7F0; }
  .d-add .d-code { color: #065F46; }

  .pr-gate {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1.4rem;
    border-top: 1px solid #ececf6;
    font-size: 0.95rem;
  }

  .gate-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 999px;
    background: rgba(4, 120, 87, 0.1);
    color: #047857;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .pr-gate .mono { color: var(--ink); font-weight: 600; }
  .gate-note { color: var(--ink-muted); }

  .pr-actions {
    display: flex;
    gap: 0.7rem;
    padding: 1rem 1.4rem 1.3rem;
    border-top: 1px solid #ececf6;
  }

  .pr-actions button {
    appearance: none;
    border: 0;
    border-radius: 9px;
    padding: 0.7rem 1.4rem;
    background: #11122d;
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .pr-actions button:hover { transform: translateY(-1px); }

  .pr-actions .pr-reject {
    background: transparent;
    border: 1px solid #d8d8ea;
    color: var(--ink-secondary);
  }

  .pr-after {
    display: none;
    margin: 0;
    padding: 1rem 1.4rem 1.2rem;
    border-top: 1px solid #ececf6;
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  .pr-card[data-verdict="approved"] .pr-actions,
  .pr-card[data-verdict="rejected"] .pr-actions { display: none; }
  .pr-card[data-verdict="approved"] .pr-after-approved { display: block; }
  .pr-card[data-verdict="rejected"] .pr-after-rejected { display: block; }

  /* ---------- proof strip (paper) ---------- */
  .proof-strip {
    background: var(--paper-0);
    border-bottom: 1px solid var(--hairline-light);
    padding: 2.6rem 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
  }

  .proof strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.9rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--ink);
    font-feature-settings: 'tnum';
  }

  .proof span {
    display: block;
    margin-top: 0.35rem;
    color: var(--ink-muted);
    font-size: 1rem;
  }

  /* ---------- open source (dark) ---------- */
  .oss2-section {
    background: #0c0b1d;
    padding: 5.5rem 0 6rem;
    border-top: 1px solid rgba(199, 201, 238, 0.08);
  }

  .oss2-grid {
    display: grid;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.1fr);
    gap: 3.5rem;
    align-items: center;
  }

  .oss2-copy h2 { color: #ffffff; font-size: clamp(2rem, 3vw, 2.9rem); letter-spacing: -0.03em; }

  .oss2-copy p {
    margin: 1rem 0 0;
    color: rgba(237, 237, 244, 0.8);
    font-size: clamp(1.15rem, 1.4vw, 1.35rem);
    line-height: 1.6;
    max-width: 32rem;
  }

  .install-pane {
    margin-top: 1.6rem;
    padding: 0.95rem 1.2rem;
    border: 1px solid rgba(199, 201, 238, 0.18);
    border-radius: 10px;
    background: #12112a;
    color: #ededf4;
    font-size: 1rem;
  }

  .install-prompt { color: #A5AAFC; margin-right: 0.3rem; }

  .oss2-gh {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.1rem;
    color: rgba(198, 200, 226, 0.75);
    font-family: var(--font-mono);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .oss2-gh:hover { color: #ffffff; }

  .oss2-list {
    border: 1px solid rgba(199, 201, 238, 0.14);
    border-radius: 12px;
    overflow: hidden;
  }

  .oss2-row {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1.2rem;
    padding: 1.05rem 1.25rem;
    background: #100f24;
    color: rgba(237, 237, 244, 0.82);
    font-size: 1.02rem;
    line-height: 1.5;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .oss2-row + .oss2-row { border-top: 1px solid rgba(199, 201, 238, 0.09); }
  .oss2-row:hover { background: #16152e; }
  .oss2-row code { color: #A5AAFC; font-size: 0.95rem; }

  /* ---------- pricing (paper) ---------- */
  .price-section {
    background: var(--paper-0);
    color: var(--ink);
    padding: 5.5rem 0 6rem;
  }


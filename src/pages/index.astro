    .t-life-leg-dot--in       { background: #A5AAFC; }
    .t-life-leg-dot--sandbox  { background: #818CF8; }
    .t-life-leg-dot--router   { background: #6366F1; }
    .t-life-leg-dot--agent    { background: #C4B5FD; }
    .t-life-leg-dot--snap     { background: #93C5FD; }
    .t-life-leg-dot--ok       { background: #34D399; }
    @media (max-width: 1024px) {
      .t-life-legend { grid-template-columns: repeat(2, 1fr); gap: 0.875rem; }
      .t-life-stage  { padding: 1.25rem 1rem; }
    }
    @media (prefers-reduced-motion: reduce) {
      .t-life-svg circle[r="14"],
      .t-life-svg circle[r="12"],
      .t-life-svg circle[r="3.5"],
      .t-life-svg circle[r="3"] { display: none; }
    }

    /* ─── Open source libraries (dark, dedicated) ─── */
    .t-oss {
      background: var(--depth-1);
      padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    }
    .t-oss-inner { max-width: 1280px; margin: 0 auto; }
    .t-oss-head { text-align: center; max-width: 56rem; margin: 0 auto 3rem; }
    .t-oss-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;

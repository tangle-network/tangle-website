---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';

const heroAgentCode = `<span class="cw-k">import</span> { <span class="cw-f">TangleClient</span> } <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/tcloud"</span>;

<span class="cw-k">const</span> tangle = <span class="cw-k">new</span> <span class="cw-f">TangleClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> box    = <span class="cw-k">await</span> tangle.sandbox.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-k">for await</span> (<span class="cw-k">const</span> ev <span class="cw-k">of</span> tangle.<span class="cw-f">agent</span>(box).<span class="cw-f">run</span>(<span class="cw-s">"Refactor src/ to TypeScript"</span>)) {
  process.stdout.<span class="cw-f">write</span>(ev.delta);
}`;

const ossLibs = [
  {
    name: '@tangle-network/tcloud',
    repo: 'tangle-network/tcloud',
    stars: 0,
    install: 'npm i @tangle-network/tcloud',
    blurb: 'TypeScript SDK + CLI for the whole platform. Sandbox, router, agents, billing — one client, one key.',
    badge: 'TypeScript',
  },
  {
    name: '@tangle-network/sandbox',
    repo: 'tangle-network/sandbox',
    stars: 0,
    install: 'npm i @tangle-network/sandbox',
    blurb: 'Spawn isolated containers in 600ms. Any Docker image. Snapshot and restore from a single call.',
    badge: 'TypeScript',
  },
  {
    name: '@tangle-network/agent-eval',
    repo: 'tangle-network/agent-eval',
    stars: 0,
    install: 'npm i @tangle-network/agent-eval',
    blurb: 'Score agent runs against rubrics. Compare variants. Powers the leaderboards on ai.tangle.tools.',
    badge: 'TypeScript',
  },
  {
    name: '@tangle-network/sandbox-ui',
    repo: 'tangle-network/sandbox-ui',
    stars: 0,
    install: 'npm i @tangle-network/sandbox-ui',
    blurb: 'React components for chat, terminal, file browser, and tool-call streams. Drop into any agent UI.',
    badge: 'React',
  },
  {
    name: '@tangle-network/browser-agent-driver',
    repo: 'tangle-network/browser-agent-driver',
    stars: 2,
    install: 'npm i -g @tangle-network/browser-agent-driver',
    blurb: 'LLM-driven Chromium with screenshot + DOM evidence per turn. Wallet-extension testing built in.',
    badge: 'CLI · SDK',
  },
  {
    name: 'blueprint-sdk',
    repo: 'tangle-network/blueprint',
    stars: 335,
    install: 'cargo add blueprint-sdk',
    blurb: 'Rust SDK for authoring Blueprints. Router, Caller, TangleArg, TangleResult, sol! macros, the lot.',
    badge: 'Rust',
  },
];

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tangle',
  url: 'https://tangle.tools',
  logo: 'https://tangle.tools/favicon.svg',
  sameAs: [
    'https://twitter.com/tangle_network',
    'https://github.com/webb-tools/tangle',
    'https://t.me/tanglenet',
    'https://www.youtube.com/@TangleNetwork',
    'https://discord.com/invite/cv8EfJu3Tn',
  ],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tangle',
  url: 'https://tangle.tools',
};
---

<BaseLayout
  title="Infrastructure for AI services"
  description="Sandboxed runtime, unified model routing, and programmable billing. One stack for the agents, APIs, and services you ship."
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

  <!-- ─────────────── 1 · HERO (dark, full-viewport, centered) ─────────────── -->
  <Hero
    layout="one-col"
    align="center"
    title='Infrastructure for <span class="wf-gradient-text">AI services</span>.'
    subtitle="Sandboxed runtime. Unified model routing. Programmable billing. The stack underneath every agent you ship."
    primaryCta={{ label: 'Try Blueprint Agent', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'Read the docs', href: 'https://docs.tangle.tools', external: true }}
    videoBg={{
      poster: '/images/hero/glass-cylinders-poster.jpg',
      webm: '/videos/glass-cylinders.webm',
      mp4: '/videos/glass-cylinders.mp4',
    }}
  />

  <!-- ─────────────── 2 · INFRASTRUCTURE GRID (vault, full-viewport, asymmetric bento) ───────────────
       Drew (R21): "second thing should be full-page like hero, grid showing
       all infrastructure pieces. Vibe Coding (Blueprint Agent), Sandbox,
       Router, Browser Agent, Agent Builder, Open Source Libraries (slightly
       larger, with a sub-grid: Sandbox UI, Browser Agent Driver, Agent
       Eval/Gateway/Blueprint UI, Blueprint SDK)." Replaces prior trust
       strip. the strip was framework-logos, this section is what we ship. -->
  <section class="t-infra" aria-label="Tangle infrastructure">
    <div class="t-infra-inner">
      <div class="t-infra-head">
        <div class="t-infra-eyebrow">WHAT WE SHIP</div>
        <h2 class="t-infra-title">Every layer of the stack, <span class="t-infra-grad">open and composable.</span></h2>
        <p class="t-infra-lede">Five products and a library set you can adopt one piece at a time. One API key. One billing rail. The same sandbox, router, and evals across every surface.</p>
      </div>

      <div class="t-infra-grid">

        <!-- 1 · Blueprint Agent (Vibe Coding). large left tile -->
        <a href="/services/blueprint-agent" class="t-infra-tile t-infra-tile--bp" data-accent="indigo">
          <div class="t-infra-tile-head">
            <span class="t-infra-tag">VIBE CODING</span>
            <span class="t-infra-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></span>
          </div>
          <div class="t-infra-tile-name">Blueprint Agent</div>
          <div class="t-infra-tile-role">Prompt to deployed Blueprint, in one workbench session.</div>
          <div class="t-infra-bp-visual" aria-hidden="true">
            <div class="t-infra-bp-prompt"><span class="t-infra-bp-cursor"></span>FROST signing + x402 paywall</div>
            <div class="t-infra-bp-files">
              <span><span class="t-infra-bp-ok"/>src/lib.rs</span>
              <span><span class="t-infra-bp-ok"/>src/jobs/sign.rs</span>
              <span><span class="t-infra-bp-ok"/>blueprint.toml</span>
            </div>
            <div class="t-infra-bp-foot"><span class="t-infra-bp-ship">SHIPPED</span> 4 operators bonded · $0.02 / sign</div>
          </div>
        </a>

        <!-- 2 · Sandbox. middle-top -->
        <a href="/services/sandbox" class="t-infra-tile t-infra-tile--sandbox" data-accent="emerald">
          <div class="t-infra-tile-head">
            <span class="t-infra-tag">ISOLATED RUNTIME</span>
            <span class="t-infra-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></span>
          </div>
          <div class="t-infra-tile-name">Sandbox</div>
          <div class="t-infra-tile-role">Sub-second VM-grade boxes. Any Docker image. Snapshot, restore, scale.</div>
          <div class="t-infra-sb-visual" aria-hidden="true">
            <div class="t-infra-sb-row"><span class="t-infra-sb-img">node:22</span><span class="t-infra-sb-ms">412ms</span></div>
            <div class="t-infra-sb-row"><span class="t-infra-sb-img">python:3.12</span><span class="t-infra-sb-ms">580ms</span></div>
            <div class="t-infra-sb-row"><span class="t-infra-sb-img">your/agent:v3</span><span class="t-infra-sb-ms">1.1s</span></div>
            <div class="t-infra-sb-row"><span class="t-infra-sb-img">node:22</span><span class="t-infra-sb-ms">389ms</span></div>
          </div>
        </a>

        <!-- 3 · Router. middle-right -->
        <a href="https://router.tangle.tools" target="_blank" rel="noopener noreferrer" class="t-infra-tile t-infra-tile--router" data-accent="blue">
          <div class="t-infra-tile-head">
            <span class="t-infra-tag">INFERENCE ROUTING</span>
            <span class="t-infra-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></span>
          </div>
          <div class="t-infra-tile-name">Router</div>
          <div class="t-infra-tile-role">671 models, 14 providers. Drop-in OpenAI-compatible. One key.</div>
          <div class="t-infra-rt-visual" aria-hidden="true">
            <div class="t-infra-rt-headline">
              <div>
                <div class="t-infra-rt-num">671</div>
                <div class="t-infra-rt-label">models routed</div>
              </div>
              <div class="t-infra-rt-failover">
                <span class="t-infra-rt-fov-dot"></span>
                AUTO-FAILOVER
              </div>
            </div>
            <div class="t-infra-rt-route">
              <span class="t-infra-rt-route-from">your call</span>
              <span class="t-infra-rt-route-arrow">→</span>
              <span class="t-infra-rt-route-target">claude-sonnet-4-6</span>
            </div>
            <div class="t-infra-rt-providers">
              <span class="t-infra-rt-prov t-infra-rt-prov--1">openai</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--2">anthropic</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--3">google</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--4">mistral</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--5">meta</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--6">cohere</span>
              <span class="t-infra-rt-prov t-infra-rt-prov--7">groq</span>
              <span class="t-infra-rt-prov">+ 7 more</span>
            </div>
          </div>
        </a>

        <!-- 4 · Browser Agent. bottom-left wide -->
        <a href="/services/browser-agent" class="t-infra-tile t-infra-tile--browser" data-accent="amber">
          <div class="t-infra-tile-head">
            <span class="t-infra-tag">BROWSER USE</span>
            <span class="t-infra-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></span>
          </div>
          <div class="t-infra-tile-name">Browser Agent</div>
          <div class="t-infra-tile-role">Plain-English goals → real Chromium. Screenshot + DOM evidence per turn.</div>
          <div class="t-infra-ba-visual" aria-hidden="true">
            <div class="t-infra-ba-chrome">
              <span class="t-infra-ba-dot"></span><span class="t-infra-ba-dot"></span><span class="t-infra-ba-dot"></span>
              <span class="t-infra-ba-url">your-app.com/dashboard</span>
              <span class="t-infra-ba-status">200 · 312ms</span>
            </div>
            <div class="t-infra-ba-stage">
              <span class="t-infra-ba-line t-infra-ba-line--1"></span>
              <span class="t-infra-ba-line t-infra-ba-line--2"></span>
              <span class="t-infra-ba-line t-infra-ba-line--3"></span>
              <button type="button" class="t-infra-ba-cta" tabindex="-1">Sign up</button>
              <span class="t-infra-ba-cursor">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2 2 L2 18 L7 14 L9 22 L13 21 L11 13 L18 12 Z"/></svg>
              </span>
            </div>
            <div class="t-infra-ba-trace">
              <span class="t-infra-ba-step">turn 1 · goto</span>
              <span class="t-infra-ba-step">turn 2 · click</span>
              <span class="t-infra-ba-step">turn 3 · verify</span>
              <span class="t-infra-ba-step t-infra-ba-step--ok">✓ goal · 4.7s</span>
            </div>
          </div>
        </a>

        <!-- 5 · Agent Builder. bottom-middle -->
        <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="t-infra-tile t-infra-tile--builder" data-accent="violet">
          <div class="t-infra-tile-head">
            <span class="t-infra-tag">AGENT WORKBENCH</span>
            <span class="t-infra-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></span>
          </div>
          <div class="t-infra-tile-name">Agent Builder</div>
          <div class="t-infra-tile-role">Editor, terminal, preview, eval in one workbench. Hot-swap profiles, A/B tools, ship variants.</div>
          <div class="t-infra-ab-visual" aria-hidden="true">
            <div class="t-infra-ab-chip"><span class="t-infra-ab-key">role</span> <span class="t-infra-ab-val">customer-support</span></div>
            <div class="t-infra-ab-chip">
              <span class="t-infra-ab-key">model</span>
              <span class="t-infra-ab-swap">
                <span class="t-infra-ab-swap-item">claude-sonnet-4-6</span>
                <span class="t-infra-ab-swap-item">gpt-5.5</span>
                <span class="t-infra-ab-swap-item">llama-3.3-70b</span>
                <span class="t-infra-ab-swap-item">gemini-3.1-pro</span>
              </span>
            </div>
            <div class="t-infra-ab-chip"><span class="t-infra-ab-key">tools</span> <span class="t-infra-ab-val">[ tickets, draft, send ]</span></div>
            <div class="t-infra-ab-eval">
              <span class="t-infra-ab-key">eval</span>
              <span class="t-infra-ab-eval-bar"><span class="t-infra-ab-eval-fill"></span></span>
              <span class="t-infra-ab-eval-num">9.4</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ─────────────── 3 · METRICS STRIP (dark, horizontal, mono) ─────────────── -->
  <div class="wf-metrics-strip">
    <div class="wf-metrics-strip-inner">
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        0.6s p50 cold-start
      </span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        671 models · 14 providers
      </span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
        90% WebBench-50
      </span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        $0.06 / vCPU-hr
      </span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        SOC 2 · 55 / 57
      </span>
      <span class="wf-metrics-strip-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09a1.65 1.65 0 00-1-1.51 1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09a1.65 1.65 0 001.51-1 1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 110 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        60+ ecosystem partners
      </span>
    </div>
  </div>

  <!-- ─────────────── 4 · OPEN SOURCE LIBRARIES (dark, dedicated) ─────────────── -->
  <section class="t-oss" aria-label="Open source libraries">
    <div class="t-oss-inner">
      <div class="t-oss-head">
        <div class="t-oss-eyebrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.15v3.18c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
          </svg>
          OPEN SOURCE
        </div>
        <h2 class="t-oss-title">The libraries underneath <span class="wf-gradient-text">everything.</span></h2>
        <p class="t-oss-lede">Take any one. Leave the rest. MIT-licensed, on GitHub, npm-shipped.</p>
      </div>

      <div class="t-oss-grid">
        {ossLibs.map((lib) => (
          <a href={`https://github.com/${lib.repo}`} target="_blank" rel="noopener noreferrer" class="t-oss-card">
            <div class="t-oss-card-head">
              <span class="t-oss-card-gh" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.15v3.18c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
              </span>
              <span class="t-oss-card-stars" aria-label={`${lib.stars} stars`}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {lib.stars}
              </span>
            </div>
            <div class="t-oss-card-name">{lib.name}</div>
            <div class="t-oss-card-blurb">{lib.blurb}</div>
            <div class="t-oss-card-foot">
              <code class="t-oss-card-install"><span class="t-oss-card-prompt">$</span>{lib.install}</code>
              <span class="t-oss-card-badge">{lib.badge}</span>
            </div>
          </a>
        ))}
      </div>

      <a href="https://github.com/tangle-network" target="_blank" rel="noopener noreferrer" class="t-oss-all">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.15v3.18c0 .31.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
        Browse all 30+ repos at github.com/tangle-network
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </section>


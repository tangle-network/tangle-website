---
import BaseLayout from '../layouts/BaseLayout.astro';

const loop = [
  {
    step: 'Run',
    title: 'Give agents real infrastructure, not a chat box.',
    body: 'Sandbox gives every run an isolated workspace with files, terminals, browser state, logs, and snapshots.',
    href: '/services/sandbox',
    product: 'Sandbox',
  },
  {
    step: 'Route',
    title: 'Choose the right model without rewriting the app.',
    body: 'Router keeps one OpenAI-compatible interface while switching providers, policies, fallback, cost, and latency.',
    href: 'https://router.tangle.tools',
    product: 'Router',
  },
  {
    step: 'Observe',
    title: 'Capture the trace that explains what happened.',
    body: 'Browser Agent turns web goals into reproducible Chromium runs with screenshots, DOM evidence, and step records.',
    href: '/services/browser-agent',
    product: 'Browser Agent',
  },
  {
    step: 'Improve',
    title: 'Score variants before they reach users.',
    body: 'Agent Eval compares runs against rubrics, holdouts, judges, costs, and regressions so improvement is measurable.',
    href: 'https://github.com/tangle-network/agent-eval',
    product: 'Agent Eval',
  },
  {
    step: 'Ship',
    title: 'Turn the best agent into a service.',
    body: 'Blueprints package the runtime, policy, operator path, and billing so an agent can graduate into production.',
    href: '/services/blueprint-agent',
    product: 'Blueprints',
  },
];

const products = [
  {
    name: 'Sandbox',
    role: 'isolated runtime',
    line: 'Create reproducible workspaces for coding agents, tool calls, tests, and browser-backed tasks.',
    href: '/services/sandbox',
  },
  {
    name: 'Router',
    role: 'model control plane',
    line: 'Route OpenAI-compatible calls across providers with fallback, policy, and health checks.',
    href: 'https://router.tangle.tools',
  },
  {
    name: 'Browser Agent',
    role: 'web action harness',
    line: 'Run real Chromium from a goal and keep the screenshot, DOM, and trace evidence.',
    href: '/services/browser-agent',
  },
  {
    name: 'Agent Eval',
    role: 'evaluation substrate',
    line: 'Score traces, compare candidates, and block regressions in agent behavior.',
    href: 'https://github.com/tangle-network/agent-eval',
  },
  {
    name: 'Blueprint Agent',
    role: 'agent workbench',
    line: 'Build, test, evaluate, and package agent services from one workspace.',
    href: '/services/blueprint-agent',
  },
  {
    name: 'x402 + Blueprints',
    role: 'commercial runtime',
    line: 'Attach usage pricing and operator deployment to the services agents create.',
    href: '/blog/x402-payments-for-ai-agents',
  },
];

const ossLibs = [
  {
    name: '@tangle-network/tcloud',
    install: 'npm i @tangle-network/tcloud',
    blurb: 'TypeScript SDK and CLI for sandbox, router, agents, billing, and manifests.',
    href: 'https://github.com/tangle-network/tcloud',
  },
  {
    name: '@tangle-network/sandbox',
    install: 'npm i @tangle-network/sandbox',
    blurb: 'Create, snapshot, restore, and inspect isolated agent workspaces from code.',
    href: 'https://sandbox.tangle.tools',
  },
  {
    name: '@tangle-network/agent-eval',
    install: 'npm i @tangle-network/agent-eval',
    blurb: 'Trace-first evaluation primitives for rubrics, judges, variants, and promotion gates.',
    href: 'https://github.com/tangle-network/agent-eval',
  },
  {
    name: '@tangle-network/browser-agent-driver',
    install: 'npm i -g @tangle-network/browser-agent-driver',
    blurb: 'Goal-driven Chromium automation with screenshots, DOM capture, and browser evidence.',
    href: 'https://github.com/tangle-network/browser-agent-driver',
  },
];

const canonicalUrl = 'https://tangle.tools/';
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${canonicalUrl}#organization`,
      name: 'Tangle',
      legalName: 'Tangle Technologies, Inc.',
      url: canonicalUrl,
      logo: 'https://tangle.tools/icons/tangle-icon-512.png',
      description: 'Infrastructure for self-improving AI agents: isolated runtime, model routing, browser evidence, evaluation, and deployment.',
      sameAs: [
        'https://twitter.com/tangle_network',
        'https://github.com/tangle-network',
        'https://www.youtube.com/@TangleNetwork',
        'https://discord.com/invite/cv8EfJu3Tn',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${canonicalUrl}#website`,
      name: 'Tangle',
      url: canonicalUrl,
      publisher: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: 'Infrastructure for self-improving agents',
      description: 'Tangle gives AI agents the runtime, router, browser harness, evals, and deployment path they need to improve safely.',
      isPartOf: { '@id': `${canonicalUrl}#website` },
      about: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
    {
      '@type': 'ItemList',
      '@id': `${canonicalUrl}#agent-infrastructure-stack`,
      name: 'Tangle agent infrastructure stack',
      itemListElement: products.map((product, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: product.name,
        description: product.line,
        url: product.href.startsWith('http') ? product.href : `https://tangle.tools${product.href}`,
      })),
    },
    ...products.map((product) => ({
      '@type': 'SoftwareApplication',
      name: product.name,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Web',
      url: product.href.startsWith('http') ? product.href : `https://tangle.tools${product.href}`,
      description: product.line,
      publisher: { '@id': `${canonicalUrl}#organization` },
    })),
  ],
};
---

<BaseLayout
  title="Infrastructure for self-improving agents"
  description="Tangle gives AI agents the runtime, router, browser harness, evals, and deployment path they need to improve safely."
  image="/images/og-self-improving-agents.png"
  imageAlt="Tangle infrastructure for self-improving AI agents"
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

  <section class="home-hero" aria-labelledby="hero-title">
    <video class="home-hero-media" autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg">
      <source src="/videos/glass-cylinders.webm" type="video/webm" />
      <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
    </video>
    <div class="home-hero-shade" aria-hidden="true"></div>
    <div class="home-hero-inner">
      <p class="home-kicker">Infrastructure for AI agents</p>
      <h1 id="hero-title">Make agents better, faster, and safer.</h1>
      <p class="home-hero-copy">
        Tangle is the execution and evaluation stack for self-improving agents: isolated runtime, model routing, browser evidence, and deployment in one system.
      </p>
      <div class="home-hero-actions">
        <a class="home-btn home-btn-primary" href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer">Open the workbench</a>
        <a class="home-btn home-btn-secondary" href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer">Read the docs</a>
      </div>
    </div>
  </section>

  <section class="agent-loop" aria-labelledby="loop-title">
    <div class="loop-head">
      <p class="home-kicker">The platform loop</p>
      <h2 id="loop-title">Every product exists to close the improvement loop.</h2>
      <p>
        Agents do not improve because a demo looks fluent. They improve when every run produces evidence, every candidate is scored, and only better variants ship.
      </p>
    </div>

    <div class="loop-panel">
      <div class="loop-rail" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="loop-steps">
        {loop.map((item) => (
          <a class="loop-card" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <span class="loop-step">{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <span class="loop-product">{item.product}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="product-system" aria-labelledby="products-title">
    <div class="product-system-head">
      <p class="home-kicker">What Tangle builds</p>
      <h2 id="products-title">A concrete stack, not a bundle of AI features.</h2>
      <p>
        The product surface is intentionally narrow: runtime, routing, browser execution, evaluation, and deployment. Each layer feeds the next one.
      </p>
    </div>

    <div class="product-grid">
      {products.map((product) => (
        <a class="product-card" href={product.href} target={product.href.startsWith('http') ? '_blank' : undefined} rel={product.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
          <span>{product.role}</span>
          <h3>{product.name}</h3>
          <p>{product.line}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="evidence-section" aria-labelledby="evidence-title">
    <div class="evidence-copy">
      <p class="home-kicker">Proof over positioning</p>
      <h2 id="evidence-title">The trace is the product boundary.</h2>
      <p>
        A useful agent platform has to prove what it did. Tangle keeps the workspace, model decision, browser observation, tool output, score, and deployment artifact attached to the same run.
      </p>
    </div>
    <div class="trace-window" aria-label="Example agent trace">
      <div class="trace-titlebar">
        <span></span><span></span><span></span>
        <code>run.trace</code>
      </div>
      <div class="trace-lines">
        <p><strong>sandbox</strong><span>node:22 workspace restored from snapshot</span><em>412ms</em></p>
        <p><strong>router</strong><span>claude-sonnet route selected by latency policy</span><em>$0.018</em></p>
        <p><strong>browser</strong><span>checkout regression reproduced with screenshot evidence</span><em>4.7s</em></p>
        <p><strong>eval</strong><span>candidate beats baseline on 43/50 heldout tasks</span><em>+12%</em></p>
        <p><strong>ship</strong><span>blueprint packaged with usage billing and health checks</span><em>ready</em></p>
      </div>
    </div>
  </section>

  <section class="oss-section" aria-labelledby="oss-title">
    <div class="oss-head">
      <p class="home-kicker">Open source substrate</p>
      <h2 id="oss-title">Use the pieces directly.</h2>
    </div>
    <div class="oss-grid">
      {ossLibs.map((lib) => (
        <a class="oss-card" href={lib.href} target="_blank" rel="noopener noreferrer">
          <h3>{lib.name}</h3>
          <code>{lib.install}</code>
          <p>{lib.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="final-cta" aria-labelledby="cta-title">
    <div>
      <p class="home-kicker">Build the loop</p>
      <h2 id="cta-title">Start with one agent run. Keep the evidence. Improve from there.</h2>
    </div>
    <div class="home-hero-actions">
      <a class="home-btn home-btn-primary" href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer">Try Blueprint Agent</a>
      <a class="home-btn home-btn-secondary" href="/services/sandbox">Explore Sandbox</a>
    </div>
  </section>
</BaseLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .home-kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8b93ff;
  }

  .home-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #070713;
    border-bottom: 1px solid var(--border-subtle);
  }

  .home-hero-media,
  .home-hero-shade {
    position: absolute;
    inset: 0;
  }

  .home-hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
  }

  .home-hero-shade {
    background:
      linear-gradient(90deg, rgba(7, 7, 19, 0.98) 0%, rgba(7, 7, 19, 0.82) 42%, rgba(7, 7, 19, 0.42) 100%),
      radial-gradient(circle at 72% 42%, rgba(139, 147, 255, 0.24), transparent 34%);
  }

  .home-hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    padding: 8rem 6% 5rem;
  }

  .home-hero h1,
  .loop-head h2,
  .product-system-head h2,
  .evidence-copy h2,
  .oss-head h2,
  .final-cta h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .home-hero h1 {
    max-width: 58rem;
    margin-top: 1rem;
    font-size: clamp(3.4rem, 7vw, 6.6rem);
  }

  .home-hero-copy {
    max-width: 46rem;
    margin: 1.25rem 0 0;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .home-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 2rem;
  }

  .home-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.35rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
  }

  .home-btn:hover {
    transform: translateY(-1px);
  }

  .home-btn-primary {
    background: #5b5ff0;
    border: 1px solid #7377ff;
    color: #ffffff;
    box-shadow: 0 14px 38px rgba(91, 95, 240, 0.34);
  }

  .home-btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--text-primary);
  }

  .agent-loop,
  .product-system,
  .evidence-section,
  .oss-section,
  .final-cta {
    max-width: 84rem;
    margin: 0 auto;
    padding: 6.5rem 6%;
  }

  .agent-loop,
  .evidence-section {
    max-width: none;
    background: #f5f6fb;
    color: #161925;
  }

  .agent-loop > *,
  .evidence-section > * {
    max-width: 84rem;
    margin-left: auto;
    margin-right: auto;
  }

  .agent-loop .home-kicker,
  .product-system .home-kicker,
  .evidence-section .home-kicker,
  .oss-section .home-kicker {
    color: #545be0;
  }

  .agent-loop h2,
  .evidence-section h2 {
    color: #171a27;
  }

  .loop-head,
  .product-system-head {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  .loop-head h2,
  .product-system-head h2,
  .evidence-copy h2,
  .oss-head h2,
  .final-cta h2 {
    font-size: clamp(2.1rem, 4vw, 4rem);
  }

  .loop-head p:last-child,
  .product-system-head p:last-child,
  .evidence-copy p:last-child {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.65;
    color: #4a5065;
  }

  .loop-panel {
    position: relative;
    padding: 1.25rem;
    background: #ffffff;
    border: 1px solid rgba(21, 24, 37, 0.1);
    border-radius: 8px;
    box-shadow: 0 28px 80px rgba(24, 28, 45, 0.08);
  }

  .loop-rail {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .loop-rail span {
    height: 4px;
    background: linear-gradient(90deg, #5b5ff0, #36b37e);
    border-radius: 999px;
  }

  .loop-steps {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .loop-card,
  .product-card,
  .oss-card {
    text-decoration: none;
  }

  .loop-card {
    min-height: 21rem;
    display: flex;
    flex-direction: column;
    padding: 1.2rem;
    background: #f7f8fc;
    border: 1px solid rgba(21, 24, 37, 0.08);
    border-radius: 8px;
    color: #161925;
    transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
  }

  .loop-card:hover {
    transform: translateY(-2px);
    border-color: rgba(84, 91, 224, 0.34);
    background: #ffffff;
  }

  .loop-step,
  .product-card span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #545be0;
  }

  .loop-card h3,
  .product-card h3,
  .oss-card h3 {
    margin: 0.85rem 0 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.12;
    letter-spacing: 0;
    color: inherit;
  }

  .loop-card p,
  .product-card p,
  .oss-card p {
    margin: 0.8rem 0 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: #596074;
  }

  .loop-product {
    margin-top: auto;
    padding-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    color: #202437;
  }

  .product-system {
    background: var(--depth-1);
  }

  .product-system-head p:last-child {
    color: var(--text-secondary);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .product-card {
    min-height: 16rem;
    padding: 1.3rem;
    background: var(--depth-2);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-primary);
    transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
  }

  .product-card:hover {
    transform: translateY(-2px);
    border-color: rgba(139, 147, 255, 0.36);
    background: var(--depth-3);
  }

  .product-card p {
    color: var(--text-secondary);
  }

  .evidence-section {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 3rem;
    align-items: center;
  }

  .evidence-section > * {
    margin-left: 0;
    margin-right: 0;
  }

  .trace-window {
    overflow: hidden;
    background: #0b0d18;
    border: 1px solid rgba(22, 25, 37, 0.16);
    border-radius: 8px;
    box-shadow: 0 30px 90px rgba(20, 24, 38, 0.2);
  }

  .trace-titlebar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.85rem 1rem;
    background: #111423;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .trace-titlebar span {
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 999px;
    background: #ff6b6b;
  }

  .trace-titlebar span:nth-child(2) {
    background: #ffd166;
  }

  .trace-titlebar span:nth-child(3) {
    background: #36b37e;
  }

  .trace-titlebar code {
    margin-left: 0.5rem;
    color: #c6c8e8;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .trace-lines {
    padding: 0.8rem;
  }

  .trace-lines p {
    display: grid;
    grid-template-columns: 6.5rem minmax(0, 1fr) 4.5rem;
    gap: 1rem;
    align-items: center;
    margin: 0;
    padding: 0.9rem 0.8rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .trace-lines p:last-child {
    border-bottom: 0;
  }

  .trace-lines strong {
    color: #8b93ff;
  }

  .trace-lines span {
    min-width: 0;
    color: #e5e7ff;
  }

  .trace-lines em {
    color: #36d399;
    font-style: normal;
    text-align: right;
  }

  .oss-section {
    background: var(--depth-1);
  }

  .oss-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .oss-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .oss-card {
    padding: 1.15rem;
    background: var(--depth-2);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-primary);
  }

  .oss-card code {
    display: block;
    margin-top: 0.85rem;
    padding: 0.6rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    background: rgba(139, 147, 255, 0.1);
    border: 1px solid rgba(139, 147, 255, 0.14);
    border-radius: 6px;
    color: #c6c8ff;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .oss-card p {
    color: var(--text-secondary);
  }

  .final-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
    background:
      radial-gradient(circle at 20% 25%, rgba(54, 211, 153, 0.18), transparent 28%),
      linear-gradient(135deg, #191d35, #0b0d18);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
  }

  .final-cta h2 {
    max-width: 52rem;
    margin-top: 0.75rem;
    font-size: clamp(2rem, 4vw, 3.6rem);
  }

  @media (max-width: 1100px) {
    .loop-steps,
    .product-grid,
    .oss-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .loop-card {
      min-height: 18rem;
    }

    .evidence-section,
    .loop-head,
    .product-system-head,
    .final-cta {
      grid-template-columns: 1fr;
      display: grid;
    }
  }

  @media (max-width: 720px) {
    .home-hero-inner,
    .agent-loop,
    .product-system,
    .evidence-section,
    .oss-section,
    .final-cta {
      padding-left: 5%;
      padding-right: 5%;
    }

    .home-hero h1 {
      font-size: clamp(3rem, 15vw, 4.6rem);
    }

    .loop-steps,
    .product-grid,
    .oss-grid {
      grid-template-columns: 1fr;
    }

    .loop-rail {

---
import BaseLayout from '../layouts/BaseLayout.astro';

const canonicalUrl = 'https://tangle.tools/';
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${canonicalUrl}#organization`,
      name: 'Tangle',
      legalName: 'Tangle Technologies, Inc.',
      url: canonicalUrl,
      logo: 'https://tangle.tools/icons/tangle-icon-512.png',
      description: 'Infrastructure for self-improving AI agents: isolated runtime, model routing, trace intelligence, evaluation, and deployment.',
      sameAs: [
        'https://twitter.com/tangle_network',
        'https://github.com/tangle-network',
        'https://www.youtube.com/@TangleNetwork',
        'https://discord.com/invite/cv8EfJu3Tn',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${canonicalUrl}#website`,
      name: 'Tangle',
      url: canonicalUrl,
      publisher: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: 'Infrastructure for self-improving agents',
      description: 'Tangle gives AI agents the runtime, router, trace intelligence, and evaluation path they need to improve safely.',
      isPartOf: { '@id': `${canonicalUrl}#website` },
      about: { '@id': `${canonicalUrl}#organization` },
      inLanguage: 'en-US',
    },
  ],
};
---

<BaseLayout
  title="Infrastructure for self-improving agents"
  description="Tangle gives AI agents the runtime, router, trace intelligence, and evaluation path they need to improve safely."
  image="/images/og-self-improving-agents.png"
  imageAlt="Tangle infrastructure for self-improving AI agents"
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

  <section class="home-hero" aria-labelledby="hero-title">
    <video class="home-hero-media" autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg">
      <source src="/videos/glass-cylinders.webm" type="video/webm" />
      <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
    </video>
    <div class="home-hero-shade" aria-hidden="true"></div>
    <div class="home-hero-inner">
      <h1 id="hero-title">Make agents better, faster, and safer.</h1>
      <p class="home-hero-copy">
        Tangle gives agents somewhere to run, a smarter way to call models, and the evidence loop required to improve from real traces.
      </p>
      <div class="home-hero-actions">
        <a class="home-btn home-btn-primary" href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer">Open the workbench</a>
        <a class="home-btn home-btn-secondary" href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer">Read the docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .home-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #070713;
    border-bottom: 1px solid var(--border-subtle);
  }

  .home-hero-media,
  .home-hero-shade {
    position: absolute;
    inset: 0;
  }

  .home-hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.32;
  }

  .home-hero-shade {
    background:
      linear-gradient(90deg, rgba(7, 7, 19, 0.98) 0%, rgba(7, 7, 19, 0.82) 42%, rgba(7, 7, 19, 0.42) 100%),
      radial-gradient(circle at 72% 42%, rgba(139, 147, 255, 0.24), transparent 34%);
  }

  .home-hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    padding: 8rem 6% 5rem;
  }

  .home-hero h1 {
    max-width: 58rem;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 7vw, 6.6rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .home-hero-copy {
    max-width: 46rem;
    margin: 1.25rem 0 0;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .home-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 2rem;
  }

  .home-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.35rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
  }

  .home-btn:hover {
    transform: translateY(-1px);
  }

  .home-btn-primary {
    background: #5b5ff0;
    border: 1px solid #7377ff;
    color: #ffffff;
    box-shadow: 0 14px 38px rgba(91, 95, 240, 0.34);
  }

  .home-btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--text-primary);
  }

  @media (max-width: 720px) {
    .home-hero-inner {
      padding-left: 5%;
      padding-right: 5%;
    }

    .home-hero h1 {
      font-size: clamp(3rem, 16vw, 4.7rem);
    }

    .home-hero-copy {
      font-size: 1.05rem;
    }
  }
</style>

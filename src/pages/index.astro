      color: var(--text-secondary);
      max-width: 44rem;
      margin: 0 auto;
    }
    .t-life-stage {
      background: var(--depth-2);
      border: 1px solid var(--border-default);
      border-radius: 16px;
      padding: 2rem 2rem 1.5rem;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    }
    .t-life-svg {
      width: 100%;
      height: auto;
      display: block;
    }
    .t-life-legend {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 0.75rem;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-subtle);
    }
    .t-life-leg {
      display: flex;
      align-items: center;
      gap: 0.55rem;

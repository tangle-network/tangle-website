  <!-- FOUR SURFACES — sticky-scroll storytelling. Pin the visual,
       advance through 4 frames as the user scrolls. Stripe/Linear pattern. -->

  <style>

    /* Frameworks strip — quick visual proof Tangle isn't crypto-only */
    .wf-frameworks {
      background: var(--depth-2);
      border-bottom: 1px solid var(--border-subtle);
      padding: 1.5rem 6%;
    }
    .wf-frameworks-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      max-width: 84rem;
      margin: 0 auto;
      flex-wrap: wrap;
    }
    .wf-frameworks-label {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    .wf-frameworks-list {
      display: flex;
      gap: 1.75rem;
      align-items: center;
      flex-wrap: wrap;
      flex: 1;
    }
    .wf-framework {
      font-family: var(--font-display);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--text-secondary);
      letter-spacing: -0.01em;
      transition: color 0.16s ease;
      cursor: default;
    }
    .wf-framework:hover { color: var(--brand-cool); }
    @media (max-width: 768px) {
      .wf-frameworks-list { gap: 1rem; }
      .wf-framework { font-size: 0.875rem; }
    }

    /* hl-build — '60 seconds, 5 lines, real agent' section. Replaces the
       generic ExamplePanel widget. Two-col split: meta + lede on left,
       code + cascading stream output on right. */
    .hl-build-section {
      background: var(--depth-1);
      border-bottom: 1px solid var(--border-subtle);
    }
    .hl-build {
      width: 100%;
      max-width: 84rem;
      margin: 0 auto;
      padding: 6rem 8%;
    }
    .hl-build-inner {
      display: grid;
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.3fr);
      gap: 5rem;
      align-items: center;
    }
    .hl-build-meta { max-width: 32rem; }
    .hl-build-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      color: #34D399;
      margin-bottom: 0.875rem;
    }
    .hl-build-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #34D399;
      box-shadow: 0 0 12px rgba(52, 211, 153, 0.65);
      animation: hl-build-dot-pulse 1.6s ease-in-out infinite;
    }
    @keyframes hl-build-dot-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.45; }
    }
    .hl-build-title {
      font-family: var(--font-display);
      font-size: var(--type-h2);
      font-weight: var(--type-h2-weight);
      line-height: var(--type-h2-line);
      letter-spacing: var(--type-h2-track);
      color: var(--text-primary);
      margin: 0 0 1.25rem;
      text-wrap: balance;
    }
    .hl-build-lede {
      font-family: var(--font-sans);
      font-size: var(--type-body-l);
      line-height: 1.6;
      color: var(--text-secondary);
      margin: 0 0 1.75rem;
    }
    .hl-build-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
      margin-bottom: 1.75rem;
    }
    .hl-build-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.55rem 0.9rem;
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--text-secondary);
    }
    .hl-build-pill strong { color: var(--brand-cool); font-weight: 700; }
    .hl-build-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.625rem 1rem;
      background: transparent;
      border: 1px solid var(--border-default);
      border-radius: 8px;
      color: var(--text-primary);
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 600;
      text-decoration: none;
      transition: border-color 0.18s ease, background-color 0.18s ease;
    }
    .hl-build-cta:hover {
      border-color: var(--border-accent);
      background: var(--depth-3);
    }
    .hl-build-frame {
      background: var(--depth-2);
      border: 1px solid var(--border-default);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    }
    .hl-build-tabs {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.625rem 0.875rem;
      background: var(--depth-3);
      border-bottom: 1px solid var(--border-default);
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .hl-build-tab--filename { color: var(--brand-cool); font-weight: 700; }
    .hl-build-tab-spacer { flex: 1; }
    .hl-build-tab-status {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.6rem;
      background: rgba(52, 211, 153, 0.12);
      border: 1px solid rgba(52, 211, 153, 0.32);
      border-radius: 999px;
      color: #34D399;
      font-weight: 700;
      font-size: 0.6875rem;
    }
    .hl-build-status-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #34D399;
      box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
      animation: hl-build-dot-pulse 1.6s ease-in-out infinite;
    }
    .hl-build-split {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 0;
      min-height: 22rem;
    }
    .hl-build-code {
      margin: 0;
      padding: 1.5rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      line-height: 1.75;
      color: var(--text-primary);
      overflow-x: auto;
      border-right: 1px solid var(--border-subtle);
      background: linear-gradient(180deg, var(--depth-2) 0%, rgba(20,19,40,0.7) 100%);
      white-space: pre-wrap;
    }
    .hl-build-stream {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      background: linear-gradient(180deg, rgba(20,19,40,0.7) 0%, var(--depth-3) 100%);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-secondary);
    }
    .hl-build-stream-line {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      opacity: 0;
      animation: hl-build-line-in 0.55s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
      transform: translateY(6px);
    }
    .hl-build-stream-line:nth-child(1) { animation-delay: 0.4s; }
    .hl-build-stream-line:nth-child(2) { animation-delay: 0.9s; }
    .hl-build-stream-line:nth-child(3) { animation-delay: 1.4s; }
    .hl-build-stream-line:nth-child(4) { animation-delay: 1.9s; }
    .hl-build-stream-line:nth-child(5) { animation-delay: 2.4s; }
    .hl-build-stream-line:nth-child(6) { animation-delay: 2.9s; }
    .hl-build-stream-line:nth-child(7) { animation-delay: 3.4s; }
    @keyframes hl-build-line-in {
      0%   { opacity: 0; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .hl-build-stream-line--done {
      margin-top: 0.5rem;
      padding-top: 0.625rem;
      border-top: 1px dashed rgba(52, 211, 153, 0.28);
    }
    .hl-build-stream-line code {
      background: rgba(165, 170, 252, 0.12);
      color: var(--text-primary);
      padding: 0.05rem 0.35rem;
      border-radius: 3px;
      font-size: 0.75rem;
    }
    .hl-build-tag {
      flex-shrink: 0;
      padding: 0.18rem 0.5rem;
      border-radius: 4px;
      font-weight: 700;
      letter-spacing: 0.04em;
      font-size: 0.6875rem;
      text-transform: uppercase;
    }
    .hl-build-tag--sandbox { background: rgba(52, 211, 153, 0.14); color: #34D399; }
    .hl-build-tag--router  { background: rgba(99, 102, 241, 0.16); color: #818CF8; }
    .hl-build-tag--agent   { background: rgba(165, 170, 252, 0.14); color: #A5AAFC; }
    .hl-build-tag--evals   { background: rgba(255, 184, 0, 0.14); color: #FFB800; }
    .hl-build-tag--ok      { background: rgba(52, 211, 153, 0.18); color: #34D399; border: 1px solid rgba(52, 211, 153, 0.42); }
    @media (max-width: 1100px) {
      .hl-build { padding: 4rem 6%; }
      .hl-build-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .hl-build-meta { max-width: none; }
      .hl-build-split { grid-template-columns: 1fr; min-height: 0; }
      .hl-build-code { border-right: 0; border-bottom: 1px solid var(--border-subtle); }
    }
    @media (prefers-reduced-motion: reduce) {
      .hl-build-stream-line, .hl-build-dot, .hl-build-status-dot { animation: none; opacity: 1; transform: none; }
    }

    /* Loop section — 2-col on desktop, generous gap. Was minmax(0, 1.05fr)
       minmax(0, 0.95fr) gap 4rem which crammed the orbit against the right
       edge per Drew (R17): 'too small / improperly done / squished.' */
    .hl-loop-wrap {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
      gap: 6rem;
      align-items: center;
    }
    .hl-loop-meta { max-width: 36rem; }
    @media (max-width: 1100px) {
      .hl-loop-wrap { grid-template-columns: 1fr; gap: 3rem; }
      .hl-loop-meta { max-width: none; }
    }

    /* Orbital loop diagram — circular SVG with 4 nodes (Profile / Sandbox
       / Data / Evals), particle riding the closed path, center pulse
       implying convergence. */
    .hl-orbit {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1 / 1;
      max-width: 32rem;
      margin: 0 auto;
      padding: 1.5rem;
    }
    .hl-orbit svg { width: 100%; height: 100%; overflow: visible; }
    .hl-orbit-pulse {
      transform-origin: center;
      transform-box: fill-box;
      animation: hl-orbit-pulse 6s linear infinite;
      opacity: 0;
    }
    .hl-orbit-node--profile .hl-orbit-pulse { animation-delay: 0s; }
    .hl-orbit-node--sandbox .hl-orbit-pulse { animation-delay: -4.5s; }
    .hl-orbit-node--data    .hl-orbit-pulse { animation-delay: -3s; }
    .hl-orbit-node--evals   .hl-orbit-pulse { animation-delay: -1.5s; }
    @keyframes hl-orbit-pulse {
      0%   { transform: scale(1);   opacity: 0; }
      8%   { transform: scale(1);   opacity: 0.95; }
      28%  { transform: scale(1.7); opacity: 0; }
      100% { transform: scale(1.7); opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hl-orbit-pulse { animation: none; opacity: 0.55; }
    }



---
// Internal art-review gallery. Unlinked, noindex. Every candidate from the
// v2/v3 generation rounds, numbered for ranking, with its full brief.
import candidates from '../data/art-review.json';
import { BRAND_CORE, HERO_FIELD_V2, CARD_SANDBOX, CARD_INTELLIGENCE, CARD_INFERENCE } from '../data/briefs-v2.mjs';
import { OPTIMIZE_FLOW, MODEL_FIELD, RESEARCH_DESK, HERO_V3, FOOTER_STRIP } from '../data/briefs-v3.mjs';

const briefs: Record<string, string> = {
  HERO_FIELD_V2,
  CARD_SANDBOX,
  CARD_INTELLIGENCE,
  CARD_INFERENCE,
  OPTIMIZE_FLOW,
  MODEL_FIELD,
  RESEARCH_DESK,
  HERO_V3,
  FOOTER_STRIP,
};
const briefLines = (k: string) => (briefs[k] || '').trim().split('\n').length;
const groups = [...new Set(candidates.map((c) => c.brief))];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Tangle art review — v2/v3 rounds</title>
  </head>
  <body>
    <main>
      <h1>Art review: {candidates.length} candidates</h1>
      <p class="hint">
        Rank by number. Each group shows its full generation brief (the prompt, verbatim).
        BRAND_CORE ({BRAND_CORE.trim().split('\n').length} lines) is prepended to every v2 brief;
        v3 briefs embed their own identity block.
      </p>

      {groups.map((g) => (
        <section>
          <h2>{g} <span class="meta">· {briefLines(g)}-line brief</span></h2>
          <details>
            <summary>Show the full prompt</summary>
            <pre>{briefs[g]}</pre>
          </details>
          <div class="grid">
            {candidates.filter((c) => c.brief === g).map((c) => (
              <figure>
                <img src={`/images/art-review/${c.file}`} alt={`${g} candidate ${c.n}`} loading="lazy" />
                <figcaption>
                  <strong>#{String(c.n).padStart(2, '0')}</strong>
                  <span>{c.engine}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      ))}
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #0c0b1d;
    color: #ededf4;
    font-family: 'Inter', system-ui, sans-serif;
  }

  main {
    max-width: 90rem;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .hint {
    max-width: 60rem;
    color: #9b9bbf;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  section { margin-top: 3.5rem; }

  h2 {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .meta { color: #9b9bbf; font-weight: 400; font-size: 1rem; }

  details {
    margin: 0.6rem 0 1rem;
    border: 1px solid rgba(199, 201, 238, 0.18);
    border-radius: 10px;
    background: #12112a;
  }

  summary {
    padding: 0.7rem 1rem;
    color: #a5aafc;
    font-size: 0.95rem;
    cursor: pointer;
  }

  pre {
    margin: 0;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    border-top: 1px solid rgba(199, 201, 238, 0.14);
    color: #c5c5dc;
    font-size: 0.82rem;
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(24rem, 1fr));
    gap: 1.25rem;
  }

  figure { margin: 0; }

  img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid rgba(199, 201, 238, 0.16);
    border-radius: 10px;
  }

  figcaption {
    display: flex;
    gap: 0.8rem;
    padding: 0.5rem 0.2rem;
    color: #9b9bbf;
    font-size: 0.9rem;
  }

  figcaption strong { color: #ededf4; font-size: 1.05rem; }
</style>

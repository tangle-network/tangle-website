---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import BlogCover from '../../../components/BlogCover.astro'
import { getCollection } from 'astro:content'

function normalizeSeries(series?: string) {
  return series?.replace(/^['"]|['"]$/g, '') || 'Standalone'
}

function seriesSlug(series: string) {
  return series
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
}
const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  const seriesMap = new Map<string, typeof posts>()

  for (const post of posts) {
    const series = post.data.series?.replace(/^['"]|['"]$/g, '') || 'Standalone'
    if (series === 'Standalone') continue
    if (!seriesMap.has(series)) seriesMap.set(series, [])
    seriesMap.get(series)?.push(post)
  }

  return [...seriesMap.entries()].map(([series, entries]) => {
    const ordered = [...entries].sort((a, b) => {
      const orderA = a.data.seriesOrder ?? 999
      const orderB = b.data.seriesOrder ?? 999
      if (orderA !== orderB) return orderA - orderB
      return new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
    })

    return {
      params: {
        slug: series
          .toLowerCase()
          .replace(/&/g, 'and')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-|-$/g, ''),
      },
      props: {
        series,
        posts: ordered,
      },
    }
  })
}

const { series, posts } = Astro.props
const representative = posts.find((post) => post.data.coverImage || post.data.heroImage) ?? posts[0]
const topics = [...new Set(posts.flatMap((post) => post.data.tags))]
---

<BaseLayout title={`${series} | Blog`} description={`${series} articles from Tangle.`}>
  <script is:inline>
    document.body.classList.add('page-editorial')
  </script>

  <section class="series-page" aria-labelledby="series-title">
    <div class="series-shell">
      <a href="/blog/" class="back-link">Blog</a>

      <header class="series-hero">
        <h1 id="series-title">{series}</h1>
      </header>

      <div class="series-layout">
        <BlogCover
          title={series}
          summary={posts[0]?.data.summary}
          series={series}
          tags={topics}
          coverImage={representative?.data.coverImage}
          imageAlt={representative?.data.imageAlt || series}
        />

        <div class="series-rows">
          {posts.map((post) => (
            <a href={`/blog/${post.data.slug}`} class="series-row">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              <div>
                <h2>{post.data.title}</h2>
                <p>{post.data.summary}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .series-page {
    min-height: 100vh;
    padding: 8rem 6% 6rem;
    background: #f7f7fb;
    color: #191c24;
  }

  .series-shell {
    width: min(78rem, 100%);
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 2rem;
    color: #4f46e5;
    font: 800 0.86rem/1 var(--font-sans);
    text-decoration: none;
  }

  .series-hero {
    max-width: 58rem;
    margin-bottom: 2.5rem;
  }

  .series-hero h1,
  .series-row h2 {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0;
    color: #191c24;
    text-wrap: balance;
  }

  .series-hero h1 {
    font-size: clamp(3.1rem, 6vw, 5.6rem);
    font-weight: 800;
    line-height: 1;
  }

  .series-layout {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .series-rows {
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
  }

  .series-row {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    gap: 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(25, 28, 36, 0.12);
    color: inherit;
    text-decoration: none;
  }

  .series-row time {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #64677a;
  }

  .series-row h2 {
    font-size: clamp(1.12rem, 2vw, 1.5rem);
    font-weight: 760;
    line-height: 1.18;
  }

  .series-row p {
    max-width: 52rem;
    margin: 0.55rem 0 0;
    color: #4a4c5f;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .series-row:hover h2 {
    color: #4f46e5;
  }

  :global(.page-editorial .wf-nav) {
    background: rgba(247, 247, 251, 0.86);
    border-bottom: 1px solid rgba(25, 28, 36, 0.1);
    backdrop-filter: blur(18px);
  }

  :global(.page-editorial .wf-nav-brand-type),
  :global(.page-editorial .wf-nav-menu-link) {
    color: #191c24 !important;
  }

  :global(.page-editorial .wf-mobile-icon) {
    filter: invert(1);
  }

  @media (max-width: 840px) {
    .series-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .series-page {
      padding: 6.25rem 1rem 4rem;
    }

    .series-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
  }
</style>

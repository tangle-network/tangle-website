---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Group by series
const seriesMap = new Map();
const standalone = [];

for (const post of posts) {
  const series = post.data.series;
  if (series) {
    if (!seriesMap.has(series)) {
      seriesMap.set(series, []);
    }
    seriesMap.get(series).push(post);
  } else {
    standalone.push(post);
  }
}

// Sort articles within each series by order
for (const [_, articles] of seriesMap) {
  articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
}

// Define series metadata
const seriesMeta = {
  'Tangle Re-Introduction': {
    description: 'A ground-up walkthrough of Tangle\'s architecture: from why decentralization matters to how Blueprints, verification, and trusted execution work together.',
    color: '#6366F1',
  },
  'x402 Production Runway': {
    description: 'From TOML config to paid job execution. How Blueprint SDK integrates x402 payments, restricted invocation, pricing engines, and on-chain settlement.',
    color: '#818CF8',
  },
  'Building an AI Tax Agent': {
    description: 'Building an AI agent that actually files your taxes. Sandboxed code execution, IRS e-filing, crypto tax handling, and the architecture behind it.',
    color: '#f59e0b',
  },
};

// Sort series: most recent article first
const sortedSeries = [...seriesMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map(p => new Date(p.data.date).getTime()));
  const latestB = Math.max(...b[1].map(p => new Date(p.data.date).getTime()));
  return latestB - latestA;
});
---

<BaseLayout title="Blog" description="Technical articles on Tangle's infrastructure, Blueprint SDK, AI services, and decentralized cloud.">
  <div style="position: fixed; inset: 0; z-index: -1; pointer-events: none; background: radial-gradient(ellipse at 15% 0%, rgba(130, 99, 255, 0.1) 0%, transparent 50%), radial-gradient(ellipse at 85% 100%, rgba(104, 136, 249, 0.06) 0%, transparent 50%);" aria-hidden="true"></div>

  <!-- Dark hero strip -->
  <section style="padding: 7rem 6% 3rem; background-color: var(--depth-1); border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 72rem; margin: 0 auto;">
      <span style="display: inline-block; font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #10B981; margin-bottom: 1rem;">Writing</span>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; line-height: 1; letter-spacing: -0.03em; color: var(--text-primary); margin: 0 0 1rem;">Technical deep dives.</h1>
      <p style="font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.6; color: var(--text-secondary); max-width: 42rem; margin: 0;">Real architecture, real code, real problems solved. Organized by series so you can read front-to-back or jump to the one that fixes your current bug.</p>
    </div>
  </section>

  <!-- Table listing — VAULT (light) surface -->
  <section style="background-color: #f4f4f9; color: #191c24; padding: 4rem 6% 6rem;">
    <div style="max-width: 72rem; margin: 0 auto;">
      {sortedSeries.map(([seriesName, articles]) => {
        const meta = seriesMeta[seriesName] || { description: '', color: '#6366F1' };
        return (
          <div style="margin-bottom: 4rem;">
            <div style="display: flex; align-items: baseline; gap: 1rem; border-bottom: 1px solid rgba(25, 28, 36, 0.1); padding-bottom: 1rem; margin-bottom: 0.5rem;">
              <h2 style={`font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; letter-spacing: -0.015em; color: #191c24; margin: 0;`}>
                {seriesName}
              </h2>
              <span style="font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.12em; color: #5E5E7A;">{articles.length} articles</span>
            </div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.55; color: #3a3a50; max-width: 44rem; margin: 0 0 1.5rem;">{meta.description}</p>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {articles.map((post) => (
                <li>
                  <a
                    href={`/blog/${post.data.slug}`}
                    style="display: grid; grid-template-columns: 3rem minmax(0, 1fr) auto; gap: 1.25rem; align-items: center; padding: 1rem 0.75rem; border-top: 1px solid rgba(25, 28, 36, 0.08); text-decoration: none; transition: background-color 0.16s ease;"
                    onmouseover="this.style.backgroundColor='rgba(99,102,241,0.05)'"
                    onmouseout="this.style.backgroundColor='transparent'"
                  >
                    <span style={`font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: ${meta.color}; letter-spacing: 0.04em;`}>
                      {post.data.seriesOrder !== undefined ? String(post.data.seriesOrder).padStart(2, '0') : '--'}
                    </span>
                    <div style="min-width: 0;">
                      <div style="font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: #191c24; letter-spacing: -0.005em; margin-bottom: 0.125rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        {post.data.title}
                      </div>
                      <div style="font-family: var(--font-sans); font-size: 0.875rem; color: #3a3a50; line-height: 1.45; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{post.data.summary}</div>
                    </div>
                    <time datetime={post.data.date} style="font-family: var(--font-mono); font-size: 0.75rem; color: #5E5E7A; white-space: nowrap;">
                      {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}

      {standalone.length > 0 && (
        <div style="margin-bottom: 2rem;">
          <div style="display: flex; align-items: baseline; gap: 1rem; border-bottom: 1px solid rgba(25, 28, 36, 0.1); padding-bottom: 1rem; margin-bottom: 0.5rem;">
            <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; letter-spacing: -0.015em; color: #191c24; margin: 0;">
              One-offs
            </h2>
            <span style="font-family: var(--font-mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.12em; color: #5E5E7A;">{standalone.length} articles</span>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0;">
            {standalone.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).map((post) => (
              <li>
                <a
                  href={`/blog/${post.data.slug}`}
                  style="display: grid; grid-template-columns: 3rem minmax(0, 1fr) auto; gap: 1.25rem; align-items: center; padding: 1rem 0.75rem; border-top: 1px solid rgba(25, 28, 36, 0.08); text-decoration: none; transition: background-color 0.16s ease;"
                  onmouseover="this.style.backgroundColor='rgba(99,102,241,0.05)'"
                  onmouseout="this.style.backgroundColor='transparent'"
                >
                  <span style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: #6366F1; letter-spacing: 0.04em;">—</span>
                  <div style="min-width: 0;">
                    <div style="font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: #191c24; letter-spacing: -0.005em; margin-bottom: 0.125rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      {post.data.title}
                    </div>
                    <div style="font-family: var(--font-sans); font-size: 0.875rem; color: #3a3a50; line-height: 1.45; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{post.data.summary}</div>
                  </div>
                  <time datetime={post.data.date} style="font-family: var(--font-mono); font-size: 0.75rem; color: #5E5E7A; white-space: nowrap;">
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

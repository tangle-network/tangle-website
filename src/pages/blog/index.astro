---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog" description="All Tangle blog posts">
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="mb-12">
      <p class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-2">Archive</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">All Tangle blog posts</h1>
      <p class="text-text-secondary">Full post archive, sorted by most recent publication.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sortedPosts.map((post, i) => {
        const seriesOrder = post.data.seriesOrder;
        return (
          <a href={`/blog/${post.data.slug}`} class="group block">
            <article class="rounded-xl border border-white/5 bg-[#141430] overflow-hidden transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5">
              {post.data.coverImage && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.data.coverImage}
                    alt={post.data.imageAlt || post.data.title}
                    class="w-full h-full object-cover transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                {post.data.series && (
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-brand-primary/15 text-brand-cool">
                      {post.data.series}
                    </span>
                  </div>
                )}
                {seriesOrder !== undefined && (
                  <p class="text-xs font-mono text-text-muted mb-1">DAY {seriesOrder}</p>
                )}
                <h2 class="text-lg font-semibold mb-2 group-hover:text-brand-cool transition-colors leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-sm text-text-secondary mb-4 line-clamp-3">{post.data.summary}</p>
                <div class="flex items-center justify-between">
                  <time datetime={post.data.date} class="text-xs text-text-muted">
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <div class="flex gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-xs px-1.5 py-0.5 rounded bg-white/5 text-text-muted">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCover from '../../components/BlogCover.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const seriesMap = new Map();
const standalone = [];

for (const post of posts) {
  const series = post.data.series;
  if (series) {
    if (!seriesMap.has(series)) {
      seriesMap.set(series, []);
    }
    seriesMap.get(series).push(post);
  } else {
    standalone.push(post);
  }
}

for (const [, articles] of seriesMap) {
  articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
}

const seriesMeta = {
  'Tangle Re-Introduction': {
    name: 'Tangle Re-Introduction',
    description: 'A ground-up walkthrough of Tangle architecture: why decentralization matters, how Blueprints work, and where trusted execution fits.',
    color: '#4F46E5',
  },
  'x402 Production Runway': {
    name: 'x402 Production Runway',
    description: 'From TOML config to paid job execution: payment-gated ingress, operator economics, pricing engines, and mainnet rollout checks.',
    color: '#7C3AED',
  },
  'Building an AI Tax Agent': {
    name: 'Building an AI Tax Agent',
    description: 'Sandboxed code execution, filing workflows, crypto tax handling, and the architecture behind an agent that can do real work.',
    color: '#0F766E',
  },
  'the-self-improving-stack': {
    name: 'The Self-Improving Stack',
    description: 'The operating system around self-improving agents: traces, evaluation gates, skills, memory, runtime topology, and release governance.',
    color: '#047857',
  },
};

const sortedSeries = [...seriesMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map((p) => new Date(p.data.date).getTime()));
  const latestB = Math.max(...b[1].map((p) => new Date(p.data.date).getTime()));
  return latestB - latestA;
});

const sortedStandalone = standalone.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const totalPublished = posts.length;

const formatDate = (date: string) => new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title="Blog" description="Technical articles on Tangle's infrastructure, Blueprint SDK, AI services, and decentralized cloud.">
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <span>Writing</span>
      <h1>Technical deep dives.</h1>
      <p>Architecture notes, implementation guides, and production lessons from the Tangle stack.</p>
      <div class="blog-hero-meta">{totalPublished} published posts</div>
    </div>
  </section>

  <section class="blog-index">
    <div class="blog-index-inner">
      {sortedSeries.map(([seriesName, articles]) => {
        const meta = seriesMeta[seriesName] || { name: seriesName, description: '', color: '#4F46E5' };
        return (
          <section class="series-block" style={`--series-color: ${meta.color};`}>
            <header class="series-header">
              <div>
                <h2>{meta.name}</h2>
                {meta.description && <p>{meta.description}</p>}
              </div>
              <span>{articles.length} posts</span>
            </header>
            <div class="post-grid">
              {articles.map((post) => (
                <a href={`/blog/${post.data.slug}`} class="post-card">
                  <BlogCover
                    title={post.data.title}
                    summary={post.data.summary}
                    series={post.data.series}
                    seriesOrder={post.data.seriesOrder}
                    tags={post.data.tags}
                    coverImage={post.data.coverImage}
                    imageAlt={post.data.imageAlt || post.data.title}
                    variant="card"
                  />
                  <div class="post-card-body">
                    <div class="post-card-meta">
                      {post.data.seriesOrder !== undefined && <span>Part {post.data.seriesOrder}</span>}
                      <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.summary}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}

      {sortedStandalone.length > 0 && (
        <section class="series-block" style="--series-color: #4338CA;">
          <header class="series-header">
            <div>
              <h2>Standalone Research</h2>
              <p>Single-topic writeups that sit outside the running series.</p>
            </div>
            <span>{sortedStandalone.length} posts</span>
          </header>
          <div class="post-grid">
            {sortedStandalone.map((post) => (
              <a href={`/blog/${post.data.slug}`} class="post-card">
                <BlogCover
                  title={post.data.title}
                  summary={post.data.summary}
                  tags={post.data.tags}
                  coverImage={post.data.coverImage}
                  imageAlt={post.data.imageAlt || post.data.title}
                  variant="card"
                />
                <div class="post-card-body">
                  <div class="post-card-meta">
                    <span>{post.data.tags[0] || 'Research'}</span>
                    <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.summary}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: 7rem 6% 3rem;
    background: #0c0b1d;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .blog-hero-inner,
  .blog-index-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .blog-hero span {
    display: inline-block;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #10B981;
  }

  .blog-hero h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
    color: #ffffff;
  }

  .blog-hero p {
    max-width: 42rem;
    margin: 1rem 0 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.68);
  }

  .blog-hero-meta {
    margin-top: 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
  }

  .blog-index {
    padding: 4rem 6% 6rem;
    background: #f4f4f9;
    color: #191c24;
  }

  .series-block {
    margin-bottom: 4rem;
  }

  .series-block:last-child {
    margin-bottom: 0;
  }

  .series-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.35rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(25, 28, 36, 0.1);
  }

  .series-header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    color: #191c24;
  }

  .series-header p {
    max-width: 44rem;
    margin: 0.55rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.96rem;
    line-height: 1.55;
    color: #3a3a50;
  }

  .series-header > span {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--series-color);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .post-card {
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(25, 28, 36, 0.09);
    border-radius: 8px;
    background: #ffffff;
    text-decoration: none;
    box-shadow: 0 16px 50px rgba(15, 23, 42, 0.06);
    transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--series-color) 38%, rgba(25, 28, 36, 0.09));
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.1);
  }

  .post-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.05rem;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: #5E5E7A;
  }

  .post-card-meta span {
    color: var(--series-color);
  }

  .post-card h3 {
    display: -webkit-box;
    min-height: 3.3em;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    color: #191c24;
  }

  .post-card p {
    display: -webkit-box;
    margin: 0.75rem 0 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.5;
    color: #3a3a50;
  }

  @media (max-width: 980px) {
    .post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding: 5.5rem 1rem 2.25rem;
    }

    .blog-index {
      padding: 2.5rem 1rem 4rem;
    }

    .series-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.75rem;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

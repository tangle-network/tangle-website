---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Group by series
const seriesMap = new Map();
const standalone = [];

for (const post of posts) {
  const series = post.data.series;
  if (series) {
    if (!seriesMap.has(series)) {
      seriesMap.set(series, []);
    }
    seriesMap.get(series).push(post);
  } else {
    standalone.push(post);
  }
}

// Sort articles within each series by order
for (const [_, articles] of seriesMap) {
  articles.sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0));
}

// Define series metadata
const seriesMeta = {
  'Tangle Re-Introduction': {
    description: 'A ground-up walkthrough of Tangle\'s architecture: from why decentralization matters to how Blueprints, verification, and trusted execution work together.',
    color: '#6366F1',
  },
  'x402 Production Runway': {
    description: 'From TOML config to paid job execution. How Blueprint SDK integrates x402 payments, restricted invocation, pricing engines, and on-chain settlement.',
    color: '#818CF8',
  },
  'Building an AI Tax Agent': {
    description: 'Building an AI agent that actually files your taxes. Sandboxed code execution, IRS e-filing, crypto tax handling, and the architecture behind it.',
    color: '#f59e0b',
  },
};

// Sort series: most recent article first
const sortedSeries = [...seriesMap.entries()].sort((a, b) => {
  const latestA = Math.max(...a[1].map(p => new Date(p.data.date).getTime()));
  const latestB = Math.max(...b[1].map(p => new Date(p.data.date).getTime()));
  return latestB - latestA;
});
---

<BaseLayout title="Blog" description="Technical articles on Tangle's infrastructure, Blueprint SDK, AI services, and decentralized cloud.">
  <div style="position: fixed; inset: 0; z-index: -1; pointer-events: none; background: radial-gradient(ellipse at 15% 0%, rgba(130, 99, 255, 0.1) 0%, transparent 50%), radial-gradient(ellipse at 85% 100%, rgba(104, 136, 249, 0.06) 0%, transparent 50%);" aria-hidden="true"></div>

  <section class="max-w-6xl mx-auto px-4" style="padding-top: 10rem; padding-bottom: 4rem; position: relative;">
    <div class="mb-16">
      <p class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-2">Blog</p>
      <h1 style="font-family: var(--font-display); font-size: 48px; font-weight: 600; line-height: 1.1;" class="mb-3">Technical deep dives</h1>
      <p class="text-text-secondary text-lg">Real architecture, real code, real problems solved. Organized by series.</p>
    </div>

    {sortedSeries.map(([seriesName, articles]) => {
      const meta = seriesMeta[seriesName] || { description: '', color: '#6366F1' };
      return (
        <div class="mb-16">
          <div class="mb-6" style={`border-left: 3px solid ${meta.color}; padding-left: 1.25rem;`}>
            <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">
              {seriesName}
            </h2>
            <p class="text-text-secondary text-sm" style="max-width: 40rem;">{meta.description}</p>
            <p class="text-text-muted text-xs mt-1 font-mono">{articles.length} articles</p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {articles.map((post) => (
              <a href={`/blog/${post.data.slug}`} class="group block">
                <article style="border: 2px solid rgba(100,100,148,0.18); border-radius: 24px;" class="bg-[#141430] overflow-hidden transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5 h-full">
                  {post.data.coverImage && (
                    <div class="aspect-video overflow-hidden" style="border-radius: 22px 22px 0 0;">
                      <img
                        src={post.data.coverImage}
                        alt={post.data.imageAlt || post.data.title}
                        class="w-full h-full object-cover transition-transform group-hover:scale-105"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-5">
                    <div class="flex items-center gap-2 mb-2">
                      {post.data.seriesOrder !== undefined && (
                        <span class="text-xs font-mono px-2 py-0.5 rounded-full" style={`background: ${meta.color}20; color: ${meta.color}; border: 1px solid ${meta.color}30;`}>
                          Part {post.data.seriesOrder}
                        </span>
                      )}
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-white/5 text-text-muted">{tag}</span>
                      ))}
                    </div>
                    <h3 style="font-family: var(--font-display); font-weight: 600;" class="text-base mb-2 group-hover:text-brand-cool transition-colors leading-snug">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-text-secondary line-clamp-2">{post.data.summary}</p>
                    <time datetime={post.data.date} class="text-xs text-text-muted mt-3 block">
                      {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      );
    })}

    {standalone.length > 0 && (
      <div class="mb-16">
        <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: white; margin-bottom: 1rem;">
          More articles
        </h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {standalone.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).map((post) => (
            <a href={`/blog/${post.data.slug}`} class="group block">
              <article style="border: 2px solid rgba(100,100,148,0.18); border-radius: 24px;" class="bg-[#141430] overflow-hidden transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5 h-full">
                <div class="p-5">
                  <h3 style="font-family: var(--font-display); font-weight: 600;" class="text-base mb-2 group-hover:text-brand-cool transition-colors leading-snug">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-text-secondary line-clamp-2">{post.data.summary}</p>
                  <time datetime={post.data.date} class="text-xs text-text-muted mt-3 block">
                    {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

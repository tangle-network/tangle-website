---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Filter out drafts from public listing
const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog" description="Technical articles on Tangle's infrastructure, Blueprint SDK, AI services, and decentralized cloud.">
  <section class="max-w-6xl mx-auto px-4" style="padding-top: 10rem; padding-bottom: 4rem;">
    <div class="mb-12">
      <p class="text-sm font-mono text-brand-primary uppercase tracking-wider mb-2">Archive</p>
      <h1 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-size: 48px; font-weight: 600; line-height: 1.1;" class="mb-3">All Tangle blog posts</h1>
      <p class="text-text-secondary">Full post archive, sorted by most recent publication.</p>
    </div>

    <div class="wf-section-wrapper" style="padding: 2rem;">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.map((post, i) => {
          const seriesOrder = post.data.seriesOrder;
          return (
            <a href={`/blog/${post.data.slug}`} class="group block">
              <article style="border: 2px solid rgb(42, 43, 57); border-radius: 32px;" class="bg-[#141430] overflow-hidden transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5">
                {post.data.coverImage && (
                  <div class="aspect-video overflow-hidden" style="border-radius: 30px 30px 0 0;">
                    <img
                      src={post.data.coverImage}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover transition-transform group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-2 flex-wrap">
                    {post.data.series && (
                      <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-brand-primary/15 text-brand-cool">
                        {post.data.series}
                      </span>
                    )}
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-white/5 text-text-muted">{tag}</span>
                    ))}
                  </div>
                  {seriesOrder !== undefined && (
                    <p class="text-xs font-mono text-text-muted mb-1">DAY {seriesOrder}</p>
                  )}
                  <h2 style="font-family: 'Satoshi Variable', 'Satoshi', sans-serif; font-weight: 600;" class="text-lg mb-2 group-hover:text-brand-cool transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-text-secondary mb-4 line-clamp-3">{post.data.summary}</p>
                  <div class="flex items-center justify-between">
                    <time datetime={post.data.date} class="text-xs text-text-muted">
                      {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

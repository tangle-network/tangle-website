---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCover from '../../components/BlogCover.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const normalizeSeries = (series?: string) => series?.replace(/^['"]|['"]$/g, '') || 'Standalone'
const slugifySeries = (series: string) =>
  series
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })

const topicLabels: Record<string, string> = {
  agents: 'Agents',
  'browser-agent': 'Browser',
  x402: 'x402',
  'tax-agent': 'Tax agent',
  'blueprint-agent': 'Blueprint agent',
  'tangle-protocol': 'Protocol',
  'code-auditor': 'Code audit',
}

const topicOptions = Object.keys(topicLabels).filter((topic) =>
  sortedPosts.some((post) => post.data.tags.includes(topic)),
)

const seriesMap = new Map<string, typeof sortedPosts>()
for (const post of sortedPosts) {
  const series = normalizeSeries(post.data.series)
  if (!seriesMap.has(series)) seriesMap.set(series, [])
  seriesMap.get(series)?.push(post)
}

const seriesGroups = [...seriesMap.entries()]
  .filter(([name]) => name !== 'Standalone')
  .map(([name, entries]) => {
    const ordered = [...entries].sort((a, b) => {
      const orderA = a.data.seriesOrder ?? 999
      const orderB = b.data.seriesOrder ?? 999
      if (orderA !== orderB) return orderA - orderB
      return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
    })

    const representative = ordered.find((post) => post.data.coverImage || post.data.heroImage) ?? ordered[0]
    const latest = [...entries].sort(
      (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    )[0]

    return {
      name,
      slug: slugifySeries(name),
      representative,
      latest,
      topics: [...new Set(entries.flatMap((post) => post.data.tags))],
    }
  })
  .sort((a, b) => {
    if (a.name === 'Standalone') return 1
    if (b.name === 'Standalone') return -1
    return a.name.localeCompare(b.name)
  })
---

<BaseLayout
  title="Blog"
  description="Implementation notes, product essays, research threads, and field reports from the Tangle stack."
  bodyClass="page-editorial"
>
  <section class="blog-page" aria-labelledby="blog-title">
    <div class="blog-shell">
      <header class="blog-hero">
        <h1 id="blog-title">Writing from Tangle.</h1>
      </header>

      <div class="topic-filter" aria-label="Filter posts by topic">
        <button type="button" class="topic-filter-button is-active" data-topic-filter="all">All</button>
        {topicOptions.map((topic) => (
          <button type="button" class="topic-filter-button" data-topic-filter={topic}>
            {topicLabels[topic]}
          </button>
        ))}
      </div>

      <section class="series-index" aria-labelledby="series-title">
        <div class="section-heading">
          <h2 id="series-title">Series</h2>
        </div>

        <div class="series-grid">
          {seriesGroups.map((group) => (
            <a
              href={`/blog/series/${group.slug}`}
              class="series-card"
              data-series-card
              data-series={group.name}
              data-topics={group.topics.join(' ')}
            >
              <BlogCover
                title={group.name}
                summary={group.latest.data.summary}
                series={group.name}
                tags={group.topics}
                coverImage={group.representative.data.coverImage}
                imageAlt={group.representative.data.imageAlt || group.name}
              />
              <div class="series-card-copy">
                <h3>{group.name}</h3>
                <p>{group.latest.data.summary}</p>
                <time datetime={group.latest.data.date}>{formatDate(group.latest.data.date)}</time>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="post-index" aria-labelledby="post-index-title">
        <div class="section-heading post-index-heading">
          <div>
            <h2 id="post-index-title">Archive</h2>
          </div>
        </div>

        <div class="post-list" data-post-list>
          {sortedPosts.map((post) => (
            <a
              href={`/blog/${post.data.slug}`}
              class="post-row"
              data-post-row
              data-series={normalizeSeries(post.data.series)}
              data-topics={post.data.tags.join(' ')}
            >
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              <div>
                <h3>{post.data.title}</h3>
                <p>{post.data.summary}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>

  <script is:inline>
    const buttons = [...document.querySelectorAll('[data-topic-filter]')]
    const rows = [...document.querySelectorAll('[data-post-row]')]
    const cards = [...document.querySelectorAll('[data-series-card]')]

    for (const button of buttons) {
      button.addEventListener('click', () => {
        const topic = button.getAttribute('data-topic-filter')
        for (const option of buttons) option.classList.toggle('is-active', option === button)

        for (const row of rows) {
          const topics = row.getAttribute('data-topics') || ''
          row.hidden = topic !== 'all' && !topics.split(' ').includes(topic)
        }

        for (const card of cards) {
          const topics = card.getAttribute('data-topics') || ''
          card.hidden = topic !== 'all' && !topics.split(' ').includes(topic)
        }
      })
    }
  </script>
</BaseLayout>

<style>
  .blog-page {
    min-height: 100vh;
    padding: 8rem 6% 6rem;
    background: var(--editorial-paper);
    color: var(--editorial-ink);
  }

  .blog-shell {
    width: min(78rem, 100%);
    margin: 0 auto;
  }

  .blog-hero {
    max-width: 55rem;
    margin-bottom: 1.5rem;
  }

  .blog-hero h1,
  .section-heading h2,
  .series-card h3,
  .post-row h3 {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0;
    color: #191c24;
    text-wrap: balance;
  }

  .blog-hero h1 {
    font-size: clamp(3.2rem, 6vw, 5.5rem);
    font-weight: 600;
    line-height: 1;
  }

  .series-card p,
  .post-row p {
    color: #4a4c5f;
  }

  .series-index {
    margin-top: 2.5rem;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.2rem;
  }

  .section-heading h2 {
    font-size: clamp(1.7rem, 3vw, 2.55rem);
    font-weight: 600;
    line-height: 1.05;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .series-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(25, 28, 36, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.74);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
  }

  .series-card:hover h3,
  .post-row:hover h3 {
    color: #4f46e5;
  }

  .series-card-copy {
    padding: 1rem 1rem 1.1rem;
  }

  .series-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.18;
  }

  .series-card p {
    margin: 0.55rem 0 0;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .series-card time,
  .post-row time {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #64677a;
  }

  .series-card time {
    margin-top: 0.9rem;
  }

  .post-index {
    margin-top: 4.5rem;
  }

  .post-index-heading {
    align-items: start;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
  }

  .topic-filter {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.4rem;
    width: 100%;
    overflow-x: auto;
    padding: 0.75rem 0;
    background: var(--editorial-paper);
    scrollbar-width: none;
  }

  .topic-filter::-webkit-scrollbar {
    display: none;
  }

  .topic-filter-button {
    flex: 0 0 auto;
    appearance: none;
    border: 1px solid rgba(25, 28, 36, 0.14);
    border-radius: 999px;
    padding: 0.48rem 0.72rem;
    background: rgba(255, 255, 255, 0.72);
    color: #34364a;
    font: 700 0.8rem/1 var(--font-sans);
    cursor: pointer;
  }

  .topic-filter-button:hover,
  .topic-filter-button.is-active {
    border-color: rgba(79, 70, 229, 0.45);
    background: #4f46e5;
    color: #ffffff;
  }

  .post-list {
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
  }

  .post-row {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    gap: 2rem;
    padding: 1.35rem 0;
    border-top: 1px solid rgba(25, 28, 36, 0.12);
    color: inherit;
    text-decoration: none;
  }

  .post-row h3 {
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    font-weight: 600;
    line-height: 1.18;
  }

  .post-row p {
    max-width: 54rem;
    margin: 0.55rem 0 0;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 980px) {
    .series-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .blog-page {
      padding: 6.25rem 1rem 4rem;
    }

    .blog-hero {
      margin-bottom: 1.15rem;
    }

    .blog-hero h1 {
      font-size: clamp(2.8rem, 16vw, 4.4rem);
    }

    .series-grid {
      grid-template-columns: 1fr;
    }

    .post-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding: 1.1rem 0;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeTabs from '../components/CodeTabs';
import FAQ from '../components/FAQ.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';

const heroBlueprintCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::*;

<span class="cw-c">// Define a job — the unit of work operators run on chain.</span>
<span class="cw-p">#[job(id = 0, params(x, y))]</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">add</span>(
  <span class="cw-v">ctx</span>: &amp;<span class="cw-f">Ctx</span>,
  <span class="cw-v">x</span>: <span class="cw-f">u64</span>,
  <span class="cw-v">y</span>: <span class="cw-f">u64</span>,
) -&gt; <span class="cw-f">Result</span>&lt;<span class="cw-f">u64</span>&gt; {
  <span class="cw-f">Ok</span>(<span class="cw-v">x</span> + <span class="cw-v">y</span>)
}

<span class="cw-c">// Bundle jobs into a deployable Blueprint.</span>
<span class="cw-p">#[blueprint(name = "my-service", jobs(add))]</span>
<span class="cw-k">struct</span> <span class="cw-f">MyService</span>;`;

const getStartedSteps = [
  { title: 'Learn the SDK', desc: 'Read the docs, explore the Blueprint SDK, and understand how services are defined.' },
  { title: 'Build a Blueprint', desc: 'Use the Blueprint Agent or the CLI to create your first service — oracles, bridges, AI agents, MPC.' },
  { title: 'Deploy & Earn', desc: 'Deploy to Tangle Network. Operators pick up your Blueprint and you earn fees on every execution.' },
];

const blueprintExamples = [
  { name: 'Envio Indexer', description: 'A Tangle Blueprint for running envio indexers on any supported chain. Envio-as-a-service for Tangle.', github: 'https://github.com/tangle-network/envio-indexer-blueprint', logo: '/images/webflow/envio_indexer_logo.jpeg' },
  { name: 'Threshold BLS Signatures', description: 'A BLS Blueprint that can run keygen and signing jobs on demand from the Tangle Network.', github: 'https://github.com/tangle-network/bls-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'LayerZero DVN', description: 'A Blueprint for creating LayerZero Decentralized Verifier Network (DVN) on the Tangle Network.', github: 'https://github.com/tangle-network/layerzero-dvn-blueprint-template', logo: '/images/webflow/layerzero.jpeg' },
  { name: 'FROST Signatures', description: 'A Flexible Round-Optimized Schnorr Threshold Signatures Blueprint for Tangle Network.', github: 'https://github.com/tangle-network/frost-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'Hyperlane Validator', description: 'A Blueprint that provides automated dev ops for running Hyperlane validators with Tangle Network integration.', github: 'https://github.com/tangle-network/hyperlane-validator-blueprint', logo: '/images/webflow/Hyperlane.png' },
  { name: 'Rig AI Agent', description: 'An intelligent agent that automatically improves code documentation and style across repositories.', github: 'https://github.com/tangle-network/rig-ai-agent-blueprint', logo: '/images/webflow/icon-2.svg' },
];

const faqs = [
  { question: 'What is a Blueprint?', answer: 'A Blueprint is a reusable template for a decentralized service. It defines jobs and background processes that operators run on Tangle Network. Blueprints let you monetize any software — oracles, bridges, AI agents, MPC protocols — as a service that earns fees on every execution.' },
  { question: 'What languages can I build with?', answer: 'The Blueprint SDK supports Rust as the primary language, with TypeScript SDK extensions available. The Blueprint Agent (ai.tangle.tools) can generate Blueprints from natural language in any supported language.' },
  { question: 'How do I earn from my Blueprint?', answer: 'When operators instantiate and run your Blueprint, you earn fees on every job execution. Pricing, billing, and payouts are handled by the protocol — you just deploy and collect.' },
  { question: 'Where do I start?', answer: 'Visit docs.tangle.tools for the SDK documentation, or go to ai.tangle.tools to build your first Blueprint with AI assistance. Join our Discord for developer support.' },
];
---

<BaseLayout title="Developers" description="Build and monetize decentralized services on Tangle Network. Blueprint SDK, AI-powered development, and operator network.">

  <!-- Hero -->
  <section class="wf-section-hero" id="builders-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="dev-hero-grid">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Blueprint SDK</div>
            </div>
          </div>
          <h1 class="wf-h1">Build on Tangle Network</h1>
          <div class="wf-body-01">Create and monetize decentralized services using the Blueprint SDK. Deploy AI agents, oracles, bridges, and MPC protocols — and earn on every execution.</div>
          <div class="wf-button-row">
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Read the Docs</a>
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Build with AI</a>
          </div>
        </div>
        <div class="dev-hero-code">
          <CodeWindow
            tabs={[
              { id: 'blueprint', label: 'lib.rs', icon: 'code', html: heroBlueprintCode },
            ]}
          />
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/cube-poster.jpg" class="wf-hero-video-poster">
          <source src="/videos/cube-dark.webm" type="video/webm" />
          <source src="/videos/cube-dark.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <StatsStrip
    items={[
      { label: 'Rust SDK + TypeScript bindings', icon: 'code' },
      { label: 'earn on every operator-served instance', icon: 'dollar' },
      { label: 'staking-backed SLAs', icon: 'shield' },
      { label: 'Blueprint Agent — AI scaffolding', icon: 'zap' },
    ]}
  />

  <!-- Ways to earn — VAULT (light) surface — moved UP -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 72rem;">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #047857;">WAYS TO EARN</span>
          <h2 class="wf-h3" style="text-align: left; margin: 0; max-width: 44rem; color: #191c24;">Ship once. Earn on every instance.</h2>
          <p class="wf-body-01" style="margin: 0.5rem 0 0; color: #3a3a50; max-width: 44rem;">Every Blueprint you deploy is a service operators can run. Pricing, billing, and SLAs are enforced by the protocol — you collect fees per execution without running infrastructure.</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 2.5rem;">
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">SERVICE FEES</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Paid on every job run.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Define your price per invocation. The protocol collects, settles, and routes payouts to you — no Stripe webhook.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">INSTANCE ROYALTIES</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Every operator instance compounds.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Publish once, hundreds of operators instantiate. You earn on each instance as long as it runs — no ongoing work.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">PROTOCOL REWARDS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Inflation accrues to useful Blueprints.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Top Blueprints by usage earn a share of network rewards. The more your service is called, the more you compound.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tangle Blueprints -->
  <section class="wf-section">
    <div class="wf-section-wrapper" id="builders_section_1" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Tangle Blueprints</div>
            </div>
          </div>
          <div class="wf-h3">The Future of Modular Infrastructure</div>
          <div class="wf-body-02 align-center">Tangle Blueprints are an innovative way to build and monetize software with their flexibility and expressivity in leveraging open source libraries.</div>
        </div>
        <div style="max-width: 1280px; margin: 0 auto;">
          <img src="/images/webflow/modular blueprint.png" alt="Modular Blueprint Diagram" style="width: 100%; border-radius: 16px;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Get Started — with code example -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Get Started</div>
            </div>
          </div>
          <div class="wf-h3">Your first Blueprint</div>
          <div class="wf-body-02 align-center">Install the SDK, define your service, deploy to the network.</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 3rem; max-width: 80rem; margin: 0 auto; align-items: start;">
          <!-- Left: steps -->
          <div style="display: flex; flex-direction: column; gap: 0;">
            {getStartedSteps.map((step, i) => (
              <div style="padding: 1.5rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                  <div style={`width: 28px; height: 28px; border-radius: 8px; background: rgba(97,114,243,0.12); border: 1px solid rgba(97,114,243,0.2); display: flex; align-items: center; justify-content: center;`}>
                    <span style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 800; color: #6366F1;">{i + 1}</span>
                  </div>
                  <span style="font-family: var(--font-sans); font-size: 1.1rem; font-weight: 700; color: white;">{step.title}</span>
                </div>
                <p style="font-family: var(--font-sans); font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.55); line-height: 1.6; padding-left: 40px;">{step.desc}</p>
              </div>
            ))}
          </div>

          <!-- Right: interactive code terminal -->
          <div style="position: relative;">
            <div style="position: absolute; inset: -12px; border-radius: 20px; background: radial-gradient(ellipse at 50% 0%, rgba(97,114,243,0.12) 0%, transparent 70%); filter: blur(30px); pointer-events: none;"></div>
            <div style="position: relative;">
              <CodeTabs variant="blueprint" client:load />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blueprint Examples -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Build + Deploy</div>
          <div class="wf-body-02 align-center">A Blueprint is an infrastructure-as-code template defining jobs and background services that orchestrate useful services for customers.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {blueprintExamples.map((bp) => (
            <a href={bp.github} target="_blank" rel="noopener noreferrer" class="wf-builder-feature-card" style="text-decoration: none; color: inherit;">
              <div class="wf-builder-feature-top" style="display: flex; align-items: center; gap: 12px;">
                <img src={bp.logo} alt={bp.name} style="width: 36px; height: 36px; border-radius: 8px; object-fit: cover;" loading="lazy" />
                <div class="wf-h4" style="font-size: 1.1rem;">{bp.name}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: var(--font-sans); font-size: 0.95rem; font-weight: 500; line-height: 1.55;">{bp.description}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Ecosystem</div>
            </div>
          </div>
          <div class="wf-h3">Build on these platforms with AI</div>
          <div class="wf-body-02 align-center">Custom templates and deep SDK integrations for 40+ ecosystems.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px; margin: 2rem auto 0;">
          {[
            { name: 'Coinbase', logo: 'coinbase-logo.svg' },
            { name: 'Solana', logo: 'solana-logo.svg' },
            { name: 'EigenLayer', logo: 'eigenlayer-logo.svg' },
            { name: 'Worldcoin', logo: 'worldcoin-logo.svg' },
            { name: 'Arbitrum', logo: 'arbitrum-logo.svg' },
            { name: 'Base', logo: 'base-logo.svg' },
            { name: 'Chainlink', logo: 'chainlink.svg' },
            { name: 'Aave', logo: 'aave.svg' },
            { name: 'Aptos', logo: 'aptos-logo.svg' },
            { name: 'Sui', logo: 'sui-logo.svg' },
            { name: 'OpenZeppelin', logo: 'openzeppelin-logo.svg' },
            { name: 'Starknet', logo: 'starknet-logo.svg' },
          ].map(p => (
            <div style="display: grid; align-items: center; justify-items: center; padding: 16px; border: 1px solid #40366f; border-radius: 1px; height: 184px;">
              <a href="#" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 120px; text-decoration: none;">
                <img src={`/images/partners/${p.logo}`} alt={p.name} style="height: 60px; width: auto;" loading="lazy" />
              </a>
              <p style="color: white; font-family: var(--font-display); font-size: 20px; font-weight: 600; text-align: center; margin: 0;">{p.name}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <FAQ faqs={faqs} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start building on Tangle.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Read the docs, build your first Blueprint, deploy to the network. Earn on every execution.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Read the Docs</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    if (typeof createGridReveal === 'function') {
      document.addEventListener("DOMContentLoaded", function() {
        createGridReveal('builders-hero');
        createGridReveal('builders_section_1');
      });
    }
  </script>


</BaseLayout>

<style>
  /* 2-col hero grid (mirrors index.astro / operators.astro) */
  .dev-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 3rem;
    align-items: center;
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .dev-hero-code { min-width: 0; }
  @media (max-width: 991px) {
    .dev-hero-grid { grid-template-columns: minmax(0, 1fr); gap: 2rem; }
  }
</style>

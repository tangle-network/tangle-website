---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeTabs from '../components/CodeTabs';
import FAQ from '../components/FAQ.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import BentoCell from '../components/ui/BentoCell.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';

const heroBlueprintCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::{<span class="cw-f">Router</span>, tangle::extract::{<span class="cw-f">Caller</span>, <span class="cw-f">TangleArg</span>, <span class="cw-f">TangleResult</span>}};
<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::alloy::sol;

<span class="cw-k">pub const</span> <span class="cw-v">HELLO_JOB_ID</span>: <span class="cw-f">u8</span> = <span class="cw-n">0</span>;

<span class="cw-c">// ABI-compatible payloads. operators decode these on-chain.</span>
sol! {
  <span class="cw-k">struct</span> <span class="cw-f">HelloRequest</span> { <span class="cw-f">string</span> name; }
  <span class="cw-k">struct</span> <span class="cw-f">HelloResponse</span> { <span class="cw-f">string</span> message; <span class="cw-f">string</span> operator; }
}

<span class="cw-c">// A job is just an async fn. Extractors give you what you need.</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">hello</span>(
  <span class="cw-f">Caller</span>(caller): <span class="cw-f">Caller</span>,
  <span class="cw-f">TangleArg</span>(req): <span class="cw-f">TangleArg</span>&lt;<span class="cw-f">HelloRequest</span>&gt;,
) -&gt; <span class="cw-f">TangleResult</span>&lt;<span class="cw-f">HelloResponse</span>&gt; {
  <span class="cw-f">TangleResult</span>(<span class="cw-f">HelloResponse</span> {
    message: <span class="cw-f">format!</span>(<span class="cw-s">"Hello, {}!"</span>, req.name),
    operator: <span class="cw-f">format!</span>(<span class="cw-s">"{caller:#x}"</span>),
  })
}

<span class="cw-c">// Mount jobs on a Router. Operators run this binary.</span>
<span class="cw-k">pub fn</span> <span class="cw-f">router</span>() -&gt; <span class="cw-f">Router</span> {
  <span class="cw-f">Router</span>::<span class="cw-f">new</span>().<span class="cw-f">route</span>(<span class="cw-v">HELLO_JOB_ID</span>, <span class="cw-v">hello</span>)
}`;

const getStartedSteps = [
  { title: 'Learn the SDK', desc: 'Read the docs. See how jobs, contexts, and Blueprints fit together.' },
  { title: 'Build a Blueprint', desc: 'Use the Blueprint Agent or the CLI to scaffold oracles, bridges, AI agents, MPC.' },
  { title: 'Deploy & Earn', desc: 'Push to Tangle. Operators run instances. You earn per execution.' },
];

const blueprintExamples = [
  { name: 'Envio Indexer', description: 'A Tangle Blueprint for running envio indexers on any supported chain. Envio-as-a-service for Tangle.', github: 'https://github.com/tangle-network/envio-indexer-blueprint', logo: '/images/webflow/envio_indexer_logo.jpeg' },
  { name: 'Threshold BLS Signatures', description: 'A BLS Blueprint that can run keygen and signing jobs on demand from the Tangle Network.', github: 'https://github.com/tangle-network/bls-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'LayerZero DVN', description: 'A Blueprint for creating LayerZero Decentralized Verifier Network (DVN) on the Tangle Network.', github: 'https://github.com/tangle-network/layerzero-dvn-blueprint-template', logo: '/images/webflow/layerzero.jpeg' },
  { name: 'FROST Signatures', description: 'A Flexible Round-Optimized Schnorr Threshold Signatures Blueprint for Tangle Network.', github: 'https://github.com/tangle-network/frost-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'Hyperlane Validator', description: 'Run Hyperlane validators with Tangle integration. Automated dev ops included.', github: 'https://github.com/tangle-network/hyperlane-validator-blueprint', logo: '/images/webflow/Hyperlane.png' },
  { name: 'Rig AI Agent', description: 'An agent that improves code documentation and style across repositories.', github: 'https://github.com/tangle-network/rig-ai-agent-blueprint', logo: '/images/webflow/icon-2.svg' },
];

const faqs = [
  { question: 'What is a Blueprint?', answer: 'A reusable service template. Defines jobs and background processes operators run on Tangle. Wrap oracles, bridges, AI agents, or MPC protocols and earn fees per execution.' },
  { question: 'What languages can I build with?', answer: 'Rust as primary, with TypeScript SDK extensions. The Blueprint Agent at ai.tangle.tools generates Blueprints from natural language.' },
  { question: 'How do I earn from my Blueprint?', answer: 'Operators instantiate your Blueprint and you earn fees per job. Pricing, billing, and payouts settle on chain.' },
  { question: 'Where do I start?', answer: 'docs.tangle.tools for the SDK. ai.tangle.tools to scaffold with AI. Discord for support.' },
];
---

<BaseLayout title="Developers" description="Build Blueprints with the Rust SDK or AI scaffolding. Earn per execution.">

  <!-- Hero -->
  <Hero
    eyebrow="BLUEPRINT SDK"
    eyebrowColor="brand"
    eyebrowIcon="code"
    title="Build decentralized services"
    subtitle="Define jobs in Rust. Operators run instances. You earn per execution. AI agents, oracles, bridges, MPC."
    lede="Your code becomes a Blueprint: a Rust job spec with input/output types, a pricing rule, and a slashing condition. Anyone can request an instance. Operators race to serve it. You collect a cut of every execution. No infra, no SLA, no on-call."
    primaryCta={{ label: 'Build with AI', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'Read the Docs', href: 'https://docs.tangle.tools', external: true }}
    videoBg={{
      poster: '/images/hero/cube-poster.jpg',
      webm: '/videos/cube-dark.webm',
      mp4: '/videos/cube-dark.mp4',
    }}
  >
    <CodeWindow
      tabs={[
        { id: 'blueprint', label: 'lib.rs', icon: 'code', html: heroBlueprintCode },
      ]}
    />
  </Hero>

  <StatsStrip
    items={[
      { label: 'Rust SDK + TypeScript bindings', icon: 'code' },
      { label: 'earn on every operator-served instance', icon: 'dollar' },
      { label: 'staking-backed SLAs', icon: 'shield' },
      { label: 'Blueprint Agent for AI scaffolding', icon: 'zap' },
    ]}
  />

  <!-- Ways to earn. VAULT (light) surface. Gen 3 ported -->
  <Section variant="vault" pad="default">
    <div style="margin-bottom: 2.5rem;">
      <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: var(--brand-cool); text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 0.75rem;">Ways to earn</div>
      <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: #191c24; margin: 0 0 0.75rem; max-width: 44rem;">Ship once. Earn on every instance.</h2>
      <p style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.55; color: #3a3a50; max-width: 44rem; margin: 0;">Pricing, billing, and SLAs settle on chain. You collect fees per execution without running infrastructure.</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
      <BentoCell variant="vault">
        <Fragment slot="label">Service fees</Fragment>
        <Fragment slot="title">Paid on every job run.</Fragment>
        <Fragment slot="body">Set price per invocation. The protocol collects, settles, and routes payouts. No Stripe webhook.</Fragment>
      </BentoCell>
      <BentoCell variant="vault">
        <Fragment slot="label">Instance royalties</Fragment>
        <Fragment slot="title">Every operator instance compounds.</Fragment>
        <Fragment slot="body">Publish once. Operators instantiate. You earn per instance for as long as it runs.</Fragment>
      </BentoCell>
      <BentoCell variant="vault">
        <Fragment slot="label">Protocol rewards</Fragment>
        <Fragment slot="title">Inflation accrues to useful Blueprints.</Fragment>
        <Fragment slot="body">Top Blueprints by usage earn a share of network rewards. More calls, more compounding.</Fragment>
      </BentoCell>
    </div>
  </Section>

  <!-- Tangle Blueprints -->
  <Section variant="dark" pad="default" id="builders_section_1">
    <div style="text-align: center; margin-bottom: 3rem;">
      <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: var(--brand-cool); text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 0.75rem;">Tangle Blueprints</div>
      <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: var(--text-primary); margin: 0 0 1rem;">A Blueprint is a service template.</h2>
      <p style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.55; color: var(--text-secondary); max-width: 44rem; margin: 0 auto;">Jobs and background tasks in Rust. Operators run instances. Customers pay per call. You collect.</p>
    </div>
    <div style="max-width: 1280px; margin: 0 auto;">
      <img src="/images/webflow/modular blueprint.png" alt="Modular Blueprint Diagram" style="width: 100%; border-radius: 16px;" loading="lazy" />
    </div>
  </Section>

  <!-- Get Started. with code example -->
  <Section variant="vault" pad="default">
    <div style="text-align: center; margin-bottom: 3rem;">
      <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: var(--brand-cool); text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 0.75rem;">Get Started</div>
      <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: var(--text-primary); margin: 0 0 1rem;">Your first Blueprint.</h2>
      <p style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.55; color: var(--text-secondary); max-width: 44rem; margin: 0 auto;">Install the SDK. Define a job. Deploy.</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 3rem; max-width: 80rem; margin: 0 auto; align-items: start;">
      <!-- Left: steps -->
      <div class="dev-steps">
        {getStartedSteps.map((step, i) => (
          <div class="dev-step">
            <div class="dev-step-head">
              <div class="dev-step-num"><span>{i + 1}</span></div>
              <span class="dev-step-title">{step.title}</span>
            </div>
            <p class="dev-step-desc">{step.desc}</p>
          </div>
        ))}
      </div>

      <!-- Right: interactive code terminal -->
      <div class="dev-code-wrap">
        <CodeTabs variant="blueprint" client:load />
      </div>
    </div>
  </Section>

  <!-- Blueprint Examples. heading killed per Drew (2026-04-25); cards
       carry their own context and the prior eyebrow/title/lede stack
       added redundancy. Section header removed; grid is now the section. -->
  <Section variant="dark" pad="default">
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 1100px; margin: 0 auto;">
      {blueprintExamples.map((bp) => (
        <a href={bp.github} target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: block;">
          <BentoCell sharp>
            <Fragment slot="title">
              <span style="display: flex; align-items: center; gap: 12px;">
                <img src={bp.logo} alt="" role="presentation" style="width: 36px; height: 36px; border-radius: 8px; object-fit: cover; flex-shrink: 0;" loading="lazy" />
                <span>{bp.name}</span>
              </span>
            </Fragment>
            <Fragment slot="body">{bp.description}</Fragment>
          </BentoCell>
        </a>
      ))}
    </div>
  </Section>

  <!-- Partners. ecosystem grid kept inline (bespoke LIVE-pill hover) -->
  <Section variant="vault" pad="default">
    <div style="text-align: center; margin-bottom: 3rem;">
      <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: var(--brand-cool); text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 0.75rem;">Web3 vertical</div>
      <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: var(--text-primary); margin: 0 0 1rem;">One of <em style="font-style: normal; background: linear-gradient(135deg, #818cf8, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">many ecosystems</em> we ship for.</h2>
      <p style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.55; color: var(--text-secondary); max-width: 44rem; margin: 0 auto;">Crypto blueprints are the maturity case: staking-backed SLAs, on-chain payouts, slashing. The same workbench targets agent frameworks, AI runtimes, and any service you can wrap in a job spec.</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 1px; margin: 2rem auto 0;">
          {[
            { name: 'Coinbase', logo: 'coinbase-logo.svg' },
            { name: 'Solana', logo: 'solana-logo.svg' },
            { name: 'EigenLayer', logo: 'eigenlayer-logo.svg' },
            { name: 'Worldcoin', logo: 'worldcoin-logo.svg' },
            { name: 'Arbitrum', logo: 'arbitrum-logo.svg' },
            { name: 'Base', logo: 'base-logo.svg' },
            { name: 'Chainlink', logo: 'chainlink.svg' },
            { name: 'Aave', logo: 'aave.svg' },
            { name: 'Aptos', logo: 'aptos-logo.svg' },
            { name: 'Sui', logo: 'sui-logo.svg' },
            { name: 'OpenZeppelin', logo: 'openzeppelin-logo.svg' },
            { name: 'Starknet', logo: 'starknet-logo.svg' },
          ].map(p => (
            <div class="dev-partner-tile" style="position: relative; display: grid; align-items: center; justify-items: center; padding: 16px; border: 1px solid var(--border-subtle); border-radius: 8px; height: 184px; transition: border-color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;">
              <span class="dev-partner-status" aria-hidden="true">
                <span class="dev-partner-status-dot"></span>
                LIVE
              </span>
              <a href="#" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 120px; text-decoration: none;">
                <img src={`/images/partners/${p.logo}`} alt={p.name} style="height: 60px; width: auto;" loading="lazy" />
              </a>
              <p style="color: var(--text-secondary); font-family: var(--font-display); font-size: 14px; font-weight: 600; text-align: center; margin: 0;">{p.name}</p>
            </div>
          ))}
        </div>
  </Section>

  <!-- FAQ -->
  <Section variant="dark" pad="default">
    <FAQ faqs={faqs} />
  </Section>

  <!-- CTA -->
  <CtaBlock
    title="Start building on Tangle."
    body="Docs, scaffold, deploy. Earn per execution."
    primaryCta={{ label: 'Read the Docs', href: 'https://docs.tangle.tools', external: true }}
  />

  <script is:inline>
    if (typeof createGridReveal === 'function') {
      document.addEventListener("DOMContentLoaded", function() {
        createGridReveal('builders-hero');
        createGridReveal('builders_section_1');
      });
    }
  </script>


</BaseLayout>

<style>
  /* Get-started steps. tokenized */
  .dev-steps { display: flex; flex-direction: column; gap: 0; }
  .dev-step { padding: 1.5rem 0; border-top: 1px solid var(--border-subtle); }
  .dev-step-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .dev-step-num {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-cool);
  }
  .dev-step-num span {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 800;
  }
  .dev-step-title {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .dev-step-desc {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.6;
    padding-left: 40px;
    margin: 0;
  }
  .dev-code-wrap { position: relative; }

  /* Ecosystem partner tile. hover lift + LIVE status pill */
  .dev-partner-tile:hover {
    border-color: rgba(52, 211, 153, 0.55);
    transform: translateY(-2px);
    background-color: rgba(52, 211, 153, 0.04);
  }
  .dev-partner-status {
    position: absolute;
    top: 10px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(52, 211, 153, 0.9);
    /* Hide via opacity, NOT transparent color. audits read color
       contrast on the resting state and would flag transparent text
       as 1:1. Opacity-on-element keeps the intent (revealed on hover)
       without the contrast violation. */
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .dev-partner-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34D399;
    opacity: 0.5;
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .dev-partner-tile:hover .dev-partner-status { opacity: 1; }
  .dev-partner-tile:hover .dev-partner-status-dot {
    opacity: 1;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
    animation: dev-partner-pulse 1.6s ease-in-out infinite;
  }
  @keyframes dev-partner-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.45; }
  }
  @media (prefers-reduced-motion: reduce) {
    .dev-partner-tile, .dev-partner-status, .dev-partner-status-dot { transition: none; animation: none; }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro'
import BlogCover from '../components/BlogCover.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog', ({ data }) => !data.draft)

const researchPosts = posts
  .filter((post) => post.data.series?.replace(/^['"]|['"]$/g, '') === 'the-self-improving-stack')
  .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0))

const leadPost =
  researchPosts.find((post) => post.data.slug === 'self-improving-stack-trace-systems') ?? researchPosts[0]
const remainingPosts = researchPosts.filter((post) => post.data.slug !== leadPost?.data.slug)

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })
---

<BaseLayout
  title="Research"
  description="Research notes on self-improving agents, trace systems, evaluation gates, and runtime design."
  bodyClass="page-editorial"
>
  <section class="research-page" aria-labelledby="research-title">
    <div class="research-shell">
      <header class="research-hero">
        <h1 id="research-title">Research</h1>
      </header>

      {leadPost && (
        <a href={`/blog/${leadPost.data.slug}`} class="research-feature">
          <BlogCover
            title={leadPost.data.title}
            summary={leadPost.data.summary}
            series={leadPost.data.series}
            seriesOrder={leadPost.data.seriesOrder}
            tags={leadPost.data.tags}
            coverImage={leadPost.data.coverImage}
            imageAlt={leadPost.data.imageAlt || leadPost.data.title}
            variant="hero"
          />
          <div class="research-feature-copy">
            <time datetime={leadPost.data.date}>{formatDate(leadPost.data.date)}</time>
            <h2>{leadPost.data.title}</h2>
            <p>{leadPost.data.summary}</p>
          </div>
        </a>
      )}

      <section class="research-list" aria-labelledby="research-list-title">
        <div class="section-heading">
          <h2 id="research-list-title">Self-improving agents</h2>
        </div>

        <div class="research-rows">
          {remainingPosts.map((post) => (
            <a href={`/blog/${post.data.slug}`} class="research-row">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              <div>
                <h3>{post.data.title}</h3>
                <p>{post.data.summary}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .research-page {
    min-height: 100vh;
    padding: 8rem 6% 6rem;
    background: #fbfaf7;
    color: #191c24;
  }

  .research-shell {
    width: min(76rem, 100%);
    margin: 0 auto;
  }

  .research-hero {
    max-width: 54rem;
    margin-bottom: 3.5rem;
  }

  .research-hero h1,
  .research-feature h2,
  .section-heading h2,
  .research-row h3 {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0;
    color: #191c24;
    text-wrap: balance;
  }

  .research-hero h1 {
    font-size: clamp(3.4rem, 7vw, 6.2rem);
    font-weight: 800;
    line-height: 1;
  }

  .research-hero p {
    max-width: 44rem;
    margin: 1.2rem 0 0;
    color: #4b4a57;
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    line-height: 1.58;
  }

  .research-feature {
    display: grid;
    grid-template-columns: minmax(18rem, 0.8fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid rgba(25, 28, 36, 0.12);
    border-radius: 8px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 20px 70px rgba(15, 23, 42, 0.07);
  }

  .research-feature-copy {
    padding-right: 1rem;
  }

  .research-feature time,
  .research-row time {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #66636f;
  }

  .research-feature h2 {
    max-width: 42rem;
    margin-top: 0.7rem;
    font-size: clamp(1.9rem, 4vw, 3.25rem);
    font-weight: 800;
    line-height: 1.04;
  }

  .research-feature p {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: #4b4a57;
    font-size: 1.05rem;
    line-height: 1.62;
  }

  .research-list {
    margin-top: 4.5rem;
  }

  .section-heading {
    padding-bottom: 1.1rem;
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
  }

  .section-heading h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    font-weight: 800;
    line-height: 1.05;
  }

  .section-heading p {
    max-width: 43rem;
    margin: 0.55rem 0 0;
    color: #52515d;
    font-size: 1rem;
    line-height: 1.55;
  }

  .research-rows {
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
  }

  .research-row {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    gap: 2rem;
    padding: 1.35rem 0;
    border-top: 1px solid rgba(25, 28, 36, 0.12);
    color: inherit;
    text-decoration: none;
  }

  .research-row h3 {
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    font-weight: 760;
    line-height: 1.18;
  }

  .research-row p {
    max-width: 54rem;
    margin: 0.55rem 0 0;
    color: #52515d;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .research-row:hover h3,
  .research-feature:hover h2 {
    color: #4f46e5;
  }

  @media (max-width: 840px) {
    .research-feature {
      grid-template-columns: 1fr;
    }

    .research-feature-copy {
      padding: 0 0.35rem 0.35rem;
    }
  }

  @media (max-width: 640px) {
    .research-page {
      padding: 6.25rem 1rem 4rem;
    }

    .research-hero {
      margin-bottom: 2.4rem;
    }

    .research-hero h1 {
      font-size: clamp(3.1rem, 17vw, 4.7rem);
    }

    .research-feature {
      padding: 0.7rem;
      gap: 1.25rem;
    }

    .research-feature :global(.blog-cover) {
      min-height: 16rem;
    }

    .research-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding: 1.1rem 0;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const weekTimeline = [
  { week: 1, title: 'Foundations & Onboarding', items: ['Interactive workshops on Blueprint development fundamentals', 'Technical setup and office hours', 'Meet the team'] },
  { week: 2, title: 'Ideation', items: ['Deeper technical workshops and concept development', 'Advanced Blueprint development techniques and patterns'] },
  { week: 3, title: 'Building', items: ['Introduction to partner tracks and locking in your projects', 'Collaborative ideation and technical development sessions'] },
  { week: 4, title: 'Launch & Demo Day', items: ['Final development and refinement of your Blueprint', 'Demo Day: Present your Blueprint to the community & a panel of judges', 'Prizes to be announced soon'] },
];

const blueprintExamples = [
  { name: 'Envio Indexer', description: 'A Tangle Blueprint for running envio indexers on any supported chain. Envio-as-a-service for Tangle.', github: 'https://github.com/tangle-network/envio-indexer-blueprint', logo: '/images/webflow/envio_indexer_logo.jpeg' },
  { name: 'Threshold BLS Signatures', description: 'A BLS Blueprint that can run keygen and signing jobs on demand from the Tangle Network.', github: 'https://github.com/tangle-network/bls-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'LayerZero DVN', description: 'A Blueprint for creating LayerZero Decentralized Verifier Network (DVN) on the Tangle Network.', github: 'https://github.com/tangle-network/layerzero-dvn-blueprint-template', logo: '/images/webflow/layerzero.jpeg' },
  { name: 'FROST Signatures', description: 'A Flexible Round-Optimized Schnorr Threshold Signatures Blueprint for Tangle Network.', github: 'https://github.com/tangle-network/frost-blueprint', logo: '/images/webflow/iacrlogo_small.png' },
  { name: 'Hyperlane Validator', description: 'A Blueprint that provides automated dev ops for running Hyperlane validators with Tangle Network integration.', github: 'https://github.com/tangle-network/hyperlane-validator-blueprint', logo: '/images/webflow/Hyperlane.png' },
  { name: 'Rig AI Agent', description: 'An intelligent agent that automatically improves code documentation and style across repositories.', github: 'https://github.com/tangle-network/rig-ai-agent-blueprint', logo: '/images/webflow/icon-2.svg' },
];

const faqs = [
  { question: 'What is the Tangle Builders Program?', answer: 'The Tangle Builders Program is an educational initiative designed to introduce developers to Tangle Blueprints and help them create their own Blueprints. Through workshops, tutorials, and hands-on guidance, we aim to empower developers with the tools to monetize open-source software. The program offers technical support, mentorship, and access to workshops and webinars to help developers build successful Blueprints.' },
  { question: 'What is a Blueprint and why should I build one?', answer: 'A Blueprint is a reusable template for a decentralized service that allows developers to monetize software such as oracles, bridges, AI agents, and multi-party computation applications.' },
  { question: 'Who should join the Tangle Builders Program?', answer: 'Developers with an interest in monetizing open-sourced softwares and learn about cutting edge use cases to collaborate with our Builders Program partners.' },
  { question: 'Can I earn rewards for participating?', answer: 'Yes! By participating in our Season 1 Builders Program, you may be eligible for prizes and swags complying with our judging criteria. You may also be eligible for future airdrop.' },
];
---

<BaseLayout title="Builders Program" description="Join the Tangle Builders Program — a 4-week education and hackathon to build Blueprints on Tangle Network.">

  <!-- Hero -->
  <section class="wf-section-hero" id="builders-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Season 1</div>
            </div>
          </div>
          <h1 class="wf-h1">Tangle Network Builders Program</h1>
          <div class="wf-body-01">Join our 4-weeks education + hackathon program where innovation meets execution. Come build with us!</div>
          <div class="wf-button-row">
            <a href="https://form.typeform.com/to/IE4hT9jW" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Apply Now</a>
            <a href="https://discord.com/invite/PasupPmkaW" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Join Community</a>
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/cube-poster.jpg" class="wf-hero-video-poster">
          <source src="/videos/cube-dark.webm" type="video/webm" />
          <source src="/videos/cube-dark.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- Tangle Blueprints -->
  <section class="wf-section">
    <div class="wf-section-wrapper" id="builders_section_1" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Tangle Blueprints</div>
            </div>
          </div>
          <div class="wf-h3">The Future of Modular Infrastructure</div>
          <div class="wf-body-02 align-center">Tangle Blueprints are an innovative way to build and monetize software with their flexibility and expressivity in leveraging open source libraries.</div>
        </div>
        <div style="max-width: 900px; margin: 0 auto;">
          <img src="/images/webflow/modular blueprint.png" alt="Modular Blueprint Diagram" style="width: 100%; border-radius: 16px;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Build, Innovate, Deploy</div>
          <div class="wf-body-02 align-center">A structured 4-week journey that takes you from zero to a production-ready Blueprint, with expert guidance at every step.</div>
        </div>

        <div style="display: flex; gap: 3rem; align-items: flex-start; flex-wrap: wrap;">
          <!-- Left side: expectations -->
          <div style="flex: 0 0 38%; min-width: 280px;">
            <div class="wf-h4" style="font-size: 1.5rem; margin-bottom: 1rem;">What you can expect</div>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px;">
              <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500;">
                <span style="margin-top: 8px; width: 6px; height: 6px; border-radius: 50%; background: #4a3aff; flex-shrink: 0;"></span>
                Hands-on experience building open source services.
              </li>
              <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500;">
                <span style="margin-top: 8px; width: 6px; height: 6px; border-radius: 50%; background: #4a3aff; flex-shrink: 0;"></span>
                Mentorship from industry leaders with weekly AMAs.
              </li>
              <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500;">
                <span style="margin-top: 8px; width: 6px; height: 6px; border-radius: 50%; background: #4a3aff; flex-shrink: 0;"></span>
                A completed project with real-world impact.
              </li>
            </ul>
          </div>

          <!-- Right side: week timeline -->
          <div style="flex: 1; min-width: 320px; display: flex; flex-direction: column; position: relative; padding-left: 2rem;">
            <!-- Vertical connecting line -->
            <div style="position: absolute; left: 7px; top: 12px; bottom: 12px; width: 2px; background: linear-gradient(180deg, #6172f3 0%, rgba(97,114,243,0.15) 100%);"></div>
            {weekTimeline.map((week) => (
              <div style="display: flex; align-items: flex-start; gap: 1.25rem; position: relative; padding-bottom: 1.5rem;">
                <!-- Step dot -->
                <div style="position: absolute; left: -2rem; top: 4px; width: 16px; height: 16px; border-radius: 50%; background: #161425; border: 2px solid #6172f3; z-index: 1; display: flex; align-items: center; justify-content: center;">
                  <div style="width: 6px; height: 6px; border-radius: 50%; background: #6172f3;"></div>
                </div>
                <!-- Card -->
                <div class="wf-builder-feature-card" style="flex: 1;">
                  <div class="wf-builder-feature-top">
                    <div style="color: #6172f3; font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Week {week.week}</div>
                    <div class="wf-h4" style="font-size: 1.5rem;">{week.title}</div>
                  </div>
                  <div class="wf-builder-feature-bottom" style="flex-direction: column; gap: 8px;">
                    {week.items.map((item) => (
                      <div style="display: flex; align-items: flex-start; gap: 10px; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; line-height: 1.5;">
                        <span style="margin-top: 6px; width: 5px; height: 5px; border-radius: 50%; background: #6172f3; flex-shrink: 0;"></span>
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blueprint Examples -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Build + Deploy</div>
          <div class="wf-body-02 align-center">A Blueprint is an infrastructure-as-code template defining jobs and background services that orchestrate useful services for customers.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
          {blueprintExamples.map((bp) => (
            <a href={bp.github} target="_blank" rel="noopener noreferrer" class="wf-builder-feature-card" style="text-decoration: none; color: inherit;">
              <div class="wf-builder-feature-top" style="display: flex; align-items: center; gap: 12px;">
                <img src={bp.logo} alt={bp.name} style="width: 36px; height: 36px; border-radius: 8px; object-fit: cover;" loading="lazy" />
                <div class="wf-h4" style="font-size: 1.1rem;">{bp.name}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; line-height: 1.5;">{bp.description}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Build Blueprints with Industry-Leading Partners</div>
          <div class="wf-body-02 align-center">Collaborate with top teams in the ecosystem to create impactful infrastructure services.</div>
        </div>
        <div style="display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; padding: 2rem 0;">
          <img src="/images/webflow/EigenLayer.png" alt="EigenLayer" style="height: 48px; width: auto; opacity: 0.8;" loading="lazy" />
          <img src="/images/webflow/Phala.png" alt="Phala" style="height: 48px; width: auto; opacity: 0.8;" loading="lazy" />
          <img src="/images/webflow/edwin1.png" alt="Edwin" style="height: 48px; width: auto; opacity: 0.8;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 800px;">
        <div class="wf-section-head">
          <div class="wf-h3">Frequently Asked Questions</div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {faqs.map((faq, i) => (
            <details style="border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; overflow: hidden;" {...(i === 0 ? { open: true } : {})}>
              <summary style="display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 1.25rem 1.5rem; font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 600; color: white; list-style: none;">
                {faq.question}
                <svg style="width: 20px; height: 20px; flex-shrink: 0; margin-left: 16px; color: #6b7094; transition: transform 0.2s;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div style="padding: 0 1.5rem 1.25rem; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; line-height: 1.6;">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Shape the Future of Decentralized Services</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Come build innovative Blueprints with us! Join Tangle's Builder Program and be a part of shaping the future of decentralized services!</div>
        <div class="wf-cta-button-row">
          <a href="https://form.typeform.com/to/IE4hT9jW" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Building</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    if (typeof createGridReveal === 'function') {
      document.addEventListener("DOMContentLoaded", function() {
        createGridReveal('builders-hero');
        createGridReveal('builders_section_1');
      });
    }
  </script>

</BaseLayout>

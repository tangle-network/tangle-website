  { name: 'CoinGecko', description: 'Real-time analytics for cryptocurrency market', badge: 'Tool', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/coingecko.jpg' },
  { name: 'Common', description: 'Create onchain together', badge: 'Social', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/common.png' },
  { name: 'Cookbook.dev', description: 'Discover contracts, libraries, protocols', badge: 'AI', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/cookbookdev.jpg' },
  { name: 'Den', description: 'The fastest multisig for onchain teams', badge: 'Security', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/den.png' },
  { name: 'Edgeware', description: 'A DAO-first smart contract platform', badge: 'Development', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/edgeware.png' },
  { name: 'EigenLayer', description: 'Open Innovation and Infinite Sum Games', badge: 'Restaking', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/eigenlayer.png' },
  { name: 'Envio', description: "Web3's Backend", badge: 'Indexing', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/envio.jpeg' },

---
import BaseLayout from '../layouts/BaseLayout.astro';

const partners = [
  { name: 'Astar', description: 'Blockchain for the next big Web3 innovations', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/astar.png' },

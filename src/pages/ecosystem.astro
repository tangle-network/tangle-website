  { name: 'Hyperlane', description: 'Open interoperability framework', categories: ['Bridge', 'DeFi'], logo: '/images/webflow/Hyperlane.png' },
  { name: 'LayerZero', description: 'Build Omnichain', categories: ['Bridge', 'DeFi'], logo: '/images/webflow/layerzero.jpeg' },
  { name: 'Lemniscap', description: 'Investing in emerging blockchain startups', categories: ['Investor'], logo: '/images/webflow/Lemniscap.png' },
  { name: 'Level', description: 'The first stablecoin powered by restaking', categories: ['Asset', 'DeFi'], logo: '/images/webflow/level.png' },
  { name: 'Livepeer', description: 'Decentralized video infrastructure', categories: ['Development'], logo: '/images/webflow/livepeer.png' },
  { name: 'Merkly', description: 'Cross-chain messaging and bridging', categories: ['Bridge', 'Tool'], logo: '/images/webflow/merkly.png' },
  { name: 'MetaMask', description: 'The ultimate crypto wallet for web3 & DeFi', categories: ['Wallet', 'Tool'], logo: '/images/webflow/free-metamask-2728406-2261817.png' },

  { name: 'ZeePrime Capital', description: 'Totally supercool and chilled VC', categories: ['Investor'], logo: '/images/webflow/ZeePrime Capital.png' },
];

const allCategories = ['All', ...new Set(partners.flatMap(p => p.categories))].slice(0, 12);

const featuredLogos = partners.filter(p => p.logo).slice(0, 10);
---

<BaseLayout title="Ecosystem" description="Explore the Tangle Network ecosystem of partners, investors, and integrations.">

  <!-- Hero -->
  <section style="background-image: linear-gradient(127deg, #4f40b9, #7aa0ff); border-radius: 0 0 16px 16px; margin: 0 1.5%; overflow: hidden; position: relative;">
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 10rem 5% 5rem; max-width: 80rem; margin: 0 auto;">
      <div style="width: 45%;">
        <h1 class="wf-h1" style="font-size: 3.5rem;">Tangle Network Ecosystem</h1>
        <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="margin-top: 1rem;">Launch dApp &rarr;</a>
      </div>
      <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; width: 45%;">
        {featuredLogos.map((p) => (
          <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; overflow: hidden;">
            <img src={p.logo} alt={p.name} style="width: 40px; height: 40px; object-fit: contain; border-radius: 8px;" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Grid with Sidebar -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div style="display: flex; gap: 0; align-items: flex-start;">
          <!-- Left Sidebar Filters -->
          <div style="width: 18%; flex-shrink: 0; position: sticky; top: 6rem; padding-right: 1.5rem;" id="eco-filters">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin-bottom: 1rem; padding-left: 12px;">Categories</div>
            <div style="display: flex; flex-direction: column; gap: 2px;">
              {allCategories.map((cat, i) => (
                <button
                  data-category={cat}
                  style={`display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: 8px; border: none; background: ${i === 0 ? 'rgba(97,114,243,0.1)' : 'transparent'}; color: ${i === 0 ? '#6172f3' : 'var(--color-text-secondary)'}; font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.2s; text-align: left; width: 100%;`}
                >
                  <img src="/images/webflow/tangle icon.png" style="width: 16px; height: 16px; opacity: 0.6;" alt="" />
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <!-- Right Content: Partner Grid -->
          <div style="width: 82%;">
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);" id="eco-grid">
              {partners.map((p) => (
                <div class="eco-card" data-categories={p.categories.join(',')} style="background: var(--color-bg-dark); padding: 2rem; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; transition: background 0.2s; border: 1px solid rgba(255,255,255,0.05);">
                  <div style="width: 56px; height: 56px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; overflow: hidden;">
                    {p.logo ? (
                      <img src={p.logo} alt={p.name} style="width: 36px; height: 36px; object-fit: contain; border-radius: 6px;" loading="lazy" />
                    ) : (
                      <span style="font-family: 'Satoshi', sans-serif; font-size: 0.7rem; font-weight: 700; color: var(--color-text-secondary);">{p.name.slice(0, 2).toUpperCase()}</span>
                    )}
                  </div>
                  <div style="font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 700; color: white;">{p.name}</div>
                  <div style="font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500; color: var(--color-text-secondary); line-height: 1.4;">{p.description}</div>
                  <div style="display: flex; gap: 6px; flex-wrap: wrap; justify-content: center;">
                    {p.categories.map((cat) => (
                      <span style="font-size: 0.7rem; padding: 3px 10px; border-radius: 50px; border: 1px solid rgba(255,255,255,0.1); color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-weight: 500;">{cat}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Shape the Future of Decentralized AI Services</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Come build innovative Blueprints with us! Join Tangle's Builder Program and be a part of shaping the future of decentralized services!</div>
        <div class="wf-cta-button-row">
          <a href="https://form.typeform.com/to/IE4hT9jW" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Building</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const filters = document.querySelectorAll('#eco-filters button');
      const cards = document.querySelectorAll('.eco-card');

      filters.forEach(btn => {
        btn.addEventListener('click', () => {
          const cat = btn.dataset.category;

          filters.forEach(b => {
            b.style.background = 'transparent';
            b.style.color = 'var(--color-text-secondary)';
          });
          btn.style.background = 'rgba(97,114,243,0.1)';
          btn.style.color = '#6172f3';

          cards.forEach(card => {
            if (cat === 'All') {
              card.style.display = '';
            } else {
              const cats = card.dataset.categories.split(',');
              card.style.display = cats.includes(cat) ? '' : 'none';
            }
          });
        });
      });
    });
  </script>

</BaseLayout>

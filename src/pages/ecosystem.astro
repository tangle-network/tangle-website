  { name: 'Den', description: 'Multisig treasury management', categories: ['DeFi', 'Tool'], logo: '/images/webflow/den.png' },
  { name: 'Edgeware', description: 'A DAO-first smart contract platform', categories: ['Development'], logo: '/images/webflow/edgeware.png' },

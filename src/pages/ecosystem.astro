  { name: 'Talisman', description: 'Multi-chain wallet for Polkadot and Ethereum', categories: ['Wallet', 'Tool'], logo: '/images/webflow/talisman.png' },
  { name: 'Tanssi', description: 'Appchain infrastructure protocol', categories: ['Development'], logo: '/images/webflow/tanssi.jpg' },
  { name: 'The Graph', description: 'Indexing protocol for blockchain data', categories: ['Asset', 'Tool'], logo: '/images/webflow/66d13c81e13a7d03db13b49a_The%20Graph%20-%20Logomark%20-%20Dark.png' },

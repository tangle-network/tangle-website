  { name: 'Blockscout', description: 'Open-source blockchain explorer for EVM', badge: 'Explorer', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/blockscout.png' },
  { name: 'Boltzmann', description: 'Unleash the power of decentralized AI', badge: 'AI', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/boltzmann.png' },
  { name: 'Byzantine', description: 'Trustless & efficient restaking layer', badge: 'Restaking', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/byzantine.webp' },

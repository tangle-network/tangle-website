  { name: 'Livepeer', description: 'Decentralized video streaming infrastructure', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/livepeer.png' },
  { name: 'Merkly', description: 'Simplified blockchain bridging and refueling', badge: 'Bridge', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/merkly.webp' },
  { name: 'MetaMask', description: 'The ultimate crypto wallet for web3 & DeFi', badge: 'Wallet', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/metamask.png' },
  { name: 'Moonbeam', description: 'Cross-chain connected smart contract platform', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/moonbeam.svg' },
  { name: 'Nodes.Guru', description: 'Leading crypto staking platform', badge: 'Validator', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/nodesguru.png' },
  { name: 'Obol', description: 'Distributed validator technology for Ethereum', badge: 'DVT', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/obol.png' },
  { name: 'Opensquare', description: 'Empower Web3 collaboration with blockchain', badge: 'Explorer', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/opensquare.jpeg' },
  { name: 'Phala', description: 'Verifiable Computation for Web3', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/phala.png' },
  { name: 'Pnyx Ventures', description: 'Investing in early stage blockchain projects', badge: 'Investor', badgeColor: 'orange', tab: 'Investor', logo: '/images/ecosystem/pnyx-ventures.png' },
  { name: 'Polkachu', description: 'Trusted validators on PoS blockchains', badge: 'Validator', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/polkachu.png' },
  { name: 'Polkadot', description: 'Interoperable blockchain & parachains', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/polkadot.png' },

  { name: 'Security Research Labs', description: 'Research firm focused on cybersecurity', badge: 'Security', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/security-research-labs.jpeg' },
  { name: 'SubWallet', description: 'Highly secure and comprehensive Web3 wallet', badge: 'Wallet', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/subwallet.png' },
  { name: 'Superbridge', description: 'Efficient Cross-Chain Bridging', badge: 'Bridge', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/superbridge.png' },
  { name: 'Sygma', description: 'Interoperability layer for cross-chain apps', badge: 'Bridge', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/sygma.png' },
  { name: 'Talisman', description: 'Multi-chain wallet for Ethereum & Polkadot', badge: 'Wallet', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/talisman.png' },
  { name: 'Tanssi', description: 'Launch your blockchain in minutes, not months', badge: 'Blueprint', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/tanssi.jpg' },
  { name: 'The Graph', description: 'Indexing protocol for blockchain data', badge: 'Asset', badgeColor: 'green', tab: 'DeFi', logo: '/images/ecosystem/the-graph.png' },
  { name: 'The League of Entropy', description: 'Verifiable, decentralized randomness beacon', badge: 'Security', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/the-league-of-entropy.png' },
  { name: 'TLS Notary', description: 'Privacy-preserving data portability', badge: 'Blueprint', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/tls-notary.png' },
  { name: 'WalletConnect', description: 'Connecting dApps to mobile wallets', badge: 'Wallet', badgeColor: 'pink', tab: 'Tool', logo: '/images/ecosystem/walletconnect.png' },
  { name: 'Webb', description: 'Privacy that brings blockchain together', badge: 'Development', badgeColor: 'indigo', tab: 'Development', logo: '/images/ecosystem/webb.png' },
  { name: 'Youbi Capital', description: 'Investing in Blockchain technologies', badge: 'Investor', badgeColor: 'orange', tab: 'Investor', logo: '/images/ecosystem/youbi-capital.jpg' },
  { name: 'ZeePrime Capital', description: 'Totally supercool and chilled VC', badge: 'Investor', badgeColor: 'orange', tab: 'Investor', logo: '/images/ecosystem/zeeprime-capital.png' },
];

const filterTabs = ['All', 'DeFi', 'Development', 'Tool', 'Investor'];
const featuredLogos = partners.filter(p => p.logo).slice(0, 10);
---

<BaseLayout title="Ecosystem" description="Explore the Tangle Network ecosystem of partners, investors, and integrations.">

  <!-- Hero -->
  <div class="eco-hero">
    <div class="eco-hero-inner">
      <div class="eco-hero-left">
        <h1 class="eco-hero-title">Tangle Network Ecosystem</h1>
      </div>
      <div class="eco-hero-right">
        <div class="eco-hero-logos">
          {featuredLogos.map((p) => (
            <div class="eco-hero-logo-circle">
              <img src={p.logo} alt={p.name} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Section wrapper with tabs + grid -->
  <div class="eco-section">
    <div class="eco-section-inner">
      <div class="eco-content">
        <!-- Sidebar tabs -->
        <div class="eco-tabs" id="eco-tabs">
          {filterTabs.map((tab, i) => (
            <a
              class={`eco-tab ${i === 0 ? 'eco-tab--active' : ''}`}
              data-tab={tab}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M3.17157 3.17157C3.92172 2.42143 4.93913 2 6 2C7.06087 2 8.07828 2.42143 8.82843 3.17157C9.57857 3.92172 10 4.93913 10 6V8H14V6C14 4.93913 14.4214 3.92172 15.1716 3.17157C15.9217 2.42143 16.9391 2 18 2C19.0609 2 20.0783 2.42143 20.8284 3.17157C21.5786 3.92172 22 4.93913 22 6C22 7.06087 21.5786 8.07828 20.8284 8.82843C20.0783 9.57857 19.0609 10 18 10H16V14H18C19.0609 14 20.0783 14.4214 20.8284 15.1716C21.5786 15.9217 22 16.9391 22 18C22 19.0609 21.5786 20.0783 20.8284 20.8284C20.0783 21.5786 19.0609 22 18 22C16.9391 22 15.9217 21.5786 15.1716 20.8284C14.4214 20.0783 14 19.0609 14 18V16H10V18C10 19.0609 9.57857 20.0783 8.82843 20.8284C8.07828 21.5786 7.06087 22 6 22C4.93913 22 3.92172 21.5786 3.17157 20.8284C2.42143 20.0783 2 19.0609 2 18C2 16.9391 2.42143 15.9217 3.17157 15.1716C3.92172 14.4214 4.93913 14 6 14H8V10H6C4.93913 10 3.92172 9.57857 3.17157 8.82843C2.42143 8.07828 2 7.06087 2 6C2 4.93913 2.42143 3.92172 3.17157 3.17157Z" fill="currentColor" fill-opacity="0.94"/>
              </svg>
              {tab}
            </a>
          ))}
        </div>

        <!-- Partner Grid -->
        <div class="eco-grid" id="eco-grid">
          {partners.map((p) => (
            <div class="eco-card" data-tab={p.tab}>
              <div class="eco-card-logo-wrap">
                <img src={p.logo} alt={p.name} loading="lazy" />
              </div>
              <div class="eco-card-info">
                <div class="eco-card-name">{p.name}</div>
                <div class="eco-card-desc">{p.description}</div>
              </div>
              <div class={`eco-badge eco-badge--${p.badgeColor}`}>
                <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
                {p.badge}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Hero */
    .eco-hero {
      background-image: url('/images/webflow/q-cb7440aa.png.png'), linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), linear-gradient(90deg, #1e2035, #5a64e7);
      background-size: cover;
      background-position: center;
      border-radius: 0 0 16px 16px;
      margin: 0 1.5%;
      overflow: hidden;
      padding: 180px 72px 90px;
    }

    .eco-hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      max-width: 80rem;
      margin: 0 auto;
      align-items: center;
    }

    .eco-hero-left {
      display: flex;
      align-items: flex-end;
    }

    .eco-hero-title {
      font-family: var(--font-sans);
      font-size: 54px;
      font-weight: 700;
      color: #fff;
      line-height: 66px;
      margin: 0;
      letter-spacing: 0;
    }

    .eco-hero-right {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .eco-hero-logos {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      justify-items: center;
    }

    .eco-hero-logo-circle {
      width: 81px;
      height: 81px;
      border-radius: 100px;
      background: rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .eco-hero-logo-circle img {
      width: 48px;
      height: 48px;
      object-fit: contain;
      border-radius: 100px;
    }

    /* Section wrapper */
    .eco-section {
      padding: 0 1.5%;
    }

    .eco-section-inner {
      border: 1px solid rgb(33, 26, 65);
      border-radius: 16px;
      margin-top: 32px;
      padding: 72px 42px 144px;
      overflow: hidden;
    }

    .eco-content {
      display: flex;
      gap: 0;
      max-width: 80rem;
      margin: 0 auto;
    }

    /* Sidebar tabs */
    .eco-tabs {
      display: flex;
      flex-direction: column;
      gap: 0;
      width: 213px;
      flex-shrink: 0;
    }

    .eco-tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 42px 14px 14px;
      margin-bottom: 16px;
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 400;
      color: #fff;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s;
      border: none;
      background: none;
      white-space: nowrap;
    }

    .eco-tab svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      opacity: 0.94;
    }

    .eco-tab--active {
      color: #6366F1;
    }

    .eco-tab:hover {
      color: #6366F1;
    }

    /* Partner grid - 3 columns like the live site (w-col-4 = 4/12 = 33.3%) */
    .eco-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      flex: 1;
      min-width: 0;
    }

    /* Cards */
    .eco-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 16px 32px;
      gap: 24px;
      border: 1px solid #6366F1;
      background: transparent;
      transition: background 0.2s;
    }

    .eco-card:hover {
      background: rgba(97, 114, 243, 0.05);
    }

    /* Logo wrapper */
    .eco-card-logo-wrap {
      width: 80px;
      height: 80px;
      border-radius: 100%;
      background: rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }

    .eco-card-logo-wrap img {
      width: 48px;
      height: 48px;
      object-fit: contain;
      border-radius: 100px;
    }

    /* Card info */
    .eco-card-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .eco-card-name {
      font-family: var(--font-sans);
      font-size: 20px;
      font-weight: 600;
      color: #fff;
      line-height: 1.5;
    }

    .eco-card-desc {
      font-family: var(--font-sans);
      font-size: 14.4px;
      font-weight: 300;
      color: #f0f0f8;
      line-height: 1.5;
      padding: 0 20px;
    }

    /* Badges */
    .eco-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 2px 10px;
      border-radius: 160px;
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
    }

    .eco-badge svg {
      width: 8px;
      height: 8px;
      flex-shrink: 0;
    }

    .eco-badge--green {
      background: rgba(236, 253, 243, 0.1);
      color: #12b76a;
    }

    .eco-badge--indigo {
      background: rgba(238, 244, 255, 0.1);
      color: #3f78e0;
    }

    .eco-badge--pink {
      background: rgba(253, 242, 250, 0.1);
      color: #ee46bc;
    }

    .eco-badge--orange {
      background: rgba(254, 246, 238, 0.1);
      color: #f79009;
    }

    /* Responsive */
    @media screen and (max-width: 991px) {
      .eco-hero {
        padding: 120px 40px 60px;
      }

      .eco-hero-inner {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .eco-hero-title {
        font-size: 40px;
        line-height: 48px;
      }

      .eco-content {
        flex-direction: column;
        gap: 32px;
      }

      .eco-tabs {
        flex-direction: row;
        width: 100%;
        flex-wrap: wrap;
        gap: 0;
      }

      .eco-tab {
        padding: 10px 16px;
        margin-bottom: 8px;
      }

      .eco-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .eco-section-inner {
        padding: 40px 20px 80px;
      }
    }

    @media screen and (max-width: 479px) {
      .eco-hero {
        padding: 100px 20px 40px;
      }

      .eco-hero-title {
        font-size: 32px;
        line-height: 40px;
      }

      .eco-hero-logos {
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
      }

      .eco-hero-logo-circle {
        width: 48px;
        height: 48px;
      }

      .eco-hero-logo-circle img {
        width: 28px;
        height: 28px;
      }

      .eco-grid {
        grid-template-columns: 1fr;
      }

      .eco-section-inner {
        padding: 24px 12px 60px;
      }

      .eco-tab {
        font-size: 13px;
        padding: 8px 12px;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const tabs = document.querySelectorAll('.eco-tab');
      const cards = document.querySelectorAll('.eco-card');

      tabs.forEach(btn => {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          const tab = this.dataset.tab;

          tabs.forEach(b => b.classList.remove('eco-tab--active'));
          this.classList.add('eco-tab--active');

          cards.forEach(card => {
            if (tab === 'All') {
              card.style.display = '';
            } else {
              card.style.display = card.dataset.tab === tab ? '' : 'none';
            }
          });
        });
      });
    });
  </script>

</BaseLayout>

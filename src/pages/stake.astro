<style>
  /* Detail label (uppercase small heading) */
  .stake-detail-label {
    color: #6b7094;
    font-family: 'Satoshi Variable', 'Satoshi', Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.12px;
  }

  /* ===========================
     TABS SECTION
     =========================== */
  .stake-tabs-outer {
    background: #37344d;
    border-radius: 40px;
    padding: 20px;
  }

  .stake-tabs-inner {
    padding: 64px;
  }

  .stake-tabs-wrapper {
    display: flex;
    gap: 0;
    margin: 0 auto;
    align-items: stretch;
  }

  .stake-tabs-menu {
    display: flex;
    flex-direction: column;
    width: 333px;
    flex-shrink: 0;
  }

  .stake-tab-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px 24px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, border-radius 0.3s;
    border-radius: 0;
    background: transparent;
  }

  .stake-tab-link:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .stake-tab-link--active {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
  }

  .stake-tab-title {
    color: white;
    font-family: 'Satoshi Variable', 'Satoshi', Arial, sans-serif;
    font-size: 22.4px;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }

  .stake-tab-desc {
    color: #aab0bc;
    font-family: 'Satoshi Variable', 'Satoshi', Arial, sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }

  .stake-tabs-content {
    width: 556px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .stake-tab-image {
    width: 100%;
    border-radius: 12px;
    display: block;
  }

  /* ===========================
     ASSETS GRID (Season 1)
     =========================== */
  .stake-assets-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    padding: 0;
  }

  .stake-asset-item {
    display: grid;
    align-items: center;
    justify-items: center;
    padding: 16px;
    border: 1px solid #40366f;
    border-radius: 1px;
    height: 184px;
  }

  .stake-asset-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 120px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }

  .stake-asset-icon-link:hover {
    opacity: 0.8;
  }

  .stake-asset-svg {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stake-asset-label {
    color: white;
    font-family: 'Satoshi Variable', 'Satoshi', Arial, sans-serif;
    font-size: 20px;
    font-weight: 600;
    text-align: center;
    margin: 0;
  }

  /* ===========================
     RESPONSIVE
     =========================== */
  @media screen and (max-width: 991px) {
    .stake-tabs-wrapper {
      flex-direction: column;
    }
    .stake-tabs-menu {
      width: 100%;
    }
    .stake-tabs-content {
      width: 100%;
      flex-shrink: 1;
      padding-top: 2rem;
    }
    .stake-tabs-inner {
      padding: 32px;
    }
    .stake-tabs-outer {
      border-radius: 24px;
    }
  }

  @media screen and (max-width: 767px) {
    .stake-assets-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .stake-asset-item {
      height: 140px;
    }
    .stake-tabs-inner {
      padding: 20px;
    }
  }
</style>

<script>
  // Tab interaction
  document.addEventListener('DOMContentLoaded', () => {
    const tabLinks = document.querySelectorAll('.stake-tab-link');
    tabLinks.forEach(link => {
      link.addEventListener('click', () => {
        tabLinks.forEach(l => {
          l.classList.remove('stake-tab-link--active');
          l.setAttribute('aria-selected', 'false');
        });
        link.classList.add('stake-tab-link--active');
        link.setAttribute('aria-selected', 'true');

        // Switch images
        const tabId = link.getAttribute('data-tab');
        document.querySelectorAll('.stake-tab-image').forEach(img => {
          (img as HTMLElement).style.display = 'none';
        });
        const activeImg = document.querySelector(`.stake-tab-image[data-tab-image="${tabId}"]`);
        if (activeImg) (activeImg as HTMLElement).style.display = 'block';
      });
    });

  });
</script>

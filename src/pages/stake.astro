---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';

const tabs = [
  { id: 'tab1', title: 'Deposit Assets', description: 'Stake any assets from any ecosystem; earn XP and rewards for your community.' },
  { id: 'tab2', title: 'Delegate Operators', description: 'Delegate and earn a share of operators revenue.' },
  { id: 'tab3', title: 'Power Decentralized Services', description: 'Power the decentralized cloud and open-source innovation.' },
  { id: 'tab4', title: 'Secure Quality of Service', description: 'Slashing underperformance and rewarding reliable, high-performing operators.' },
];

const faqs = [
  {
    question: 'How does Restaking on Tangle contribute to decentralized infrastructure?',
    answer: 'Tangle is building a decentralized cloud marketplace where staking secures the infrastructure. By <a href="https://ai.tangle.tools/restake/deposit">depositing</a> and <a href="https://ai.tangle.tools/restake/delegate" target="_blank">delegating</a> assets now, you earn TNT incentives immediately and position yourself for future service revenue as Blueprint services launch. Tangle supports various assets, with TNT holders receiving priority in the reward system.',
  },
  {
    question: 'What is Season 1 launch campaign? How do rewards work?',
    answer: 'Season 1 rewards participants with both immediate TNT rewards from vaults and points for future airdrops. Activities rewarded include staking assets, operating nodes, building Blueprints, creating service instances, and producing educational content. Track your progress on the dApp and our <a href="https://leaderboard.tangle.tools" target="_blank">leaderboard</a>.',
  },
  {
    question: 'How to get started with staking on Tangle?',
    answer: 'Visit <a href="https://ai.tangle.tools" target="_blank">ai.tangle.tools</a> and connect your wallet. Deposit assets in the "Staking" tab, then delegate to operators by selecting them and choosing which Blueprints to support. Watch our <a href="https://www.youtube.com/watch?v=WBziMPEhvHo&list=PLfn6GQGNrM_mSyyROBgftfKJKIJc1Dg6k" target="_blank">tutorial videos</a> for visual guidance on the process.',
  },
  {
    question: 'How to try Tangle Restaking on Testnet?',
    answer: 'Test restaking on Tangle\'s Testnet by getting tokens from the <a href="https://tangle-faucet.fly.dev/" target="_blank">Tangle Faucet</a>. Try all functions: depositing and delegating. Testnet activities earn experience points for future airdrops. Join our <a href="https://discord.gg/JBCKxYrR" target="_blank">Discord</a> for support or to report issues.',
  },
];
---

<BaseLayout title="Stake" description="Deposit &amp; delegate assets to secure decentralized AI services.">

  <!-- Hero -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Coming Soon</div>
            </div>
          </div>
          <h1 class="wf-h1">Tangle Staking</h1>
          <div class="wf-body-01">Join Season 1 of Tangle's Staking Campaign. Deposit & delegate assets to secure decentralized services.</div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools/" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Get Started</a>
            <a href="https://docs.tangle.tools/restake/restake-introduction" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">View Docs</a>
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/abstract-objects-poster.jpg" class="wf-hero-video-poster">
          <source src="/videos/abstract-objects.webm" type="video/webm" />
          <source src="/videos/abstract-objects.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- From Staking to Real-World Impact -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="stake-detail-label">tangle restaking</div>
          <div class="wf-h3" style="width: 100%;">From Staking to Real-World Impact</div>
          <div class="wf-body-02 align-center">Stake on Tangle to secure operators running decentralized services.</div>
        </div>

        <div class="stake-tabs-outer">
          <div class="stake-tabs-inner">
            <div class="stake-tabs-wrapper">
              <div class="stake-tabs-menu" role="tablist">
                {tabs.map((tab, i) => (
                  <a
                    role="tab"
                    aria-selected={i === 0 ? 'true' : 'false'}
                    class={`stake-tab-link${i === 0 ? ' stake-tab-link--active' : ''}`}
                    data-tab={tab.id}
                  >
                    <h3 class="stake-tab-title">{tab.title}</h3>
                    <p class="stake-tab-desc">{tab.description}</p>
                  </a>
                ))}
              </div>
              <div class="stake-tabs-content">
                <img src="/images/webflow/swipe-1.png" alt="Deposit Assets" class="stake-tab-image" data-tab-image="tab1" loading="lazy" />
                <img src="/images/webflow/swipe-2.png" alt="Delegate Operators" class="stake-tab-image" data-tab-image="tab2" style="display:none;" loading="lazy" />
                <img src="/images/webflow/swipe-3.png" alt="Power Decentralized Services" class="stake-tab-image" data-tab-image="tab3" style="display:none;" loading="lazy" />
                <img src="/images/webflow/swipe-4.png" alt="Secure Quality of Service" class="stake-tab-image" data-tab-image="tab4" style="display:none;" loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Season 1: Staking Launch -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="stake-detail-label">Experience Points</div>
          <div class="wf-h3" style="width: 100%;">Season 1: Staking Launch</div>
          <div class="wf-body-02 align-center" style="max-width: 800px;">Season 1 marks the launch of Tangle Restaking. Users can deposit assets, delegate to operators, secure services, and earn rewards. Staking on Tangle provides critical security to decentralized services.<br /><br />There are many ways to participate in the launch campaign to earn XP, alongside incentivized stake vaults to earn direct TNT&nbsp;incentives through deposit.</div>
        </div>
        <div class="wf-button-row" style="justify-content: center; padding-bottom: 2rem;">
          <a href="https://ai.tangle.tools/" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Deposit</a>
          <a href="https://docs.tangle.tools/network/points-mechanics" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Points Mechanisms</a>
        </div>

        <div class="stake-assets-grid">
          <div class="stake-asset-item">
            <a href="#" class="stake-asset-icon-link">

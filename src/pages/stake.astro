---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  { title: 'Deposit Assets', description: 'Stake any assets from any ecosystem; earn XP and rewards', image: '/images/webflow/deposit assets.png' },
  { title: 'Delegate Operators', description: 'Delegate and earn a share of operators revenue', image: '/images/webflow/delegate operators.png' },
  { title: 'Power Decentralized Services', description: 'Power the decentralized cloud', image: '/images/webflow/operate services.png' },
  { title: 'Secure Quality of Service', description: 'Slash underperformance, reward reliability', image: '/images/webflow/secure blueprints.png' },
];

const faqs = [
  { question: 'How does Restaking contribute to decentralized infrastructure?', answer: 'Tangle is building a decentralized cloud marketplace where staking secures the infrastructure. Restaked assets provide economic security for Blueprint instances, ensuring operators perform their duties reliably.' },
  { question: 'What is Season 1 launch campaign?', answer: 'Season 1 rewards participants with immediate TNT rewards and points for future airdrops. It marks the launch of Tangle Restaking where users can deposit, delegate, secure services, and earn rewards.' },
  { question: 'How to get started?', answer: 'Visit ai.tangle.tools, connect your wallet, deposit assets, and delegate to operators. You can start earning rewards immediately.' },
  { question: 'Is there a testnet?', answer: 'Yes! Test on Tangle\'s Testnet using the Tangle Faucet at faucet.tangle.tools to get testnet tokens before committing mainnet assets.' },
];

const supportedAssets = [
  { name: 'cbETH', icon: '/images/webflow/cbETH-2yYhjWvl.svg' },
  { name: 'rETH', icon: '/images/webflow/rETH-CAmIBB-2.svg' },
  { name: 'wstETH', icon: '/images/webflow/wstETH-BeNty4Eq.svg' },
  { name: 'WBTC', icon: '/images/webflow/WBTC-Bd9t_EX0.svg' },
  { name: 'reALT', icon: '/images/webflow/reALT.svg' },
];
---

<BaseLayout title="Stake" description="Join Season 1 of Tangle's Staking Campaign. Deposit & delegate assets to secure decentralized services.">

  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Coming Soon</div>
            </div>
          </div>
          <h1 class="wf-h1">Tangle Staking</h1>
          <div class="wf-body-01">Join Season 1 of Tangle's Staking Campaign. Deposit & delegate assets to secure decentralized services.</div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools/" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Get Started</a>
            <a href="https://docs.tangle.tools/restake/restake-introduction" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">View Docs</a>
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/abstract-objects-poster.jpg" class="wf-hero-video-poster">
          <source src="/videos/abstract-objects.webm" type="video/webm" />
          <source src="/videos/abstract-objects.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">From Staking to <span class="wf-gradient-text">Real-World Impact</span></div>
          <div class="wf-body-02 align-center">Stake on Tangle to secure operators running decentralized services.</div>
        </div>

        <div style="display: flex; gap: 3rem; max-width: 1100px; margin: 0 auto; align-items: center;">
          <div style="width: 40%; display: flex; flex-direction: column; gap: 2rem;">
            {steps.map((step, i) => (
              <div style="display: flex; gap: 1rem; align-items: flex-start;">
                <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(97,114,243,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #6172f3; font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 700;">{i + 1}</div>
                <div>
                  <div class="wf-h4" style="font-size: 1.1rem; margin-bottom: 4px;">{step.title}</div>
                  <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; line-height: 1.5;">{step.description}</div>
                </div>
              </div>
            ))}
          </div>
          <div style="width: 60%;">
            <img src="/images/webflow/Restake UI sample.png" alt="Tangle Restaking UI" style="width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.08);" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Season 1</div>
            </div>
          </div>
          <div class="wf-h3">Season 1 Launch</div>
          <div class="wf-body-02 align-center">Season 1 marks the launch of Tangle Restaking. Users can deposit, delegate, secure services, and earn rewards.</div>
        </div>
        <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; padding: 2rem 0;">
          <a href="https://ai.tangle.tools/" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Deposit</a>
          <a href="https://docs.tangle.tools/network/points-mechanics" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Points Mechanisms</a>
        </div>
        <div style="text-align: center; padding-top: 2rem;">
          <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">Supported Assets</div>
          <div style="display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; align-items: center;">
            {supportedAssets.map((asset) => (
              <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; overflow: hidden;">
                  <img src={asset.icon} alt={asset.name} style="width: 32px; height: 32px; object-fit: contain;" loading="lazy" />
                </div>
                <span style="font-family: 'Satoshi', sans-serif; font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary);">{asset.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 800px;">
        <div class="wf-section-head">
          <div class="wf-h3">Frequently Asked Questions</div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {faqs.map((faq, i) => (
            <details open={i === 0} style="border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; overflow: hidden;">
              <summary style="display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 1.25rem 1.5rem; font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 600; color: white; list-style: none;">
                {faq.question}
                <svg style="width: 20px; height: 20px; flex-shrink: 0; margin-left: 16px; color: #6b7094; transition: transform 0.2s;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div style="padding: 0 1.5rem 1.25rem; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; line-height: 1.6;">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Shape the Future of Decentralized AI Services</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Come build innovative Blueprints with us! Join Tangle's Builder Program and be a part of shaping the future of decentralized services!</div>
        <div class="wf-cta-button-row">
          <a href="https://form.typeform.com/to/IE4hT9jW" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Building</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

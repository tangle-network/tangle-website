---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';
import ExamplePanel from '../../components/ui/ExamplePanel.astro';
import Hero from '../../components/ui/Hero.astro';
import StoryScroller from '../../components/ui/StoryScroller.astro';
import Section from '../../components/ui/Section.astro';
import BentoCell from '../../components/ui/BentoCell.astro';
import CtaBlock from '../../components/ui/CtaBlock.astro';

const bpLifecycleStages = [
  { id: 'spec',  num: '01', title: 'Spec.',  body: 'Describe the agent in plain English. The workbench scaffolds a Rust crate, jobs, manifest, and tests. <strong>One prompt, one repo.</strong>' },
  { id: 'build', num: '02', title: 'Build.', body: 'CodeMirror + xterm.js + live preview, all in one sandbox. Interrupt mid-edit, type, resume. <strong>The agent never loses context.</strong>' },
  { id: 'eval',  num: '03', title: 'Eval.',  body: 'Rubrics, judges, ground-truth. Every variant scored before merge. <strong>No silent regressions.</strong>' },
  { id: 'ship',  num: '04', title: 'Ship.',  body: 'Merge a PR. Publish a versioned API. Drop a buy-link. <strong>Operators run it; you collect.</strong>' },
];

const bpHeroPrompt = `<span class="cw-c">╭ blueprint-agent · ai.tangle.tools ──────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">FROST threshold-signing service. t-of-n keygen,</span>
     <span class="cw-v">x402 paywall on /v1/sign, deploy to Tangle testnet.</span>

<span class="cw-sh">▸ plan</span>     <span class="cw-c">frost-secp256k1 keygen + sign jobs</span>
          <span class="cw-c">x402 facilitator on POST /v1/sign</span>
          <span class="cw-c">tangle-operator bonding + slashing hooks</span>

<span class="cw-sh">▸ scaffold</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-ok">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-ok">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-ok">✓</span>

<span class="cw-sh">▸ verify</span>
          <span class="cw-v">cargo check</span>  <span class="cw-c">0 errors · 2.1s</span>
          <span class="cw-v">cargo test</span>   <span class="cw-c">7 passed · 0 failed</span>

<span class="cw-sh">▸ ship</span>
          <span class="cw-ok">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
          <span class="cw-ok">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">tangle testnet · 4 operators bonded</span>
          <span class="cw-ok">✓</span> <span class="cw-v">earn</span>     <span class="cw-k">/v1/sign live · $0.02 per signature</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const bpChatCode = `<span class="cw-c">╭ Blueprint Agent · ai.tangle.tools ─────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">Ship me a FROST threshold-signing Blueprint with</span>
     <span class="cw-v">an x402-gated REST endpoint.</span>

<span class="cw-sh">▸ agent</span>  <span class="cw-c">planning…</span>
        <span class="cw-c">→ frost-secp256k1 keygen + sign jobs</span>
        <span class="cw-c">→ x402 facilitator on /v1/sign</span>
        <span class="cw-c">→ tangle-operator bonding + slashing hooks</span>

        <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/main.rs</span>         <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-ok">✓</span>

        <span class="cw-v">cargo check</span> <span class="cw-c">· 0 errors · 2.1s</span>
        <span class="cw-v">generated 187 lines across 4 files</span>

        <span class="cw-ok">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
        <span class="cw-ok">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">one-click to Tangle testnet</span>

<span class="cw-c">╰────────────────────────────────────────────────────────╯</span>`;

const bpGeneratedCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::{
  <span class="cw-v">extract</span>::<span class="cw-f">Context</span>,
  <span class="cw-v">macros</span>::<span class="cw-f">debug_job</span>,
  <span class="cw-v">tangle</span>::<span class="cw-f">TangleLayer</span>,
  <span class="cw-f">Router</span>, <span class="cw-f">Result</span>,
};
<span class="cw-k">use</span> <span class="cw-v">frost_secp256k1</span>::<span class="cw-f">SigningPackage</span>;
<span class="cw-k">use</span> <span class="cw-k">crate</span>::<span class="cw-v">context</span>::<span class="cw-f">FrostCtx</span>;

<span class="cw-k">pub const</span> <span class="cw-v">SIGN_JOB_ID</span>: <span class="cw-f">u32</span> = 0;

<span class="cw-c">/// t-of-n FROST signing — scaffolded by Blueprint Agent.</span>
<span class="cw-c">/// Audit, tune, ship. You own the repo.</span>
<span class="cw-p">#[debug_job]</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">sign</span>(
  <span class="cw-f">Context</span>(<span class="cw-v">ctx</span>): <span class="cw-f">Context</span>&lt;<span class="cw-f">FrostCtx</span>&gt;,
  <span class="cw-v">message</span>: <span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;,
  <span class="cw-v">threshold</span>: <span class="cw-f">u16</span>,
) -&gt; <span class="cw-f">Result</span>&lt;<span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;&gt; {
  <span class="cw-k">let</span> <span class="cw-v">round1</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round1</span>(<span class="cw-v">threshold</span>).<span class="cw-k">await</span>?;
  <span class="cw-k">let</span> <span class="cw-v">pkg</span>    = <span class="cw-f">SigningPackage</span>::<span class="cw-f">new</span>(<span class="cw-v">round1</span>.commitments, &amp;<span class="cw-v">message</span>);
  <span class="cw-k">let</span> <span class="cw-v">shares</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round2</span>(&amp;<span class="cw-v">pkg</span>).<span class="cw-k">await</span>?;
  <span class="cw-v">ctx</span>.<span class="cw-f">aggregate</span>(&amp;<span class="cw-v">pkg</span>, &amp;<span class="cw-v">shares</span>)
}

<span class="cw-c">// wiring — BlueprintRunner composes producer/consumer/router</span>
<span class="cw-f">Router</span>::<span class="cw-f">new</span>()
  .<span class="cw-f">route</span>(<span class="cw-v">SIGN_JOB_ID</span>, <span class="cw-v">sign</span>.<span class="cw-f">layer</span>(<span class="cw-f">TangleLayer</span>))</span>`;

// ─── Build for any framework — 4 deploy-target examples ───────────────────
// Each "group" is a different framework/ecosystem; each group has 2 tabs:
// the natural-language prompt + the file the agent ships.

const dspyPrompt = `<span class="cw-c">╭ blueprint-agent ────────────────────────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">A DSPy program that classifies support tickets into</span>
     <span class="cw-v">{billing, technical, sales} with a few-shot teleprompter.</span>

<span class="cw-sh">▸ scaffold</span>
       <span class="cw-v">writing</span> <span class="cw-f">programs/triage.py</span>     <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">tests/test_triage.py</span>   <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">requirements.txt</span>       <span class="cw-ok">✓</span>

<span class="cw-sh">▸ verify</span>
       <span class="cw-v">pytest</span>           <span class="cw-c">11 passed · 0 failed</span>
       <span class="cw-v">teleprompt</span>       <span class="cw-c">acc 0.84 → 0.92 after 4 rounds</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const dspyCode = `<span class="cw-k">import</span> <span class="cw-v">dspy</span>
<span class="cw-k">from</span> <span class="cw-v">dspy.teleprompt</span> <span class="cw-k">import</span> <span class="cw-f">BootstrapFewShot</span>

dspy.<span class="cw-f">configure</span>(lm=dspy.<span class="cw-f">LM</span>(<span class="cw-s">"openai/gpt-4o-mini"</span>))

<span class="cw-k">class</span> <span class="cw-f">TriageTicket</span>(dspy.<span class="cw-f">Signature</span>):
    <span class="cw-s">"""Classify a support ticket into billing, technical, or sales."""</span>
    ticket  = dspy.<span class="cw-f">InputField</span>(desc=<span class="cw-s">"the user's message"</span>)
    label   = dspy.<span class="cw-f">OutputField</span>(desc=<span class="cw-s">"billing | technical | sales"</span>)

triage = dspy.<span class="cw-f">ChainOfThought</span>(<span class="cw-f">TriageTicket</span>)

<span class="cw-c"># Compile with a few-shot teleprompter — auto-improves accuracy.</span>
trainset = <span class="cw-f">load_examples</span>(<span class="cw-s">"data/triage.jsonl"</span>)
optimized = <span class="cw-f">BootstrapFewShot</span>(metric=<span class="cw-f">f1_score</span>).<span class="cw-f">compile</span>(triage, trainset=trainset)

<span class="cw-c"># Use it.</span>
<span class="cw-k">print</span>(optimized(ticket=<span class="cw-s">"my card was double charged"</span>).label)
<span class="cw-c"># → billing</span>`;

const mastraPrompt = `<span class="cw-c">╭ blueprint-agent ────────────────────────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">A Mastra agent that watches my Gmail inbox, drafts</span>
     <span class="cw-v">replies for ones flagged 'follow-up', uses Sandbox</span>
     <span class="cw-v">SDK to run code blocks the user pastes in.</span>

<span class="cw-sh">▸ scaffold</span>
       <span class="cw-v">writing</span> <span class="cw-f">agents/inbox.ts</span>          <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">tools/gmail.ts</span>           <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">tools/sandbox-exec.ts</span>    <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">workflows/triage.ts</span>      <span class="cw-ok">✓</span>

<span class="cw-sh">▸ ship</span>
       <span class="cw-ok">✓</span> <span class="cw-v">mastra dev</span>     <span class="cw-c">running on :4111</span>
       <span class="cw-ok">✓</span> <span class="cw-v">10 emails</span>      <span class="cw-c">3 drafts pending review</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const mastraCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">Agent</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@mastra/core"</span>;
<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;
<span class="cw-k">import</span> <span class="cw-v">{ gmail, sandboxExec }</span> <span class="cw-k">from</span> <span class="cw-s">"./tools"</span>;

<span class="cw-k">const</span> <span class="cw-v">sandbox</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });

<span class="cw-k">export const</span> <span class="cw-v">inbox</span> = <span class="cw-k">new</span> <span class="cw-f">Agent</span>({
  name:        <span class="cw-s">"inbox-agent"</span>,
  instructions: <span class="cw-s">"Triage labelled emails. Draft replies. Run any code blocks the sender pasted in a Tangle sandbox."</span>,
  model:       { provider: <span class="cw-s">"openai"</span>, name: <span class="cw-s">"gpt-4o-mini"</span> },
  tools:       { gmail, sandboxExec: <span class="cw-f">sandboxExec</span>(sandbox) },
});

<span class="cw-c">// Tangle Router: model goes through router.tangle.tools — same key as the sandbox.</span>
<span class="cw-c">// Eval: every reply scored against your style guide before send.</span>
<span class="cw-c">// Billing: one invoice — sandbox minutes + tokens + Mastra runs.</span>`;

const vercelPrompt = `<span class="cw-c">╭ blueprint-agent ────────────────────────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">Wrap this prompt as a Vercel Edge function. Stream</span>
     <span class="cw-v">the response. Cache responses by hash for 60s.</span>

<span class="cw-sh">▸ scaffold</span>
       <span class="cw-v">writing</span> <span class="cw-f">app/api/ask/route.ts</span>     <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">vercel.json</span>              <span class="cw-ok">✓</span>

<span class="cw-sh">▸ deploy</span>
       <span class="cw-ok">✓</span> <span class="cw-v">vercel deploy</span>   <span class="cw-c">my-app.vercel.app/api/ask · 18 regions · 41ms p50</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const vercelCode = `<span class="cw-c">// app/api/ask/route.ts — generated by Blueprint Agent</span>
<span class="cw-k">import</span> <span class="cw-v">OpenAI</span> <span class="cw-k">from</span> <span class="cw-s">"openai"</span>;
<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">OpenAIStream</span><span class="cw-v">, </span><span class="cw-f">StreamingTextResponse</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"ai"</span>;

<span class="cw-k">export const</span> <span class="cw-v">runtime</span> = <span class="cw-s">"edge"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">OpenAI</span>({
  baseURL: <span class="cw-s">"https://router.tangle.tools/v1"</span>,
  apiKey:  process.env.<span class="cw-v">TANGLE_API_KEY</span>,
});

<span class="cw-k">export async function</span> <span class="cw-f">POST</span>(req<span class="cw-k">:</span> <span class="cw-f">Request</span>) {
  <span class="cw-k">const</span> <span class="cw-v">{ messages }</span> = <span class="cw-k">await</span> req.<span class="cw-f">json</span>();
  <span class="cw-k">const</span> <span class="cw-v">res</span> = <span class="cw-k">await</span> client.chat.completions.<span class="cw-f">create</span>({
    model:    <span class="cw-s">"openai/gpt-4o-mini"</span>,
    messages, stream: <span class="cw-k">true</span>,
  });
  <span class="cw-k">return new</span> <span class="cw-f">StreamingTextResponse</span>(<span class="cw-f">OpenAIStream</span>(res));
}`;

const x402Prompt = `<span class="cw-c">╭ blueprint-agent ────────────────────────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">Add a Coinbase x402 paywall to /v1/sign — $0.02 per</span>
     <span class="cw-v">request. Settle in USDC on Base.</span>

<span class="cw-sh">▸ scaffold</span>
       <span class="cw-v">writing</span> <span class="cw-f">middleware/x402.ts</span>      <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">.env.production</span>         <span class="cw-ok">✓</span>

<span class="cw-sh">▸ verify</span>
       <span class="cw-v">curl /v1/sign</span>     <span class="cw-c">→ 402 Payment Required · X-Pay header issued</span>
       <span class="cw-v">curl + signed</span>     <span class="cw-c">→ 200 · 0.020000 USDC settled</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const x402Code = `<span class="cw-c">// middleware/x402.ts — generated by Blueprint Agent</span>
<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">x402</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@coinbase/x402"</span>;

<span class="cw-k">export const</span> <span class="cw-v">paywall</span> = <span class="cw-f">x402</span>({
  network: <span class="cw-s">"base-mainnet"</span>,
  asset:   <span class="cw-s">"USDC"</span>,
  routes:  {
    <span class="cw-s">"POST /v1/sign"</span>: { price: <span class="cw-s">"0.02"</span>, recipient: process.env.<span class="cw-v">PAYOUT_ADDRESS</span> },
  },
  facilitator: <span class="cw-s">"https://x402.coinbase.com"</span>,
});

<span class="cw-c">// 402 → client signs an EIP-3009 transferAuthorization → middleware verifies</span>
<span class="cw-c">// the signed payload, settles via the Coinbase facilitator, then calls next().</span>
<span class="cw-c">// One line of middleware, every request paid.</span>`;

const faqs = [
  { question: 'What is Blueprint Agent?', answer: 'A workbench that turns an English prompt into a Tangle Blueprint — Rust crate, jobs, manifest, tests — and deploys to operators. Editor, terminal, preview run in an isolated sandbox. You own the repo.' },
  { question: 'Which ecosystems can a Blueprint target?', answer: 'Any runtime you can describe — agent frameworks (DSPy, Mastra, LangChain, CrewAI), AI providers (OpenAI, Anthropic, Vercel AI), and 40+ blockchains (Solana, Ethereum, Arbitrum, Base, EigenLayer, Starknet, Sui, Aptos, and more). Each target ships a starter template with SDK wiring, fixtures, and passing tests.' },
  { question: 'How does multi-model work?', answer: 'Same prompt across Claude, GPT, GLM, Kimi in parallel. Diff the repos, run their tests, ship the variant that compiles. One PR from the winner.' },
  { question: 'Can I create PRs from the workbench?', answer: 'Yes. Connect a GitHub repo. The agent opens a branch, commits, and creates a PR with prompt, model, and test output in the body.' },
  { question: 'Is this a coding assistant?', answer: 'No. It is a Blueprint authoring workbench. Output is a deployable service with on-chain bonding, fee collection, and operator dispatch wired up.' },
];
---

<BaseLayout title="Blueprint Agent — prompt to deployed Blueprint" description="English in, deployed Blueprint out. Live workbench, real cargo compile, operators bonded the same session.">

  <style>
    /* Gen 3 ported: bp-bento-* and bp-section-* rules deleted — those
       surfaces now use <BentoCell> + inline section headers driven by
       --type-* tokens. The lifecycle StoryScroller visuals + partner
       marquee + responsive media query remain (still page-specific). */

    /* Lifecycle StoryScroller visuals */
    .bp-story-kv { display: flex; flex-direction: column; gap: 0; }
    .bp-story-row { display: flex; gap: 1rem; align-items: baseline; font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.55rem 0; border-bottom: 1px dashed rgba(165,170,252,0.18); }
    .bp-story-row:last-child { border-bottom: 0; }
    .bp-story-key { color: var(--brand-cool); min-width: 5.5rem; }
    .bp-story-val { color: var(--text-primary); }
    .bp-story-ok { color: #34D399; }
    .bp-story-pending { color: #FFB800; }

    .bp-story-stack { display: flex; flex-direction: column; gap: 0.625rem; }
    .bp-story-box { display: flex; justify-content: space-between; align-items: center; padding: 0.875rem 1.125rem; background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.18); border-radius: 8px; font-family: var(--font-mono); font-size: 0.875rem; color: var(--text-primary); }
    .bp-story-box .bp-story-ok, .bp-story-box .bp-story-pending { font-size: 0.75rem; }

    .bp-story-evals { display: flex; flex-direction: column; gap: 0.85rem; }
    .bp-story-eval { display: grid; grid-template-columns: 11rem 1fr 2.5rem; gap: 0.875rem; align-items: center; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary); }
    .bp-story-bar { height: 6px; background: rgba(255,255,255,0.04); border-radius: 3px; overflow: hidden; display: block; }
    .bp-story-bar > span { display: block; height: 100%; background: linear-gradient(90deg, #34D399, #6EE7B7); border-radius: 3px; }
    .bp-story-score { color: #34D399; font-weight: 700; text-align: right; font-family: var(--font-mono); }

    .bp-story-release { display: flex; flex-direction: column; gap: 0.85rem; }
    .bp-story-release-head { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-subtle); }
    .bp-story-release-name { font-family: var(--font-mono); font-size: 1rem; font-weight: 700; color: var(--text-primary); }
    .bp-story-release-ver { font-family: var(--font-mono); font-size: 0.875rem; color: #34D399; font-weight: 700; }
    .bp-story-release-meta { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem 1.25rem; font-family: var(--font-mono); font-size: 0.8125rem; color: var(--text-muted); }
    .bp-story-release-meta strong { color: var(--text-primary); font-weight: 700; }
    .bp-story-release-pill { font-family: var(--font-mono); font-size: 0.75rem; color: #818CF8; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.22); padding: 0.55rem 0.85rem; border-radius: 999px; text-align: center; letter-spacing: 0.02em; }


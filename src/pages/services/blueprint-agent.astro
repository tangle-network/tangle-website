---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blueprint Agent — AI Service Builder" description="The AI vibecoding platform for Tangle Blueprints. Describe your service — the agent builds, tests, and deploys it.">

  <!-- ======================================
       HERO — Full-width left-aligned
       ====================================== -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container" style="z-index: 1; position: relative;">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 5px 14px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.25); background: rgba(142,89,255,0.06); margin-bottom: 20px;">
            <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">Service</span>
          </div>
          <h1 class="wf-h1">Build services by<br/>describing them.</h1>
          <div class="wf-body-01" style="max-width: 540px;">The AI vibecoding platform for Tangle Blueprints. Describe your service — the agent builds, tests, and deploys it.</div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Launch Agent</a>
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">View Docs</a>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- ======================================
       HOW IT WORKS — 4 Steps
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">From idea to <span class="wf-gradient-text">revenue</span></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { step: '1', title: 'Describe', desc: 'Tell the agent what service you want to build in plain English. Oracles, bridges, AI agents — anything.', accent: 'rgba(142,89,255,0.12)' },
            { step: '2', title: 'Generate', desc: 'The AI writes your Blueprint — smart contracts, service logic, tests, and deployment config. Production-ready code.', accent: 'rgba(97,114,243,0.12)' },
            { step: '3', title: 'Deploy', desc: 'One-click deployment to Tangle Network. Your Blueprint goes live and operators can start running it immediately.', accent: 'rgba(74,58,255,0.12)' },
            { step: '4', title: 'Earn', desc: 'Operators instantiate your Blueprint and you earn fees on every execution. Build once, earn forever.', accent: 'rgba(104,136,249,0.12)' },
          ].map((s) => (
            <div style="text-align: center; padding: 1.5rem 1rem; border-radius: 1.5rem; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03); transition: border-color 0.3s;">
              <div style={`width: 48px; height: 48px; border-radius: 12px; background: ${s.accent}; border: 1px solid rgba(142,89,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;`}>
                <span style="font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 800; color: #8e59ff;">{s.step}</span>
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.05rem; font-weight: 700; color: white; margin-bottom: 8px;">{s.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.5;">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       USE CASES — What you can build
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Use Cases</div>
            </div>
          </div>
          <div class="wf-h3">Describe it. The agent <span class="wf-gradient-text">builds it.</span></div>
          <div class="wf-body-02 align-center">From oracle networks to bridge infrastructure — if it runs on Tangle, you can vibecode it.</div>
        </div>

        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { title: 'AI Agent Services', desc: 'Build autonomous agents that run on decentralized infrastructure. LLM reasoning, tool use, multi-step execution — all verifiable on-chain.' },
            { title: 'Oracle Networks', desc: 'Price feeds, weather data, sports scores, API bridges. The agent generates the data-fetching logic, aggregation, and on-chain submission.' },
            { title: 'Bridge Infrastructure', desc: 'Cross-chain messaging, token bridges, state relayers. Describe the chains and assets — the agent handles the protocol logic.' },
            { title: 'MPC Services', desc: 'Threshold signing, distributed key generation, secure computation. Multi-party protocols generated from high-level descriptions.' },
          ].map((uc) => (
            <div class="wf-builder-feature-card" style="padding: 1.5rem;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 8px;">{uc.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.5); line-height: 1.6;">{uc.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       FEATURES — Capabilities grid
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Platform</div>
            </div>
          </div>
          <div class="wf-h3">One agent. <span class="wf-gradient-text">Full stack.</span></div>
        </div>
        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(3, 1fr);">
          {[
            { title: 'Vibecoding', desc: 'Describe what you want to build in natural language. The AI agent writes the code, tests it, and iterates until it works.' },
            { title: 'Full-Stack Generation', desc: 'Smart contracts, service logic, deployment config, and tests. Complete, production-ready Blueprints from a single prompt.' },
            { title: 'Blueprint Templates', desc: 'Start from proven templates — oracles, bridges, AI agents, MPC protocols — and customize to your use case.' },
            { title: 'One-Click Deploy', desc: 'Deploy your Blueprint to Tangle Network with a single click. Operators discover it and start running immediately.' },
            { title: 'Monetization Built In', desc: 'Every Blueprint earns revenue when operators instantiate and execute it. Pricing, billing, and payouts handled by the protocol.' },
            { title: 'Collaborative', desc: 'Share projects, fork templates, and build together. Real-time AI assistance with context across your entire project.' },
          ].map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.15rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: rgba(255,255,255,0.5); font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; line-height: 1.6;">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       CTA
       ====================================== -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start building with AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Describe your service, watch the agent build it, deploy to Tangle and start earning.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

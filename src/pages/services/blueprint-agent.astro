---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blueprint Agent — AI Service Builder" description="The AI vibecoding platform for Tangle Blueprints. Describe your service — the agent builds, tests, and deploys it.">

  <style>
    .bp-hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
    .bp-hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 70% 60% at 20% 75%, rgba(99,102,241,0.07), transparent),
        radial-gradient(ellipse 60% 50% at 80% 25%, rgba(236,72,153,0.05), transparent);
    }
    .bp-hero-inner { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; padding: 0 5%; }
    .bp-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(99,102,241,0.3); background: rgba(99,102,241,0.08); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #818cf8; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 1.5rem; }
    .bp-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: bp-pulse 2s infinite; }
    @keyframes bp-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .bp-h1 { font-family: 'Satoshi', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 1.5rem; }
    .bp-h1 em { font-style: normal; background: linear-gradient(135deg, #818cf8, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-sub { font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.8); max-width: 540px; margin-bottom: 2rem; }

    /* Full-width showcase */
    .bp-showcase-wrap { max-width: 64rem; margin: 0 auto; padding: 0 5%; }
    .bp-showcase {
      background: #0e0e1c;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      overflow: hidden;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      line-height: 1.8;
    }
    .bp-showcase-chrome {
      display: flex; align-items: center; gap: 6px; padding: 14px 20px;
      background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .bp-showcase-dot { width: 12px; height: 12px; border-radius: 50%; }
    .bp-showcase-title { margin-left: 12px; font-size: 12px; color: rgba(255,255,255,0.25); }
    .bp-showcase-body { padding: 1.5rem 2rem; }
    .bp-line { display: block; min-height: 1.8em; }
    .bp-prompt { color: #818cf8; }
    .bp-cmd { color: #e2e8f0; }
    .bp-flag { color: #ec4899; }
    .bp-string { color: #818cf8; }
    .bp-dim { color: rgba(255,255,255,0.2); }
    .bp-info { color: rgba(255,255,255,0.35); }
    .bp-success { color: #4ade80; }
    .bp-output { color: rgba(255,255,255,0.45); }
    .bp-highlight { background: rgba(99,102,241,0.05); margin: 0 -2rem; padding: 0 2rem; }
    .bp-accent { color: #ec4899; }
    .bp-file { color: #fbbf24; }

    /* Bento grid */
    .bp-bento { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 64rem; margin: 0 auto; }
    .bp-bento-cell { background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2rem 2.25rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .bp-bento-cell:hover { background: rgba(255,255,255,0.04); border-color: rgba(99,102,241,0.2); box-shadow: 0 0 40px rgba(99,102,241,0.04); }
    .bp-bento-cell.span-2 { grid-column: span 2; }
    .bp-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(99,102,241,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .bp-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.2; }
    .bp-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.6; }
    .bp-bento-code { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.5); padding: 1.25rem 1.5rem; border-radius: 12px; margin-top: 1.5rem; white-space: pre; overflow-x: auto; line-height: 1.75; border: 1px solid rgba(255,255,255,0.04); }
    .bp-bento-code .g { color: #4ade80; }
    .bp-bento-code .p { color: #ec4899; }
    .bp-bento-code .i { color: #818cf8; }
    .bp-bento-code .w { color: #e2e8f0; }
    .bp-bento-code .d { color: rgba(255,255,255,0.3); }
    .bp-bento-code .f { color: #fbbf24; }

    /* Section headers */
    .bp-section { padding: 8rem 5% 6rem; max-width: 80rem; margin: 0 auto; }
    .bp-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(99,102,241,0.5); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .bp-section-title { font-family: 'Satoshi', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; text-align: center; line-height: 1.15; margin-bottom: 1rem; }
    .bp-section-title em { font-style: normal; background: linear-gradient(45deg, #818cf8, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-section-sub { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.8); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    /* Mobile */
    @media (max-width: 768px) {
      .bp-bento { grid-template-columns: 1fr; }
      .bp-bento-cell.span-2 { grid-column: span 1; }
      .bp-showcase { font-size: 12px; }
      .bp-showcase-body { padding: 1rem; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="bp-hero">
    <div class="bp-hero-inner">
      <div class="bp-badge">Live</div>
      <h1 class="bp-h1">Build services by<br/><em>describing them.</em></h1>
      <p class="bp-sub">The AI vibecoding platform for Tangle Blueprints. Describe your service in plain English — the agent writes the code, tests it, and deploys it to production.</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 14px 28px;">Launch Agent</a>
        <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none; transition: border-color 0.3s;">
          View Docs
        </a>
      </div>
    </div>
  </section>

  <!-- =======================================
       FULL-WIDTH SHOWCASE — Prompt → Generation
       ======================================= -->
  <div class="bp-section">
    <div class="bp-section-label">See It Work</div>
    <div class="bp-section-title">One prompt. <em>Production code.</em></div>
    <div class="bp-section-sub">Describe what you want to build and the agent generates a complete, deployable Tangle Blueprint.</div>
  </div>
  <div class="bp-showcase-wrap">
    <div class="bp-showcase">
      <div class="bp-showcase-chrome">
        <div class="bp-showcase-dot" style="background: rgba(255,95,87,0.8);"></div>
        <div class="bp-showcase-dot" style="background: rgba(254,188,46,0.8);"></div>
        <div class="bp-showcase-dot" style="background: rgba(99,102,241,0.8);"></div>
        <span class="bp-showcase-title">Blueprint Agent — ai.tangle.tools</span>
      </div>
      <div class="bp-showcase-body">
        <span class="bp-line"><span class="bp-prompt">you:</span> <span class="bp-cmd">Build me an EigenLayer AVS that validates price feeds from 5 sources</span></span>
        <span class="bp-line"></span>
        <span class="bp-line"><span class="bp-accent">agent:</span> <span class="bp-info">Understanding requirements...</span></span>
        <span class="bp-line"><span class="bp-output">  Building a price-feed validation AVS with multi-source aggregation.</span></span>
        <span class="bp-line"><span class="bp-output">  Architecture: 5 oracle sources → median aggregation → on-chain attestation</span></span>
        <span class="bp-line"></span>
        <span class="bp-line bp-highlight"><span class="bp-accent">agent:</span> <span class="bp-info">Generating Blueprint...</span></span>
        <span class="bp-line bp-highlight"><span class="bp-output">  <span class="bp-file">src/lib.rs</span>          — Blueprint service logic (price validation)</span></span>
        <span class="bp-line bp-highlight"><span class="bp-output">  <span class="bp-file">src/oracle.rs</span>       — Multi-source price fetching (Chainlink, Band, Pyth, API3, DIA)</span></span>
        <span class="bp-line bp-highlight"><span class="bp-output">  <span class="bp-file">src/aggregator.rs</span>   — Median calculation + outlier detection</span></span>
        <span class="bp-line bp-highlight"><span class="bp-output">  <span class="bp-file">contracts/avs.sol</span>   — EigenLayer AVS registration + task submission</span></span>
        <span class="bp-line bp-highlight"><span class="bp-output">  <span class="bp-file">tests/</span>              — Integration tests for all 5 sources</span></span>
        <span class="bp-line"></span>
        <span class="bp-line"><span class="bp-success">  ✓ Blueprint generated</span> <span class="bp-info">— 5 files, 1,247 lines, all tests passing</span></span>
        <span class="bp-line"><span class="bp-info">  Ready to deploy → tangle deploy</span></span>
      </div>
    </div>
  </div>

  <!-- =======================================
       BENTO GRID — Capabilities
       ======================================= -->
  <div class="bp-section">
    <div class="bp-section-label">Platform</div>
    <div class="bp-section-title">Describe. Generate. <em>Deploy.</em></div>
  </div>
  <div style="max-width: 64rem; margin: 0 auto; padding: 0 5% 6rem;">
    <div class="bp-bento">
      <!-- Large: Vibecoding -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Vibecoding</div>
          <div class="bp-bento-title">Natural language to production Blueprints.</div>
          <div class="bp-bento-desc">Describe what you want in plain English. The AI agent writes Rust service logic, Solidity contracts, deployment configs, and tests — iterating until everything compiles and passes.</div>
        </div>
        <div class="bp-bento-code"><span class="i">you:</span> <span class="w">Create a bridge that relays messages between Ethereum and Tangle</span>
      <span class="w">with signature verification and replay protection</span>

<span class="p">agent:</span> <span class="d">analyzing requirements → generating 8 files</span>
  <span class="f">src/relay.rs</span>      signature verification + nonce tracking
  <span class="f">contracts/</span>        bridge contracts for both chains

<span class="g">✓ All tests passing</span>  ·  ready to deploy</div>
      </div>

      <!-- Small: Templates -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Templates</div>
          <div class="bp-bento-title">Start from proven code.</div>
          <div class="bp-bento-desc">Oracle networks, bridges, AI agents, MPC protocols — battle-tested templates you can fork and customize.</div>
        </div>
        <div class="bp-bento-code"><span class="d">Available templates:</span>
<span class="i">oracle</span>    price-feed AVS
<span class="i">bridge</span>    cross-chain relay
<span class="i">mpc</span>       threshold signing
<span class="i">agent</span>     autonomous AI</div>
      </div>

      <!-- Small: One-Click Deploy -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">One-Click Deploy</div>
          <div class="bp-bento-title">Live in seconds.</div>
          <div class="bp-bento-desc">Deploy your Blueprint to Tangle Network with a single click. Operators discover it and start running immediately.</div>
        </div>
        <div class="bp-bento-code"><span class="p">agent:</span> deploying to Tangle...
  <span class="g">✓</span> contracts verified
  <span class="g">✓</span> blueprint registered
  <span class="g">✓</span> <span class="w">live on mainnet</span></div>
      </div>

      <!-- Large: Monetization -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Monetization</div>
          <div class="bp-bento-title">Build once. Earn forever.</div>
          <div class="bp-bento-desc">Every Blueprint earns revenue when operators instantiate and execute it. Pricing, billing, and payouts are handled by the protocol — you just collect fees on every run.</div>
        </div>
        <div class="bp-bento-code"><span class="d">BLUEPRINT              OPERATORS    EXECUTIONS    REVENUE</span>
<span class="w">price-feed-avs</span>         12           48,230        <span class="g">$2,411.50</span>
<span class="w">eth-tangle-bridge</span>      8            12,840        <span class="g">$1,926.00</span>
<span class="w">mpc-signing</span>            23           91,200        <span class="g">$4,560.00</span>
<span class="d">──────────────────────────────────────────────────────</span>
<span class="w">Total (30d)</span>                                        <span class="g">$8,897.50</span></div>
      </div>

      <!-- Small: Collaborative -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Collaborative</div>
          <div class="bp-bento-title">Build together.</div>
          <div class="bp-bento-desc">Share projects, fork templates, and collaborate in real-time. The AI maintains context across your entire project history.</div>
        </div>
        <div class="bp-bento-code"><span class="d">team activity:</span>
<span class="i">alice</span> forked <span class="f">oracle-avs</span>
<span class="i">bob</span>   deployed <span class="f">bridge-v2</span>
<span class="g">✓</span> 3 members · 12 projects</div>
      </div>
    </div>
  </div>

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start building with AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Describe your service, watch the agent build it, deploy to Tangle and start earning.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
  { title: 'Vibecoding Platform', description: 'Describe what you want to build in natural language. The AI agent writes, tests, and deploys your Blueprint.' },
  { title: 'Full-Stack Generation', description: 'From smart contracts to backend services to frontend UIs — generate complete, production-ready code.' },
  { title: 'Blueprint Templates', description: 'Start from proven templates — oracles, bridges, AI agents, MPC services — and customize for your use case.' },
  { title: 'One-Click Deploy', description: 'Deploy your Blueprint to Tangle Network with a single click. Operators pick it up and start running it.' },
  { title: 'Monetization Built In', description: 'Every Blueprint earns revenue when operators instantiate it. Build once, earn forever.' },
  { title: 'Collaborative', description: 'Share projects, fork templates, and build together. Real-time collaboration with AI assistance.' },
];
---

<BaseLayout title="Blueprint Agent" description="AI vibecoding platform for building and deploying Tangle Blueprints. Describe what you want, the AI builds it.">

  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Service</div>
            </div>
          </div>
          <h1 class="wf-h1">Blueprint Agent</h1>
          <div class="wf-body-01">The AI vibecoding platform for Tangle Blueprints. Describe your service in natural language — the agent builds, tests, and deploys it.</div>
          <div class="wf-button-row">
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Launch Agent</a>
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">View Docs</a>
          </div>
        </div>
      </div>
    </section>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Features</div>
            </div>
          </div>
          <div class="wf-h3">Build Services by <span class="wf-gradient-text">Describing Them</span></div>
          <div class="wf-body-02 align-center">The fastest way to go from idea to deployed, monetizable infrastructure service. No boilerplate, no DevOps, just describe and ship.</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {features.map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.35rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; line-height: 1.6;">{f.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">From Idea to Revenue</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; max-width: 1000px; margin: 0 auto;">
          {[
            { step: '1', title: 'Describe', desc: 'Tell the agent what service you want to build.' },
            { step: '2', title: 'Generate', desc: 'AI writes the Blueprint code, tests, and configuration.' },
            { step: '3', title: 'Deploy', desc: 'One-click deployment to Tangle Network.' },
            { step: '4', title: 'Earn', desc: 'Operators instantiate your Blueprint. You earn fees.' },
          ].map((s) => (
            <div style="text-align: center;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: #6172f3; margin-bottom: 12px;">{s.step}</div>
              <div class="wf-h4" style="font-size: 1.25rem; margin-bottom: 8px;">{s.title}</div>
              <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500;">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start Building with AI</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Describe your service, watch the agent build it, deploy to Tangle Network, and start earning.</div>
        <div class="wf-cta-button-row">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

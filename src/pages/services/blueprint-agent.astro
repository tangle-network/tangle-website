---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';
import Hero from '../../components/ui/Hero.astro';

const bpHeroPrompt = `<span class="cw-c">╭ blueprint-agent · ai.tangle.tools ──────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">FROST threshold-signing service. t-of-n keygen,</span>
     <span class="cw-v">x402 paywall on /v1/sign, deploy to Tangle testnet.</span>

<span class="cw-sh">▸ plan</span>     <span class="cw-c">frost-secp256k1 keygen + sign jobs</span>
          <span class="cw-c">x402 facilitator on POST /v1/sign</span>
          <span class="cw-c">tangle-operator bonding + slashing hooks</span>

<span class="cw-sh">▸ scaffold</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-ok">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-ok">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-ok">✓</span>

<span class="cw-sh">▸ verify</span>
          <span class="cw-v">cargo check</span>  <span class="cw-c">0 errors · 2.1s</span>
          <span class="cw-v">cargo test</span>   <span class="cw-c">7 passed · 0 failed</span>

<span class="cw-sh">▸ ship</span>
          <span class="cw-ok">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
          <span class="cw-ok">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">tangle testnet · 4 operators bonded</span>
          <span class="cw-ok">✓</span> <span class="cw-v">earn</span>     <span class="cw-k">/v1/sign live · $0.02 per signature</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const bpChatCode = `<span class="cw-c">╭ Blueprint Agent · ai.tangle.tools ─────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">Ship me a FROST threshold-signing Blueprint with</span>
     <span class="cw-v">an x402-gated REST endpoint.</span>

<span class="cw-sh">▸ agent</span>  <span class="cw-c">planning…</span>
        <span class="cw-c">→ frost-secp256k1 keygen + sign jobs</span>
        <span class="cw-c">→ x402 facilitator on /v1/sign</span>
        <span class="cw-c">→ tangle-operator bonding + slashing hooks</span>

        <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/main.rs</span>         <span class="cw-ok">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-ok">✓</span>

        <span class="cw-v">cargo check</span> <span class="cw-c">· 0 errors · 2.1s</span>
        <span class="cw-v">generated 187 lines across 4 files</span>

        <span class="cw-ok">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
        <span class="cw-ok">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">one-click to Tangle testnet</span>

<span class="cw-c">╰────────────────────────────────────────────────────────╯</span>`;

const bpGeneratedCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::{
  <span class="cw-v">extract</span>::<span class="cw-f">Context</span>,
  <span class="cw-v">macros</span>::<span class="cw-f">debug_job</span>,
  <span class="cw-v">tangle</span>::<span class="cw-f">TangleLayer</span>,
  <span class="cw-f">Router</span>, <span class="cw-f">Result</span>,
};
<span class="cw-k">use</span> <span class="cw-v">frost_secp256k1</span>::<span class="cw-f">SigningPackage</span>;
<span class="cw-k">use</span> <span class="cw-k">crate</span>::<span class="cw-v">context</span>::<span class="cw-f">FrostCtx</span>;

<span class="cw-k">pub const</span> <span class="cw-v">SIGN_JOB_ID</span>: <span class="cw-f">u32</span> = 0;

<span class="cw-c">/// t-of-n FROST signing — scaffolded by Blueprint Agent.</span>
<span class="cw-c">/// Audit, tune, ship. You own the repo.</span>
<span class="cw-p">#[debug_job]</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">sign</span>(
  <span class="cw-f">Context</span>(<span class="cw-v">ctx</span>): <span class="cw-f">Context</span>&lt;<span class="cw-f">FrostCtx</span>&gt;,
  <span class="cw-v">message</span>: <span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;,
  <span class="cw-v">threshold</span>: <span class="cw-f">u16</span>,
) -&gt; <span class="cw-f">Result</span>&lt;<span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;&gt; {
  <span class="cw-k">let</span> <span class="cw-v">round1</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round1</span>(<span class="cw-v">threshold</span>).<span class="cw-k">await</span>?;
  <span class="cw-k">let</span> <span class="cw-v">pkg</span>    = <span class="cw-f">SigningPackage</span>::<span class="cw-f">new</span>(<span class="cw-v">round1</span>.commitments, &amp;<span class="cw-v">message</span>);
  <span class="cw-k">let</span> <span class="cw-v">shares</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round2</span>(&amp;<span class="cw-v">pkg</span>).<span class="cw-k">await</span>?;
  <span class="cw-v">ctx</span>.<span class="cw-f">aggregate</span>(&amp;<span class="cw-v">pkg</span>, &amp;<span class="cw-v">shares</span>)
}

<span class="cw-c">// wiring — BlueprintRunner composes producer/consumer/router</span>
<span class="cw-f">Router</span>::<span class="cw-f">new</span>()
  .<span class="cw-f">route</span>(<span class="cw-v">SIGN_JOB_ID</span>, <span class="cw-v">sign</span>.<span class="cw-f">layer</span>(<span class="cw-f">TangleLayer</span>))</span>`;

const faqs = [
  { question: 'What is Blueprint Agent?', answer: 'A workbench that turns an English prompt into a Tangle Blueprint — Rust crate, jobs, manifest, tests — and deploys to operators. Editor, terminal, preview run in an isolated sandbox. You own the repo.' },
  { question: 'Which ecosystems can a Blueprint target?', answer: 'Solana, Ethereum, Arbitrum, Base, Coinbase, EigenLayer, Starknet, Sui, Aptos, and 30+ more. Each ships a starter template with SDK wiring, fixtures, and passing tests.' },
  { question: 'How does multi-model work?', answer: 'Same prompt across Claude, GPT, GLM, Kimi in parallel. Diff the repos, run their tests, ship the variant that compiles. One PR from the winner.' },
  { question: 'Can I create PRs from the workbench?', answer: 'Yes. Connect a GitHub repo. The agent opens a branch, commits, and creates a PR with prompt, model, and test output in the body.' },
  { question: 'Is this a coding assistant?', answer: 'No. It is a Blueprint authoring workbench. Output is a deployable service with on-chain bonding, fee collection, and operator dispatch wired up.' },
];
---

<BaseLayout title="Blueprint Agent — prompt to deployed Blueprint" description="English in, deployed Blueprint out. Live workbench, real cargo compile, operators bonded the same session.">

  <style>
    /* Bento */
    .bp-bento { display: grid; overflow: hidden; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 80rem; margin: 0 auto; }
    .bp-bento-cell { min-width: 0; overflow: hidden; background: var(--depth-2); border: 1px solid var(--border-default); border-radius: 16px; padding: 2.25rem 2.5rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .bp-bento-cell:hover { background: var(--depth-3); border-color: var(--border-accent); box-shadow: var(--shadow-glow); }
    .bp-bento-cell.span-2 { grid-column: span 2; }
    .bp-bento-cell.span-3 { grid-column: span 3; }
    .bp-bento-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .bp-bento-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem; line-height: 1.2; letter-spacing: -0.015em; }
    .bp-bento-desc { font-family: var(--font-sans); font-size: 1rem; font-weight: 500; color: var(--text-secondary); line-height: 1.6; }

    /* Partner marquee */
    .bp-partners { display: flex; overflow: hidden; padding: 2rem 0; }
    .bp-partners-inner { display: flex; align-items: center; gap: 3rem; animation: bp-scroll 40s linear infinite; flex-shrink: 0; }
    @keyframes bp-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    .bp-section { padding: 8rem 5% 4rem; max-width: 80rem; margin: 0 auto; }
    .bp-section-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .bp-section-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; color: var(--text-primary); text-align: center; line-height: 1.05; margin-bottom: 1rem; letter-spacing: -0.025em; }
    .bp-section-title em { font-style: normal; background: linear-gradient(135deg, #818cf8, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-section-sub { font-family: var(--font-sans); font-size: 1.1rem; font-weight: 500; color: var(--text-secondary); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    @media (max-width: 768px) {
      .bp-bento { grid-template-columns: 1fr; padding: 0 16px; }
      .bp-bento-cell.span-2, .bp-bento-cell.span-3 { grid-column: span 1; }
      .bp-bento-cell { padding: 1.5rem; }
      .bp-bento-title { font-size: 1.25rem; }
      .bp-section { padding: 4rem 16px 2rem; }
      .bp-section-title { font-size: 1.75rem; }
      .bp-section-sub { font-size: 0.95rem; }
      .bp-partner-contact { flex-direction: column !important; }
      .bp-partner-contact > div:last-child { display: none; }
      .bp-partner-grid-3 { grid-template-columns: 1fr !important; }
    }

    /* Model race — speed badge fades in once the bar finishes filling */
    .bp-model-speed {
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    .bp-models.bp-models--running .bp-model-speed {
      opacity: 1;
    }
    @media (prefers-reduced-motion: reduce) {
      .bp-model-bar { transition: none !important; }
      .bp-model-speed { transition: none !important; opacity: 1 !important; }
    }
  </style>

  <Hero
    eyebrow="AI DEVELOPMENT PLATFORM"
    eyebrowColor="brand"
    eyebrowIcon="code"
    title='Blueprint <span class="wf-gradient-text">Agent</span>.'
    subtitle="Describe a service in English. The workbench scaffolds the Rust crate, runs cargo test, and deploys to operators — same session."
    installPill={{ command: 'npm install -g @tangle-network/blueprint-sdk' }}
    primaryCta={{ label: 'Open the workbench', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'See what it ships', href: '#how-it-ships' }}
    videoBg={{
      poster: '/images/hero/cube-poster.jpg',
      webm: '/videos/cube-dark.webm',
      mp4: '/videos/cube-dark.mp4',
      opacity: 0.22,
    }}
  >
    <CodeWindow
      tabs={[
        { id: 'prompt', label: 'workbench', icon: 'terminal', html: bpHeroPrompt },
        { id: 'generated', label: 'src/jobs/sign.rs', icon: 'code', html: bpGeneratedCode },
      ]}
    />
  </Hero>

  <StatsStrip
    items={[
      { label: '40+ ecosystem templates', icon: 'layers' },
      { label: 'multi-model · Claude · GPT · GLM · Kimi', icon: 'code' },
      { label: 'cargo check + tests every turn', icon: 'shield' },
      { label: 'one-click deploy to Tangle operators', icon: 'zap' },
    ]}
  />

  <!-- Who ships with it — VAULT (light) surface -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 72rem;">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #047857;">BUILT FOR</span>
          <h2 class="wf-h3" style="text-align: left; margin: 0; max-width: 44rem; color: #191c24;">Teams shipping Blueprints as a product.</h2>
          <p class="wf-body-01" style="margin: 0.5rem 0 0; color: #3a3a50; max-width: 44rem;">Not a coding assistant. A Blueprint authoring workbench wired to the protocol — generated services are deployable and fee-collecting day one.</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 2.5rem;">
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">L1 / L2 FOUNDATIONS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Onboard your ecosystem.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">White-label the workbench. Pin your SDKs and docs. Generated Blueprints land on your stack.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">INFRASTRUCTURE TEAMS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Operator-backed services.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Bridges, oracles, indexers, MPC. Generate, deploy to operators, collect fees through the protocol.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">SOLO DEVS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Ship a service in a weekend.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Prompt to deployed Blueprint earning fees. No DevOps, no billing layer.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM PROMPT — consistent CodeWindow surface -->
  <section id="how-it-ships" class="wf-section" style="background: var(--depth-1);">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 80rem;">
        <SectionHead
          eyebrow="FROM PROMPT"
          eyebrowColor="brand"
          title="Describe it. We scaffold it."
          description="One prompt produces a Rust crate, jobs, manifest, tests, and a preview URL."
          align="center"
        />
        <div style="max-width: 64rem; margin: 2.5rem auto 0;">
          <CodeWindow
            tabs={[
              { id: 'chat', label: 'workbench', icon: 'terminal', html: bpChatCode },
              { id: 'generated', label: 'src/jobs/sign.rs', icon: 'code', html: bpGeneratedCode },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS — Real logos -->
  <div style="border-top: 1px solid rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.04); overflow: hidden;">
    <div style="text-align: center; padding: 2rem 0 0;">
      <span style="font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;">Runs on any ecosystem</span>
    </div>
    <div class="bp-partners">
      <div class="bp-partners-inner">
        {[
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
        ].map(logo => (
          <img src={`/images/partners/${logo}`} alt="" style="height: 28px; width: auto; opacity: 0.5;  flex-shrink: 0;" loading="lazy" />
        ))}
      </div>
    </div>
  </div>

  <!-- WORKBENCH SHOWCASE -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="bp-section" style="padding-top: 4rem;">
          <div class="bp-section-label">The workbench</div>
          <div class="bp-section-title">Editor, terminal, preview. <em>One sandbox.</em></div>
          <div class="bp-section-sub">CodeMirror, xterm.js, live preview per turn. Interrupt mid-edit, type, resume.</div>
        </div>
        <div style="position: relative; max-width: 100%;">
          <div style="position: absolute; inset: -12px; border-radius: 16px; background: linear-gradient(135deg, rgba(129,140,248,0.12), rgba(255,184,0,0.06)); filter: blur(32px); pointer-events: none;"></div>
          <img src="/images/products/blueprint-agent-workbench.png" alt="Blueprint Agent workbench — chat, editor, and file tree" style="position: relative; width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 80px rgba(0,0,0,0.6);" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO GRID -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="bp-section" style="padding-top: 4rem;">
          <div class="bp-section-label">How it ships</div>
          <div class="bp-section-title">English in. <em>Merged PR out.</em></div>
        </div>
        <div style="padding: 0 0 4rem;">
    <div class="bp-bento">
      <!-- Row 1: Workbench (span-2) + Multi-Model -->
      <div class="bp-bento-cell span-2">
        <div>
          <div class="bp-bento-label">Live workbench</div>
          <div class="bp-bento-title">Editor, terminal, preview — one sandbox.</div>
          <div class="bp-bento-desc">Watch the agent edit. Interrupt mid-turn, type, resume. Tests run on the same container that ships.</div>
        </div>
        <!-- Visual: 3 colored panels representing the IDE -->
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-top: 1.5rem;">
          <div style="background: rgba(129,140,248,0.08); border: 1px solid rgba(129,140,248,0.15); border-radius: 8px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: var(--font-mono); font-size: 10px; color: #818cf8; margin-bottom: 8px; font-weight: 600;">Editor</div>
            <div style="height: 6px; width: 70%; background: rgba(129,140,248,0.2); border-radius: 3px; margin-bottom: 4px;"></div>
            <div style="height: 6px; width: 50%; background: rgba(255,184,0,0.18); border-radius: 3px; margin-bottom: 4px;"></div>
            <div style="height: 6px; width: 85%; background: rgba(255,255,255,0.06); border-radius: 3px;"></div>
          </div>
          <div style="background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12); border-radius: 8px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: var(--font-mono); font-size: 10px; color: #4ade80; margin-bottom: 8px; font-weight: 600;">Preview</div>
            <div style="height: 24px; width: 60%; background: rgba(74,222,128,0.1); border-radius: 4px; margin-bottom: 6px;"></div>
            <div style="height: 16px; width: 80%; background: rgba(129,140,248,0.15); border-radius: 4px;"></div>
          </div>
          <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.7); margin-bottom: 8px; font-weight: 600;">Terminal</div>
            <div style="font-family: var(--font-mono); font-size: 9px; color: #4ade80;">$ pnpm test</div>
            <div style="font-family: var(--font-mono); font-size: 9px; color: rgba(255,255,255,0.65);">28 passed · 0 failed</div>
          </div>
        </div>
      </div>

      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Multi-model</div>
          <div class="bp-bento-title">Same prompt. Four agents.</div>
          <div class="bp-bento-desc">Claude, GPT, GLM, Kimi build in parallel. The eval picks the winner.</div>
        </div>
        <!-- Visual: model race — bars fill on viewport-enter -->
        <div class="bp-models" style="display: flex; flex-direction: column; gap: 10px; margin-top: 1.25rem;">
          {[
            { name: 'Claude',  color: '#818cf8', width: '95%', speed: '34s' },
            { name: 'GPT-5',   color: '#10B981', width: '88%', speed: '28s' },
            { name: 'GLM',     color: '#FFB800', width: '85%', speed: '12s' },
            { name: 'Kimi',    color: '#4AABFF', width: '72%', speed: '8s'  },
          ].map((m, i) => (
            <div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <span style="font-family: var(--font-sans); font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.7);">{m.name}</span>

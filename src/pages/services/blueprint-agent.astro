  <script>
    // Model-race bars: fill from 0 → target width when the .bp-models block
    // enters the viewport. One-shot per page load so it reads as a benchmark
    // running, not a screenshot.
    document.querySelectorAll<HTMLElement>('.bp-models').forEach((group) => {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const block = entry.target as HTMLElement;
          block.querySelectorAll<HTMLElement>('.bp-model-bar').forEach((bar) => {
            const target = bar.getAttribute('data-target-width') ?? '0%';
            requestAnimationFrame(() => { bar.style.width = target; });
          });
          block.classList.add('bp-models--running');
          io.unobserve(block);
        }
      }, { threshold: 0.4 });
      io.observe(group);
    });
  </script>


        <span class="cw-ok">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">one-click to Tangle testnet</span>

<span class="cw-c">╰────────────────────────────────────────────────────────╯</span>`;

const bpGeneratedCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::{
  <span class="cw-f">Router</span>,
  tangle::{extract::{<span class="cw-f">Context</span>, <span class="cw-f">TangleArg</span>, <span class="cw-f">TangleResult</span>}, layers::<span class="cw-f">TangleLayer</span>},
};
<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::alloy::sol;
<span class="cw-k">use</span> <span class="cw-k">crate</span>::context::<span class="cw-f">FrostCtx</span>;

<span class="cw-k">pub const</span> <span class="cw-v">SIGN_JOB_ID</span>: <span class="cw-f">u8</span> = <span class="cw-n">0</span>;

sol! {
  <span class="cw-k">struct</span> <span class="cw-f">SignRequest</span>  { <span class="cw-f">bytes</span> message; <span class="cw-f">uint16</span> threshold; }
  <span class="cw-k">struct</span> <span class="cw-f">SignResponse</span> { <span class="cw-f">bytes</span> signature; }
}

<span class="cw-c">/// t-of-n FROST signing — scaffolded by Blueprint Agent.</span>
<span class="cw-c">/// Audit, tune, ship. You own the repo.</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">sign</span>(
  <span class="cw-f">Context</span>(ctx): <span class="cw-f">Context</span>&lt;<span class="cw-f">FrostCtx</span>&gt;,
  <span class="cw-f">TangleArg</span>(req): <span class="cw-f">TangleArg</span>&lt;<span class="cw-f">SignRequest</span>&gt;,
) -&gt; <span class="cw-f">TangleResult</span>&lt;<span class="cw-f">SignResponse</span>&gt; {
  <span class="cw-k">let</span> round1 = ctx.<span class="cw-f">round1</span>(req.threshold).<span class="cw-k">await</span>.<span class="cw-f">unwrap</span>();
  <span class="cw-k">let</span> pkg    = ctx.<span class="cw-f">package</span>(&amp;round1.commitments, &amp;req.message);
  <span class="cw-k">let</span> shares = ctx.<span class="cw-f">round2</span>(&amp;pkg).<span class="cw-k">await</span>.<span class="cw-f">unwrap</span>();
  <span class="cw-k">let</span> sig    = ctx.<span class="cw-f">aggregate</span>(&amp;pkg, &amp;shares).<span class="cw-f">unwrap</span>();
  <span class="cw-f">TangleResult</span>(<span class="cw-f">SignResponse</span> { signature: sig.into() })
}

<span class="cw-c">// Mount on a Router. TangleLayer injects on-chain metadata.</span>
<span class="cw-k">pub fn</span> <span class="cw-f">router</span>(ctx: <span class="cw-f">FrostCtx</span>) -&gt; <span class="cw-f">Router</span> {
  <span class="cw-f">Router</span>::<span class="cw-f">new</span>()
    .<span class="cw-f">route</span>(<span class="cw-v">SIGN_JOB_ID</span>, sign.<span class="cw-f">layer</span>(<span class="cw-f">TangleLayer</span>))
    .<span class="cw-f">with_context</span>(ctx)
}`;

// ─── Build for any framework — 4 deploy-target examples ───────────────────
// Each "group" is a different framework/ecosystem; each group has 2 tabs:
// the natural-language prompt + the file the agent ships.

const dspyPrompt = `<span class="cw-c">╭ blueprint-agent ────────────────────────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">A DSPy program that classifies support tickets into</span>
     <span class="cw-v">{billing, technical, sales} with a few-shot teleprompter.</span>

<span class="cw-sh">▸ scaffold</span>
       <span class="cw-v">writing</span> <span class="cw-f">programs/triage.py</span>     <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">tests/test_triage.py</span>   <span class="cw-ok">✓</span>
       <span class="cw-v">writing</span> <span class="cw-f">requirements.txt</span>       <span class="cw-ok">✓</span>

<span class="cw-sh">▸ verify</span>
       <span class="cw-v">pytest</span>           <span class="cw-c">11 passed · 0 failed</span>
       <span class="cw-v">teleprompt</span>       <span class="cw-c">acc 0.84 → 0.92 after 4 rounds</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const dspyCode = `<span class="cw-k">import</span> <span class="cw-v">dspy</span>
<span class="cw-k">from</span> <span class="cw-v">dspy.teleprompt</span> <span class="cw-k">import</span> <span class="cw-f">BootstrapFewShot</span>

dspy.<span class="cw-f">configure</span>(lm=dspy.<span class="cw-f">LM</span>(<span class="cw-s">"openai/gpt-4o-mini"</span>))

<span class="cw-k">class</span> <span class="cw-f">TriageTicket</span>(dspy.<span class="cw-f">Signature</span>):
    <span class="cw-s">"""Classify a support ticket into billing, technical, or sales."""</span>
    ticket  = dspy.<span class="cw-f">InputField</span>(desc=<span class="cw-s">"the user's message"</span>)
    label   = dspy.<span class="cw-f">OutputField</span>(desc=<span class="cw-s">"billing | technical | sales"</span>)

triage = dspy.<span class="cw-f">ChainOfThought</span>(<span class="cw-f">TriageTicket</span>)

<span class="cw-c"># Compile with a few-shot teleprompter — auto-improves accuracy.</span>
trainset = <span class="cw-f">load_examples</span>(<span class="cw-s">"data/triage.jsonl"</span>)
optimized = <span class="cw-f">BootstrapFewShot</span>(metric=<span class="cw-f">f1_score</span>).<span class="cw-f">compile</span>(triage, trainset=trainset)

<span class="cw-c"># Use it.</span>
<span class="cw-k">print</span>(optimized(ticket=<span class="cw-s">"my card was double charged"</span>).label)
<span class="cw-c"># → billing</span>`;


---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';

const bpHeroPrompt = `<span class="cw-c">╭ blueprint-agent · ai.tangle.tools ──────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">FROST threshold-signing service. t-of-n keygen,</span>
     <span class="cw-v">x402 paywall on /v1/sign, deploy to Tangle testnet.</span>

<span class="cw-sh">▸ plan</span>     <span class="cw-c">frost-secp256k1 keygen + sign jobs</span>
          <span class="cw-c">x402 facilitator on POST /v1/sign</span>
          <span class="cw-c">tangle-operator bonding + slashing hooks</span>

<span class="cw-sh">▸ scaffold</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-sh">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-sh">✓</span>
          <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-sh">✓</span>

<span class="cw-sh">▸ verify</span>
          <span class="cw-v">cargo check</span>  <span class="cw-c">0 errors · 2.1s</span>
          <span class="cw-v">cargo test</span>   <span class="cw-c">7 passed · 0 failed</span>

<span class="cw-sh">▸ ship</span>
          <span class="cw-sh">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
          <span class="cw-sh">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">tangle testnet · 4 operators bonded</span>
          <span class="cw-sh">✓</span> <span class="cw-v">earn</span>     <span class="cw-k">/v1/sign live · $0.02 per signature</span>

<span class="cw-c">╰─────────────────────────────────────────────────────────╯</span>`;

const bpChatCode = `<span class="cw-c">╭ Blueprint Agent · ai.tangle.tools ─────────────────────╮</span>

<span class="cw-p">you</span>  <span class="cw-v">Ship me a FROST threshold-signing Blueprint with</span>
     <span class="cw-v">an x402-gated REST endpoint.</span>

<span class="cw-sh">▸ agent</span>  <span class="cw-c">planning…</span>
        <span class="cw-c">→ frost-secp256k1 keygen + sign jobs</span>
        <span class="cw-c">→ x402 facilitator on /v1/sign</span>
        <span class="cw-c">→ tangle-operator bonding + slashing hooks</span>

        <span class="cw-v">writing</span> <span class="cw-f">src/lib.rs</span>          <span class="cw-sh">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/jobs/sign.rs</span>    <span class="cw-sh">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">src/main.rs</span>         <span class="cw-sh">✓</span>
        <span class="cw-v">writing</span> <span class="cw-f">blueprint.toml</span>      <span class="cw-sh">✓</span>

        <span class="cw-v">cargo check</span> <span class="cw-c">· 0 errors · 2.1s</span>
        <span class="cw-v">generated 187 lines across 4 files</span>

        <span class="cw-sh">✓</span> <span class="cw-v">preview</span>  <span class="cw-s">ai.tangle.tools/p/frost-a8f3</span>
        <span class="cw-sh">✓</span> <span class="cw-v">deploy</span>   <span class="cw-k">one-click to Tangle testnet</span>

<span class="cw-c">╰────────────────────────────────────────────────────────╯</span>`;

const bpGeneratedCode = `<span class="cw-k">use</span> <span class="cw-v">blueprint_sdk</span>::{
  <span class="cw-v">extract</span>::<span class="cw-f">Context</span>,
  <span class="cw-v">macros</span>::<span class="cw-f">debug_job</span>,
  <span class="cw-v">tangle</span>::<span class="cw-f">TangleLayer</span>,
  <span class="cw-f">Router</span>, <span class="cw-f">Result</span>,
};
<span class="cw-k">use</span> <span class="cw-v">frost_secp256k1</span>::<span class="cw-f">SigningPackage</span>;
<span class="cw-k">use</span> <span class="cw-k">crate</span>::<span class="cw-v">context</span>::<span class="cw-f">FrostCtx</span>;

<span class="cw-k">pub const</span> <span class="cw-v">SIGN_JOB_ID</span>: <span class="cw-f">u32</span> = 0;

<span class="cw-c">/// t-of-n FROST signing — scaffolded by Blueprint Agent.</span>
<span class="cw-c">/// Audit, tune, ship. You own the repo.</span>
<span class="cw-p">#[debug_job]</span>
<span class="cw-k">pub async fn</span> <span class="cw-f">sign</span>(
  <span class="cw-f">Context</span>(<span class="cw-v">ctx</span>): <span class="cw-f">Context</span>&lt;<span class="cw-f">FrostCtx</span>&gt;,
  <span class="cw-v">message</span>: <span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;,
  <span class="cw-v">threshold</span>: <span class="cw-f">u16</span>,
) -&gt; <span class="cw-f">Result</span>&lt;<span class="cw-f">Vec</span>&lt;<span class="cw-f">u8</span>&gt;&gt; {
  <span class="cw-k">let</span> <span class="cw-v">round1</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round1</span>(<span class="cw-v">threshold</span>).<span class="cw-k">await</span>?;
  <span class="cw-k">let</span> <span class="cw-v">pkg</span>    = <span class="cw-f">SigningPackage</span>::<span class="cw-f">new</span>(<span class="cw-v">round1</span>.commitments, &amp;<span class="cw-v">message</span>);
  <span class="cw-k">let</span> <span class="cw-v">shares</span> = <span class="cw-v">ctx</span>.<span class="cw-f">round2</span>(&amp;<span class="cw-v">pkg</span>).<span class="cw-k">await</span>?;
  <span class="cw-v">ctx</span>.<span class="cw-f">aggregate</span>(&amp;<span class="cw-v">pkg</span>, &amp;<span class="cw-v">shares</span>)
}

<span class="cw-c">// wiring — BlueprintRunner composes producer/consumer/router</span>
<span class="cw-f">Router</span>::<span class="cw-f">new</span>()
  .<span class="cw-f">route</span>(<span class="cw-v">SIGN_JOB_ID</span>, <span class="cw-v">sign</span>.<span class="cw-f">layer</span>(<span class="cw-f">TangleLayer</span>))</span>`;

const faqs = [
  { question: 'What is Blueprint Agent?', answer: 'A workbench that turns an English prompt into a Tangle Blueprint — Rust crate, jobs, manifest, tests — and deploys it to operators on the protocol you target. Editor, terminal, and live preview run inside an isolated sandbox; you own the repo.' },
  { question: 'Which ecosystems can a generated Blueprint target?', answer: 'Solana, Ethereum, Arbitrum, Base, Coinbase, EigenLayer, Starknet, Sui, Aptos, plus 30+ more. Each ecosystem ships a starter template with SDK wiring, fixtures, and a passing test suite.' },
  { question: 'How does multi-model work?', answer: 'Run the same prompt across Claude, GPT, GLM, and Kimi in parallel. Diff the generated repos, run their tests, ship the variant that compiles cleanly and matches your style. One PR from the winner.' },
  { question: 'Can I create PRs from the workbench?', answer: 'Yes. Connect a GitHub repo and the agent opens a branch, commits the generated files, and creates a PR with the prompt, model, and test output in the body. Merge or iterate from your normal review flow.' },
  { question: 'Is this a coding assistant?', answer: 'No. It is a Blueprint authoring workbench. The output is a deployable service with on-chain bonding, fee collection, and operator dispatch wired up — not a code suggestion in your editor.' },
];
---

<BaseLayout title="Blueprint Agent — prompt to deployed Blueprint" description="Generate Blueprints in English. Live workbench, real compile, deploy to operators the same day. 40+ ecosystems, multi-model.">

  <style>
    /* 2-col hero (matches sandbox / browser-agent / operators pattern) */
    .bp-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3rem;
      align-items: center;
      width: 100%;
      max-width: 84rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .bp-hero-code { min-width: 0; }
    @media (max-width: 991px) {
      .bp-hero-grid { grid-template-columns: minmax(0, 1fr); gap: 2rem; }
    }

    .bp-h1 em {
      font-style: normal;
      background: linear-gradient(135deg, #818cf8, #6366F1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* Copy pill tooltip */
    .bp-copy-pill { position: relative; }
    .bp-copy-tooltip {
      position: absolute;
      right: -8px;
      top: -32px;
      background: var(--brand-primary);
      color: #fff;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .bp-copy-pill.copied .bp-copy-tooltip { opacity: 1; }

    /* Bento */
    .bp-bento { display: grid; overflow: hidden; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 80rem; margin: 0 auto; }
    .bp-bento-cell { min-width: 0; overflow: hidden; background: var(--depth-2); border: 1px solid var(--border-default); border-radius: 20px; padding: 2.25rem 2.5rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .bp-bento-cell:hover { background: var(--depth-3); border-color: var(--border-accent); box-shadow: 0 4px 40px rgba(129,140,248,0.06); }
    .bp-bento-cell.span-2 { grid-column: span 2; }
    .bp-bento-cell.span-3 { grid-column: span 3; }
    .bp-bento-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .bp-bento-title { font-family: var(--font-sans); font-size: 1.6rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem; line-height: 1.2; letter-spacing: -0.01em; }
    .bp-bento-desc { font-family: var(--font-sans); font-size: 1rem; font-weight: 500; color: var(--text-secondary); line-height: 1.6; }

    /* Partner marquee */
    .bp-partners { display: flex; overflow: hidden; padding: 2rem 0; }
    .bp-partners-inner { display: flex; align-items: center; gap: 3rem; animation: bp-scroll 40s linear infinite; flex-shrink: 0; }
    @keyframes bp-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    .bp-section { padding: 8rem 5% 4rem; max-width: 80rem; margin: 0 auto; }
    .bp-section-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--brand-primary); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .bp-section-title { font-family: var(--font-sans); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: var(--text-primary); text-align: center; line-height: 1.15; margin-bottom: 1rem; letter-spacing: -0.02em; }
    .bp-section-title em { font-style: normal; background: linear-gradient(135deg, #818cf8, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-section-sub { font-family: var(--font-sans); font-size: 1.1rem; font-weight: 500; color: var(--text-secondary); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    @media (max-width: 768px) {
      .bp-bento { grid-template-columns: 1fr; padding: 0 16px; }
      .bp-bento-cell.span-2, .bp-bento-cell.span-3 { grid-column: span 1; }
      .bp-bento-cell { padding: 1.5rem; }
      .bp-bento-title { font-size: 1.25rem; }
      .bp-section { padding: 4rem 16px 2rem; }
      .bp-section-title { font-size: 1.75rem; }
      .bp-section-sub { font-size: 0.95rem; }
      .bp-partner-contact { flex-direction: column !important; }
      .bp-partner-contact > div:last-child { display: none; }
      .bp-partner-grid-3 { grid-template-columns: 1fr !important; }
    }
  </style>

  <!-- HERO -->
  <section class="wf-section-hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 10rem 5% 4rem; justify-content: flex-start;">
      <div class="bp-hero-grid">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Blueprint Agent</div>
            </div>
          </div>
          <h1 class="wf-h1 bp-h1">Prompt in. <em>Blueprint out.</em></h1>
          <div class="wf-body-01">Describe the service in English. The workbench scaffolds the Rust crate, runs the test suite, and deploys to operators — same session, same protocol you target.</div>
          <div class="wf-install-pill bp-copy-pill" style="margin-top: 8px; cursor: pointer; position: relative;">
            <span class="prompt">$</span>
            <code>npm install -g @tangle-network/blueprint-sdk</code>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-left: auto; opacity: 0.4; flex-shrink: 0;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span class="bp-copy-tooltip">Copied!</span>
          </div>
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: var(--brand-primary); color: white; border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Open the workbench</a>
            <a href="#how-it-ships" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--depth-3); border: 1px solid var(--border-default); color: var(--text-primary); border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">See what it ships</a>
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; color: var(--text-secondary); font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Docs →</a>
          </div>
        </div>

        <div class="bp-hero-code">
          <CodeWindow
            tabs={[
              { id: 'prompt', label: 'workbench', icon: 'terminal', html: bpHeroPrompt },
              { id: 'generated', label: 'src/jobs/sign.rs', icon: 'code', html: bpGeneratedCode },
            ]}
          />
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/cube-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.35;">
          <source src="/videos/cube-dark.webm" type="video/webm" />
          <source src="/videos/cube-dark.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <StatsStrip
    items={[
      { label: '40+ ecosystem templates', icon: 'layers' },
      { label: 'multi-model · Claude · GPT · GLM · Kimi', icon: 'code' },
      { label: 'cargo check + tests every turn', icon: 'shield' },
      { label: 'one-click deploy to Tangle operators', icon: 'zap' },
    ]}
  />

  <!-- Who ships with it — VAULT (light) surface -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 72rem;">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #047857;">BUILT FOR</span>
          <h2 class="wf-h3" style="text-align: left; margin: 0; max-width: 44rem; color: #191c24;">Teams shipping Blueprints as a product.</h2>
          <p class="wf-body-01" style="margin: 0.5rem 0 0; color: #3a3a50; max-width: 44rem;">Not a coding assistant. A Blueprint authoring workbench wired to the protocol — every service it generates is deployable and revenue-collecting the same day.</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 2.5rem;">
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">L1 / L2 FOUNDATIONS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Onboard your ecosystem.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">White-label the workbench. Deep-link your docs and SDK examples. Every Blueprint the agent generates lands on your stack.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">INFRASTRUCTURE TEAMS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Operator-backed services.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Bridges, oracles, indexers, MPC. Generate in English, deploy to operators, collect service fees through the protocol.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">SOLO DEVS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Ship a service in a weekend.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">From prompt to deployed Blueprint earning fees. No DevOps, no billing layer, no infrastructure to babysit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FROM PROMPT — consistent CodeWindow surface -->
  <section id="how-it-ships" class="wf-section" style="background: var(--depth-1);">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 80rem;">
        <SectionHead
          eyebrow="FROM PROMPT"
          eyebrowColor="brand"
          title="Describe it. We scaffold it."
          description="One prompt produces a working Blueprint — Rust crate, jobs, manifest, tests, and a live preview URL. Inspect what it built, edit anything, ship when ready."
          align="center"
        />
        <div style="max-width: 64rem; margin: 2.5rem auto 0;">
          <CodeWindow
            tabs={[
              { id: 'chat', label: 'workbench', icon: 'terminal', html: bpChatCode },
              { id: 'generated', label: 'src/jobs/sign.rs', icon: 'code', html: bpGeneratedCode },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS — Real logos -->
  <div style="border-top: 1px solid rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.04); overflow: hidden;">
    <div style="text-align: center; padding: 2rem 0 0;">
      <span style="font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em;">Generated Blueprints target these protocols</span>
    </div>
    <div class="bp-partners">
      <div class="bp-partners-inner">
        {[
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
        ].map(logo => (
          <img src={`/images/partners/${logo}`} alt="" style="height: 28px; width: auto; opacity: 0.5;  flex-shrink: 0;" loading="lazy" />
        ))}
      </div>
    </div>
  </div>

  <!-- WORKBENCH SHOWCASE -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="bp-section" style="padding-top: 4rem;">
          <div class="bp-section-label">The workbench</div>
          <div class="bp-section-title">Editor, terminal, preview. <em>One sandbox.</em></div>
          <div class="bp-section-sub">CodeMirror, xterm.js, and a live preview that updates per turn. The agent edits files in front of you; you intervene whenever you want.</div>
        </div>
        <div style="position: relative; max-width: 100%;">
          <div style="position: absolute; inset: -12px; border-radius: 24px; background: linear-gradient(135deg, rgba(129,140,248,0.12), rgba(236,72,153,0.06)); filter: blur(32px); pointer-events: none;"></div>
          <img src="/images/products/blueprint-agent-workbench.png" alt="Blueprint Agent workbench — chat, editor, and file tree" style="position: relative; width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 80px rgba(0,0,0,0.6);" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO GRID -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="bp-section" style="padding-top: 4rem;">
          <div class="bp-section-label">Platform</div>
          <div class="bp-section-title">Workbench, 40+ templates, multi-model, <em>GitHub PRs.</em></div>
        </div>
        <div style="padding: 0 0 4rem;">
    <div class="bp-bento">
      <!-- Row 1: Workbench (span-2) + Multi-Model -->
      <div class="bp-bento-cell span-2">
        <div>
          <div class="bp-bento-label">Live workbench</div>
          <div class="bp-bento-title">Editor, terminal, preview — same sandbox.</div>
          <div class="bp-bento-desc">CodeMirror with cargo diagnostics. xterm.js wired to the build container. Preview reloads on every edit. Stop the agent mid-turn, type, resume.</div>
        </div>

  <script>
    document.querySelector('.bp-copy-pill')?.addEventListener('click', () => {
      navigator.clipboard.writeText('npm install -g @tangle-network/blueprint-sdk');
      const pill = document.querySelector('.bp-copy-pill');
      pill?.classList.add('copied');
      setTimeout(() => pill?.classList.remove('copied'), 1500);
    });

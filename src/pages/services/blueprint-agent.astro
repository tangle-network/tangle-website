const bpLifecycleStages = [
  { id: 'spec',  num: '01', title: 'Spec.',  body: 'Describe the agent in plain English. The workbench scaffolds a Rust crate, jobs, manifest, and tests. <strong>One prompt, one repo.</strong>' },
  { id: 'build', num: '02', title: 'Build.', body: 'CodeMirror + xterm.js + live preview, all in one sandbox. Interrupt mid-edit, type, resume. <strong>The agent never loses context.</strong>' },
  { id: 'eval',  num: '03', title: 'Eval.',  body: 'Rubrics, judges, ground-truth. Every variant scored before merge. <strong>No silent regressions.</strong>' },
  { id: 'ship',  num: '04', title: 'Ship.',  body: 'Merge a PR. Publish a versioned API. Drop a buy-link. <strong>Operators run it; you collect.</strong>' },
];


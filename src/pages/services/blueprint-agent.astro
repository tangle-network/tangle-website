---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blueprint Agent — AI Development Platform" description="Build production-grade applications 10x faster. Live workbench, 40+ partner ecosystems, multi-model comparison.">

  <style>
    .bp-hero { position: relative; padding: 12rem 0 6rem; }
    .bp-hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 30% 70%, rgba(129,140,248,0.08), transparent),
        radial-gradient(ellipse 60% 50% at 70% 30%, rgba(236,72,153,0.05), transparent);
    }
    .bp-hero-inner { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; padding: 0 5%; text-align: center; }
    .bp-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(129,140,248,0.3); background: rgba(129,140,248,0.08); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #a5b4fc; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 1.5rem; }
    .bp-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: bp-pulse 2s infinite; }
    @keyframes bp-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .bp-h1 { font-family: 'Satoshi', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 1.5rem; max-width: 700px; }
    .bp-h1 em { font-style: normal; background: linear-gradient(135deg, #818cf8, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-sub { font-family: 'Satoshi', sans-serif; font-size: 1.2rem; font-weight: 500; line-height: 1.6; color: rgba(255,255,255,0.7); max-width: 560px; margin-bottom: 2rem; }

    .bp-terminal-wrap { max-width: 72rem; margin: 0 auto; padding: 0 5%; }
    .bp-terminal { background: #08080f; border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; overflow: hidden; font-family: 'JetBrains Mono', monospace; font-size: 14px; line-height: 1.8; }
    .bp-terminal-chrome { display: flex; align-items: center; gap: 6px; padding: 14px 20px; background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.04); }
    .bp-terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
    .bp-terminal-title { margin-left: 12px; font-size: 12px; color: rgba(255,255,255,0.25); }
    .bp-terminal-body { padding: 1.5rem 2rem; overflow-x: auto; }
    .bp-line { display: block; min-height: 1.8em; white-space: pre-wrap; word-break: break-word; }
    .bp-user { color: #a5b4fc; }
    .bp-agent { color: rgba(255,255,255,0.7); }
    .bp-file { color: #4ade80; }
    .bp-cmd { color: #fbbf24; }
    .bp-dim { color: rgba(255,255,255,0.25); }
    .bp-success { color: #4ade80; }
    .bp-highlight { background: rgba(129,140,248,0.04); margin: 0 -2rem; padding: 0 2rem; }

    .bp-bento { display: grid; overflow: hidden; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 72rem; margin: 0 auto; }
    .bp-bento-cell { min-width: 0; overflow: hidden; background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2.25rem 2.5rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .bp-bento-cell:hover { background: #1a1a30; border-color: rgba(129,140,248,0.25); box-shadow: 0 4px 40px rgba(129,140,248,0.06); }
    .bp-bento-cell.span-2 { grid-column: span 2; }
    .bp-bento-cell.span-3 { grid-column: span 3; }
    .bp-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #818cf8; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .bp-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.6rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.2; }
    .bp-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.6; }
    .bp-bento-code { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: rgba(255,255,255,0.8); background: #0a0a14; padding: 1rem 1.25rem; border-radius: 10px; margin-top: 1.25rem; white-space: pre-wrap; word-break: break-all; line-height: 1.7; border: 1px solid rgba(255,255,255,0.06); }
    .bp-bento-code .g { color: #4ade80; }
    .bp-bento-code .p { color: #ec4899; }
    .bp-bento-code .i { color: #818cf8; }
    .bp-bento-code .w { color: #f1f5f9; }
    .bp-bento-code .y { color: #fbbf24; }
    .bp-bento-code .d { color: rgba(255,255,255,0.3); }

    .bp-partners { display: flex; overflow: hidden; padding: 2rem 0; }
    .bp-partners-inner { display: flex; align-items: center; gap: 3rem; animation: bp-scroll 40s linear infinite; flex-shrink: 0; }
    @keyframes bp-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
    .bp-partner { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 600; color: rgba(255,255,255,0.25); white-space: nowrap; }

    .bp-section { padding: 8rem 5% 4rem; max-width: 80rem; margin: 0 auto; }
    .bp-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #818cf8; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .bp-section-title { font-family: 'Satoshi', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; text-align: center; line-height: 1.15; margin-bottom: 1rem; }
    .bp-section-title em { font-style: normal; background: linear-gradient(135deg, #818cf8, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .bp-section-sub { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.55); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    @media (max-width: 768px) {
      .bp-bento { grid-template-columns: 1fr; }
      .bp-bento-cell.span-2, .bp-bento-cell.span-3 { grid-column: span 1; }
      .bp-terminal { font-size: 12px; }
    }
  </style>

  <!-- HERO — Centered, single column -->
  <section class="bp-hero">
    <div class="bp-hero-inner">
      <div class="bp-badge" style="margin-left: auto; margin-right: auto;">AI Development Platform</div>
      <h1 class="bp-h1" style="max-width: none; margin-left: auto; margin-right: auto;">Blueprint <em>Agent</em></h1>
      <p class="bp-sub" style="max-width: 600px; margin-left: auto; margin-right: auto;">Our premier vibecoding platform for developer onboarding and engagement. Live workbench, 40+ partner ecosystems, multi-model AI — all in one tool.</p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 4rem;">
        <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 14px 28px;">Try Blueprint Agent</a>
        <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none;">View Docs</a>
      </div>

      <!-- Product showcase with glow -->
      <div style="position: relative; max-width: 1000px; margin: 0 auto;">
        <div style="position: absolute; inset: -16px; border-radius: 24px; background: linear-gradient(135deg, rgba(129,140,248,0.15), rgba(236,72,153,0.08)); filter: blur(40px); pointer-events: none;"></div>
        <div style="position: absolute; inset: -30px; border-radius: 32px; background: radial-gradient(ellipse at 50% 0%, rgba(129,140,248,0.1), transparent 70%); pointer-events: none;"></div>
        <img src="/images/products/blueprint-agent-live.png" alt="Blueprint Agent" style="position: relative; width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(129,140,248,0.05);" loading="eager" />
      </div>
    </div>
  </section>

  <!-- PARTNERS — Real logos -->
  <div style="border-top: 1px solid rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.04); overflow: hidden;">
    <div class="bp-partners">
      <div class="bp-partners-inner">
        {[
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
          'coinbase-logo.svg', 'solana-logo.svg', 'worldcoin-logo.svg', 'eigenlayer-logo.svg',
          'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aave.svg',
          'aptos-logo.svg', 'sui-logo.svg', 'hyperliquid.svg', 'openzeppelin-logo.svg',
          'starknet-logo.svg', 'optimism.svg', 'injective-logo.svg', 'succinct-logo.svg',
        ].map(logo => (
          <img src={`/images/partners/${logo}`} alt="" style="height: 28px; width: auto; opacity: 0.5; filter: brightness(0) invert(1); flex-shrink: 0;" loading="lazy" />
        ))}
      </div>
    </div>
  </div>

  <!-- TERMINAL SHOWCASE -->
  <div class="bp-section">
    <div class="bp-section-label">See It Work</div>
    <div class="bp-section-title">From prompt to <em>production.</em></div>
    <div class="bp-section-sub">Describe what you want. The agent generates code, runs it in a sandbox, and shows you a live preview.</div>
  </div>
  <!-- Workbench screenshot with glow -->
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 5%;">
    <div style="position: relative;">
      <div style="position: absolute; inset: -12px; border-radius: 24px; background: linear-gradient(135deg, rgba(129,140,248,0.12), rgba(236,72,153,0.06)); filter: blur(32px); pointer-events: none;"></div>
      <div style="position: absolute; inset: -24px; border-radius: 32px; background: radial-gradient(ellipse at 50% 50%, rgba(129,140,248,0.08), transparent 70%); pointer-events: none;"></div>
      <img src="/images/products/blueprint-agent-workbench.png" alt="Blueprint Agent workbench — chat, editor, and file tree" style="position: relative; width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 80px rgba(0,0,0,0.6);" loading="lazy" />
  </div>

  <!-- BENTO GRID -->
  <div class="bp-section">
    <div class="bp-section-label">Platform</div>
    <div class="bp-section-title">Everything you need to <em>ship.</em></div>
  </div>
  <div style="max-width: 80rem; margin: 0 auto; padding: 0 5% 6rem;">
    <div class="bp-bento">
      <!-- Row 1: Workbench (span-2) + Multi-Model -->
      <div class="bp-bento-cell span-2">
        <div>
          <div class="bp-bento-label">Live Workbench</div>
          <div class="bp-bento-title">Editor. Terminal. Preview. All live.</div>
          <div class="bp-bento-desc">CodeMirror editor, xterm.js terminal, and live preview — updating in real-time as the agent writes.</div>
        </div>
        <!-- Visual: 3 colored panels representing the IDE -->
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-top: 1.5rem;">
          <div style="background: rgba(129,140,248,0.08); border: 1px solid rgba(129,140,248,0.15); border-radius: 10px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #818cf8; margin-bottom: 8px; font-weight: 600;">Editor</div>
            <div style="height: 6px; width: 70%; background: rgba(129,140,248,0.2); border-radius: 3px; margin-bottom: 4px;"></div>
            <div style="height: 6px; width: 50%; background: rgba(236,72,153,0.15); border-radius: 3px; margin-bottom: 4px;"></div>
            <div style="height: 6px; width: 85%; background: rgba(255,255,255,0.06); border-radius: 3px;"></div>
          </div>
          <div style="background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12); border-radius: 10px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #4ade80; margin-bottom: 8px; font-weight: 600;">Preview</div>
            <div style="height: 24px; width: 60%; background: rgba(74,222,128,0.1); border-radius: 4px; margin-bottom: 6px;"></div>
            <div style="height: 16px; width: 80%; background: rgba(129,140,248,0.15); border-radius: 4px;"></div>
          </div>
          <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 14px 16px; min-height: 80px;">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.4); margin-bottom: 8px; font-weight: 600;">Terminal</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #4ade80;">$ next dev</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: rgba(255,255,255,0.3);">✓ Ready :3000</div>
          </div>
        </div>
      </div>

      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Multi-Model</div>
          <div class="bp-bento-title">Compare AI models.</div>
          <div class="bp-bento-desc">Same prompt across Claude, GPT, GLM, Kimi. Pick the best.</div>
        </div>
        <!-- Visual: model comparison bars -->
        <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 1.25rem;">
          {[
            { name: 'Claude', color: '#818cf8', width: '95%', speed: '34s' },
            { name: 'GPT-5', color: '#4ade80', width: '88%', speed: '28s' },
            { name: 'GLM', color: '#fbbf24', width: '85%', speed: '12s' },
            { name: 'Kimi', color: '#ec4899', width: '72%', speed: '8s' },
          ].map(m => (
            <div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                <span style="font-family: 'Satoshi', sans-serif; font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.7);">{m.name}</span>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.35);">{m.speed}</span>
              </div>
              <div style="height: 6px; background: rgba(255,255,255,0.04); border-radius: 3px; overflow: hidden;">
                <div style={`height: 100%; width: ${m.width}; background: ${m.color}; border-radius: 3px; opacity: 0.6;`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Row 2: Partners (with logos) + Batch + GitHub -->
      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">40+ Partners</div>
          <div class="bp-bento-title">Every ecosystem.</div>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 1rem;">
          {['coinbase-logo.svg', 'solana-logo.svg', 'eigenlayer-logo.svg', 'arbitrum-logo.svg', 'base-logo.svg', 'chainlink.svg', 'aptos-logo.svg', 'sui-logo.svg', 'aave.svg', 'openzeppelin-logo.svg', 'starknet-logo.svg', 'optimism.svg'].map(logo => (
            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center;">
              <img src={`/images/partners/${logo}`} alt="" style="height: 16px; width: auto; opacity: 0.5; filter: brightness(0) invert(1);" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Batch Tasks</div>
          <div class="bp-bento-title">Parallel execution.</div>
          <div class="bp-bento-desc">Run across models, compare side-by-side, create PRs from best variant.</div>
        </div>
        <!-- Visual: parallel task bars -->
        <div style="display: flex; flex-direction: column; gap: 6px; margin-top: 1rem;">
          {['Claude', 'GPT', 'GLM'].map((m, i) => (
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style={`width: 8px; height: 8px; border-radius: 50%; background: ${['#818cf8','#4ade80','#fbbf24'][i]};`}></div>
              <div style={`height: 4px; flex: 1; background: ${['#818cf8','#4ade80','#fbbf24'][i]}; border-radius: 2px; opacity: 0.3;`}></div>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: rgba(255,255,255,0.3);">{m}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">GitHub Native</div>
          <div class="bp-bento-title">PR in one click.</div>
          <div class="bp-bento-desc">Push, create PRs, track merges — from the workbench.</div>
        </div>
        <!-- Visual: PR status badges -->
        <div style="display: flex; flex-direction: column; gap: 6px; margin-top: 1rem;">
          <div style="display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12); border-radius: 6px;">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #4ade80;"></div>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: rgba(255,255,255,0.6);">PR #42 merged</span>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: rgba(129,140,248,0.06); border: 1px solid rgba(129,140,248,0.12); border-radius: 6px;">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #818cf8;"></div>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: rgba(255,255,255,0.6);">PR #43 open</span>
          </div>
        </div>
      </div>

      <!-- Row 3: Templates (span-2) + Thinking -->
      <div class="bp-bento-cell span-2">
        <div>
          <div class="bp-bento-label">Starter Templates</div>
          <div class="bp-bento-title">Pre-configured stacks. 3x faster.</div>
          <div class="bp-bento-desc">Battle-tested templates for every partner ecosystem.</div>
        </div>
        <!-- Visual: template pills -->
        <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 1.25rem;">
          {[
            { name: 'Solana DEX', color: '#818cf8' },
            { name: 'Coinbase Commerce', color: '#3b82f6' },
            { name: 'EigenLayer AVS', color: '#a78bfa' },
            { name: 'NFT Marketplace', color: '#ec4899' },
            { name: 'Smart Wallet', color: '#3b82f6' },
            { name: 'Staking', color: '#818cf8' },
            { name: 'Trading Bot', color: '#fbbf24' },
            { name: 'Risc0 ZK', color: '#4ade80' },
            { name: 'World ID', color: '#f97316' },
            { name: 'Tangle Blueprint', color: '#8e59ff' },
          ].map(t => (
            <div style={`padding: 5px 12px; border-radius: 6px; border: 1px solid ${t.color}25; background: ${t.color}08; font-family: 'Satoshi', sans-serif; font-size: 11px; font-weight: 600; color: ${t.color};`}>{t.name}</div>
          ))}
        </div>
      </div>

      <div class="bp-bento-cell">
        <div>
          <div class="bp-bento-label">Extended Thinking</div>
          <div class="bp-bento-title">See the reasoning.</div>
          <div class="bp-bento-desc">Watch the AI think through architecture decisions before writing code.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start building with AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">40+ ecosystems. Multi-model. Live preview. Production-ready in minutes.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Blueprint Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
  { title: 'AI Tax Preparation', description: 'Upload your documents and let the AI extract, categorize, and prepare your tax return automatically.' },
  { title: 'Multi-Format Support', description: 'W-2s, 1099s, K-1s, receipts, bank statements — any format, any source. The agent handles it all.' },
  { title: 'Real-Time Review', description: 'Interactive review process where you can ask questions, request changes, and verify every line item.' },
  { title: 'Deduction Discovery', description: 'AI identifies deductions and credits you might miss. Optimizes your return for maximum savings.' },
  { title: 'Secure & Private', description: 'Your data never leaves the secure environment. End-to-end encryption with sandboxed execution.' },
  { title: 'Audit-Ready', description: 'Every calculation is documented with source references. Full audit trail if you ever need it.' },
];
---

<BaseLayout title="Tax Agent" description="AI-powered tax preparation. Upload your documents, let the AI prepare your return, review and file.">

  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Service</div>
            </div>
          </div>
          <h1 class="wf-h1">Tax Agent</h1>
          <div class="wf-body-01">AI-powered tax preparation that actually works. Upload your documents, review the AI's work, and file with confidence.</div>
          <div class="wf-button-row">
            <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Try Tax Agent</a>
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">View Docs</a>
          </div>
        </div>
      </div>
    </section>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Features</div>
            </div>
          </div>
          <div class="wf-h3">Taxes Made <span class="wf-gradient-text">Effortless</span></div>
          <div class="wf-body-02 align-center">Stop overpaying for tax prep. The AI agent reads your documents, finds every deduction, and prepares your return in minutes.</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {features.map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.35rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; line-height: 1.6;">{f.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">How It Works</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; max-width: 900px; margin: 0 auto;">
          <div style="text-align: center;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: #6172f3; margin-bottom: 12px;">1</div>
            <div class="wf-h4" style="font-size: 1.25rem; margin-bottom: 8px;">Upload</div>
            <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500;">Drop your tax documents — W-2s, 1099s, receipts, bank statements. Any format works.</div>
          </div>
          <div style="text-align: center;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: #6172f3; margin-bottom: 12px;">2</div>
            <div class="wf-h4" style="font-size: 1.25rem; margin-bottom: 8px;">Review</div>
            <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500;">The AI extracts data, finds deductions, and prepares your return. Review every line interactively.</div>
          </div>
          <div style="text-align: center;">
            <div style="font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: #6172f3; margin-bottom: 12px;">3</div>
            <div class="wf-h4" style="font-size: 1.25rem; margin-bottom: 8px;">File</div>
            <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500;">Approve and file electronically. Get your refund fast with full audit documentation.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">File Your Taxes with AI</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Upload your documents and let the AI do the rest. Faster, cheaper, and more accurate than traditional tax prep.</div>
        <div class="wf-cta-button-row">
          <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Filing</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

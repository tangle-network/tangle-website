---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tax Agent — AI-Powered Tax Prep" description="Upload your documents, review the AI's work, file with confidence. Faster and cheaper than a CPA.">

  <style>
    .ta-hero { position: relative; padding: 12rem 0 6rem; }
    .ta-hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 25% 70%, rgba(251,191,36,0.06), transparent),
        radial-gradient(ellipse 60% 50% at 70% 30%, rgba(142,89,255,0.05), transparent);
    }
    .ta-hero-inner { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; padding: 0 5%; text-align: center; }
    .ta-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(251,191,36,0.3); background: rgba(251,191,36,0.08); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #fbbf24; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 1.5rem; }
    .ta-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: ta-pulse 2s infinite; }
    @keyframes ta-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .ta-h1 { font-family: 'Satoshi', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 1.5rem; }
    .ta-h1 em { font-style: normal; background: linear-gradient(135deg, #fbbf24, #f97316); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ta-sub { font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto 2rem; }

    /* Flow steps */
    .ta-flow-wrap { max-width: 64rem; margin: 0 auto; padding: 0 5%; }
    .ta-flow { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; align-items: stretch; }
    .ta-flow-step { position: relative; text-align: center; padding: 3rem 2rem; background: #141428; border: 1px solid rgba(255,255,255,0.12); transition: all 0.4s; }
    .ta-flow-step:first-child { border-radius: 20px 0 0 20px; }
    .ta-flow-step:last-child { border-radius: 0 20px 20px 0; }
    .ta-flow-step:hover { background: rgba(255,255,255,0.04); border-color: rgba(251,191,36,0.2); }
    .ta-flow-num { font-family: 'Satoshi', sans-serif; font-size: 3.5rem; font-weight: 800; line-height: 1; margin-bottom: 1rem; background: linear-gradient(135deg, rgba(251,191,36,0.4), rgba(249,115,22,0.2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ta-flow-title { font-family: 'Satoshi', sans-serif; font-size: 1.3rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
    .ta-flow-desc { font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.6; }
    .ta-flow-arrow { position: absolute; right: -14px; top: 50%; transform: translateY(-50%); z-index: 2; width: 28px; height: 28px; border-radius: 50%; background: #111118; border: 1px solid rgba(251,191,36,0.25); display: flex; align-items: center; justify-content: center; }
    .ta-flow-arrow svg { width: 14px; height: 14px; color: #fbbf24; }

    /* Bento grid */
    .ta-bento { display: grid; overflow: hidden; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 72rem; margin: 0 auto; }
    .ta-bento-cell { min-width: 0; overflow: hidden; background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2rem 2.25rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .ta-bento-cell:hover { background: rgba(255,255,255,0.04); border-color: rgba(251,191,36,0.2); box-shadow: 0 0 40px rgba(251,191,36,0.04); }
    .ta-bento-cell.span-2 { grid-column: span 2; }
    .ta-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(251,191,36,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .ta-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.2; }
    .ta-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.6; }
    .ta-bento-visual { background: rgba(0,0,0,0.4); padding: 1.25rem 1.5rem; border-radius: 12px; margin-top: 1.5rem; border: 1px solid rgba(255,255,255,0.04); }
    .ta-bento-visual .row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-family: 'Satoshi', sans-serif; font-size: 0.85rem; }
    .ta-bento-visual .row:last-child { border-bottom: none; }
    .ta-bento-visual .row-label { color: rgba(255,255,255,0.8); font-weight: 500; }
    .ta-bento-visual .row-value { color: white; font-weight: 600; }
    .ta-bento-visual .row-value.green { color: #4ade80; }
    .ta-bento-visual .row-value.amber { color: #fbbf24; }
    .ta-stat { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .ta-stat-num { font-family: 'Satoshi', sans-serif; font-size: 2rem; font-weight: 800; color: white; }
    .ta-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.08em; }

    /* Section headers */
    .ta-section { padding: 8rem 5% 6rem; max-width: 80rem; margin: 0 auto; }
    .ta-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(251,191,36,0.5); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .ta-section-title { font-family: 'Satoshi', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; text-align: center; line-height: 1.15; margin-bottom: 1rem; }
    .ta-section-title em { font-style: normal; background: linear-gradient(45deg, #fbbf24, #f97316); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ta-section-sub { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.8); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    /* Mobile */
    @media (max-width: 768px) {
      .ta-flow { grid-template-columns: 1fr; gap: 12px; }
      .ta-flow-step { border-radius: 20px !important; }
      .ta-flow-arrow { display: none; }
      .ta-bento { grid-template-columns: 1fr; }
      .ta-bento-cell.span-2 { grid-column: span 1; }
      .ta-bento-cell.span-2 { grid-column: span 1; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="ta-hero">
    <div class="ta-hero-inner">
      <div class="ta-badge">Live</div>
      <h1 class="ta-h1">Taxes made<br/><em>effortless.</em></h1>
      <p class="ta-sub">Upload your documents, review the AI's work, file with confidence. Faster and cheaper than a CPA — with a full audit trail for every number.</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 4rem;">
        <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 14px 28px;">Start Filing</a>
        <a href="#how-it-works" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none;">
          See How It Works
        </a>
      </div>

      <!-- Product screenshot -->
      <div style="position: relative; max-width: 1000px; margin: 0 auto;">
        <div style="position: absolute; inset: -16px; border-radius: 24px; background: linear-gradient(135deg, rgba(251,191,36,0.1), rgba(249,115,22,0.05)); filter: blur(40px); pointer-events: none;"></div>
        <img src="/images/products/tax-agent-app.png" alt="Tax Agent" style="position: relative; width: 100%; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 80px rgba(0,0,0,0.5);" loading="eager" />
      </div>
    </div>
  </section>

  <!-- =======================================
       FLOW — Upload → Process → Review → Filed
       ======================================= -->
  <div class="ta-section" id="how-it-works">
    <div class="ta-section-label">How It Works</div>
    <div class="ta-section-title">Four steps to <em>filed.</em></div>
    <div class="ta-section-sub">Drop your documents and let the AI handle the rest. Review every line before you file.</div>
  </div>

  <!-- Product screenshot -->
  <div style="max-width: 56rem; margin: 0 auto 3rem; padding: 0 5%;">
    <div style="position: relative;">
      <div style="position: absolute; inset: -6px; border-radius: 16px; background: linear-gradient(135deg, rgba(251,191,36,0.1), rgba(249,115,22,0.05)); filter: blur(20px); pointer-events: none;"></div>
      <img src="/images/products/tax-agent-app.png" alt="Tax Agent — taxes.tangle.tools" style="position: relative; width: 100%; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);" loading="eager" />
    </div>
  </div>

  <div class="ta-flow-wrap">
    <div class="ta-flow">
      <div class="ta-flow-step">
        <div class="ta-flow-num">1</div>
        <div class="ta-flow-title">Upload</div>
        <div class="ta-flow-desc">Drop W-2s, 1099s, K-1s, receipts, bank statements. Any format — PDF, photo, CSV.</div>
        <div class="ta-flow-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </div>
      <div class="ta-flow-step">
        <div class="ta-flow-num">2</div>
        <div class="ta-flow-title">AI Processing</div>
        <div class="ta-flow-desc">The agent extracts every number, categorizes income, finds deductions you'd miss.</div>
        <div class="ta-flow-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </div>
      <div class="ta-flow-step">
        <div class="ta-flow-num">3</div>
        <div class="ta-flow-title">Review</div>
        <div class="ta-flow-desc">Verify every line item interactively. Ask questions in plain English. Request changes.</div>
        <div class="ta-flow-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </div>
      <div class="ta-flow-step">
        <div class="ta-flow-num">4</div>
        <div class="ta-flow-title">Filed</div>
        <div class="ta-flow-desc">Approve and e-file directly. Full audit documentation with source references for every calculation.</div>
      </div>
    </div>
  </div>

  <!-- =======================================
       BENTO GRID — Capabilities
       ======================================= -->
  <div class="ta-section">
    <div class="ta-section-label">Capabilities</div>
    <div class="ta-section-title">Every scenario. <em>Handled.</em></div>
  </div>
  <div style="max-width: 64rem; margin: 0 auto; padding: 0 5% 6rem;">
    <div class="ta-bento">
      <!-- Small: Individual Filing -->
      <div class="ta-bento-cell">
        <div>
          <div class="ta-bento-label">Individual Filing</div>
          <div class="ta-bento-title">W-2s to rentals.</div>
          <div class="ta-bento-desc">Wages, freelance 1099s, investment gains, rental properties, itemized deductions. Federal and state returns prepared together.</div>
        </div>
        <div class="ta-bento-visual">
          <div class="row"><span class="row-label">W-2 Income</span><span class="row-value">$95,200</span></div>
          <div class="row"><span class="row-label">1099 Freelance</span><span class="row-value">$23,400</span></div>
          <div class="row"><span class="row-label">Deductions Found</span><span class="row-value green">$14,820</span></div>
        </div>
      </div>

      <!-- Small: Business Taxes -->
      <div class="ta-bento-cell">
        <div>
          <div class="ta-bento-label">Business Taxes</div>
          <div class="ta-bento-title">LLCs to S-Corps.</div>
          <div class="ta-bento-desc">Profit & loss categorization, estimated payments, depreciation schedules, and quarterly filings for any entity type.</div>
        </div>
        <div class="ta-bento-visual">
          <div class="row"><span class="row-label">Revenue</span><span class="row-value">$342,000</span></div>
          <div class="row"><span class="row-label">Expenses</span><span class="row-value">$198,400</span></div>
          <div class="row"><span class="row-label">Tax Liability</span><span class="row-value amber">$31,752</span></div>
        </div>
      </div>

      <!-- Large: Crypto Taxes -->
      <div class="ta-bento-cell span-2">
        <div>
          <div class="ta-bento-label">Crypto Taxes</div>
          <div class="ta-bento-title">Thousands of transactions. One click.</div>
          <div class="ta-bento-desc">Import from any exchange or wallet. Automatic cost-basis calculation across DeFi, NFTs, staking rewards, and airdrops — FIFO, LIFO, or specific ID methods.</div>
        </div>
        <div class="ta-bento-visual">
          <div class="row"><span class="row-label">Exchanges Imported</span><span class="row-value">Coinbase, Kraken, Uniswap, MetaMask</span></div>
          <div class="row"><span class="row-label">Transactions Processed</span><span class="row-value">4,218</span></div>
          <div class="row"><span class="row-label">Short-Term Gains</span><span class="row-value amber">$8,340</span></div>
          <div class="row"><span class="row-label">Long-Term Gains</span><span class="row-value green">$24,120</span></div>
          <div class="row"><span class="row-label">Harvested Losses</span><span class="row-value green">-$6,200</span></div>
        </div>
      </div>

      <!-- Small: Deduction Discovery -->
      <div class="ta-bento-cell">
        <div>
          <div class="ta-bento-label">Deduction Discovery</div>
          <div class="ta-bento-title">Find what you missed.</div>
          <div class="ta-bento-desc">The AI cross-references your documents against 800+ deduction rules. Finds credits and write-offs you'd never catch manually.</div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 1.5rem;">
          <div class="ta-stat">
            <div class="ta-stat-num">$4,200</div>
            <div class="ta-stat-label">Avg. Found</div>
          </div>
          <div class="ta-stat">
            <div class="ta-stat-num">800+</div>
            <div class="ta-stat-label">Rules Checked</div>
          </div>
        </div>
      </div>

      <!-- Small: Secure & Private -->
      <div class="ta-bento-cell">
        <div>
          <div class="ta-bento-label">Secure & Private</div>
          <div class="ta-bento-title">Your data stays yours.</div>
          <div class="ta-bento-desc">End-to-end encryption. Documents processed in isolated sandboxes. Your data is never used for training or shared with third parties.</div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 1.5rem;">
          <div class="ta-stat">
            <div class="ta-stat-num">E2E</div>
            <div class="ta-stat-label">Encrypted</div>
          </div>
          <div class="ta-stat">
            <div class="ta-stat-num">SOC 2</div>
            <div class="ta-stat-label">Compliant</div>
          </div>
        </div>
      </div>

      <!-- Small: Audit-Ready -->
      <div class="ta-bento-cell">
        <div>
          <div class="ta-bento-label">Audit-Ready</div>
          <div class="ta-bento-title">Every number traced.</div>
          <div class="ta-bento-desc">Every calculation documented with source references. Full audit trail linking each number back to its original document.</div>
        </div>
        <div class="ta-bento-visual">
          <div class="row"><span class="row-label">Source References</span><span class="row-value green">148</span></div>
          <div class="row"><span class="row-label">Audit Score</span><span class="row-value green">A+</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">File your taxes with AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Upload, review, file. Faster and cheaper than a CPA — with a full audit trail.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Filing</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tax Agent — AI-Powered Tax Prep" description="Upload your documents, review the AI's work, file with confidence. Faster and cheaper than a CPA.">

  <!-- ======================================
       HERO — Full-width left-aligned
       ====================================== -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container" style="z-index: 1; position: relative;">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 5px 14px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.25); background: rgba(142,89,255,0.06); margin-bottom: 20px;">
            <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">Service</span>
          </div>
          <h1 class="wf-h1">Taxes made effortless.</h1>
          <div class="wf-body-01" style="max-width: 540px;">Upload your documents, review the AI's work, file with confidence. Faster and cheaper than a CPA.</div>
          <div class="wf-button-row">
            <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Start Filing</a>
            <a href="#how-it-works" class="wf-btn-primary">Learn More</a>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- ======================================
       HOW IT WORKS — 3 Steps
       ====================================== -->
  <section class="wf-section" id="how-it-works">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">Three steps to <span class="wf-gradient-text">filed</span></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; max-width: 1000px; margin: 0 auto;">
          {[
            { step: '1', title: 'Upload', desc: 'Drop your tax documents — W-2s, 1099s, K-1s, receipts, bank statements, crypto reports. Any format, any source.', accent: 'rgba(142,89,255,0.12)' },
            { step: '2', title: 'Review', desc: 'The AI extracts every number, finds deductions you\'d miss, and prepares your return. Review every line item interactively.', accent: 'rgba(97,114,243,0.12)' },
            { step: '3', title: 'File', desc: 'Approve and e-file directly. Full audit documentation with source references for every calculation.', accent: 'rgba(74,58,255,0.12)' },
          ].map((s) => (
            <div style="text-align: center; padding: 2rem 1.5rem; border-radius: 1.5rem; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03); transition: border-color 0.3s;">
              <div style={`width: 56px; height: 56px; border-radius: 14px; background: ${s.accent}; border: 1px solid rgba(142,89,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;`}>
                <span style="font-family: 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 800; color: #8e59ff;">{s.step}</span>
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.2rem; font-weight: 700; color: white; margin-bottom: 10px;">{s.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.6;">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       USE CASES — Tax scenarios
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Use Cases</div>
            </div>
          </div>
          <div class="wf-h3">Every tax scenario, <span class="wf-gradient-text">handled</span></div>
          <div class="wf-body-02 align-center">From simple W-2 returns to multi-entity crypto portfolios. One agent covers it all.</div>
        </div>

        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { title: 'Individual Filing', desc: 'W-2 income, freelance 1099s, investment gains, rental properties, itemized deductions. Federal and state returns prepared together.' },
            { title: 'Business Taxes', desc: 'Sole proprietors, LLCs, S-Corps. Profit & loss categorization, estimated payments, depreciation schedules, and quarterly filings.' },
            { title: 'Crypto Taxes', desc: 'Import from any exchange or wallet. Automatic cost-basis calculation across thousands of transactions — FIFO, LIFO, or specific ID.' },
            { title: 'Quarterly Estimates', desc: 'Track income throughout the year, calculate estimated payments, and generate vouchers. Never miss a deadline or overpay.' },
          ].map((uc) => (
            <div class="wf-builder-feature-card" style="padding: 1.5rem;">
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 8px;">{uc.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.5); line-height: 1.6;">{uc.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       FEATURES — Capabilities grid
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Platform</div>
            </div>
          </div>
          <div class="wf-h3">AI that actually <span class="wf-gradient-text">understands</span> taxes.</div>
        </div>
        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(3, 1fr);">
          {[
            { title: 'AI Tax Prep', desc: 'Upload documents and the AI extracts, categorizes, and prepares your return automatically. No data entry, no copy-pasting.' },
            { title: 'Multi-Format Support', desc: 'W-2s, 1099s, K-1s, receipts, bank statements, brokerage reports — PDFs, photos, CSVs. Any format, any source.' },
            { title: 'Deduction Discovery', desc: 'The AI cross-references your documents against 800+ deduction rules. Finds credits and write-offs you\'d never catch manually.' },
            { title: 'Interactive Review', desc: 'Ask questions about any line item. Request changes in plain English. Verify every number before filing.' },
            { title: 'Secure & Private', desc: 'End-to-end encryption. Documents processed in isolated sandboxes. Your data is never used for training.' },
            { title: 'Audit-Ready', desc: 'Every calculation documented with source references. Full audit trail linking each number back to its original document.' },
          ].map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.15rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: rgba(255,255,255,0.5); font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; line-height: 1.6;">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       CTA
       ====================================== -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">File your taxes with AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Upload, review, file. Faster and cheaper than a CPA — with a full audit trail.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://taxes.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Start Filing</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

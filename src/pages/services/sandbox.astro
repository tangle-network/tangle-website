            </div>

            <div style="font-family: 'JetBrains Mono', monospace; font-size: 24px; color: rgba(97,114,243,0.4); padding: 0 0.5rem;">→</div>

            <!-- API -->
            <div style="text-align: center; padding: 0 1.5rem;">
              <div style="width: 64px; height: 64px; border-radius: 16px; background: rgba(97,114,243,0.1); border: 1px solid rgba(97,114,243,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 8px;">
                <span style="font-size: 28px;">⚡</span>
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 600; color: white;">Tangle API</div>
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.3);">orchestrate</div>
            </div>


---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
import SandboxShowcase from '../../components/SandboxShowcase';
import FAQ from '../../components/FAQ.astro';

const faqs = [
  { question: 'What is the Sandbox SDK?', answer: 'The Sandbox SDK lets you create isolated cloud containers for AI agents via a TypeScript SDK or CLI. Each sandbox is a full Linux environment with root access, SSH, file system operations, and optional GPU support — provisioned in seconds.' },
  { question: 'What AI backends are supported?', answer: 'Sandboxes support multiple agent backends: OpenCode (multi-provider, default), Claude Code (Anthropic-native), Codex (OpenAI-native), AMP (Sourcegraph), and Factory Droids. You can also bring your own API key and switch backends per request.' },
  { question: 'What languages and runtimes work?', answer: 'Any Docker image works — Node.js, Python, Rust, Go, Ubuntu, or your own custom Dockerfile. Pre-built images are available for common stacks like Ethereum, Solana, and ML workloads. GPU images with CUDA support are available for inference and training.' },
  { question: 'How does snapshot and restore work?', answer: 'You can checkpoint the full state of any sandbox — filesystem, installed packages, everything. Restore instantly to create new sandboxes from that state. Bring your own S3-compatible storage (AWS S3, GCS, Cloudflare R2) for snapshot persistence.' },
];
---

<BaseLayout title="Sandbox SDK — Secure Cloud for AI Agents" description="Spin up isolated environments, run AI agents, stream results. TypeScript SDK, CLI, zero DevOps.">

  <style>
    .sb-gradient-text em {
      font-style: normal;
      background: linear-gradient(135deg, #818cf8, #6172f3);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .sb-copy-pill { position: relative; }
    .sb-copy-tooltip {
      position: absolute;
      right: -8px;
      top: -32px;
      background: #4ade80;
      color: #000;
      font-family: 'Satoshi', sans-serif;
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .sb-copy-pill.copied .sb-copy-tooltip { opacity: 1; }

    /* Problem/Solution cards */
    .sb-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .sb-card {
      background: transparent;
      border: 2px solid rgb(42,43,57);
      border-radius: 32px;
      padding: 2.25rem 2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .sb-card:hover { border-color: rgba(142,89,255,0.35); box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
    .sb-card-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      color: rgba(97,114,243,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;
    }
    .sb-card-title { font-family: 'Satoshi', sans-serif; font-size: 1.35rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.25; }
    .sb-card-desc { font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.55); line-height: 1.6; }

    /* How it works steps */
    .sb-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; max-width: 64rem; margin: 0 auto; }
    .sb-step { text-align: center; }
    .sb-step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(97,114,243,0.12); border: 2px solid rgba(97,114,243,0.3);
      font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #818cf8;
      margin-bottom: 1.25rem;
    }
    .sb-step-title { font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
    .sb-step-desc { font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.6; }
    .sb-step-connector { display: none; }

    /* Bento grid */
    .sb-bento { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .sb-bento-cell {
      background: transparent;
      border: 2px solid rgb(42,43,57);
      border-radius: 32px;
      padding: 2rem 2.25rem;
      display: flex;
      flex-direction: column;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .sb-bento-cell:hover { border-color: rgba(142,89,255,0.35); box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
    .sb-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(97,114,243,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .sb-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.35rem; font-weight: 700; color: white; margin-bottom: 0.5rem; line-height: 1.25; }
    .sb-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.55); line-height: 1.6; }

    /* Section label */
    .sb-section-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      color: rgba(97,114,243,0.5); text-transform: uppercase;
      letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem;
    }

    /* Hero grid */
    .sb-hero-grid {
      display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: center;
    }

    /* Mobile */
    @media (max-width: 991px) {
      .sb-hero-grid { grid-template-columns: 1fr !important; }
    }
    @media (max-width: 768px) {
      .sb-cards { grid-template-columns: 1fr; }
      .sb-steps { grid-template-columns: 1fr; gap: 1.5rem; }
      .sb-bento { grid-template-columns: 1fr; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="wf-section-hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 10rem 5% 4rem; justify-content: flex-start;">
      <div style="max-width: 80rem; width: 100%; margin: 0 auto; position: relative; z-index: 1;">
        <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: center;">
          <div class="wf-hero-text" style="align-items: flex-start;">
            <div class="wf-glowing-wrapper">
              <div class="wf-glowing-wrapper-button">
                <div class="wf-button-text-pill">Sandbox SDK</div>
              </div>
            </div>
            <h1 class="wf-h1 sb-gradient-text">Give your agents the <em>real world,</em> safely.</h1>
            <div class="wf-body-01">Isolated cloud containers for AI agents. Create, execute, stream — from TypeScript or CLI. Sub-second provisioning, any Docker image, zero DevOps.</div>
            <div class="wf-install-pill sb-copy-pill" style="margin-top: 8px; cursor: pointer; position: relative;">
              <span class="prompt">$</span>
              <code>npm install @tangle-network/sandbox</code>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-left: auto; opacity: 0.4; flex-shrink: 0;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span class="sb-copy-tooltip">Copied!</span>
            </div>
            <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
              <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: white; color: #211f54; border-radius: 48px; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none;">Documentation</a>
              <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: #1e116e; color: white; border-radius: 48px; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none;">Join Waitlist</a>
            </div>
          </div>
          <!-- Hero terminal — live streaming feel -->
          <div style="position: relative; z-index: 1;">
            <div style="position: absolute; inset: -12px; border-radius: 20px; background: radial-gradient(ellipse at 50% 0%, rgba(97,114,243,0.12) 0%, transparent 70%); filter: blur(30px); pointer-events: none;"></div>
            <div style="position: relative; overflow: hidden; border-radius: 16px; border: 2px solid rgb(42,43,57); background: #0a0a0a;">
              <div style="display: flex; align-items: center; padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.015);">
                <div style="display: flex; gap: 6px; margin-right: 14px;">
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,95,87,0.7);"></div>
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(254,188,46,0.7);"></div>
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(74,222,128,0.7);"></div>
                </div>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.2);">sandbox — streaming</span>
              </div>
              <pre style="padding: 20px 24px; font-family: 'JetBrains Mono', monospace; font-size: 13.5px; line-height: 1.75; color: rgba(255,255,255,0.7); margin: 0; white-space: pre-wrap;"><code><span style="color: #c084fc;">const</span> <span style="color: rgba(255,255,255,0.8);">box</span> = <span style="color: #c084fc;">await</span> client.<span style="color: rgba(255,255,255,0.8);">create</span>({"{"} image: <span style="color: #a78bfa;">'node:22'</span> {"}"});

<span style="color: rgba(255,255,255,0.3);">// Stream an AI agent task in real-time</span>
<span style="color: #c084fc;">for await</span> (<span style="color: #c084fc;">const</span> <span style="color: rgba(255,255,255,0.8);">event</span> <span style="color: #c084fc;">of</span> box.<span style="color: rgba(255,255,255,0.8);">streamTask</span>(
  <span style="color: #a78bfa;">'Refactor src/ to TypeScript and add tests'</span>
)) {"{"}<span style="color: rgba(255,255,255,0.3);"></span>
  <span style="color: #c084fc;">if</span> (event.type === <span style="color: #a78bfa;">'tool_call'</span>)
    console.log(<span style="color: #a78bfa;">`Using: </span><span style="color: #fbbf24;">$&#123;event.tool&#125;</span><span style="color: #a78bfa;">`</span>);
  <span style="color: #c084fc;">if</span> (event.type === <span style="color: #a78bfa;">'message'</span>)
    process.stdout.write(event.content);
{"}"}

<span style="color: #4ade80;">✓ 12 files converted</span>  <span style="color: rgba(255,255,255,0.3);">· 47 tests passing</span>
<span style="color: #4ade80;">✓ PR #18 created</span>      <span style="color: rgba(255,255,255,0.3);">· src/ → TypeScript</span></code></pre>
            </div>
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.35;">
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- INTERACTIVE SHOWCASE — immediately after hero -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">See It Work</div>
          <div class="wf-h3 sb-gradient-text">SDK and CLI. <em>Full control.</em></div>
          <div class="wf-body-02 align-center">Every example uses the real <code style="color: #818cf8; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">@tangle-network/sandbox</code> API.</div>
        </div>
        <SandboxShowcase client:load />
      </div>
    </div>
  </section>

  <!-- =======================================
       PROBLEM → SOLUTION
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">The Problem</div>
          <div class="wf-h3 sb-gradient-text">Agents need <em>real environments.</em></div>
        </div>
        <div class="sb-cards">
          <div class="sb-card">
            <div class="sb-card-label">Isolation</div>
            <div class="sb-card-title">Run untrusted code safely.</div>
            <div class="sb-card-desc">Each sandbox is a locked-down container — dropped capabilities, no privilege escalation, no network escape by default. Agents experiment freely without touching your infrastructure.</div>
          </div>
          <div class="sb-card">
            <div class="sb-card-label">Speed</div>
            <div class="sb-card-title">Scale to thousands.</div>
            <div class="sb-card-desc">Sandboxes provision in seconds, not minutes. Run batch tasks across dozens of containers in parallel. Autoscaling and host pooling handle the fleet.</div>
          </div>
          <div class="sb-card">
            <div class="sb-card-label">Flexibility</div>
            <div class="sb-card-title">Any language. Any tool.</div>
            <div class="sb-card-desc">Docker-based — use any image. Node, Python, Rust, CUDA, or your own Dockerfile. Full root access, SSH, file I/O, git operations, and tool installation via mise.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =======================================
       HOW IT WORKS
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">How It Works</div>
          <div class="wf-h3 sb-gradient-text">Three steps to a <em>running agent.</em></div>
        </div>
        <div class="sb-steps">
          <div class="sb-step">
            <div class="sb-step-num">1</div>
            <div class="sb-step-title">Create</div>
            <div class="sb-step-desc">Pick a Docker image, set resources, and call <code style="color: #818cf8; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">client.create()</code>. Your sandbox is running in seconds with full root access.</div>
          </div>
          <div class="sb-step">
            <div class="sb-step-num">2</div>
            <div class="sb-step-title">Execute</div>
            <div class="sb-step-desc">Run commands with <code style="color: #818cf8; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">box.exec()</code>, send agent tasks with <code style="color: #818cf8; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">box.task()</code>, or SSH in directly. Read/write files, search code, manage git.</div>
          </div>
          <div class="sb-step">
            <div class="sb-step-num">3</div>
            <div class="sb-step-title">Stream</div>
            <div class="sb-step-desc">Watch agent output in real-time with <code style="color: #818cf8; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">box.streamTask()</code>. See tool calls, text deltas, and task completion events as they happen.</div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- =======================================
       FEATURES BENTO
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">Platform</div>
          <div class="wf-h3 sb-gradient-text">Everything you need to <em>ship.</em></div>
        </div>
        <div class="sb-bento">
          <div class="sb-bento-cell">
            <div class="sb-bento-label">Docker Images</div>
            <div class="sb-bento-title">Any image. Full root.</div>
            <div class="sb-bento-desc">Node, Python, Ubuntu, CUDA — or your own Dockerfile. Pre-built images for Ethereum, Solana, Rust, Go, and ML workloads. Every sandbox gets full root access.</div>
          </div>
          <div class="sb-bento-cell">
            <div class="sb-bento-label">SSH Access</div>
            <div class="sb-bento-title">Connect directly.</div>
            <div class="sb-bento-desc">Enable SSH on any sandbox with one flag. Get host, port, and credentials. Browser terminal also available for quick access without local SSH setup.</div>
          </div>
          <div class="sb-bento-cell">
            <div class="sb-bento-label">GPU Support</div>
            <div class="sb-bento-title">CUDA-enabled.</div>
            <div class="sb-bento-desc">Run ML inference, training, and GPU-accelerated workloads. Request specific GPU types and memory. PyTorch and CUDA images ready to use.</div>
          </div>
          <div class="sb-bento-cell">
            <div class="sb-bento-label">Checkpoint / Restore</div>
            <div class="sb-bento-title">Save and resume state.</div>
            <div class="sb-bento-desc">Snapshot the full sandbox state — filesystem, packages, everything. Restore instantly. Bring your own S3-compatible storage for persistence.</div>
          </div>
          <div class="sb-bento-cell">
            <div class="sb-bento-label">Security</div>
            <div class="sb-bento-title">Locked down by default.</div>
            <div class="sb-bento-desc">Dropped capabilities, no privilege escalation, PID limits, readonly rootfs. PASETO auth, ChaCha20-Poly1305 encryption for secrets at rest, rate limiting.</div>
          </div>
          <div class="sb-bento-cell">
            <div class="sb-bento-label">Real-time Streaming</div>
            <div class="sb-bento-title">Watch output live.</div>
            <div class="sb-bento-desc">SSE event streams for agent execution. See tool calls, text generation, and task completion as they happen. Build responsive UIs with typed event handlers.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =======================================
       FAQ
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <FAQ faqs={faqs} />
      </div>
    </div>
  </section>

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Cloud containers for AI agents.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Create your first sandbox, run an agent, stream results. One npm install.</div>
        <div class="wf-cta-button-row">
          <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Get Started</a>
        </div>
      </div>
    </div>
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
  </div>

<script>
  document.querySelector('.sb-copy-pill')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npm install @tangle-network/sandbox');
    const pill = document.querySelector('.sb-copy-pill');
    pill?.classList.add('copied');
    setTimeout(() => pill?.classList.remove('copied'), 1500);
  });
</script>

</BaseLayout>

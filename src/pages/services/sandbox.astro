                <div style="padding: 6px 14px; border-radius: 8px; border: 1px solid rgba(97,114,243,0.2); background: rgba(97,114,243,0.06); font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #818cf8;">{img}</div>
              ))}

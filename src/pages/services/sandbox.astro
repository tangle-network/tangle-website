---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
import SandboxShowcase from '../../components/SandboxShowcase';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';

const faqs = [
  { question: 'What is the Sandbox SDK?', answer: 'The Sandbox SDK lets you create isolated cloud containers for AI agents via a TypeScript SDK or CLI. Each sandbox is a full Linux environment with root access, SSH, file system operations, and optional GPU support — provisioned in seconds.' },
  { question: 'What AI backends are supported?', answer: 'Sandboxes support multiple agent backends: OpenCode (multi-provider, default), Claude Code (Anthropic-native), Codex (OpenAI-native), AMP (Sourcegraph), and Factory Droids. You can also bring your own API key and switch backends per request.' },
  { question: 'What languages and runtimes work?', answer: 'Any Docker image works — Node.js, Python, Rust, Go, Ubuntu, or your own custom Dockerfile. Pre-built images are available for common stacks like Ethereum, Solana, and ML workloads. GPU images with CUDA support are available for inference and training.' },
  { question: 'How does snapshot and restore work?', answer: 'You can checkpoint the full state of any sandbox — filesystem, installed packages, everything. Restore instantly to create new sandboxes from that state. Bring your own S3-compatible storage (AWS S3, GCS, Cloudflare R2) for snapshot persistence.' },
];
---

<BaseLayout title="Sandbox SDK — Secure Cloud for AI Agents" description="Spin up isolated environments, run AI agents, stream results. TypeScript SDK, CLI, zero DevOps.">

  <style>
    .sb-gradient-text em {
      font-style: normal;
      background: linear-gradient(135deg, #818cf8, #6366F1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .sb-copy-pill { position: relative; }
    .sb-copy-tooltip {
      position: absolute;
      right: -8px;
      top: -32px;
      background: #4ade80;
      color: #000;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .sb-copy-pill.copied .sb-copy-tooltip { opacity: 1; }

    /* Problem/Solution cards */
    .sb-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .sb-card {
      background: transparent;
      border: 2px solid rgba(100,100,148,0.18);
      border-radius: 32px;
      padding: 2.25rem 2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .sb-card:hover { border-color: rgba(142,89,255,0.35); box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
    .sb-card-label {
      font-family: var(--font-mono); font-size: 0.7rem;
      color: rgba(97,114,243,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;
    }
    .sb-card-title { font-family: var(--font-sans); font-size: 1.35rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.25; }
    .sb-card-desc { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.55); line-height: 1.6; }

    /* How it works steps */
    .sb-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; max-width: 64rem; margin: 0 auto; }
    .sb-step { text-align: center; }
    .sb-step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(97,114,243,0.12); border: 2px solid rgba(97,114,243,0.3);
      font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: #818cf8;
      margin-bottom: 1.25rem;
    }
    .sb-step-title { font-family: var(--font-sans); font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
    .sb-step-desc { font-family: var(--font-sans); font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.6; }
    .sb-step-connector { display: none; }

    /* Bento grid */
    .sb-bento { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .sb-bento-cell {
      background: transparent;
      border: 2px solid rgba(100,100,148,0.18);
      border-radius: 32px;
      padding: 2rem 2.25rem;
      display: flex;
      flex-direction: column;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .sb-bento-cell:hover { border-color: rgba(142,89,255,0.35); box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
    .sb-bento-label { font-family: var(--font-mono); font-size: 0.8rem; color: rgba(97,114,243,0.8); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .sb-bento-title { font-family: var(--font-sans); font-size: 1.75rem; font-weight: 700; color: white; margin-bottom: 0.5rem; line-height: 1.2; }
    .sb-bento-desc { font-family: var(--font-sans); font-size: 1.05rem; font-weight: 500; color: rgba(255,255,255,0.55); line-height: 1.6; }

    /* Section label */
    .sb-section-label {
      font-family: var(--font-mono); font-size: 0.7rem;
      color: rgba(97,114,243,0.5); text-transform: uppercase;
      letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem;
    }

    /* Hero grid */
    .sb-hero-grid {
      display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: center;
    }

    /* Mobile */
    @media (max-width: 991px) {
      .sb-hero-grid { grid-template-columns: 1fr !important; }
    }
    @media (max-width: 768px) {
      .sb-cards { grid-template-columns: 1fr; }
      .sb-steps { grid-template-columns: 1fr; gap: 1.5rem; }
      .sb-bento { grid-template-columns: 1fr; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="wf-section-hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 10rem 5% 4rem; justify-content: flex-start;">
      <div style="max-width: 80rem; width: 100%; margin: 0 auto; position: relative; z-index: 1;">
        <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; align-items: center;">
          <div class="wf-hero-text" style="align-items: flex-start;">
            <div class="wf-glowing-wrapper">
              <div class="wf-glowing-wrapper-button">
                <div class="wf-button-text-pill">Sandbox SDK</div>
              </div>
            </div>
            <h1 class="wf-h1 sb-gradient-text">Give your agents the <em>real world,</em> safely.</h1>
            <div class="wf-body-01">Isolated cloud containers for AI agents. Create, execute, stream — from TypeScript or CLI. Sub-second provisioning, any Docker image, zero DevOps.</div>
            <div class="wf-install-pill sb-copy-pill" style="margin-top: 8px; cursor: pointer; position: relative;">
              <span class="prompt">$</span>
              <code>npm install @tangle-network/sandbox</code>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-left: auto; opacity: 0.4; flex-shrink: 0;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span class="sb-copy-tooltip">Copied!</span>
            </div>
            <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
              <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: white; color: #211f54; border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Documentation</a>
              <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: #1e116e; color: white; border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Join Waitlist</a>
            </div>
          </div>
          <!-- Hero terminal — live streaming feel -->
          <div style="position: relative; z-index: 1;">
            <div style="position: absolute; inset: -12px; border-radius: 20px; background: radial-gradient(ellipse at 50% 0%, rgba(97,114,243,0.12) 0%, transparent 70%); filter: blur(30px); pointer-events: none;"></div>
            <div style="position: relative; overflow: hidden; border-radius: 16px; border: 2px solid rgba(100,100,148,0.18); background: #0a0a0a;">
              <div style="display: flex; align-items: center; padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.015);">
                <div style="display: flex; gap: 6px; margin-right: 14px;">
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,95,87,0.7);"></div>
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(254,188,46,0.7);"></div>
                  <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(74,222,128,0.7);"></div>
                </div>
                <span style="font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,0.2);">sandbox — streaming</span>
              </div>
              <pre style="padding: 20px 24px; font-family: var(--font-mono); font-size: 15px; line-height: 1.8; color: rgba(255,255,255,0.7); margin: 0; white-space: pre-wrap;"><code><span style="color: #c084fc;">const</span> <span style="color: rgba(255,255,255,0.8);">box</span> = <span style="color: #c084fc;">await</span> client.<span style="color: rgba(255,255,255,0.8);">create</span>({"{"} image: <span style="color: #a78bfa;">'node:22'</span> {"}"});

<span style="color: rgba(255,255,255,0.3);">// Stream an AI agent task in real-time</span>
<span style="color: #c084fc;">for await</span> (<span style="color: #c084fc;">const</span> <span style="color: rgba(255,255,255,0.8);">event</span> <span style="color: #c084fc;">of</span> box.<span style="color: rgba(255,255,255,0.8);">streamTask</span>(
  <span style="color: #a78bfa;">'Refactor src/ to TypeScript and add tests'</span>
)) {"{"}<span style="color: rgba(255,255,255,0.3);"></span>
  <span style="color: #c084fc;">if</span> (event.type === <span style="color: #a78bfa;">'tool_call'</span>)
    console.log(<span style="color: #a78bfa;">`Using: </span><span style="color: #fbbf24;">$&#123;event.tool&#125;</span><span style="color: #a78bfa;">`</span>);
  <span style="color: #c084fc;">if</span> (event.type === <span style="color: #a78bfa;">'message'</span>)
    process.stdout.write(event.content);
{"}"}

<span style="color: #4ade80;">✓ 12 files converted</span>  <span style="color: rgba(255,255,255,0.3);">· 47 tests passing</span>
<span style="color: #4ade80;">✓ PR #18 created</span>      <span style="color: rgba(255,255,255,0.3);">· src/ → TypeScript</span></code></pre>
            </div>
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.35;">
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <StatsStrip
    items={[
      { label: '&lt;1s provisioning', icon: 'zap' },
      { label: 'any Docker image · SSH access', icon: 'terminal' },
      { label: 'mTLS-isolated sidecar', icon: 'shield' },
      { label: 'snapshot · restore · bring your S3', icon: 'layers' },
    ]}
  />

  <!-- INTERACTIVE SHOWCASE — immediately after hero -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">See It Work</div>
          <div class="wf-h3 sb-gradient-text">SDK and CLI. <em>Full control.</em></div>
          <div class="wf-body-02 align-center">Every example uses the real <code style="color: #818cf8; font-family: var(--font-mono); font-size: 0.9rem;">@tangle-network/sandbox</code> API.</div>
        </div>
        <SandboxShowcase client:load />
      </div>
    </div>
  </section>

  <!-- =======================================
       WHAT YOU GET — visual architecture
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="sb-section-label">What You Get</div>
          <div class="wf-h3 sb-gradient-text">A full computer for every <em>agent.</em></div>
          <div class="wf-body-02 align-center">Not a REPL. Not a function. A real Linux environment with filesystem, networking, tools, and root access.</div>
        </div>

        <!-- Visual: before/after terminal comparison -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 2rem;">
          <!-- Before — crashed terminal -->
          <div style="border-radius: 24px; overflow: hidden; border: 2px solid rgba(248,113,113,0.15); background: linear-gradient(160deg, rgba(248,113,113,0.06) 0%, #0a0a0a 40%);">
            <div style="padding: 12px 16px; border-bottom: 1px solid rgba(248,113,113,0.1); display: flex; align-items: center; gap: 6px;">
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(248,113,113,0.8);"></div>
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(248,113,113,0.4);"></div>
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(248,113,113,0.2);"></div>
              <span style="margin-left: 8px; font-family: var(--font-mono); font-size: 11px; color: rgba(248,113,113,0.4);">without sandbox</span>
            </div>
            <div style="padding: 20px; font-family: var(--font-mono); font-size: 15px; line-height: 1.85;">
              <div style="color: rgba(255,255,255,0.5);"><span style="color: #f87171;">$</span> agent.run("refactor to TypeScript")</div>
              <div style="color: rgba(255,255,255,0.3);">  → reading files...</div>
              <div style="color: #f87171;">  ✗ ENOENT: no filesystem access</div>
              <div style="color: rgba(255,255,255,0.3); margin-top: 8px;"><span style="color: #f87171;">$</span> agent.run("install and test")</div>
              <div style="color: rgba(255,255,255,0.3);">  → npm install...</div>
              <div style="color: #f87171;">  ✗ EPERM: cannot execute binaries</div>
              <div style="color: rgba(255,255,255,0.3); margin-top: 8px;"><span style="color: #f87171;">$</span> agent.run("complex migration")</div>
              <div style="color: #f87171;">  ✗ TIMEOUT: killed after 30s</div>
              <div style="color: rgba(248,113,113,0.3); margin-top: 12px;">3 tasks attempted · 0 succeeded</div>
            </div>
          </div>

          <!-- After — successful terminal -->
          <div style="border-radius: 24px; overflow: hidden; border: 2px solid rgba(74,222,128,0.2); background: linear-gradient(160deg, rgba(74,222,128,0.05) 0%, #0a0a0a 40%);">
            <div style="padding: 12px 16px; border-bottom: 1px solid rgba(74,222,128,0.1); display: flex; align-items: center; gap: 6px;">
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(74,222,128,0.8);"></div>
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(74,222,128,0.5);"></div>
              <div style="width: 10px; height: 10px; border-radius: 50%; background: rgba(74,222,128,0.3);"></div>
              <span style="margin-left: 8px; font-family: var(--font-mono); font-size: 11px; color: rgba(74,222,128,0.5);">with sandbox</span>
            </div>
            <div style="padding: 20px; font-family: var(--font-mono); font-size: 15px; line-height: 1.85;">
              <div style="color: rgba(255,255,255,0.5);"><span style="color: #4ade80;">$</span> box.task("refactor to TypeScript")</div>
              <div style="color: rgba(255,255,255,0.4);">  → 23 files converted</div>
              <div style="color: #4ade80;">  ✓ done (18s)</div>
              <div style="color: rgba(255,255,255,0.5); margin-top: 8px;"><span style="color: #4ade80;">$</span> box.exec("npm install && npm test")</div>
              <div style="color: rgba(255,255,255,0.4);">  → 847 packages, 47 tests</div>
              <div style="color: #4ade80;">  ✓ all passing (12s)</div>
              <div style="color: rgba(255,255,255,0.5); margin-top: 8px;"><span style="color: #4ade80;">$</span> box.task("create PR with changes")</div>
              <div style="color: #4ade80;">  ✓ PR #18 created (3s)</div>
              <div style="color: rgba(74,222,128,0.4); margin-top: 12px;">3 tasks · 3 succeeded · 33s total</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>



  <!-- =======================================
       FAQ
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <FAQ faqs={faqs} />
      </div>
    </div>
  </section>

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Cloud containers for AI agents.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Create your first sandbox, run an agent, stream results. One npm install.</div>
        <div class="wf-cta-button-row">
          <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Get Started</a>
        </div>
      </div>
    </div>
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
  </div>

<script>
  document.querySelector('.sb-copy-pill')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npm install @tangle-network/sandbox');
    const pill = document.querySelector('.sb-copy-pill');
    pill?.classList.add('copied');
    setTimeout(() => pill?.classList.remove('copied'), 1500);
  });
</script>

</BaseLayout>

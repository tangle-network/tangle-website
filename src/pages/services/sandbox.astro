---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Sandbox SDK — Secure Cloud for AI" description="Spin up isolated environments, run AI agents, stream results. Zero DevOps.">

  <style>
    .sb-hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
    .sb-hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 70% 60% at 30% 75%, rgba(74,222,128,0.07), transparent),
        radial-gradient(ellipse 60% 50% at 75% 25%, rgba(34,211,238,0.05), transparent);
    }
    .sb-hero-inner { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; padding: 0 5%; display: grid; grid-template-columns: 1fr 1.3fr; gap: 4rem; align-items: center; }
    .sb-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(74,222,128,0.3); background: rgba(74,222,128,0.08); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #4ade80; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 1.5rem; }
    .sb-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: sb-pulse 2s infinite; }
    @keyframes sb-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .sb-h1 { font-family: 'Satoshi', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 1.5rem; }
    .sb-h1 em { font-style: normal; background: linear-gradient(135deg, #4ade80, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .sb-sub { font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.8); max-width: 440px; margin-bottom: 2rem; }
    .sb-glow { position: relative; }
    .sb-glow::before { content: ''; position: absolute; inset: -8px; border-radius: 18px; background: linear-gradient(135deg, rgba(74,222,128,0.12), rgba(34,211,238,0.06)); filter: blur(28px); pointer-events: none; }

    /* Full-width terminal */
    .sb-terminal-wrap { max-width: 64rem; margin: 0 auto; padding: 0 5%; }
    .sb-terminal {
      background: #0e0e1c;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      overflow: hidden;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      line-height: 1.8;
    }
    .sb-terminal-chrome {
      display: flex; align-items: center; gap: 6px; padding: 14px 20px;
      background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .sb-terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
    .sb-terminal-title { margin-left: 12px; font-size: 12px; color: rgba(255,255,255,0.25); }
    .sb-terminal-body { padding: 1.5rem 2rem; }
    .sb-line { display: block; min-height: 1.8em; }
    .sb-prompt { color: #4ade80; }
    .sb-cmd { color: #e2e8f0; }
    .sb-flag { color: #22d3ee; }
    .sb-string { color: #4ade80; }
    .sb-dim { color: rgba(255,255,255,0.2); }
    .sb-info { color: rgba(255,255,255,0.35); }
    .sb-success { color: #4ade80; }
    .sb-output { color: rgba(255,255,255,0.45); }
    .sb-highlight { background: rgba(74,222,128,0.04); margin: 0 -2rem; padding: 0 2rem; }
    .sb-accent { color: #22d3ee; }

    /* Bento grid */
    .sb-bento { display: grid; overflow: hidden; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 64rem; margin: 0 auto; }
    .sb-bento-cell { min-width: 0; overflow: hidden; background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2rem 2.25rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .sb-bento-cell:hover { background: rgba(255,255,255,0.04); border-color: rgba(74,222,128,0.2); box-shadow: 0 0 40px rgba(74,222,128,0.04); }
    .sb-bento-cell.span-2 { grid-column: span 2; }
    .sb-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(74,222,128,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .sb-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.2; }
    .sb-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.6; }
    .sb-bento-code { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: rgba(255,255,255,0.8); background: rgba(0,0,0,0.5); padding: 1.25rem 1.5rem; border-radius: 12px; margin-top: 1.5rem; white-space: pre-wrap; word-break: break-all; overflow-x: auto; line-height: 1.75; border: 1px solid rgba(255,255,255,0.04); }
    .sb-bento-code .g { color: #4ade80; }
    .sb-bento-code .c { color: #22d3ee; }
    .sb-bento-code .s { color: #a78bfa; }
    .sb-bento-code .w { color: #e2e8f0; }
    .sb-bento-code .d { color: rgba(255,255,255,0.3); }

    /* Section headers */
    .sb-section { padding: 8rem 5% 6rem; max-width: 80rem; margin: 0 auto; }
    .sb-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(74,222,128,0.5); text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .sb-section-title { font-family: 'Satoshi', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; text-align: center; line-height: 1.15; margin-bottom: 1rem; }
    .sb-section-title em { font-style: normal; background: linear-gradient(45deg, #4ade80, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .sb-section-sub { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.8); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    /* Pricing */
    .sb-pricing { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 64rem; margin: 0 auto; }
    .sb-price-cell { background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2.5rem 2rem; text-align: center; transition: all 0.4s; }
    .sb-price-cell:hover { border-color: rgba(74,222,128,0.2); box-shadow: 0 0 40px rgba(74,222,128,0.04); }
    .sb-price-cell.featured { background: rgba(74,222,128,0.04); border-color: rgba(74,222,128,0.2); }
    .sb-price-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
    .sb-price-cell.featured .sb-price-tag { color: rgba(74,222,128,0.7); }
    .sb-price-amount { font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: white; line-height: 1; }
    .sb-price-unit { font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.3); margin-top: 6px; }

    /* Mobile */
    @media (max-width: 768px) {
      .sb-hero-inner { grid-template-columns: 1fr; gap: 2rem; }
      .sb-bento { grid-template-columns: 1fr; }
      .sb-bento-cell.span-2 { grid-column: span 1; }
      .sb-pricing { grid-template-columns: 1fr; }
      .sb-terminal { font-size: 12px; }
      .sb-terminal-body { padding: 1rem; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="sb-hero">
    <div class="sb-hero-inner">
      <div>
        <div class="sb-badge">Coming Soon</div>
        <h1 class="sb-h1">Cloud in a<br/><em>command.</em></h1>
        <p class="sb-sub">Spin up isolated environments, run AI agents inside them, stream results in real-time. One npm install, zero DevOps.</p>
        <div class="wf-install-pill" style="margin-bottom: 1.5rem;">
          <span class="prompt">$</span>
          <code>npm install @tangle-network/sandbox</code>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 14px 28px;">Documentation</a>
          <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none; transition: border-color 0.3s;">
            Join Waitlist
          </a>
        </div>
      </div>
      <div class="sb-glow">
        <div style="position: relative;">
          <CodeTabs client:load variant="sandbox" />
        </div>
      </div>
    </div>
  </section>

  <!-- =======================================
       FULL-WIDTH TERMINAL
       ======================================= -->
  <div class="sb-section">
    <div class="sb-section-label">See It Work</div>
    <div class="sb-section-title">Create. Connect. <em>Execute.</em></div>
    <div class="sb-section-sub">From zero to running sandbox in under 10 seconds. SSH in, run code, stream output — all from one CLI.</div>
  </div>
  <div class="sb-terminal-wrap">
    <div class="sb-terminal">
      <div class="sb-terminal-chrome">
        <div class="sb-terminal-dot" style="background: rgba(255,95,87,0.8);"></div>
        <div class="sb-terminal-dot" style="background: rgba(254,188,46,0.8);"></div>
        <div class="sb-terminal-dot" style="background: rgba(74,222,128,0.8);"></div>
        <span class="sb-terminal-title">Terminal — tangle sandbox</span>
      </div>
      <div class="sb-terminal-body">
        <span class="sb-line"><span class="sb-prompt">$</span> <span class="sb-cmd">tangle sandbox create</span> \</span>
        <span class="sb-line sb-highlight">    <span class="sb-flag">--image</span> <span class="sb-string">ubuntu:22.04</span> \</span>
        <span class="sb-line">    <span class="sb-flag">--gpu</span> <span class="sb-string">a100</span> <span class="sb-flag">--memory</span> <span class="sb-dim">16gb</span></span>
        <span class="sb-line"></span>
        <span class="sb-line"><span class="sb-info">sandbox-sdk v0.4.0</span></span>
        <span class="sb-line"><span class="sb-info">Provisioning sandbox...</span></span>
        <span class="sb-line"><span class="sb-success">  ✓ Sandbox created</span> <span class="sb-info">sbx_7k3m9x2p  ·  region: us-east  ·  3.2s</span></span>
        <span class="sb-line"></span>
        <span class="sb-line"><span class="sb-prompt">$</span> <span class="sb-cmd">tangle sandbox ssh</span> <span class="sb-accent">sbx_7k3m9x2p</span></span>
        <span class="sb-line"><span class="sb-info">Connecting to sbx_7k3m9x2p...</span></span>
        <span class="sb-line"></span>
        <span class="sb-line"><span class="sb-success">root@sbx_7k3m9x2p</span><span class="sb-dim">:</span><span class="sb-accent">~</span><span class="sb-dim">#</span> <span class="sb-cmd">python3 train.py --epochs 50 --batch-size 64</span></span>
        <span class="sb-line"><span class="sb-output">  Epoch 1/50  ████████████████████  loss: 0.834  acc: 0.72</span></span>
        <span class="sb-line"><span class="sb-output">  Epoch 2/50  ████████████████████  loss: 0.412  acc: 0.85</span></span>
        <span class="sb-line"><span class="sb-output">  Epoch 3/50  ████████████████████  loss: 0.198  acc: 0.93</span></span>
        <span class="sb-line"></span>
        <span class="sb-line"><span class="sb-prompt">$</span> <span class="sb-cmd">tangle sandbox list</span></span>
        <span class="sb-line"><span class="sb-dim">  ID              IMAGE          GPU     STATUS    UPTIME    COST</span></span>
        <span class="sb-line"><span class="sb-output">  sbx_7k3m9x2p   ubuntu:22.04   a100    running   4m 12s    $0.76</span></span>
        <span class="sb-line"><span class="sb-output">  sbx_a1b2c3d4   node:20        —       paused    22m       $0.22</span></span>
      </div>
    </div>
  </div>

  <!-- =======================================
       BENTO GRID
       ======================================= -->
  <div class="sb-section">
    <div class="sb-section-label">Platform</div>
    <div class="sb-section-title">TypeScript SDK. CLI. <em>Full control.</em></div>
  </div>
  <div style="max-width: 64rem; margin: 0 auto; padding: 0 5% 6rem;">
    <div class="sb-bento">
      <!-- Large: Docker Images -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">Docker Images</div>
          <div class="sb-bento-title">Any image. Full root. GPU support.</div>
          <div class="sb-bento-desc">Node, Python, Ubuntu, CUDA — or your own custom Dockerfile. Every sandbox gets full root access, custom dependencies, and optional GPU acceleration.</div>
        </div>
        <div class="sb-bento-code"><span class="g">$</span> <span class="w">tangle sandbox create</span> <span class="c">--image</span> <span class="s">pytorch/pytorch:2.1-cuda12</span> \
    <span class="c">--gpu</span> <span class="w">a100</span> <span class="c">--memory</span> <span class="w">32gb</span> <span class="c">--disk</span> <span class="w">100gb</span>

<span class="g">✓ Sandbox created</span>  ·  sbx_9f2k1m  ·  GPU: A100 80GB  ·  4.1s</div>
      </div>

      <!-- Small: AI Agent Runtime -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">AI Agent Runtime</div>
          <div class="sb-bento-title">Built-in LLM proxy.</div>
          <div class="sb-bento-desc">Run Claude Code, Codex, or custom agents with tool access and file I/O inside isolated containers.</div>
        </div>
        <div class="sb-bento-code"><span class="g">$</span> <span class="w">tangle agent task</span> <span class="s">sbx_id</span> \
  <span class="c">"Build an API with auth"</span>
<span class="g">✓</span> task complete · 42s</div>
      </div>

      <!-- Small: SSH & Terminal -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">SSH & Terminal</div>
          <div class="sb-bento-title">Connect your way.</div>
          <div class="sb-bento-desc">SSH directly, use the browser terminal, or control programmatically via the TypeScript SDK.</div>
        </div>
        <div class="sb-bento-code"><span class="g">$</span> <span class="w">tangle sandbox ssh</span> <span class="s">sbx_id</span>
<span class="d">root@sbx:</span><span class="c">~#</span> <span class="w">nvidia-smi</span>
<span class="g">✓</span> A100 80GB · 0% util</div>
      </div>

      <!-- Small: Snapshots -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">Snapshots</div>
          <div class="sb-bento-title">Checkpoint anything.</div>
          <div class="sb-bento-desc">Save state at any point. Restore from snapshots instantly. Bring your own S3 for persistence.</div>
        </div>
        <div class="sb-bento-code"><span class="g">$</span> <span class="w">tangle sandbox snapshot</span> \
  <span class="c">--name</span> <span class="s">"pre-deploy"</span>
<span class="g">✓</span> saved · 2.1 GB · 0.8s</div>
      </div>

      <!-- File Operations -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">File Operations</div>
          <div class="sb-bento-title">Upload. Download. Stream.</div>
          <div class="sb-bento-desc">Full filesystem access — upload training data, download results, stream logs in real-time. Bring your own S3 for persistence.</div>
        </div>
        <div class="sb-bento-code"><span class="g">$</span> <span class="w">tangle sandbox upload</span> <span class="s">./data</span> <span class="c">:/workspace</span>
<span class="g">✓</span> 2.4GB uploaded in 8.1s

<span class="g">$</span> <span class="w">tangle sandbox exec</span> sbx_7k3m <span class="s">"python train.py"</span>
<span class="d">Epoch 1/10 ████████░░ 80%</span>

<span class="g">$</span> <span class="w">tangle sandbox download</span> <span class="c">:/workspace/model.pt</span> <span class="s">./</span>
<span class="g">✓</span> model.pt (1.8GB) saved</div>
      </div>

      <!-- Small: Isolation -->
      <div class="sb-bento-cell">
        <div>
          <div class="sb-bento-label">Isolation</div>
          <div class="sb-bento-title">Locked down by default.</div>
          <div class="sb-bento-desc">Dropped capabilities, no privilege escalation. gVisor and Firecracker isolation options.</div>
        </div>
        <div class="sb-bento-code"><span class="c">[security]</span> caps: ALL dropped
<span class="c">[runtime]</span> gVisor enabled
<span class="g">✓</span> sandbox isolated</div>
      </div>
    </div>
  </div>

  <!-- Pricing removed — users visit sandbox.tangle.tools for pricing -->

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">The decentralized cloud is coming.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Create your first sandbox, run an AI agent, ship faster. Free tier included.</div>
        <div class="wf-cta-button-row">
          <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Join Waitlist</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

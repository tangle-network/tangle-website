---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
  { title: 'Secure Sandboxes', description: 'Hardware-isolated containers with TEE attestation. Run untrusted AI workloads safely — no escape, no data leaks.' },
  { title: 'CLI-First', description: 'Deploy, SSH, manage, and destroy environments from your terminal. One command to spin up a GPU-enabled sandbox.' },
  { title: 'TypeScript SDK', description: 'Full programmatic control. Create sandboxes, execute commands, stream logs, and manage lifecycle from your app.' },
  { title: 'Instant Provisioning', description: 'Environments spin up in seconds. Scale from 1 to 1000 on demand. No reserved instances, no idle costs.' },
  { title: 'Decentralized Infrastructure', description: 'Runs on Tangle\'s operator network. No single point of failure, no vendor lock-in, cryptographic verification.' },
  { title: 'AI-Native', description: 'Purpose-built for agent workloads. Pre-configured with Python, Node, CUDA. SSH access, dependency management, GPU support.' },
];
---

<BaseLayout title="Sandbox SDK" description="Secure cloud environments for AI workloads. CLI and TypeScript SDK for deploying sandboxed containers on decentralized infrastructure.">

  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container" style="z-index: 1; position: relative;">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Coming Soon</div>
            </div>
          </div>
          <h1 class="wf-h1">Sandbox SDK</h1>
          <div class="wf-body-01">Deploy secure, sandboxed cloud environments for AI agents. CLI-first. SDK-native. Powered by Tangle's decentralized operator network.</div>
          <div class="wf-button-row">
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Documentation</a>
            <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">Join Waitlist</a>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- CLI Quick Start -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">CLI</div>
            </div>
          </div>
          <div class="wf-h3">Cloud From Your <span class="wf-gradient-text">Terminal</span></div>
          <div class="wf-body-02 align-center">No dashboards, no GUIs, no tickets. Just commands.</div>
        </div>

        <div style="max-width: 900px; margin: 0 auto;">
          <div style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 2rem; font-family: 'Space Mono', monospace; font-size: 0.85rem; line-height: 2.2; color: var(--color-text-secondary); overflow-x: auto;">
            <div style="color: #6b7094;">$ # Install</div>
            <div style="color: white;">npm install -g @tangle-network/sandbox-cli</div>
            <br/>
            <div style="color: #6b7094;">$ # Create a sandbox with GPU</div>
            <div style="color: white;">tangle sandbox create --name my-agent \</div>
            <div style="color: white; padding-left: 1rem;">--image ubuntu:22.04 \</div>
            <div style="color: white; padding-left: 1rem;">--gpu a100 \</div>
            <div style="color: white; padding-left: 1rem;">--deps "python3 pytorch transformers"</div>
            <br/>
            <div style="color: #6172f3;">✓ Sandbox 'my-agent' ready in 8.2s</div>
            <div style="color: #6172f3;">  SSH: tangle sandbox ssh my-agent</div>
            <div style="color: #6172f3;">  URL: https://my-agent.sandbox.tangle.tools</div>
            <br/>
            <div style="color: #6b7094;">$ # SSH in and run your workload</div>
            <div style="color: white;">tangle sandbox ssh my-agent</div>
            <div style="color: white;">root@my-agent:~$ python train.py --model llama-3.2</div>
            <br/>
            <div style="color: #6b7094;">$ # List running sandboxes</div>
            <div style="color: white;">tangle sandbox list</div>
            <div style="color: #6b7094;">NAME        STATUS    GPU    UPTIME    COST</div>
            <div style="color: white;">my-agent    running   A100   2h 14m    $0.42</div>
            <br/>
            <div style="color: #6b7094;">$ # Destroy when done</div>
            <div style="color: white;">tangle sandbox destroy my-agent</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SDK -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">SDK</div>
            </div>
          </div>
          <div class="wf-h3">Programmatic <span class="wf-gradient-text">Control</span></div>
          <div class="wf-body-02 align-center">Build sandbox orchestration into your applications with the TypeScript SDK.</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 1100px; margin: 0 auto;">
          <div class="wf-builder-feature-card" style="padding: 0; overflow: hidden;">
            <div class="wf-builder-feature-top">
              <div style="color: #6172f3; font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Create & Execute</div>
              <div class="wf-h4" style="font-size: 1.15rem;">Spawn sandboxes from code</div>
            </div>
            <div style="background: rgba(0,0,0,0.3); padding: 1.5rem; font-family: 'Space Mono', monospace; font-size: 0.78rem; line-height: 1.8; color: var(--color-text-secondary); border-top: 1px solid rgba(255,255,255,0.05);">
              <div style="color: #6172f3;">import {'{ Sandbox }'} from '@tangle-network/sdk';</div>
              <br/>
              <div style="color: white;">const sb = await Sandbox.create(&#123;</div>
              <div style="color: white; padding-left: 1rem;">image: 'python:3.12',</div>
              <div style="color: white; padding-left: 1rem;">gpu: 'a100',</div>
              <div style="color: white; padding-left: 1rem;">timeout: '2h',</div>
              <div style="color: white;">&#125;);</div>
              <br/>
              <div style="color: white;">const result = await sb.exec(</div>
              <div style="color: white; padding-left: 1rem;">'python -c "import torch; print(torch.cuda.is_available())"'</div>
              <div style="color: white;">);</div>
              <div style="color: #6b7094;">// result.stdout → "True"</div>
            </div>
          </div>

          <div class="wf-builder-feature-card" style="padding: 0; overflow: hidden;">
            <div class="wf-builder-feature-top">
              <div style="color: #6172f3; font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">File Operations</div>
              <div class="wf-h4" style="font-size: 1.15rem;">Upload, download, stream</div>
            </div>
            <div style="background: rgba(0,0,0,0.3); padding: 1.5rem; font-family: 'Space Mono', monospace; font-size: 0.78rem; line-height: 1.8; color: var(--color-text-secondary); border-top: 1px solid rgba(255,255,255,0.05);">
              <div style="color: #6b7094;">// Upload training data</div>
              <div style="color: white;">await sb.upload('./data', '/workspace/data');</div>
              <br/>
              <div style="color: #6b7094;">// Run training with live logs</div>
              <div style="color: white;">const stream = sb.execStream(</div>
              <div style="color: white; padding-left: 1rem;">'python train.py --epochs 100'</div>
              <div style="color: white;">);</div>
              <div style="color: white;">for await (const line of stream) &#123;</div>
              <div style="color: white; padding-left: 1rem;">console.log(line);</div>
              <div style="color: white;">&#125;</div>
              <br/>
              <div style="color: #6b7094;">// Download trained model</div>
              <div style="color: white;">await sb.download('/workspace/model.pt', '.');</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Built for <span class="wf-gradient-text">AI Workloads</span></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {features.map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.25rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; line-height: 1.6;">{f.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 800px;">
        <div class="wf-section-head">
          <div class="wf-h3">Pay Per Second</div>
          <div class="wf-body-02 align-center">No reserved instances. No minimum commitments. Metered by the second.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 700px; margin: 0 auto;">
          <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; margin-bottom: 8px;">CPU</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2rem; font-weight: 800;">$0.01</div>
            <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/minute</div>
          </div>
          <div style="background: rgba(97,114,243,0.08); border: 1px solid rgba(97,114,243,0.2); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: #6172f3; font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; margin-bottom: 8px;">GPU (A100)</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2rem; font-weight: 800;">$0.18</div>
            <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/minute</div>
          </div>
          <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; margin-bottom: 8px;">Storage</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2rem; font-weight: 800;">$0.05</div>
            <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/GB/day</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">The Decentralized Cloud is Coming</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Join the waitlist for early access. Deploy AI workloads on secure, decentralized infrastructure.</div>
        <div class="wf-cta-button-row">
          <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Join Waitlist</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

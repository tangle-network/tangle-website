---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Sandbox SDK — Secure Cloud for AI" description="Spin up. Run agents. Pay per second. Zero DevOps.">

  <!-- ======================================
       HERO — Split: Copy left, Code right
       ====================================== -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="justify-content: center; align-items: center; height: auto; min-height: 90vh; padding-top: 8rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; max-width: 80rem; width: 100%; padding: 0 5%; align-items: center; z-index: 1; position: relative;">

        <div>
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 5px 14px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.25); background: rgba(142,89,255,0.06); margin-bottom: 20px;">
            <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">Coming Soon</span>
          </div>

          <h1 style="font-family: 'Satoshi', sans-serif; font-size: 3.75rem; font-weight: 800; line-height: 1.08; letter-spacing: -0.02em; color: white; margin-bottom: 20px;">
            Cloud in a<br/>command.
          </h1>

          <p style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.6; color: rgba(255,255,255,0.6); max-width: 420px; margin-bottom: 24px;">
            Spin up isolated environments, run AI agents inside them, stream results in real-time. One npm install, zero DevOps.
          </p>

          <div class="wf-install-pill" style="margin-bottom: 24px;">
            <span class="prompt">$</span>
            <code>npm install @tangle-network/sandbox</code>
          </div>

          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 16px 28px; font-size: 16px;">Documentation</a>
            <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" class="wf-btn-primary" style="padding: 16px 28px; font-size: 16px;">Join Waitlist</a>
          </div>
        </div>

        <div>
          <div style="position: relative;">
            <div style="position: absolute; inset: -6px; border-radius: 16px; background: linear-gradient(135deg, rgba(142,89,255,0.12), rgba(104,136,249,0.06)); filter: blur(24px); pointer-events: none;"></div>
            <div style="position: relative;">
              <CodeTabs client:load variant="sandbox" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- ======================================
       HOW IT WORKS — Lifecycle
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">Sandbox <span class="wf-gradient-text">lifecycle</span></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { step: '1', title: 'Create', desc: 'Specify an image, GPU, and dependencies. Environment ready in seconds.' },
            { step: '2', title: 'Connect', desc: 'SSH in, use the web terminal, or control programmatically via SDK.' },
            { step: '3', title: 'Execute', desc: 'Run code, AI agents, multi-turn tasks. Stream output in real-time.' },
            { step: '4', title: 'Done', desc: 'Snapshot state, download artifacts, destroy. Billed by the second.' },
          ].map((s) => (
            <div style="text-align: center; padding: 1.5rem 1rem; border-radius: 1.5rem; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.015);">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(142,89,255,0.1); border: 1px solid rgba(142,89,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                <span style="font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 800; color: #8e59ff;">{s.step}</span>
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.05rem; font-weight: 700; color: white; margin-bottom: 8px;">{s.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500; color: rgba(255,255,255,0.45); line-height: 1.5;">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       USE CASES
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Use Cases</div>
            </div>
          </div>
          <div class="wf-h3">Not just sandboxes. <span class="wf-gradient-text">Possibilities.</span></div>
        </div>

        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { title: 'AI Agent Runtime', desc: 'Run Claude Code, Codex, or custom agents in isolated containers. Built-in LLM proxy, SSH access, multi-turn task execution.', cmd: 'tangle agent task sbx_id "Build an API with auth"' },
            { title: 'Code Interpreter', desc: 'Execute user-submitted code safely. Full process isolation, dropped capabilities, resource limits. Perfect for AI-generated code.', cmd: 'await box.exec("python user_script.py")' },
            { title: 'CI/CD Environments', desc: 'Ephemeral build environments with GPU support. Spin up for a build, run tests, tear down. No idle cost.', cmd: 'tangle sandbox create --image node:20 --timeout 30m' },
            { title: 'Data Processing', desc: 'Process sensitive data in TEE-attested environments. Upload, transform, download — with cryptographic proof of isolation.', cmd: 'await box.upload("./data.csv", "/workspace/")' },
          ].map((uc) => (
            <div class="wf-builder-feature-card" style="padding: 0; overflow: hidden;">
              <div style="padding: 1.5rem 1.5rem 1rem;">
                <div style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 8px;">{uc.title}</div>
                <div style="font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.5); line-height: 1.6;">{uc.desc}</div>
              </div>
              <div style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.04); padding: 12px 16px; font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace; font-size: 12px; color: rgba(255,255,255,0.4); overflow-x: auto; white-space: nowrap;">
                <span style="color: #4ade80;">$</span> {uc.cmd}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       FEATURES
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Platform</div>
            </div>
          </div>
          <div class="wf-h3">TypeScript SDK. CLI. <span class="wf-gradient-text">Full control.</span></div>
        </div>
        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(3, 1fr);">
          {[
            { title: 'Any Docker Image', desc: 'Node, Python, Ubuntu, or your own. Full root access, custom dependencies, GPU support.' },
            { title: 'AI Agent Runtime', desc: 'Built-in LLM proxy. Run Claude Code, Codex, or any agent with tool access and file I/O.' },
            { title: 'SSH & Web Terminal', desc: 'SSH directly into any sandbox. Or connect through the browser-based terminal. Your choice.' },
            { title: 'Snapshots', desc: 'Checkpoint state at any point. Restore from snapshots. Bring your own S3 for persistence.' },
            { title: 'Isolated & Secure', desc: 'Dropped capabilities, no privilege escalation. gVisor and Firecracker isolation options.' },
            { title: 'Pay Per Second', desc: 'No reserved instances. No monthly minimums. Idle sandboxes auto-hibernate. Metered billing.' },
          ].map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.15rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: rgba(255,255,255,0.5); font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; line-height: 1.6;">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       PRICING
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="font-size: 2.5rem;">Pay per second</div>
          <div class="wf-body-02 align-center">No reserved instances. No minimums. Just compute.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 700px; margin: 0 auto;">
          <div style="background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: rgba(255,255,255,0.4); font-family: 'Space Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">CPU</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2.5rem; font-weight: 800;">$0.01</div>
            <div style="color: rgba(255,255,255,0.35); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/minute</div>
          </div>
          <div style="background: rgba(142,89,255,0.05); border: 1px solid rgba(142,89,255,0.2); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: #8e59ff; font-family: 'Space Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">GPU (A100)</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2.5rem; font-weight: 800;">$0.18</div>
            <div style="color: rgba(255,255,255,0.35); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/minute</div>
          </div>
          <div style="background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 2rem; text-align: center;">
            <div style="color: rgba(255,255,255,0.4); font-family: 'Space Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px;">Storage</div>
            <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 2.5rem; font-weight: 800;">$0.05</div>
            <div style="color: rgba(255,255,255,0.35); font-family: 'Satoshi', sans-serif; font-size: 0.85rem;">/GB/day</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       CTA
       ====================================== -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">The decentralized cloud is coming.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Create your first sandbox, run an AI agent, ship faster. Free tier included.</div>
        <div class="wf-cta-button-row">
          <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Join Waitlist</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

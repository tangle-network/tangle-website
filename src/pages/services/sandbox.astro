---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';
import ExamplePanel from '../../components/ui/ExamplePanel.astro';
import FeatureCard from '../../components/ui/FeatureCard.astro';
import Hero from '../../components/ui/Hero.astro';
import StoryScroller from '../../components/ui/StoryScroller.astro';
import Section from '../../components/ui/Section.astro';
import BentoCell from '../../components/ui/BentoCell.astro';
import CtaBlock from '../../components/ui/CtaBlock.astro';

const sbLifecycleStages = [
  { id: 'spawn',    num: '01', title: 'Spawn.',    body: 'Sub-second cold start. Pick a base image or bring your own Dockerfile. <strong>Per-job isolation, no shared filesystem.</strong>' },
  { id: 'run',      num: '02', title: 'Run.',      body: 'mTLS sidecar enforces policy. Filesystem, network egress, compute envelope all bounded. <strong>Logs stream out; secrets stay in.</strong>' },
  { id: 'snapshot', num: '03', title: 'Snapshot.', body: 'Freeze any box mid-execution. Restore on a different host, in a different region, weeks later. <strong>Same PIDs, same memory, same answer.</strong>' },
  { id: 'scale',    num: '04', title: 'Scale.',    body: 'Burst to thousands of concurrent boxes in seconds. Pay per second. <strong>Pin specific boxes if you need warm starts.</strong>' },
];

// ─── Showcase examples. nested groups (sandbox × tasks × language) ───
const sbCreateSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> <span class="cw-v">box</span>    = <span class="cw-k">await</span> client.<span class="cw-f">create</span>({
  image:      <span class="cw-s">"node:22"</span>,
  cpu:        <span class="cw-n">4</span>,
  memoryMB:   <span class="cw-n">8192</span>,
  networking: <span class="cw-s">"restricted"</span>,   <span class="cw-c">// allowlist egress only</span>
});

<span class="cw-k">await</span> box.<span class="cw-f">exec</span>(<span class="cw-s">"git clone https://github.com/tangle-network/demo"</span>);
<span class="cw-k">await</span> box.<span class="cw-f">exec</span>(<span class="cw-s">"pnpm install"</span>);
<span class="cw-ok">✓</span> <span class="cw-v">ready in 0.8s</span>  <span class="cw-c">· sbx_a8f3c2d1 · 4 vCPU · 8 GB · SSH ready</span>`;

const sbCreateCli = `<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> \\
  <span class="cw-k">--image</span>    <span class="cw-s">node:22</span> \\
  <span class="cw-k">--cpu</span>      <span class="cw-n">4</span> \\
  <span class="cw-k">--memory</span>   <span class="cw-n">8192</span> \\
  <span class="cw-k">--network</span>  <span class="cw-s">restricted</span>

<span class="cw-p">→</span> <span class="cw-v">sbx_a8f3c2d1</span>  <span class="cw-c">· ready in 0.8s · ssh tangle@sbx_a8f3c2d1</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox exec</span> <span class="cw-s">sbx_a8f3c2d1</span> <span class="cw-k">--</span> pnpm test
<span class="cw-ok">✓</span> <span class="cw-v">47 passed</span>  <span class="cw-c">· 0 failed · 2.1s</span>`;

const sbAgentSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> <span class="cw-v">box</span>    = <span class="cw-k">await</span> client.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-c">// Stream a coding agent. tool calls, file diffs, messages.</span>
<span class="cw-k">for await</span> (<span class="cw-k">const</span> <span class="cw-v">event</span> <span class="cw-k">of</span> box.<span class="cw-f">streamTask</span>({
  goal:     <span class="cw-s">"Refactor src/ to TypeScript and add tests"</span>,
  maxTurns: <span class="cw-n">30</span>,
  backend:  <span class="cw-s">"claude-code"</span>,
})) {
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"tool_call"</span>) console.<span class="cw-f">log</span>(<span class="cw-s">\`▶ \${event.tool}\`</span>);
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"message"</span>)   process.stdout.<span class="cw-f">write</span>(event.content);
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"file_diff"</span>) await <span class="cw-f">apply</span>(event.diff);
}

<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 7 turns · 22s · 12 files changed</span>`;

const sbAgentCli = `<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
  <span class="cw-k">--goal</span>     <span class="cw-s">"Refactor src/ to TypeScript and add tests"</span> \\
  <span class="cw-k">--backend</span>  <span class="cw-s">claude-code</span> \\
  <span class="cw-k">--stream</span>

<span class="cw-p">▶</span> <span class="cw-v">read_file</span> src/index.js
<span class="cw-p">▶</span> <span class="cw-v">write_file</span> src/index.ts
<span class="cw-p">▶</span> <span class="cw-v">run_tests</span>  <span class="cw-c">· 47 passed, 0 failed</span>
<span class="cw-p">▶</span> <span class="cw-v">open_pr</span>    <span class="cw-c">· #18 created</span>

<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 7 turns · 22s · 12 files</span>`;

const sbSnapshotSdk = `<span class="cw-c">// Checkpoint full state. filesystem, packages, env.</span>
<span class="cw-k">const</span> <span class="cw-v">snap</span> = <span class="cw-k">await</span> box.<span class="cw-f">snapshot</span>({
  to: <span class="cw-s">"s3://my-bucket/pre-migrate"</span>,
});
<span class="cw-ok">✓</span> <span class="cw-v">snap_8f3a</span>  <span class="cw-c">· 1.2 GB · 4.3s</span>

<span class="cw-c">// Restore into a fresh sandbox. identical state, any box.</span>
<span class="cw-k">const</span> <span class="cw-v">fresh</span> = <span class="cw-k">await</span> client.<span class="cw-f">restore</span>({ snapshot: <span class="cw-s">"snap_8f3a"</span> });
<span class="cw-ok">✓</span> <span class="cw-v">sbx_c9d1e2</span>  <span class="cw-c">· ready in 1.1s · bit-identical</span>`;

const sbSnapshotCli = `<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox snapshot</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
  <span class="cw-k">--to</span> <span class="cw-s">s3://my-bucket/pre-migrate</span>
<span class="cw-p">→</span> <span class="cw-v">snap_8f3a</span>  <span class="cw-c">· 1.2 GB · 4.3s</span>

<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox restore</span> <span class="cw-s">snap_8f3a</span>
<span class="cw-p">→</span> <span class="cw-v">sbx_c9d1e2</span>  <span class="cw-c">· ready in 1.1s · bit-identical state</span>`;

const heroSdkCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> <span class="cw-v">box</span> = <span class="cw-k">await</span> client.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-c">// Stream a coding agent inside the sandbox</span>
<span class="cw-k">for await</span> (<span class="cw-k">const</span> <span class="cw-v">event</span> <span class="cw-k">of</span> box.<span class="cw-f">streamTask</span>(
  <span class="cw-s">"Refactor src/ to TypeScript and add tests"</span>
)) {
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"tool_call"</span>)
    console.<span class="cw-f">log</span>(<span class="cw-s">\`tool: \${event.tool}\`</span>);
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"message"</span>)
    process.stdout.<span class="cw-f">write</span>(event.content);
}

<span class="cw-ok">✓</span> <span class="cw-v">12 files converted</span>  <span class="cw-c">· 47 tests passing</span>
<span class="cw-ok">✓</span> <span class="cw-v">PR #18 created</span>      <span class="cw-c">· src/ → TypeScript</span>`;

const heroCliCode = `<span class="cw-c"># Install the CLI</span>
<span class="cw-sh">$</span> <span class="cw-v">npm install -g</span> <span class="cw-s">@tangle-network/sandbox</span>

<span class="cw-c"># Spin up an isolated container</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span>
<span class="cw-p">→</span> <span class="cw-v">sbx_a8f3c2d1</span>  <span class="cw-c">· ready in 0.6s</span>

<span class="cw-c"># Run a coding agent against it</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
<span class="cw-k">  --goal</span> <span class="cw-s">"Refactor src/ to TypeScript"</span> \\
<span class="cw-k">  --stream</span>

<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 4 turns · 18s · 0 errors</span>`;

const iconShield = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';
const iconLayers = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>';
const iconCamera = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>';
const iconBot = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>';
const iconUsers = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>';
const iconRefresh = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>';

const faqs = [
  { question: 'What is the Sandbox SDK?', answer: 'A TypeScript SDK and CLI for spinning up isolated cloud containers. Each sandbox is a full Linux environment with root, filesystem, networking, and optional GPU, provisioned in under a second.' },
  { question: 'Which agent backends work?', answer: 'OpenCode (default, multi-provider), Claude Code, OpenAI Codex, Sourcegraph AMP, and Factory Droids. Switch backends per request, or bring your own API key.' },
  { question: 'What images and runtimes are supported?', answer: 'Any Docker image. Pre-built images for Node, Python, Rust, Go, Ethereum, Solana, and CUDA-enabled GPU workloads. Bring your own Dockerfile if you need a custom base.' },
  { question: 'How do snapshot and restore work?', answer: 'Checkpoint the full sandbox (filesystem, packages, state), then restore instantly into a fresh sandbox. Bring your own S3-compatible bucket (S3, GCS, R2) for persistence.' },
];
---

<BaseLayout title="Sandbox | Isolated Cloud Runtime for AI Agents" description="Launch isolated Linux sandboxes for AI agents in sub-second cold starts. Bring any Docker image, stream logs, snapshot state, and scale secure runtimes on demand." image="/images/hero/glass-cylinders-poster.jpg" imageAlt="Tangle Sandbox isolated runtime">

  <style>
    .sb-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 2.5rem;
    }

    @media (max-width: 768px) {
      .sb-grid-3 { grid-template-columns: 1fr; }
    }

    /* Lifecycle StoryScroller visuals */
    .sb-story-kv { display: flex; flex-direction: column; }
    .sb-story-row { display: flex; gap: 1rem; align-items: baseline; font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.55rem 0; border-bottom: 1px dashed rgba(165,170,252,0.18); }
    .sb-story-row:last-child { border-bottom: 0; }
    .sb-story-key { color: var(--brand-cool); min-width: 6.5rem; }
    .sb-story-val { color: var(--text-primary); }
    .sb-story-ok { color: #34D399; }

    .sb-story-stack { display: flex; flex-direction: column; gap: 0.625rem; }
    .sb-story-box { display: flex; justify-content: space-between; align-items: center; padding: 0.875rem 1.125rem; background: rgba(52,211,153,0.05); border: 1px solid rgba(52,211,153,0.2); border-radius: 8px; font-family: var(--font-mono); font-size: 0.875rem; color: var(--text-primary); }
    .sb-story-pill { font-family: var(--font-mono); font-size: 0.7rem; padding: 0.2rem 0.55rem; border-radius: 999px; letter-spacing: 0.04em; }
    .sb-story-pill-ok { color: #34D399; background: rgba(52,211,153,0.12); border: 1px solid rgba(52,211,153,0.3); }
    .sb-story-pill-info { color: #818CF8; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.25); }

    .sb-story-snap { display: flex; flex-direction: column; gap: 0.85rem; }
    .sb-story-snap-row { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.85rem; align-items: center; padding: 0.85rem 1rem; background: rgba(99,102,241,0.05); border: 1px solid rgba(99,102,241,0.18); border-radius: 8px; font-family: var(--font-mono); font-size: 0.8125rem; }
    .sb-story-snap-row-restore { background: rgba(52,211,153,0.05); border-color: rgba(52,211,153,0.22); }
    .sb-story-snap-side { color: var(--text-primary); }
    .sb-story-snap-arrow { color: var(--brand-cool); font-size: 1.1rem; text-align: center; }
    .sb-story-snap-meta { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem 1.25rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); padding-left: 0.25rem; }
    .sb-story-snap-meta strong { color: var(--text-primary); font-weight: 700; }

    /* Scale visual. redesigned 2026-04-25 to fix Drew's "uncreative
       waste of space" call. Was 4 progress bars in a giant box; now a
       dense 2×3 grid: hero counter + billing card on top, region map
       and live spawn feed in the middle, percentile strip on bottom. */
    .sb-story-scale-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto auto;
      gap: 0.75rem;
      width: 100%;
    }
    .sb-story-scale-card {
      padding: 0.875rem 1rem;
      background: rgba(99,102,241,0.06);
      border: 1px solid rgba(99,102,241,0.18);
      border-radius: 8px;
    }
    .sb-story-scale-card--big { background: rgba(99,102,241,0.10); border-color: rgba(99,102,241,0.32); }
    .sb-story-scale-card-label { font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 0.4rem; }
    .sb-story-scale-card-num { font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; color: var(--text-primary); line-height: 1; letter-spacing: -0.02em; margin-bottom: 0.25rem; }
    .sb-story-scale-card--big .sb-story-scale-card-num { font-size: 2.375rem; background: linear-gradient(90deg, #A5AAFC, #818CF8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .sb-story-scale-card-trend { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-muted); }
    .sb-story-scale-trend-up { color: #34D399; font-weight: 700; }

    .sb-story-scale-regions, .sb-story-scale-feed {
      grid-column: span 1;
      padding: 0.875rem 1rem;
      background: rgba(20,19,40,0.4);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
    }
    .sb-story-scale-region-list { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.4rem; }
    .sb-story-scale-region { display: grid; grid-template-columns: 6.5rem 1fr 2.5rem; gap: 0.5rem; align-items: center; font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-secondary); }
    .sb-story-scale-region-bar { height: 4px; background: rgba(255,255,255,0.04); border-radius: 2px; overflow: hidden; }
    .sb-story-scale-region-bar > span { display: block; height: 100%; background: linear-gradient(90deg, #818CF8, #A5AAFC); border-radius: 2px; }
    .sb-story-scale-region:last-child .sb-story-scale-region-bar > span { background: linear-gradient(90deg, #34D399, #6EE7B7); }
    .sb-story-scale-region :last-child { color: var(--text-primary); font-weight: 700; text-align: right; }

    .sb-story-scale-feed-list { display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.4rem; }
    .sb-story-scale-feed-row { display: grid; grid-template-columns: 4.25rem 1fr 3rem; gap: 0.5rem; align-items: center; font-family: var(--font-mono); font-size: 0.6875rem; padding: 0.2rem 0; border-bottom: 1px dashed rgba(165,170,252,0.10); }
    .sb-story-scale-feed-row:last-child { border-bottom: 0; }
    .sb-story-scale-feed-time { color: var(--text-muted); }
    .sb-story-scale-feed-img  { color: var(--brand-cool); }
    .sb-story-scale-feed-ms   { color: #34D399; font-weight: 700; text-align: right; }

    .sb-story-scale-perc {
      grid-column: span 2;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      padding: 0.625rem 1rem;
      background: rgba(20,19,40,0.4);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
    }
    .sb-story-scale-perc-item { display: flex; flex-direction: column; gap: 0.125rem; }
    .sb-story-scale-perc-label { font-family: var(--font-mono); font-size: 0.625rem; font-weight: 700; letter-spacing: 0.08em; color: var(--text-muted); text-transform: uppercase; }
    .sb-story-scale-perc-num   { font-family: var(--font-mono); font-size: 1rem; font-weight: 700; color: var(--text-primary); }

    .sb-story-foot { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-muted); letter-spacing: 0.04em; margin-top: auto; padding-top: 0.875rem; border-top: 1px solid var(--border-subtle); }

    /* ═══ R24 hero ═══ */
    .sb-hero {
      position: relative; overflow: hidden;
      background: var(--depth-1);
      min-height: 100vh; display: flex; align-items: center;
      border-bottom: 1px solid var(--border-subtle);
    }
    .sb-hero-bg { position: absolute; inset: 0; z-index: 0; opacity: 0.20; pointer-events: none; }
    .sb-hero-bg video { width: 100%; height: 100%; object-fit: cover; }
    .sb-hero-inner {
      position: relative; z-index: 1;
      width: 100%; max-width: 84rem; margin: 0 auto;
      padding: 5rem 6% 3rem;
      display: flex; flex-direction: column; align-items: center; gap: 2.25rem;
    }
    .sb-hero-text { text-align: center; max-width: 52rem; display: flex; flex-direction: column; align-items: center; gap: 1.125rem; }
    .sb-hero-tag {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.3rem 0.75rem;
      background: rgba(52, 211, 153, 0.10);
      border: 1px solid rgba(52, 211, 153, 0.32);
      border-radius: 999px;
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.14em; color: #34D399;
    }
    .sb-hero-tag-dot {
      width: 7px; height: 7px; border-radius: 999px; background: #34D399;
      box-shadow: 0 0 10px rgba(52, 211, 153, 0.7);
      animation: sb-hero-pulse 1.6s ease-in-out infinite;
    }
    @keyframes sb-hero-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .sb-hero-title {
      font-family: var(--font-display);
      font-size: clamp(2.75rem, 6vw + 0.5rem, 5.25rem);
      font-weight: 800; letter-spacing: -0.025em; line-height: 1.05;
      color: var(--text-primary); margin: 0; text-wrap: balance;
    }
    .sb-hero-sub {
      font-family: var(--font-sans);
      font-size: clamp(1.0625rem, 1.3vw, 1.25rem);
      line-height: 1.5; color: var(--text-secondary); margin: 0;
      max-width: 38rem;
    }
    .sb-hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }
    .sb-hero-cta {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.875rem 1.5rem; border-radius: 10px;
      font-family: var(--font-sans); font-size: 1rem; font-weight: 700;
      line-height: 1.2; text-decoration: none;
      transition: background-color 0.16s ease, border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease, color 0.16s ease;
    }
    .sb-hero-cta--primary {
      background: var(--brand-dim);
      border: 1px solid var(--brand-dim);
      color: white;
      box-shadow: 0 8px 28px rgba(99, 102, 241, 0.42);
    }
    .sb-hero-cta--primary:hover {
      background: var(--brand-primary); border-color: var(--brand-primary);
      transform: translateY(-1px);
      box-shadow: 0 10px 32px rgba(99, 102, 241, 0.55);
    }
    .sb-hero-cta--ghost {
      background: transparent;
      border: 1px solid var(--border-default);
      color: var(--text-secondary); font-weight: 500;
    }
    .sb-hero-cta--ghost:hover {
      background: var(--depth-3); border-color: var(--border-accent); color: var(--text-primary);
    }
    .sb-hero-install {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.45rem 0.875rem;
      background: var(--depth-3);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      font-family: var(--font-mono); font-size: 0.8125rem;
      color: var(--text-primary);
    }
    .sb-hero-install-prompt { color: #34D399; font-weight: 700; }
    .sb-hero-install code { background: none; padding: 0; color: inherit; }
    /* Live-feel overlays anchored to the real screenshot. Pattern
       lifted from /services/blueprint-agent. No fabricated UI. */
    .sb-hero-shot-pill {
      position: absolute;
      top: 1rem;
      right: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.7rem;
      background: rgba(12, 11, 29, 0.78);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(74, 222, 128, 0.32);
      border-radius: 999px;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      color: #4ade80;
      font-weight: 600;
      text-transform: uppercase;
      z-index: 2;
    }
    .sb-hero-shot-pulse {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #4ade80;
      box-shadow: 0 0 10px #4ade80;
      animation: sb-hero-pulse 1.6s ease-in-out infinite;
    }
    @keyframes sb-hero-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.45; transform: scale(1.25); }
    }
    .sb-hero-shot-status {
      position: absolute;
      bottom: 1rem;
      right: 1rem;
      max-width: 26rem;
      padding: 0.7rem 0.875rem;
      background: rgba(12, 11, 29, 0.82);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(165, 170, 252, 0.18);
      border-radius: 10px;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.7rem;
      color: rgba(244, 244, 249, 0.85);
      z-index: 2;
      animation: sb-hero-status-in 1.2s ease-out 0.3s both;
    }
    @keyframes sb-hero-status-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .sb-hero-shot-status-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
    }
    .sb-hero-shot-status-tag {
      display: inline-block;
      padding: 0.12rem 0.4rem;
      background: rgba(74, 222, 128, 0.14);
      border: 1px solid rgba(74, 222, 128, 0.3);
      border-radius: 4px;
      color: #4ade80;
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      font-weight: 600;
    }
    .sb-hero-shot-status-name {
      color: #ffffff;
      font-weight: 600;
      font-size: 0.78rem;
    }
    .sb-hero-shot-status-meta {
      display: flex;
      gap: 0.5rem 0.625rem;
      flex-wrap: wrap;
      color: rgba(244, 244, 249, 0.55);
      font-size: 0.65rem;
    }
    .sb-hero-shot-status-meta span:not(:last-child)::after {
      content: '·';
      margin-left: 0.625rem;
      opacity: 0.4;
    }
    .sb-hero-shot-status-meta strong {
      color: #ffffff;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    @media (prefers-reduced-motion: reduce) {
      .sb-hero-shot-pulse,
      .sb-hero-shot-status { animation: none; }
    }
    @media (max-width: 768px) {
      .sb-hero-shot-pill {
        top: 0.5rem; right: 0.5rem;
        font-size: 0.6rem; padding: 0.3rem 0.55rem;
      }
      .sb-hero-shot-status {
        position: relative; bottom: auto; right: auto;
        max-width: 100%; margin: 0.75rem 0.5rem 0.5rem;
      }
    }

    .sb-hero-shot {
      position: relative;
      width: 100%; max-width: 84rem;
      border-radius: 14px; overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.10);
      box-shadow:
        0 28px 80px rgba(0, 0, 0, 0.55),
        0 0 0 1px rgba(165, 170, 252, 0.10) inset;
    }
    .sb-hero-shot::before {
      content: ''; position: absolute; inset: -24px;
      background: linear-gradient(135deg, rgba(52,211,153,0.18), rgba(99,102,241,0.18));
      filter: blur(36px); z-index: -1; pointer-events: none;
    }
    .sb-hero-shot img { display: block; width: 100%; height: auto; border-radius: inherit; }
    /* Fallback rendered when sandbox-app.png isn't present yet. terminal
       mock keyed off the same chrome dots + URL bar pattern. */
    .sb-hero-shot-fallback { display: none; }
    .sb-hero-shot--missing .sb-hero-shot-fallback {
      display: flex; flex-direction: column;
      background: #0c0b1d; aspect-ratio: 16 / 6;
    }
    .sb-hero-shot-chrome {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.625rem 0.875rem;
      background: var(--depth-2);
      border-bottom: 1px solid var(--border-default);
    }
    .sb-hero-shot-dot { width: 11px; height: 11px; border-radius: 999px; }
    .sb-hero-shot-dot:nth-child(1) { background: #ff5f57; }
    .sb-hero-shot-dot:nth-child(2) { background: #febc2e; }
    .sb-hero-shot-dot:nth-child(3) { background: #28c840; }
    .sb-hero-shot-url {
      flex: 1; padding: 0.3rem 0.625rem;
      background: var(--depth-1); border: 1px solid var(--border-subtle);
      border-radius: 999px;
      font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary);
      margin-left: 0.5rem;
    }
    .sb-hero-shot-body {
      flex: 1; display: grid; grid-template-columns: 14rem 1fr; gap: 0;
    }
    .sb-hero-shot-tree {
      padding: 1.25rem;
      background: var(--depth-2);
      border-right: 1px solid var(--border-default);
      font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.7;
      color: var(--text-secondary);
    }
    .sb-hero-shot-term {
      padding: 1.25rem;
      font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.7;
      color: var(--text-primary);
    }
    .sb-hero-shot-cursor {
      display: inline-block; width: 7px; height: 14px; background: #818CF8;
      vertical-align: middle;
      animation: sb-hero-blink 1.1s steps(2, end) infinite;
    }
    @keyframes sb-hero-blink { 0%, 60% { opacity: 1; } 61%, 100% { opacity: 0; } }
    @media (max-width: 768px) {
      .sb-hero-inner { padding: 4rem 5% 2rem; gap: 1.75rem; }
      .sb-hero-shot-body { grid-template-columns: 1fr; }
      .sb-hero-shot-tree { display: none; }
    }

    /* ═══ Scale + autoresearch ═══ */
    .sb-scale-head { max-width: 56rem; margin: 0 0 2.5rem; }
    .sb-scale-eyebrow {
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.18em; color: #34D399; text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .sb-scale-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.6vw, 3rem);
      font-weight: 700; line-height: 1.1; letter-spacing: -0.02em;
      color: var(--text-primary); margin: 0 0 1rem; text-wrap: balance;
    }
    .sb-scale-lede {
      font-family: var(--font-sans); font-size: 1.0625rem; line-height: 1.6;
      color: var(--text-secondary); max-width: 44rem; margin: 0;
    }
    .sb-scale-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto auto;
      gap: 0.875rem;
    }
    .sb-scale-card {
      padding: 1rem 1.125rem;
      background: rgba(99, 102, 241, 0.06);
      border: 1px solid rgba(99, 102, 241, 0.18);
      border-radius: 10px;
    }
    .sb-scale-card--big { background: rgba(52, 211, 153, 0.10); border-color: rgba(52, 211, 153, 0.28); }
    .sb-scale-card-label {
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.10em; color: var(--text-muted); margin-bottom: 0.5rem;
    }
    .sb-scale-card-num {
      font-family: var(--font-display); font-size: 2.5rem; font-weight: 800;
      letter-spacing: -0.03em; line-height: 1; color: var(--text-primary); margin-bottom: 0.4rem;
    }
    .sb-scale-card--big .sb-scale-card-num {
      background: linear-gradient(90deg, #6EE7B7, #34D399);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .sb-scale-card-trend { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary); }
    .sb-scale-trend-up { color: #34D399; font-weight: 700; }

    .sb-scale-regions, .sb-scale-feed {
      grid-column: span 1;
      padding: 1rem 1.125rem;
      background: rgba(20, 19, 40, 0.4);
      border: 1px solid var(--border-subtle);
      border-radius: 10px;
    }
    .sb-scale-region-list { display: flex; flex-direction: column; gap: 0.45rem; margin-top: 0.5rem; }
    .sb-scale-region {
      display: grid; grid-template-columns: 7rem 1fr 3rem; gap: 0.6rem; align-items: center;
      font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary);
    }
    .sb-scale-region-bar { height: 5px; background: rgba(255, 255, 255, 0.05); border-radius: 3px; overflow: hidden; }
    .sb-scale-region-bar > span { display: block; height: 100%; background: linear-gradient(90deg, #818CF8, #A5AAFC); border-radius: 3px; }
    .sb-scale-region:last-child .sb-scale-region-bar > span { background: linear-gradient(90deg, #34D399, #6EE7B7); }
    .sb-scale-region :last-child { color: var(--text-primary); font-weight: 700; text-align: right; }
    .sb-scale-feed-list { display: flex; flex-direction: column; gap: 0.25rem; margin-top: 0.5rem; }
    .sb-scale-feed-row {
      display: grid; grid-template-columns: 4.5rem 1fr 3rem; gap: 0.6rem; align-items: center;
      font-family: var(--font-mono); font-size: 0.75rem;
      padding: 0.225rem 0;
      border-bottom: 1px dashed rgba(165, 170, 252, 0.10);
    }
    .sb-scale-feed-row:last-child { border-bottom: 0; }
    .sb-scale-feed-time { color: var(--text-muted); }
    .sb-scale-feed-img  { color: var(--brand-cool); }
    .sb-scale-feed-ms   { color: #34D399; font-weight: 700; text-align: right; }
    .sb-scale-perc {
      grid-column: span 2;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.875rem;
      padding: 0.875rem 1.125rem;
      background: rgba(20, 19, 40, 0.4);
      border: 1px solid var(--border-subtle);
      border-radius: 10px;
    }
    .sb-scale-perc-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .sb-scale-perc-label {
      font-family: var(--font-mono); font-size: 0.625rem; font-weight: 700;
      letter-spacing: 0.10em; color: var(--text-muted); text-transform: uppercase;
    }
    .sb-scale-perc-num { font-family: var(--font-mono); font-size: 1.125rem; font-weight: 700; color: var(--text-primary); }
    @media (max-width: 768px) {
      .sb-scale-grid { grid-template-columns: 1fr; }
      .sb-scale-perc { grid-column: span 1; grid-template-columns: repeat(2, 1fr); }
    }

    /* ═══ Scale v2 — single hero stat + 4 percentile chips + 1
       hover-pause spawn feed. Replaces the prior 6-card metric soup
       (Drew: "feels bad"). ═══ */
    .sb-scale-v2 {
      max-width: 1100px;
      margin: 0 auto;
    }
    .sb-scale-v2-head {
      text-align: center;
      max-width: 56rem;
      margin: 0 auto 2.5rem;
    }
    .sb-scale-v2-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.3rem 0.7rem;
      background: rgba(74, 222, 128, 0.08);
      border: 1px solid rgba(74, 222, 128, 0.22);
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      color: #4ade80;
      font-weight: 600;
      margin-bottom: 1rem;
    }
    .sb-scale-v2-pulse {
      width: 7px; height: 7px; border-radius: 999px;
      background: #4ade80; box-shadow: 0 0 10px #4ade80;
      animation: sb-scale-v2-blink 1.6s ease-in-out infinite;
    }
    @keyframes sb-scale-v2-blink {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.45; transform: scale(1.2); }
    }
    .sb-scale-v2-title {
      font-family: var(--font-display);
      font-size: clamp(1.875rem, 3.6vw, 2.875rem);
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1.08;
      margin: 0 0 0.875rem;
    }
    .sb-scale-v2-lede {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--text-secondary);
      margin: 0;
    }

    .sb-scale-v2-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .sb-scale-v2-stat {
      padding: 1.25rem 1.25rem;
      background: rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
    .sb-scale-v2-stat-num {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .sb-scale-v2-stat-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      color: var(--text-secondary);
      text-transform: uppercase;
    }

    .sb-scale-v2-feed {
      background: rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 12px;
      overflow: hidden;
    }
    .sb-scale-v2-feed-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 1.25rem;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .sb-scale-v2-feed-label { color: rgba(244, 244, 249, 0.5); font-weight: 600; }
    .sb-scale-v2-feed-region { color: rgba(244, 244, 249, 0.35); }
    .sb-scale-v2-feed-rows {
      max-height: 14rem;
      overflow: hidden;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0, black 8%, black 92%, transparent 100%);
      mask-image: linear-gradient(to bottom, transparent 0, black 8%, black 92%, transparent 100%);
      animation: sb-scale-v2-scroll 28s linear infinite;
    }
    .sb-scale-v2-feed:hover .sb-scale-v2-feed-rows {
      animation-play-state: paused;
    }
    @keyframes sb-scale-v2-scroll {
      from { transform: translateY(0); }
      to   { transform: translateY(-50%); }
    }
    .sb-scale-v2-feed-row {
      display: grid;
      grid-template-columns: 6.5rem 1fr 5rem;
      gap: 1rem;
      padding: 0.55rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      color: rgba(244, 244, 249, 0.78);
    }
    .sb-scale-v2-feed-time { color: rgba(244, 244, 249, 0.45); }
    .sb-scale-v2-feed-img { color: #a5aafc; }
    .sb-scale-v2-feed-ms { color: #4ade80; font-weight: 600; text-align: right; font-variant-numeric: tabular-nums; }

    @media (prefers-reduced-motion: reduce) {
      .sb-scale-v2-pulse,
      .sb-scale-v2-feed-rows { animation: none; }
    }
    @media (max-width: 768px) {
      .sb-scale-v2-stats { grid-template-columns: repeat(2, 1fr); }
      .sb-scale-v2-stat-num { font-size: 1.625rem; }
      .sb-scale-v2-feed-row {
        grid-template-columns: 5rem 1fr 4rem;
        font-size: 0.72rem;
        padding: 0.45rem 1rem;
      }
      .sb-scale-v2-feed-region { display: none; }
    }

    /* ═══ Problems we solve (vault) — section deleted; styles kept
       for any straggling references but unused on this page. ═══ */
    .sb-problems-head { max-width: 56rem; margin: 0 0 2.5rem; }
    .sb-problems-eyebrow {
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.18em; color: #4F46E5; text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .sb-problems-title {
      font-family: var(--font-display);
      font-size: clamp(1.875rem, 3.4vw, 2.75rem);
      font-weight: 700; line-height: 1.15; letter-spacing: -0.02em;
      color: #191c24; margin: 0; text-wrap: balance;
    }
    .sb-problems-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
    }
    .sb-problem {
      padding: 1.75rem;
      background: #ffffff;
      border: 1px solid rgba(99, 102, 241, 0.14);
      border-radius: 12px;
    }
    .sb-problem-tag {
      font-family: var(--font-mono); font-size: 0.625rem; font-weight: 700;
      letter-spacing: 0.16em; color: #4338CA; text-transform: uppercase;
      margin-bottom: 0.875rem;
    }
    .sb-problem-pain {
      font-family: var(--font-display); font-weight: 600; font-size: 1.0625rem;
      line-height: 1.45; color: #191c24; letter-spacing: -0.01em;
      margin-bottom: 0.875rem;
    }
    .sb-problem-fix {
      font-family: var(--font-sans); font-size: 0.9375rem; line-height: 1.55;
      color: #3a3a50;
      padding-top: 0.875rem;
      border-top: 1px dashed rgba(99, 102, 241, 0.18);
    }
    @media (max-width: 768px) { .sb-problems-grid { grid-template-columns: 1fr; } }

    /* ═══ Final dual-CTA (ship today / enterprise) ═══ */
    .sb-final-cta {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    }
    .sb-final-cta-card {
      padding: 2rem;
      border-radius: 14px;
      display: flex; flex-direction: column; gap: 0.875rem;
    }
    .sb-final-cta-card--primary {
      background: linear-gradient(135deg, rgba(79, 70, 229, 0.18), rgba(165, 170, 252, 0.06));
      border: 1px solid rgba(79, 70, 229, 0.42);
    }
    .sb-final-cta-card--enterprise {
      background: var(--depth-3);
      border: 1px solid var(--border-default);
    }
    .sb-final-cta-tag {
      font-family: var(--font-mono); font-size: 0.625rem; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: #A5AAFC;
    }
    .sb-final-cta-card--enterprise .sb-final-cta-tag { color: var(--text-muted); }
    .sb-final-cta-title {
      font-family: var(--font-display); font-size: 1.875rem; font-weight: 700;
      letter-spacing: -0.02em; line-height: 1.1;
      color: var(--text-primary); margin: 0;
    }
    .sb-final-cta-body {
      font-family: var(--font-sans); font-size: 1rem; line-height: 1.55;
      color: var(--text-secondary); margin: 0; flex: 1;
    }
    .sb-final-cta-ctas { display: flex; gap: 0.625rem; flex-wrap: wrap; align-items: center; margin-top: 0.5rem; }
    .sb-final-cta-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.625rem 1rem; border-radius: 8px;
      font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700;

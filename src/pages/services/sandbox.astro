                <div>non-root user · uid 1000</div>
                <div>per-job filesystem + network</div>
                <div>secrets injected post-spawn</div>
              </div>
            </div>
            <div class="sb-iso-tier sb-iso-tier--onprem">
              <div class="sb-iso-tier-band">ENTERPRISE · ON-PREM</div>
              <div class="sb-iso-tier-name">Firecracker microVM</div>
              <div class="sb-iso-tier-providers">
                <span class="sb-iso-tier-text">firecracker</span>
              </div>
              <div class="sb-iso-tier-bullets">
                <div>hardware-virtualized boundary</div>
                <div>host kernel can't bypass</div>
                <div>same SDK call, different driver</div>
              </div>
            </div>
            <div class="sb-iso-tier sb-iso-tier--tee">
              <div class="sb-iso-tier-band">ENTERPRISE · ATTESTED</div>

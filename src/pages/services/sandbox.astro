---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SandboxShowcase from '../../components/SandboxShowcase';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';
import FeatureCard from '../../components/ui/FeatureCard.astro';

const heroSdkCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">SandboxClient</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/sandbox"</span>;

<span class="cw-k">const</span> <span class="cw-v">client</span> = <span class="cw-k">new</span> <span class="cw-f">SandboxClient</span>({ apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span> });
<span class="cw-k">const</span> <span class="cw-v">box</span> = <span class="cw-k">await</span> client.<span class="cw-f">create</span>({ image: <span class="cw-s">"node:22"</span> });

<span class="cw-c">// Stream a coding agent inside the sandbox</span>
<span class="cw-k">for await</span> (<span class="cw-k">const</span> <span class="cw-v">event</span> <span class="cw-k">of</span> box.<span class="cw-f">streamTask</span>(
  <span class="cw-s">"Refactor src/ to TypeScript and add tests"</span>
)) {
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"tool_call"</span>)
    console.<span class="cw-f">log</span>(<span class="cw-s">\`tool: \${event.tool}\`</span>);
  <span class="cw-k">if</span> (event.type === <span class="cw-s">"message"</span>)
    process.stdout.<span class="cw-f">write</span>(event.content);
}

<span class="cw-sh">✓</span> <span class="cw-v">12 files converted</span>  <span class="cw-c">· 47 tests passing</span>
<span class="cw-sh">✓</span> <span class="cw-v">PR #18 created</span>      <span class="cw-c">· src/ → TypeScript</span>`;

const heroCliCode = `<span class="cw-c"># Install the CLI</span>
<span class="cw-sh">$</span> <span class="cw-v">npm install -g</span> <span class="cw-s">@tangle-network/sandbox</span>

<span class="cw-c"># Spin up an isolated container</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle sandbox create</span> <span class="cw-k">--image</span> <span class="cw-s">node:22</span>
<span class="cw-p">→</span> <span class="cw-v">sbx_a8f3c2d1</span>  <span class="cw-c">· ready in 0.6s</span>

<span class="cw-c"># Run a coding agent against it</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle agent run</span> <span class="cw-s">sbx_a8f3c2d1</span> \\
<span class="cw-k">  --goal</span> <span class="cw-s">"Refactor src/ to TypeScript"</span> \\
<span class="cw-k">  --stream</span>

<span class="cw-sh">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 4 turns · 18s · 0 errors</span>`;

const iconShield = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';
const iconLayers = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>';
const iconCamera = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>';
const iconBot = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>';
const iconUsers = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>';
const iconRefresh = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>';

const faqs = [
  { question: 'What is the Sandbox SDK?', answer: 'A TypeScript SDK and CLI for spinning up isolated cloud containers. Each sandbox is a full Linux environment — root, filesystem, networking, optional GPU — provisioned in under a second.' },
  { question: 'Which agent backends work?', answer: 'OpenCode (default, multi-provider), Claude Code, OpenAI Codex, Sourcegraph AMP, and Factory Droids. Switch backends per request, or bring your own API key.' },
  { question: 'What images and runtimes are supported?', answer: 'Any Docker image. Pre-built images for Node, Python, Rust, Go, Ethereum, Solana, and CUDA-enabled GPU workloads. Bring your own Dockerfile if you need a custom base.' },
  { question: 'How do snapshot and restore work?', answer: 'Checkpoint the full sandbox — filesystem, packages, state — then restore instantly into a fresh sandbox. Bring your own S3-compatible bucket (S3, GCS, R2) for persistence.' },
];
---

<BaseLayout title="Sandbox SDK — Secure Cloud for AI Agents" description="Spin up isolated environments, run AI agents, stream results. TypeScript SDK, CLI, zero DevOps.">

  <style>
    .sb-gradient-text em {
      font-style: normal;
      background: linear-gradient(135deg, #818cf8, #6366F1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .sb-copy-pill { position: relative; }
    .sb-copy-tooltip {
      position: absolute;
      right: -8px;
      top: -32px;
      background: #4ade80;
      color: #000;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
      white-space: nowrap;
    }
    .sb-copy-pill.copied .sb-copy-tooltip { opacity: 1; }

    .sb-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3rem;
      align-items: center;
      width: 100%;
      max-width: 84rem;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .sb-hero-code { min-width: 0; }

    .sb-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 2.5rem;
    }

    @media (max-width: 991px) {
      .sb-hero-grid { grid-template-columns: minmax(0, 1fr); gap: 2rem; }
    }
    @media (max-width: 768px) {
      .sb-grid-3 { grid-template-columns: 1fr; }
    }
  </style>

  <!-- =======================================
       HERO
       ======================================= -->
  <section class="wf-section-hero" style="position: relative; overflow: hidden;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 10rem 5% 4rem; justify-content: flex-start;">
      <div class="sb-hero-grid">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Sandbox SDK</div>
            </div>
          </div>
          <h1 class="wf-h1 sb-gradient-text">Give your agents the <em>real world,</em> safely.</h1>
          <div class="wf-body-01">Isolated cloud containers for AI agents. Create, execute, stream — from TypeScript or the CLI. Sub-second provisioning, any Docker image, zero DevOps.</div>
          <div class="wf-install-pill sb-copy-pill" style="margin-top: 8px; cursor: pointer; position: relative;">
            <span class="prompt">$</span>
            <code>npm install @tangle-network/sandbox</code>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-left: auto; opacity: 0.4; flex-shrink: 0;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span class="sb-copy-tooltip">Copied!</span>
          </div>
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: white; color: #211f54; border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Documentation</a>
            <a href="https://discord.com/invite/cv8EfJu3Tn" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; padding: 12px 24px; background: #1e116e; color: white; border-radius: 48px; font-family: var(--font-sans); font-size: 15px; font-weight: 600; text-decoration: none;">Join Waitlist</a>
          </div>
        </div>

        <div class="sb-hero-code">
          <CodeWindow
            tabs={[
              { id: 'sdk', label: 'SDK', icon: 'code', html: heroSdkCode },
              { id: 'cli', label: 'CLI', icon: 'terminal', html: heroCliCode },
            ]}
          />
        </div>
      </div>

      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.35;">
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <StatsStrip
    items={[
      { label: '<1s provisioning', icon: 'zap' },
      { label: 'any Docker image · SSH access', icon: 'terminal' },
      { label: 'mTLS-isolated sidecar', icon: 'shield' },
      { label: 'snapshot · restore · bring your S3', icon: 'layers' },
    ]}
  />

  <!-- =======================================
       PRIMITIVES — what the SDK actually gives you
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <SectionHead
          eyebrow="PRIMITIVES"
          eyebrowColor="brand"
          title={`Three primitives. <em style="font-style: normal; background: linear-gradient(135deg, #818cf8, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Everything else composes.</em>`}
          description="Sandbox SDK is small on purpose. A handful of well-defined primitives, no hidden control plane, no leaky abstractions."
          align="center"
        />
        <div class="sb-grid-3">
          <FeatureCard
            icon={iconShield}
            iconColor="indigo"
            title="Isolated runtime"
            body="Each sandbox runs in its own VM-grade boundary with mTLS-locked sidecar control. Agents get root inside; nothing crosses the wall."
          />
          <FeatureCard
            icon={iconLayers}
            iconColor="emerald"
            title="Any Docker image"
            body="Bring any image — Node, Python, Rust, CUDA, your custom Dockerfile. Cold-start in under a second, warm pools for hot paths."
          />
          <FeatureCard
            icon={iconCamera}
            iconColor="amber"
            title="Snapshot & restore"
            body="Checkpoint filesystem, processes, and installed state. Restore into a fresh sandbox in milliseconds. BYO S3 for persistence."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- INTERACTIVE SHOWCASE -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <SectionHead
          eyebrow="SEE IT WORK"
          eyebrowColor="brand"
          title={`SDK and CLI. <em style="font-style: normal; background: linear-gradient(135deg, #818cf8, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Full control.</em>`}
          description="Every example uses the real @tangle-network/sandbox API."
          align="center"
        />
        <SandboxShowcase client:load />
      </div>
    </div>
  </section>

  <!-- =======================================
       USE CASES — vault/light surface
       ======================================= -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <SectionHead
          eyebrow="USE CASES"
          eyebrowColor="emerald"
          title="Built for the workloads you can't run on your laptop."
          description="Anywhere an agent needs a real computer — code execution, multi-tenant compute, reproducible environments — Sandbox is the substrate."
          align="center"
        />
        <div class="sb-grid-3">
          <FeatureCard
            variant="vault"
            icon={iconBot}
            iconColor="indigo"
            title="Run AI-generated code safely"
            body="Execute model-authored code without trusting it. Filesystem damage, runaway processes, and exfil attempts stay inside the box."
          />
          <FeatureCard
            variant="vault"
            icon={iconUsers}
            iconColor="emerald"
            title="Multi-tenant agent workloads"
            body="One sandbox per tenant, per session, or per task. Snapshot the base image, restore for every new user, no cross-talk."
          />
          <FeatureCard
            variant="vault"
            icon={iconRefresh}
            iconColor="amber"
            title="Reproducible dev environments"
            body="Pin a Dockerfile, snapshot the post-install state, hand teammates an identical box on demand. CI you can SSH into."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- =======================================
       FAQ
       ======================================= -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <FAQ faqs={faqs} />
      </div>
    </div>
  </section>

  <!-- =======================================
       CTA
       ======================================= -->
  <div class="wf-cta-card">
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Cloud containers for AI agents.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">Create your first sandbox, run an agent, stream results. One npm install.</div>
        <div class="wf-cta-button-row">
          <a href="https://docs.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Get Started</a>
        </div>
      </div>
    </div>
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
  </div>

<script>
  document.querySelector('.sb-copy-pill')?.addEventListener('click', () => {
    navigator.clipboard.writeText('npm install @tangle-network/sandbox');
    const pill = document.querySelector('.sb-copy-pill');
    pill?.classList.add('copied');
    setTimeout(() => pill?.classList.remove('copied'), 1500);
  });
</script>

</BaseLayout>

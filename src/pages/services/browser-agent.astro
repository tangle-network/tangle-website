---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import StatsStrip from '../../components/ui/StatsStrip.astro';
import SectionHead from '../../components/ui/SectionHead.astro';
import CodeWindow from '../../components/ui/CodeWindow.astro';
import ExamplePanel from '../../components/ui/ExamplePanel.astro';
import Hero from '../../components/ui/Hero.astro';

const baCliCode = `<span class="cw-sh">$</span> <span class="cw-v">bad run</span> <span class="cw-k">--goal</span> <span class="cw-s">"Sign up, verify dashboard loads"</span> \\
<span class="cw-k">  --url</span> <span class="cw-s">https://your-app.com</span> <span class="cw-k">--model</span> <span class="cw-s">claude-sonnet-4-6</span>

<span class="cw-c"># turn 1 · navigate</span>
<span class="cw-sh">→</span> <span class="cw-v">goto</span> <span class="cw-s">https://your-app.com</span>  <span class="cw-c">· 312ms · 200 OK</span>

<span class="cw-c"># turn 2 · plan</span>
<span class="cw-sh">→</span> <span class="cw-v">click</span> <span class="cw-s">"Sign up"</span>  <span class="cw-c">· header CTA</span>
<span class="cw-sh">→</span> <span class="cw-v">type</span> <span class="cw-s">"qa+test@tangle.tools"</span> <span class="cw-c">· #email</span>
<span class="cw-sh">→</span> <span class="cw-v">type</span> <span class="cw-s">"••••••••"</span> <span class="cw-c">· #password</span>
<span class="cw-sh">→</span> <span class="cw-v">click</span> <span class="cw-s">"Create account"</span>

<span class="cw-c"># turn 3 · verify</span>
<span class="cw-sh">→</span> <span class="cw-v">wait_for</span> <span class="cw-s">'h1:has-text("Dashboard")'</span> <span class="cw-c">· visible in 814ms</span>
<span class="cw-sh">→</span> <span class="cw-v">screenshot</span>  <span class="cw-c">· artifacts/turn-3.png</span>

<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 3 turns · 4.7s · 1 screenshot · DOM trace</span>`;

const baSdkCode = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">BrowserAgent</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/browser-agent-driver"</span>;

<span class="cw-k">const</span> <span class="cw-v">agent</span> = <span class="cw-k">new</span> <span class="cw-f">BrowserAgent</span>({
  model: <span class="cw-s">"anthropic/claude-sonnet-4-6"</span>,
  apiKey: process.env.<span class="cw-v">TANGLE_API_KEY</span>,
});

<span class="cw-k">const</span> <span class="cw-v">result</span> = <span class="cw-k">await</span> agent.<span class="cw-f">run</span>({
  goal: <span class="cw-s">"Sign up, verify dashboard loads"</span>,
  url: <span class="cw-s">"https://your-app.com"</span>,
  evidence: <span class="cw-s">"screenshots+dom"</span>,
});

<span class="cw-k">if</span> (!result.<span class="cw-v">achieved</span>) {
  <span class="cw-k">throw new</span> <span class="cw-f">Error</span>(result.<span class="cw-v">failureReason</span>);
}

<span class="cw-c">// every turn has a screenshot, DOM snapshot, and reasoning trace</span>
<span class="cw-k">for</span> (<span class="cw-k">const</span> <span class="cw-v">turn</span> <span class="cw-k">of</span> result.<span class="cw-v">turns</span>) {
  console.<span class="cw-f">log</span>(turn.<span class="cw-v">action</span>, turn.<span class="cw-v">screenshot</span>);
}`;

// ─── Showcase examples — workflows × CLI/SDK (ExamplePanel-fed) ───
const baE2eCli = `<span class="cw-sh">$</span> <span class="cw-v">bad run</span> \\
  <span class="cw-k">--goal</span> <span class="cw-s">"Sign up, verify email, check dashboard"</span> \\
  <span class="cw-k">--url</span>  <span class="cw-s">https://your-app.com</span> \\
  <span class="cw-k">--model</span> <span class="cw-s">claude-sonnet-4-6</span> <span class="cw-k">--vision</span>

<span class="cw-c"># turn 1 · navigate</span>
<span class="cw-p">→</span> <span class="cw-v">goto</span> <span class="cw-s">/signup</span>  <span class="cw-c">· 312ms · 200 OK</span>
<span class="cw-p">→</span> <span class="cw-v">type</span> <span class="cw-s">"qa+test@tangle.tools"</span>  <span class="cw-c">· #email</span>
<span class="cw-p">→</span> <span class="cw-v">click</span> <span class="cw-s">"Create account"</span>
<span class="cw-p">→</span> <span class="cw-v">wait_for</span> <span class="cw-s">'h1:has-text("Dashboard")'</span>  <span class="cw-c">· 814ms</span>
<span class="cw-p">→</span> <span class="cw-v">screenshot</span>  <span class="cw-c">· artifacts/turn-3.png</span>

<span class="cw-ok">✓</span> <span class="cw-v">Goal achieved</span>  <span class="cw-c">· 6 turns · 12.1s · video + DOM trace</span>`;

const baE2eSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">BrowserAgent</span><span class="cw-v">, </span><span class="cw-f">PlaywrightDriver</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/browser-agent-driver"</span>;
<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">chromium</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"playwright"</span>;

<span class="cw-k">const</span> <span class="cw-v">browser</span> = <span class="cw-k">await</span> chromium.<span class="cw-f">launch</span>();
<span class="cw-k">const</span> <span class="cw-v">page</span>    = <span class="cw-k">await</span> browser.<span class="cw-f">newPage</span>();
<span class="cw-k">const</span> <span class="cw-v">agent</span>   = <span class="cw-k">new</span> <span class="cw-f">BrowserAgent</span>({
  driver: <span class="cw-k">new</span> <span class="cw-f">PlaywrightDriver</span>(page),
  config: { model: <span class="cw-s">"claude-sonnet-4-6"</span>, vision: <span class="cw-n">true</span> },
});

<span class="cw-k">const</span> <span class="cw-v">result</span> = <span class="cw-k">await</span> agent.<span class="cw-f">run</span>({
  goal:     <span class="cw-s">"Sign up, verify email, check dashboard"</span>,
  startUrl: <span class="cw-s">"https://your-app.com"</span>,
});

<span class="cw-ok">✓</span> <span class="cw-v">result.success</span>      <span class="cw-c">// true</span>
<span class="cw-ok">✓</span> <span class="cw-v">result.turns</span>        <span class="cw-c">// 6</span>
<span class="cw-ok">✓</span> <span class="cw-v">result.screenshots</span>  <span class="cw-c">// ["turn-1.png", ...]</span>`;

const baSuiteCli = `<span class="cw-sh">$</span> <span class="cw-v">bad run</span> <span class="cw-k">--cases</span> <span class="cw-s">tests/e2e.json</span> <span class="cw-k">--concurrency</span> <span class="cw-n">4</span>

<span class="cw-c"># Running 5 test cases (4 concurrent)</span>
<span class="cw-ok">✓</span> <span class="cw-v">signup</span>          <span class="cw-c">· 4 turns · 8.1s</span>
<span class="cw-ok">✓</span> <span class="cw-v">login</span>           <span class="cw-c">· 2 turns · 3.4s</span>
<span class="cw-ok">✓</span> <span class="cw-v">create-project</span>  <span class="cw-c">· 6 turns · 14.2s</span>
<span class="cw-p">✗</span> <span class="cw-v">billing</span>         <span class="cw-c">· stuck at payment modal</span>
<span class="cw-ok">✓</span> <span class="cw-v">settings</span>        <span class="cw-c">· 3 turns · 5.8s</span>

<span class="cw-v">Pass: 4/5</span>  <span class="cw-c">· Fail: 1 · Duration: 31.5s · Report: results/report.html</span>`;

const baSuiteSdk = `<span class="cw-k">import</span> <span class="cw-v">{ </span><span class="cw-f">BrowserAgent</span><span class="cw-v"> }</span> <span class="cw-k">from</span> <span class="cw-s">"@tangle-network/browser-agent-driver"</span>;

<span class="cw-k">const</span> <span class="cw-v">cases</span> = [
  { id: <span class="cw-s">"signup"</span>,  goal: <span class="cw-s">"Create account"</span>,         startUrl: <span class="cw-s">"/signup"</span> },
  { id: <span class="cw-s">"login"</span>,   goal: <span class="cw-s">"Login with credentials"</span>, startUrl: <span class="cw-s">"/login"</span> },
  { id: <span class="cw-s">"billing"</span>, goal: <span class="cw-s">"Update payment method"</span>,  startUrl: <span class="cw-s">"/billing"</span> },
];

<span class="cw-k">const</span> <span class="cw-v">results</span> = <span class="cw-k">await</span> agent.<span class="cw-f">runBatch</span>(cases, { concurrency: <span class="cw-n">4</span> });

results.<span class="cw-f">forEach</span>((r) =&gt; console.<span class="cw-f">log</span>(r.id, r.success));
<span class="cw-ok">✓</span> <span class="cw-v">4 passed</span>  <span class="cw-c">· 1 failed · 31.5s</span>`;

const baAuditCli = `<span class="cw-sh">$</span> <span class="cw-v">bad design-audit</span> \\
  <span class="cw-k">--url</span>             <span class="cw-s">https://your-app.com</span> \\
  <span class="cw-k">--pages</span>           <span class="cw-s">"/, /pricing, /docs"</span> \\
  <span class="cw-k">--extract-tokens</span>

<span class="cw-c"># Auditing 3 pages at 1440×900</span>
<span class="cw-v">Health Score: </span><span class="cw-sh">82</span><span class="cw-v">/100</span>

  <span class="cw-p">⚠</span> <span class="cw-v">Typography: 3 inconsistent font sizes</span>
  <span class="cw-p">⚠</span> <span class="cw-v">Spacing: 12px / 16px mixed in cards</span>
  <span class="cw-ok">✓</span> <span class="cw-v">Colors: consistent palette</span>
  <span class="cw-ok">✓</span> <span class="cw-v">Contrast: WCAG AA compliant</span>

<span class="cw-c">Tokens → design-tokens.json · Screenshots → ./audit-results/</span>`;

const baAuditSdk = `<span class="cw-k">const</span> <span class="cw-v">audit</span> = <span class="cw-k">await</span> agent.<span class="cw-f">designAudit</span>({
  url:           <span class="cw-s">"https://your-app.com"</span>,
  pages:         [<span class="cw-s">"/"</span>, <span class="cw-s">"/pricing"</span>, <span class="cw-s">"/docs"</span>],
  extractTokens: <span class="cw-n">true</span>,
});

<span class="cw-ok">✓</span> <span class="cw-v">audit.score</span>     <span class="cw-c">// 82</span>
<span class="cw-ok">✓</span> <span class="cw-v">audit.findings</span>  <span class="cw-c">// [{ type, severity, msg }]</span>
<span class="cw-ok">✓</span> <span class="cw-v">audit.tokens</span>    <span class="cw-c">// { colors, fonts, spacing }</span>`;

const baDiffCli = `<span class="cw-sh">$</span> <span class="cw-v">bad visual-diff</span> \\
  <span class="cw-k">--baseline</span>  <span class="cw-s">./screenshots/v1</span> \\
  <span class="cw-k">--current</span>   <span class="cw-s">https://staging.your-app.com</span> \\
  <span class="cw-k">--threshold</span> <span class="cw-n">0.02</span>

<span class="cw-c"># Comparing 8 pages against baseline</span>
<span class="cw-ok">✓</span> <span class="cw-v">/</span>           <span class="cw-c">· 0.00% diff</span>
<span class="cw-ok">✓</span> <span class="cw-v">/pricing</span>    <span class="cw-c">· 0.01% diff</span>
<span class="cw-p">⚠</span> <span class="cw-v">/dashboard</span>  <span class="cw-c">· 4.21% — layout shift detected</span>
<span class="cw-ok">✓</span> <span class="cw-v">/settings</span>   <span class="cw-c">· 0.00% diff</span>

<span class="cw-v">1 regression detected</span>  <span class="cw-c">· Diff images → ./visual-diff/</span>`;

const baDiffSdk = `<span class="cw-k">const</span> <span class="cw-v">diff</span> = <span class="cw-k">await</span> agent.<span class="cw-f">visualDiff</span>({
  baseline:   <span class="cw-s">"./screenshots/v1"</span>,
  currentUrl: <span class="cw-s">"https://staging.your-app.com"</span>,
  threshold:  <span class="cw-n">0.02</span>,
});

<span class="cw-k">for</span> (<span class="cw-k">const</span> <span class="cw-v">r</span> <span class="cw-k">of</span> diff.regressions) {
  console.<span class="cw-f">log</span>(r.path, r.diffPercent);
}

<span class="cw-ok">✓</span> <span class="cw-v">1 regression</span>  <span class="cw-c">· /dashboard · 4.21%</span>`;

const faqs = [
  { question: 'What is Browser Agent?', answer: 'A browser automation agent. Describe a goal in English. It launches Chromium, navigates, clicks, types, verifies — and saves screenshots and DOM per turn.' },
  { question: 'How does it work?', answer: 'Goal + URL in. Vision-capable model decides each action, Playwright executes it. Every turn produces a screenshot, DOM snapshot, and reasoning trace.' },
  { question: 'What models does it support?', answer: 'Claude, GPT, and other vision-capable models. Choose per run with --model.' },
  { question: 'Is it open source?', answer: 'Yes — MIT. npm i -g @tangle-network/browser-agent-driver. Source: github.com/tangle-network/browser-agent-driver.' },
];
---

<BaseLayout title="Browser Agent — AI-Powered Testing" description="Describe a goal in English. The agent drives Chromium, takes screenshots, returns DOM evidence per turn.">

  <!-- Hero -->
  <Hero
    eyebrow="BROWSER AGENT"
    eyebrowColor="brand"
    eyebrowIcon="code"
    title={`Your QA team is an <span class="wf-gradient-text">AI</span>.`}
    subtitle="Goal in English. Real Chromium. Screenshot + DOM trace per turn."
    installPill={{ command: 'npm i -g @tangle-network/browser-agent-driver' }}
    primaryCta={{ label: 'Get Started', href: 'https://browser.tangle.tools', external: true }}
    secondaryCta={{ label: 'Star on GitHub', href: 'https://github.com/tangle-network/browser-agent-driver', external: true }}
    videoBg={{
      poster: '/images/hero/abstract-objects-poster.jpg',
      webm: '/videos/abstract-objects.webm',
      mp4: '/videos/abstract-objects.mp4',
      opacity: 0.18,
    }}
  >
    <CodeWindow
      tabs={[
        { id: 'cli', label: 'bad CLI', icon: 'terminal', html: baCliCode },
        { id: 'sdk', label: 'SDK', icon: 'code', html: baSdkCode },
      ]}
    />
  </Hero>

  <StatsStrip
    items={[
      { label: 'plain-English goals', icon: 'terminal' },
      { label: 'vision-enabled, any site', icon: 'globe' },
      { label: 'screenshot + DOM evidence per turn', icon: 'shield' },
      { label: 'MIT licensed · npm i -g', icon: 'code' },
    ]}
  />

  <!-- Use cases — VAULT (light) surface — moved UP -->
  <section class="wf-section wf-section-vault">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 72rem;">
        <div class="wf-section-head">
          <span class="wf-eyebrow" style="color: #047857;">WHERE TEAMS RUN IT</span>
          <h2 class="wf-h3" style="text-align: left; margin: 0; max-width: 44rem; color: #191c24;">From PR smoke to release-blocker audits.</h2>
          <p class="wf-body-01" style="margin: 0.5rem 0 0; color: #3a3a50; max-width: 44rem;">Describe what matters. The agent finds the bug, keeps the evidence.</p>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 2.5rem;">
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">PR SMOKE</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Every PR runs 30+ goals.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Run on every preview URL. Fails the build on a miss, posts evidence to the PR.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">DESIGN AUDITS</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">WCAG + brand in one pass.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Per-page punchlist: contrast ratios, spacing drift, broken components.</p>
          </div>
          <div style="background: white; border: 1px solid rgba(110, 108, 148, 0.25); border-radius: 12px; padding: 1.75rem;">
            <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: #4338CA; margin-bottom: 0.75rem;">COMPETITIVE RECON</div>
            <div style="font-family: var(--font-display); font-weight: 700; font-size: 1.125rem; color: #191c24; margin-bottom: 0.5rem;">Watch what competitors ship.</div>
            <p style="font-family: var(--font-sans); font-size: 0.9375rem; color: #3a3a50; line-height: 1.55; margin: 0;">Diff copy, pricing, flows over time. Pipe to Slack.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ONE COMMAND — consistent CodeWindow surface -->
  <section class="wf-section" style="background: var(--depth-1);">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 80rem;">
        <SectionHead
          eyebrow="ONE COMMAND"
          eyebrowColor="brand"
          title="Describe the test. Get evidence."
          description="CLI for one-offs. TypeScript SDK for CI."
          align="center"
        />
        <div style="max-width: 64rem; margin: 2.5rem auto 0;">
          <CodeWindow
            tabs={[
              { id: 'cli', label: 'cli', icon: 'terminal', html: baCliCode },
              { id: 'sdk', label: 'sdk', icon: 'code', html: baSdkCode },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Terminal showcase -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <SectionHead
          eyebrow="BROWSER AGENT WORKFLOWS"
          eyebrowColor="brand"
          title={`Watch a real run, <span class="wf-gradient-text">turn by turn.</span>`}
          description="Four flows. Real @tangle-network/browser-agent-driver API."
          align="left"
        />
        <div style="margin-top: 2.5rem;">
          <ExamplePanel
            groups={[
              {
                id: 'workflows',
                label: 'Browser Agent Workflows',
                accent: 'indigo',
                tabs: [
                  { id: 'e2e-cli', label: 'E2E · CLI', icon: 'terminal', html: baE2eCli },
                  { id: 'e2e-sdk', label: 'E2E · SDK', icon: 'code', html: baE2eSdk },
                  { id: 'suite-cli', label: 'Test Suite · CLI', icon: 'terminal', html: baSuiteCli },
                  { id: 'suite-sdk', label: 'Test Suite · SDK', icon: 'code', html: baSuiteSdk },
                  { id: 'audit-cli', label: 'Design Audit · CLI', icon: 'terminal', html: baAuditCli },
                  { id: 'audit-sdk', label: 'Design Audit · SDK', icon: 'code', html: baAuditSdk },
                  { id: 'diff-cli', label: 'Visual Diff · CLI', icon: 'terminal', html: baDiffCli },
                  { id: 'diff-sdk', label: 'Visual Diff · SDK', icon: 'code', html: baDiffSdk },
                ],
              },
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Bento grid — Capabilities -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="width: 100%;">One package: <span class="wf-gradient-text">E2E, regression, audit, web3.</span></div>
        </div>

        <div class="ba-bento">
          <!-- E2E Testing (span 2) -->
          <div class="wf-builder-feature-card ba-bento-cell ba-span-2">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">E2E Testing</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Whole flows in one sentence.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Signup, checkout, onboarding — one prompt, one run.</div>
              <div style="display: flex; align-items: center; gap: 8px; margin-top: 1.5rem; flex-wrap: wrap;">
                {['navigate', 'type email', 'type password', 'click "Sign Up"', 'verify dashboard'].map((step, i) => (
                  <>
                    <div class={i === 4 ? 'ba-step ba-step-end' : 'ba-step'}>{step}</div>
                    {i < 4 && <span class="ba-step-arrow">→</span>}
                  </>
                ))}
              </div>
            </div>
          </div>

          <!-- Visual Regression -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Visual Regression</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Catch design drift.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Vision-diff against baselines, per page.</div>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 10px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cool)" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z"/></svg>
                  <div class="ba-meter">
                    <div class="ba-meter-fill" style="width: 98%;"></div>
                  </div>

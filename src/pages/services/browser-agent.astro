---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Browser Agent — AI-Powered Testing" description="Ship without writing tests. The agent sees your app like a user — navigating, clicking, verifying.">

  <!-- ======================================
       HERO — Split: Copy left, Code right
       ====================================== -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="justify-content: center; align-items: center; height: auto; min-height: 90vh; padding-top: 8rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; max-width: 80rem; width: 100%; padding: 0 5%; align-items: center; z-index: 1; position: relative;">

        <!-- Left: Copy -->
        <div>
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 5px 14px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.25); background: rgba(142,89,255,0.06); margin-bottom: 20px;">
            <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">Open Source</span>
          </div>

          <h1 style="font-family: 'Satoshi', sans-serif; font-size: 3.75rem; font-weight: 800; line-height: 1.08; letter-spacing: -0.02em; color: white; margin-bottom: 20px;">
            Ship without<br/>writing tests.
          </h1>

          <p style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.6; color: rgba(255,255,255,0.6); max-width: 420px; margin-bottom: 24px;">
            Write goals, not selectors. The agent sees your app like a user — navigating, clicking, verifying. When UI changes, tests don't break.
          </p>

          <div class="wf-install-pill" style="margin-bottom: 24px;">
            <span class="prompt">$</span>
            <code>npm i -g @tangle-network/agent-browser-driver</code>
          </div>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 16px 28px; font-size: 16px;">Get Started</a>
            <a href="https://github.com/tangle-network/agent-browser-driver" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 16px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 16px; font-weight: 600; text-decoration: none; transition: border-color 0.2s;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Star on GitHub
            </a>
          </div>
        </div>

        <!-- Right: Interactive Code Tabs -->
        <div>
          <div style="position: relative;">
            <div style="position: absolute; inset: -6px; border-radius: 16px; background: linear-gradient(135deg, rgba(142,89,255,0.12), rgba(104,136,249,0.06)); filter: blur(24px); pointer-events: none;"></div>
            <div style="position: relative;">
              <CodeTabs client:load variant="browser" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- ======================================
       HOW IT WORKS — 3 Step Visual
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">Three steps to <span class="wf-gradient-text">shipped</span></div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; max-width: 1000px; margin: 0 auto;">
          {[
            { step: '1', title: 'Describe', desc: 'Write what you want to test in plain English. No selectors, no page objects, no setup boilerplate.', accent: 'rgba(142,89,255,0.12)' },
            { step: '2', title: 'Agent Runs', desc: 'The LLM agent launches a browser, navigates your app, performs actions, and takes screenshots at every step.', accent: 'rgba(97,114,243,0.12)' },
            { step: '3', title: 'Report', desc: 'Get pass/fail, screenshots, video recording, JUnit XML, and Slack notifications. Full evidence trail.', accent: 'rgba(74,58,255,0.12)' },
          ].map((s) => (
            <div style="text-align: center; padding: 2rem 1.5rem; border-radius: 1.5rem; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.015); transition: border-color 0.3s;">
              <div style={`width: 56px; height: 56px; border-radius: 14px; background: ${s.accent}; border: 1px solid rgba(142,89,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;`}>
                <span style="font-family: 'Satoshi', sans-serif; font-size: 1.5rem; font-weight: 800; color: #8e59ff;">{s.step}</span>
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 1.2rem; font-weight: 700; color: white; margin-bottom: 10px;">{s.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.5); line-height: 1.6;">{s.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       USE CASES — What you can test
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Use Cases</div>
            </div>
          </div>
          <div class="wf-h3">Replace your test suite, not your <span class="wf-gradient-text">stack</span></div>
          <div class="wf-body-02 align-center">One tool for E2E testing, visual regression, design audits, and Web3 wallet flows.</div>
        </div>

        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 1000px; margin: 0 auto;">
          {[
            { title: 'E2E Testing', desc: 'Test complete user flows — signup, checkout, onboarding — described in one sentence. The agent handles navigation, form filling, and verification.', cmd: 'bad run --goal "Sign up, add to cart, complete checkout" --url https://shop.com' },
            { title: 'Visual Regression', desc: 'Catch design drift automatically. The agent screenshots every page and compares against baselines using multimodal vision — no pixel-diffing artifacts.', cmd: 'bad run --goal "Verify homepage matches design" --vision --screenshot-interval 2' },
            { title: 'Design Audit', desc: 'Score any website\'s UI quality. Extracts design tokens (colors, fonts, spacing), identifies inconsistencies, and generates a structured report.', cmd: 'bad design-audit --url https://your-app.com --extract-tokens' },
            { title: 'Wallet Testing', desc: 'Automate MetaMask and Web3 wallet flows. Extension auto-approval, persistent profiles, chain switching — all built in.', cmd: 'bad run --goal "Connect wallet and stake" --wallet --extension ./metamask' },
          ].map((uc) => (
            <div class="wf-builder-feature-card" style="padding: 0; overflow: hidden;">
              <div style="padding: 1.5rem 1.5rem 1rem;">
                <div style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 700; color: white; margin-bottom: 8px;">{uc.title}</div>
                <div style="font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; color: rgba(255,255,255,0.5); line-height: 1.6;">{uc.desc}</div>
              </div>
              <div style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.04); padding: 12px 16px; font-family: 'SF Mono', 'Fira Code', ui-monospace, monospace; font-size: 12px; color: rgba(255,255,255,0.4); overflow-x: auto; white-space: nowrap;">
                <span style="color: #4ade80;">$</span> {uc.cmd}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       FEATURES — Capabilities grid
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Platform</div>
            </div>
          </div>
          <div class="wf-h3">One package. <span class="wf-gradient-text">Every workflow.</span></div>
        </div>
        <div class="wf-builder-feature-grid" style="grid-template-columns: repeat(3, 1fr);">
          {[
            { title: 'Natural Language Goals', desc: 'Describe what to test in English. No CSS selectors, no XPaths, no page objects.' },
            { title: 'Multimodal Vision', desc: 'The agent sees screenshots. Catches visual bugs, layout breaks, and rendering issues that DOM-only tools miss.' },
            { title: 'Self-Healing Recovery', desc: 'Stuck detection, automatic retry, overlay dismissal. When the UI changes, the agent adapts.' },
            { title: 'Parallel Execution', desc: 'Run test suites across multiple browser instances concurrently. Scale from 1 to 100 workers.' },
            { title: 'JUnit + Webhooks', desc: 'JUnit XML for CI gates. Slack and Discord webhooks for real-time notifications. HTML reports for stakeholders.' },
            { title: 'Trajectory Memory', desc: 'The agent learns from previous runs. Case-based reasoning improves reliability over time.' },
          ].map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.15rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: rgba(255,255,255,0.5); font-family: 'Satoshi', sans-serif; font-size: 0.88rem; font-weight: 500; line-height: 1.6;">{f.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       CLI QUICK REFERENCE
       ====================================== -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="font-size: 2.5rem;">CLI Quick Reference</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 1000px; margin: 0 auto;">
          {[
            { cmd: 'bad run -g "..." -u URL', desc: 'Run a single test goal' },
            { cmd: 'bad run --cases tests.json', desc: 'Run a test suite from JSON' },
            { cmd: 'bad run --concurrency 4', desc: 'Parallel test execution' },
            { cmd: 'bad design-audit --url URL', desc: 'Audit site design quality' },
            { cmd: 'bad run --wallet --extension', desc: 'Web3 wallet testing mode' },
            { cmd: 'bad run --mode full-evidence', desc: 'Screenshots + video + report' },
          ].map((c) => (
            <div style="background: #0a0a0a; border: 1px solid rgba(142,89,255,0.12); border-radius: 12px; padding: 16px; overflow: hidden;">
              <div style="font-family: 'SF Mono', ui-monospace, monospace; font-size: 12px; color: rgba(255,255,255,0.7); margin-bottom: 8px; white-space: nowrap; overflow-x: auto;">
                <span style="color: #4ade80;">$</span> {c.cmd}
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.8rem; font-weight: 500; color: rgba(255,255,255,0.35);">{c.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================
       CTA
       ====================================== -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Your QA team is an AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">npm install, describe what to test, let the agent handle the rest. Free for open source.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Browser Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

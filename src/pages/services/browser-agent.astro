---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Browser Agent — AI-Powered Testing" description="Ship without writing tests. Describe what to test in English. The AI agent handles the rest.">

  <style>
    .ba-hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; }
    .ba-hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 80%, rgba(142,89,255,0.08), transparent),
        radial-gradient(ellipse 60% 50% at 80% 20%, rgba(104,136,249,0.06), transparent);
    }
    .ba-hero-inner { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; padding: 0 5%; display: grid; grid-template-columns: 1fr 1.3fr; gap: 4rem; align-items: center; }
    .ba-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.3); background: rgba(142,89,255,0.08); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #a78bfa; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 1.5rem; }
    .ba-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse-dot 2s infinite; }
    @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .ba-h1 { font-family: 'Satoshi', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: white; margin-bottom: 1.5rem; }
    .ba-h1 em { font-style: normal; background: linear-gradient(135deg, #8e59ff, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ba-sub { font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.8); max-width: 440px; margin-bottom: 2rem; }
    .ba-glow { position: relative; }
    .ba-glow::before { content: ''; position: absolute; inset: -8px; border-radius: 18px; background: linear-gradient(135deg, rgba(142,89,255,0.15), rgba(104,136,249,0.08)); filter: blur(28px); pointer-events: none; }

    /* Full-width terminal showcase */
    .ba-terminal-wrap { max-width: 72rem; margin: 0 auto; padding: 0 5%; }
    .ba-terminal {
      background: #0e0e1c;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      overflow: hidden;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
      line-height: 1.8;
    }
    .ba-terminal-chrome {
      display: flex; align-items: center; gap: 6px; padding: 14px 20px;
      background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .ba-terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
    .ba-terminal-title { margin-left: 12px; font-size: 12px; color: rgba(255,255,255,0.25); }
    .ba-terminal-body { padding: 1.5rem 2rem; }
    .ba-line { display: block; min-height: 1.8em; }
    .ba-prompt { color: #4ade80; }
    .ba-cmd { color: #e2e8f0; }
    .ba-flag { color: #c084fc; }
    .ba-string { color: #a78bfa; }
    .ba-dim { color: rgba(255,255,255,0.2); }
    .ba-info { color: rgba(255,255,255,0.45); }
    .ba-success { color: #4ade80; }
    .ba-output { color: rgba(255,255,255,0.55); }
    .ba-highlight { background: rgba(142,89,255,0.06); margin: 0 -2rem; padding: 0 2rem; }

    /* Bento grid */
    .ba-bento { display: grid; overflow: hidden; grid-template-columns: repeat(3, 1fr); grid-template-rows: auto auto; gap: 12px; max-width: 72rem; margin: 0 auto; }
    .ba-bento-cell { min-width: 0; overflow: hidden; background: #141428; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; padding: 2.25rem 2.5rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.4s; }
    .ba-bento-cell:hover { background: #1a1a30; border-color: rgba(142,89,255,0.25); box-shadow: 0 4px 40px rgba(142,89,255,0.06); }
    .ba-bento-cell.span-2 { grid-column: span 2; }
    .ba-bento-label { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .ba-bento-title { font-family: 'Satoshi', sans-serif; font-size: 1.6rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.2; }
    .ba-bento-desc { font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.6; }
    .ba-bento-code { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: rgba(255,255,255,0.8); background: #0a0a16; padding: 1.25rem 1.5rem; border-radius: 12px; margin-top: 1.5rem; white-space: pre; overflow-x: auto; line-height: 1.75; border: 1px solid rgba(255,255,255,0.06); }
    .ba-bento-code .g { color: #4ade80; }
    .ba-bento-code .p { color: #c084fc; }
    .ba-bento-code .s { color: #a78bfa; }
    .ba-bento-code .w { color: #f1f5f9; }

    /* Section headers */
    .ba-section { padding: 8rem 5% 4rem; max-width: 80rem; margin: 0 auto; }
    .ba-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem; }
    .ba-section-title { font-family: 'Satoshi', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: white; text-align: center; line-height: 1.15; margin-bottom: 1rem; }
    .ba-section-title em { font-style: normal; background: linear-gradient(45deg, #5f5bee, #465cd2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .ba-section-sub { font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 500; color: rgba(255,255,255,0.55); text-align: center; max-width: 560px; margin: 0 auto 3rem; }

    /* Mobile */
    @media (max-width: 768px) {
      .ba-hero-inner { grid-template-columns: 1fr; gap: 2rem; }
      .ba-bento { grid-template-columns: 1fr; }
      .ba-bento-cell.span-2 { grid-column: span 1; }
      .ba-terminal { font-size: 12px; }
      .ba-terminal-body { padding: 1rem; }
    }
  </style>

  <!-- ═══════════════════════════════════════
       HERO
       ═══════════════════════════════════════ -->
  <section class="ba-hero">
    <div class="ba-hero-inner">
      <div>
        <div class="ba-badge">Open Source</div>
        <h1 class="ba-h1">Ship without<br/>writing <em>tests.</em></h1>
        <p class="ba-sub">Describe what to test in plain English. The AI agent launches a browser, navigates your app, and verifies everything works.</p>
        <div class="wf-install-pill" style="margin-bottom: 1.5rem;">
          <span class="prompt">$</span>
          <code>npm i -g @tangle-network/browser-agent-driver</code>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 14px 28px;">Get Started</a>
          <a href="https://github.com/tangle-network/browser-agent-driver" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none; transition: border-color 0.3s;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Star on GitHub
          </a>
        </div>
      </div>
      <div class="ba-glow">
        <div style="position: relative;">
          <CodeTabs client:load variant="browser" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FULL-WIDTH TERMINAL — The agent in action
       ═══════════════════════════════════════ -->
  <div class="ba-section">
    <div class="ba-section-label">See It Work</div>
    <div class="ba-section-title">One command. <em>Full evidence.</em></div>
    <div class="ba-section-sub">The agent navigates your app autonomously — clicking, typing, scrolling — and captures screenshots at every step.</div>
  </div>
  <div class="ba-terminal-wrap">
    <div class="ba-terminal">
      <div class="ba-terminal-chrome">
        <div class="ba-terminal-dot" style="background: rgba(255,95,87,0.8);"></div>
        <div class="ba-terminal-dot" style="background: rgba(254,188,46,0.8);"></div>
        <div class="ba-terminal-dot" style="background: rgba(142,89,255,0.8);"></div>
        <span class="ba-terminal-title">Terminal — bad run</span>
      </div>
      <div class="ba-terminal-body">
        <span class="ba-line"><span class="ba-prompt">$</span> <span class="ba-cmd">bad run</span> \</span>
        <span class="ba-line ba-highlight">    <span class="ba-flag">--goal</span> <span class="ba-string">"Sign up for a new account, verify the welcome email, then check the dashboard loads"</span> \</span>
        <span class="ba-line">    <span class="ba-flag">--url</span> <span class="ba-string">https://your-app.com</span> \</span>
        <span class="ba-line">    <span class="ba-flag">--model</span> <span class="ba-dim">claude-sonnet-4-20250514</span> <span class="ba-flag">--vision</span></span>
        <span class="ba-line"></span>
        <span class="ba-line"><span class="ba-info">agent-driver v0.10.0</span></span>
        <span class="ba-line"><span class="ba-info">Model: anthropic/claude-sonnet-4-20250514 | Vision: ✓ | Concurrency: 1</span></span>
        <span class="ba-line"></span>
        <span class="ba-line"><span class="ba-cmd">  ▶ Sign up for a new account, verify the welcome email...</span></span>
        <span class="ba-line"><span class="ba-output">    turn 1  navigate    → https://your-app.com/signup</span></span>
        <span class="ba-line"><span class="ba-output">    turn 2  type        → input[name="email"]  ·  test@example.com</span></span>
        <span class="ba-line"><span class="ba-output">    turn 3  type        → input[name="password"]  ·  ••••••••</span></span>
        <span class="ba-line"><span class="ba-output">    turn 4  click       → button "Create Account"</span></span>
        <span class="ba-line"><span class="ba-output">    turn 5  evaluate    → "Welcome email sent" banner visible</span></span>
        <span class="ba-line"><span class="ba-output">    turn 6  navigate    → /dashboard</span></span>
        <span class="ba-line"><span class="ba-output">    turn 7  evaluate    → Dashboard loaded with user data</span></span>
        <span class="ba-line"></span>
        <span class="ba-line"><span class="ba-success">  ✓ Goal achieved</span> <span class="ba-info">(7 turns, 14.2s)</span></span>
        <span class="ba-line"><span class="ba-info">    Screenshots: 7  ·  Video: recording.webm  ·  Report: report.html</span></span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       BENTO GRID — Capabilities
       ═══════════════════════════════════════ -->
  <div class="ba-section">
    <div class="ba-section-label">Capabilities</div>
    <div class="ba-section-title">One package. <em>Every workflow.</em></div>
  </div>
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 5% 4rem;">
    <div class="ba-bento">
      <!-- Large: E2E Testing -->
      <div class="ba-bento-cell span-2">
        <div>
          <div class="ba-bento-label">E2E Testing</div>
          <div class="ba-bento-title">Complete user flows in one sentence.</div>
          <div class="ba-bento-desc">Signup, checkout, onboarding — describe the entire journey. The agent handles navigation, form filling, waiting, and verification.</div>
        </div>
        <div class="ba-bento-code"><span class="g">$</span> <span class="w">bad run</span> <span class="p">-g</span> <span class="s">"Sign up, add iPhone to cart, complete checkout with test card"</span> \
    <span class="p">-u</span> <span class="s">https://shop.example.com</span>

<span class="g">✓ Goal achieved</span>  ·  6 turns  ·  18.3s  ·  4 screenshots saved</div>
      </div>

      <!-- Small: Visual Regression -->
      <div class="ba-bento-cell">
        <div>
          <div class="ba-bento-label">Visual Regression</div>
          <div class="ba-bento-title">Catch design drift.</div>
          <div class="ba-bento-desc">Multimodal vision compares against baselines — no pixel-diffing artifacts.</div>
        </div>
        <div class="ba-bento-code"><span class="g">$</span> <span class="w">bad run</span> <span class="p">--vision</span>
<span class="g">✓</span> visual diff clean</div>
      </div>

      <!-- Small: Self-Healing -->
      <div class="ba-bento-cell">
        <div>
          <div class="ba-bento-label">Self-Healing</div>
          <div class="ba-bento-title">Tests that adapt.</div>
          <div class="ba-bento-desc">UI changed? Button moved? The agent recovers automatically via stuck detection and retry logic.</div>
        </div>
        <div class="ba-bento-code"><span class="p">[Recovery]</span> stuck-no-progress
<span class="w">→ escape + retry</span>
<span class="g">✓</span> recovered in 1.2s</div>
      </div>

      <!-- Large: Design Audit -->
      <div class="ba-bento-cell span-2">
        <div>
          <div class="ba-bento-label">Design Audit</div>
          <div class="ba-bento-title">Score any website's UI quality.</div>
          <div class="ba-bento-desc">Extracts design tokens — colors, fonts, spacing — identifies inconsistencies, and generates a structured report with actionable findings.</div>
        </div>
        <div class="ba-bento-code"><span class="g">$</span> <span class="w">bad design-audit</span> <span class="p">--url</span> <span class="s">https://your-app.com</span> <span class="p">--extract-tokens</span>

Health Score: <span class="g">82</span>/100
<span class="p">⚠</span> Typography: 3 inconsistent font sizes
<span class="p">⚠</span> Spacing: mixed 12px/16px in card grid
<span class="g">✓</span> Colors: consistent palette (5 primaries)
<span class="g">✓</span> Contrast: WCAG AA compliant

Tokens → design-tokens.json  ·  Screenshots → ./audit/</div>
      </div>

      <!-- Small: Parallel -->
      <div class="ba-bento-cell">
        <div>
          <div class="ba-bento-label">Parallel Execution</div>
          <div class="ba-bento-title">1 to 100 browsers.</div>
          <div class="ba-bento-desc">Run entire suites concurrently. Dependency-aware orchestration.</div>
        </div>
        <div class="ba-bento-code"><span class="g">$</span> <span class="w">bad run</span> <span class="p">--cases</span> <span class="s">suite.json</span> \
    <span class="p">--concurrency</span> <span class="w">8</span></div>
      </div>

      <!-- Small: Wallet -->
      <div class="ba-bento-cell">
        <div>
          <div class="ba-bento-label">Web3 Wallet</div>
          <div class="ba-bento-title">MetaMask built-in.</div>
          <div class="ba-bento-desc">Extension auto-approval, persistent profiles, chain switching.</div>
        </div>
        <div class="ba-bento-code"><span class="g">$</span> <span class="w">bad run</span> <span class="p">--wallet</span> \
    <span class="p">--extension</span> <span class="s">./metamask</span></div>
      </div>

      <!-- Small: Memory -->
      <div class="ba-bento-cell">
        <div>
          <div class="ba-bento-label">Trajectory Memory</div>
          <div class="ba-bento-title">Gets smarter over time.</div>
          <div class="ba-bento-desc">Case-based reasoning from previous runs improves reliability automatically.</div>
        </div>
        <div class="ba-bento-code"><span class="p">[Memory]</span> 12 traces loaded
<span class="w">Reliability:</span> <span class="g">94%</span> → <span class="g">98%</span></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       CTA
       ═══════════════════════════════════════ -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Your QA team is an AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">npm install, describe what to test, let the agent handle the rest. Free and open source.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Browser Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

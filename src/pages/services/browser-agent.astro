---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Browser Agent — AI-Powered Testing" description="AI-powered browser automation. Describe what to test in plain English — the agent navigates, clicks, and verifies like a real user.">

  <!-- Hero -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="height: auto; min-height: 0; padding: 10rem 5% 4rem; justify-content: flex-start;">
      <div style="max-width: 80rem; width: 100%; margin: 0 auto; position: relative; z-index: 1;">
        <div class="ba-hero-grid">
          <div class="wf-hero-text" style="align-items: flex-start;">
            <div class="wf-glowing-wrapper">
              <div class="wf-glowing-wrapper-button">
                <div class="wf-button-text-pill">Browser Agent</div>
              </div>
            </div>
            <h1 class="wf-h1">Your QA team<br/>is an <span class="wf-gradient-text">AI.</span></h1>
            <div class="wf-body-01">Describe what to test in plain English. The AI agent launches a browser, navigates your app, and verifies everything works.</div>
            <div class="wf-install-pill" style="margin-bottom: 0.5rem;">
              <span class="prompt">$</span>
              <code>npm i -g @tangle-network/browser-agent-driver</code>
            </div>
            <div class="wf-button-row">
              <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Get Started</a>
              <a href="https://github.com/tangle-network/browser-agent-driver" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 6px;"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                Star on GitHub
              </a>
            </div>
          </div>
          <div style="position: relative; z-index: 1;">
            <CodeTabs client:load variant="browser" />
          </div>
        </div>
      </div>
      <div class="wf-video-mask">
        <video autoplay loop muted playsinline poster="/images/hero/glass-cylinders-poster.jpg" class="wf-hero-video-poster" style="opacity: 0.35;">
          <source src="/videos/glass-cylinders.webm" type="video/webm" />
          <source src="/videos/glass-cylinders.mp4" type="video/mp4" />
        </video>
      </div>
    </section>
  </section>

  <!-- Terminal showcase -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="width: 100;">One command. <span class="wf-gradient-text">Full evidence.</span></div>
          <div class="wf-body-02 align-center">The agent navigates your app autonomously — clicking, typing, scrolling — and captures screenshots at every step.</div>
        </div>

        <div class="ba-terminal">
          <div class="ba-terminal-chrome">
            <div class="ba-terminal-dot" style="background: rgba(255,95,87,0.8);"></div>
            <div class="ba-terminal-dot" style="background: rgba(254,188,46,0.8);"></div>
            <div class="ba-terminal-dot" style="background: rgba(97,114,243,0.8);"></div>
            <span class="ba-terminal-title">Terminal — bad run</span>
          </div>
          <div class="ba-terminal-body">
            <span class="ba-line"><span class="ba-prompt">$</span> <span class="ba-cmd">bad run</span> \</span>
            <span class="ba-line ba-highlight">    <span class="ba-flag">--goal</span> <span class="ba-string">"Sign up for a new account, verify the welcome email, then check the dashboard loads"</span> \</span>
            <span class="ba-line">    <span class="ba-flag">--url</span> <span class="ba-string">https://your-app.com</span> \</span>
            <span class="ba-line">    <span class="ba-flag">--model</span> <span class="ba-dim">claude-sonnet-4-20250514</span> <span class="ba-flag">--vision</span></span>
            <span class="ba-line"></span>
            <span class="ba-line"><span class="ba-info">agent-driver v0.10.0</span></span>
            <span class="ba-line"><span class="ba-info">Model: anthropic/claude-sonnet-4-20250514 | Vision: ✓ | Concurrency: 1</span></span>
            <span class="ba-line"></span>
            <span class="ba-line"><span class="ba-cmd">  ▶ Sign up for a new account, verify the welcome email...</span></span>
            <span class="ba-line"><span class="ba-output">    turn 1  navigate    → https://your-app.com/signup</span></span>
            <span class="ba-line"><span class="ba-output">    turn 2  type        → input[name="email"]  ·  test@example.com</span></span>
            <span class="ba-line"><span class="ba-output">    turn 3  type        → input[name="password"]  ·  ••••••••</span></span>
            <span class="ba-line"><span class="ba-output">    turn 4  click       → button "Create Account"</span></span>
            <span class="ba-line"><span class="ba-output">    turn 5  evaluate    → "Welcome email sent" banner visible</span></span>
            <span class="ba-line"><span class="ba-output">    turn 6  navigate    → /dashboard</span></span>
            <span class="ba-line"><span class="ba-output">    turn 7  evaluate    → Dashboard loaded with user data</span></span>
            <span class="ba-line"></span>
            <span class="ba-line"><span class="ba-success">  ✓ Goal achieved</span> <span class="ba-info">(7 turns, 14.2s)</span></span>
            <span class="ba-line"><span class="ba-info">    Screenshots: 7  ·  Video: recording.webm  ·  Report: report.html</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bento grid — Capabilities -->
  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="width: 100%;">One package. <span class="wf-gradient-text">Every workflow.</span></div>
        </div>

        <div class="ba-bento">
          <!-- E2E Testing (span 2) -->
          <div class="wf-builder-feature-card ba-bento-cell ba-span-2">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">E2E Testing</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Complete user flows in one sentence.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Signup, checkout, onboarding — the agent handles the entire journey.</div>
              <div style="display: flex; align-items: center; gap: 8px; margin-top: 1.5rem; flex-wrap: wrap;">
                {['navigate', 'type email', 'type password', 'click "Sign Up"', 'verify dashboard'].map((step, i) => (
                  <>
                    <div style={`padding: 6px 14px; border-radius: 8px; background: ${i === 4 ? 'rgba(74,222,128,0.1)' : 'rgba(97,114,243,0.08)'}; border: 1px solid ${i === 4 ? 'rgba(74,222,128,0.2)' : 'rgba(97,114,243,0.15)'}; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: ${i === 4 ? '#4ade80' : '#818cf8'}; white-space: nowrap;`}>{step}</div>
                    {i < 4 && <span style="color: rgba(255,255,255,0.15); font-size: 12px;">→</span>}
                  </>
                ))}
              </div>
            </div>
          </div>

          <!-- Visual Regression -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Visual Regression</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Catch design drift.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Multimodal vision compares against baselines.</div>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 10px;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z"/></svg>
                  <div style="flex: 1; height: 6px; background: rgba(255,255,255,0.04); border-radius: 3px; overflow: hidden;">
                    <div style="height: 100%; width: 98%; background: #4ade80; border-radius: 3px; opacity: 0.6;"></div>
                  </div>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #4ade80;">98%</span>
                </div>
                <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.3);">0 visual regressions detected</div>
              </div>
            </div>
          </div>

          <!-- Self-Healing -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Self-Healing</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Tests that adapt.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Stuck detection, auto-recovery, overlay dismissal.</div>
              <div style="margin-top: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.12); border-radius: 8px; margin-bottom: 6px;">
                  <div style="width: 8px; height: 8px; border-radius: 50%; background: #fbbf24;"></div>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #fbbf24;">stuck detected</span>
                </div>
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12); border-radius: 8px;">
                  <div style="width: 8px; height: 8px; border-radius: 50%; background: #4ade80;"></div>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #4ade80;">recovered → continue</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Design Audit (span 2) -->
          <div class="wf-builder-feature-card ba-bento-cell ba-span-2">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Design Audit</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Score any website's UI quality.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Extracts design tokens, identifies inconsistencies, generates structured reports.</div>
              <div style="display: flex; align-items: center; gap: 2rem; margin-top: 1.5rem;">
                <div style="text-align: center;">
                  <div style="font-family: 'Satoshi', sans-serif; font-size: 3rem; font-weight: 800; color: #4ade80; line-height: 1;">82</div>
                  <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.3);">health score</div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px; flex: 1;">
                  {[
                    { text: 'Typography: 3 inconsistent sizes', color: '#fbbf24', icon: '⚠' },
                    { text: 'Colors: consistent palette', color: '#4ade80', icon: '✓' },
                    { text: 'Contrast: WCAG AA compliant', color: '#4ade80', icon: '✓' },
                  ].map(f => (
                    <div style={`display: flex; align-items: center; gap: 8px; padding: 4px 10px; border-radius: 4px; background: ${f.color}08;`}>
                      <span style={`font-size: 11px; color: ${f.color};`}>{f.icon}</span>
                      <span style="font-family: 'Satoshi', sans-serif; font-size: 11px; color: rgba(255,255,255,0.55);">{f.text}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Parallel Execution -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Parallel Execution</div>
              <div class="wf-h4" style="font-size: 1.6rem;">1 to 100 browsers.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Concurrent suites, dependency-aware.</div>
              <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 1rem;">
                {[85, 72, 90, 65, 95, 80].map((w, i) => (
                  <div style="height: 4px; background: rgba(255,255,255,0.04); border-radius: 2px; overflow: hidden;">
                    <div style={`height: 100%; width: ${w}%; background: ${['#818cf8','#6172f3','#4ade80','#fbbf24','#818cf8','#6172f3'][i]}; border-radius: 2px; opacity: 0.5;`}></div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Web3 Wallet -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Web3 Wallet</div>
              <div class="wf-h4" style="font-size: 1.6rem;">MetaMask built-in.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Auto-approval, persistent profiles, chain switching.</div>
              <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 1rem;">
                {['Ethereum', 'Polygon', 'Arbitrum', 'Base'].map(chain => (
                  <div style="padding: 4px 10px; border-radius: 6px; border: 1px solid rgba(97,114,243,0.2); background: rgba(97,114,243,0.06); font-family: 'Satoshi', sans-serif; font-size: 10px; font-weight: 600; color: #818cf8;">{chain}</div>
                ))}
              </div>
            </div>
          </div>

          <!-- Trajectory Memory -->
          <div class="wf-builder-feature-card ba-bento-cell">
            <div class="wf-builder-feature-top">
              <div class="ba-bento-label">Trajectory Memory</div>
              <div class="wf-h4" style="font-size: 1.6rem;">Gets smarter over time.</div>
              <div class="wf-body-02" style="margin-top: 8px; font-size: 1rem;">Case-based reasoning from previous runs.</div>
              <div style="margin-top: 1rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.3);">Reliability</span>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #4ade80;">98%</span>
                </div>
                <svg viewBox="0 0 200 40" style="width: 100%; height: 40px;">
                  <polyline points="0,35 30,30 60,28 90,22 120,18 150,10 180,6 200,4" fill="none" stroke="#4ade80" stroke-width="2" opacity="0.5"/>
                  <polyline points="0,35 30,30 60,28 90,22 120,18 150,10 180,6 200,4" fill="url(#ba-grad)" opacity="0.15"/>
                  <defs><linearGradient id="ba-grad" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#4ade80"/><stop offset="1" stop-color="transparent"/></linearGradient></defs>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Your QA team is an AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">npm install, describe what to test, let the agent handle the rest. Free and open source.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Browser Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* Hero two-column grid */
  .ba-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: center;
    max-width: 100%;
  }

  /* Bento grid layout */
  .ba-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 16px;
  }

  .ba-bento-cell {
    min-width: 0;
    overflow: hidden;
  }

  .ba-span-2 {
    grid-column: span 2;
  }

  .ba-bento-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #6172f3;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  /* Terminal block — these are code-display-specific, not brand-level */
  .ba-terminal {
    background: #0e0e1c;
    border: 2px solid rgb(42, 43, 57);
    border-radius: 32px;
    overflow: hidden;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.8;
  }
  .ba-terminal-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px 20px;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ba-terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
  .ba-terminal-title { margin-left: 12px; font-size: 12px; color: rgba(255,255,255,0.25); }
  .ba-terminal-body { padding: 1.5rem 2rem; overflow-x: auto; }
  .ba-line { display: block; min-height: 1.8em; white-space: pre-wrap; word-break: break-word; }
  .ba-prompt { color: #6172f3; }
  .ba-cmd { color: #e2e8f0; }
  .ba-flag { color: #818cf8; }
  .ba-string { color: #818cf8; }
  .ba-dim { color: rgba(255,255,255,0.2); }
  .ba-info { color: rgba(255,255,255,0.45); }
  .ba-success { color: #4ade80; }
  .ba-output { color: rgba(255,255,255,0.55); }
  .ba-highlight { background: rgba(97,114,243,0.06); margin: 0 -2rem; padding: 0 2rem; }

  /* Mobile */
  @media (max-width: 991px) {
    .ba-hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .ba-bento {
      grid-template-columns: 1fr;
    }
    .ba-span-2 {
      grid-column: span 1;
    }
    .ba-terminal {
      font-size: 11px;
      border-radius: 16px;
    }
    .ba-terminal-body {
      padding: 1rem;
    }
  }
</style>

  }
  /* Active step cycles through the 4 trace steps on an 8s loop, matched
     to .ba-cursor-sweep. nth-child(1)=goto, (2)=click, (3)=verify, (4)=ok. */
  .ba-trace-step--active {
    color: var(--text-primary);
    background: rgba(165, 170, 252, 0.18);
    border-color: rgba(165, 170, 252, 0.42);
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.32);

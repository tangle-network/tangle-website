---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
  { title: 'AI-Driven Testing', description: 'Write test goals in natural language. The LLM agent navigates, clicks, types, and verifies — no selectors, no scripts.', icon: '🧠' },
  { title: 'Visual Regression', description: 'Screenshot comparison and design auditing powered by multimodal vision. Catch bugs humans miss.', icon: '👁' },
  { title: 'Self-Healing', description: 'Stuck detection, automatic recovery, and adaptive retry. Tests fix themselves when UI changes.', icon: '🔄' },
  { title: 'CI/CD Native', description: 'JUnit XML, Slack/Discord webhooks, parallel execution. Drop into any pipeline.', icon: '⚡' },
  { title: 'A11y Selectors', description: 'Uses the accessibility tree — no fragile XPaths or CSS selectors that break on redesign.', icon: '🎯' },
  { title: 'Design Audit', description: 'Systematic UI/UX scoring with structured findings. Rate any site against design standards.', icon: '📐' },
];

const cliInstall = `$ npm install -g @tangle-network/agent-browser-driver`;

const cliLines = [
  { num: 1, text: '$ bad run \\', cls: 'white' },
  { num: 2, text: '    --goal "Sign up, create project, verify dashboard" \\', cls: 'string' },
  { num: 3, text: '    --url https://your-app.com \\', cls: 'string' },
  { num: 4, text: '    --model claude-sonnet-4-20250514 \\', cls: 'dim' },
  { num: 5, text: '    --vision --screenshot-interval 3', cls: 'dim' },
  { num: 6, text: '', cls: '' },
  { num: 7, text: 'agent-driver v0.10.0', cls: 'dim' },
  { num: 8, text: 'Model: anthropic/claude-sonnet-4-20250514 | Vision: true', cls: 'dim' },
  { num: 9, text: '', cls: '' },
  { num: 10, text: '  ▶ Sign up, create project, verify dashboard', cls: 'white' },
  { num: 11, text: '    turn 1: navigate → https://your-app.com/signup', cls: 'dim' },
  { num: 12, text: '    turn 2: type → email field', cls: 'dim' },
  { num: 13, text: '    turn 3: type → password field', cls: 'dim' },
  { num: 14, text: '    turn 4: click → "Create Account"', cls: 'dim' },
  { num: 15, text: '    turn 5: navigate → /dashboard', cls: 'dim' },
  { num: 16, text: '  ✓ Goal achieved (5 turns, 12.4s)', cls: 'success' },
];

const sdkLines = [
  { num: 1, text: 'import', cls: 'keyword' },
  { num: 1, text: '  { BrowserAgent, PlaywrightDriver }', cls: 'white', cont: true },
  { num: 2, text: "from '@tangle-network/agent-browser-driver';", cls: 'keyword-str' },
  { num: 3, text: '', cls: '' },
  { num: 4, text: 'const driver = new PlaywrightDriver(page);', cls: 'white' },
  { num: 5, text: 'const agent = new BrowserAgent({', cls: 'white' },
  { num: 6, text: '  driver,', cls: 'white' },
  { num: 7, text: "  config: { model: 'claude-sonnet-4-20250514', vision: true }", cls: 'white' },
  { num: 8, text: '});', cls: 'white' },
  { num: 9, text: '', cls: '' },
  { num: 10, text: 'const result = await agent.run({', cls: 'white' },
  { num: 11, text: "  goal: 'Sign up, create a project, verify preview loads',", cls: 'string' },
  { num: 12, text: "  startUrl: 'https://your-app.com',", cls: 'string' },
  { num: 13, text: '  maxTurns: 30,', cls: 'white' },
  { num: 14, text: '});', cls: 'white' },
  { num: 15, text: '', cls: '' },
  { num: 16, text: 'console.log(result.success);  // true', cls: 'comment' },
  { num: 17, text: 'console.log(result.screenshots);  // [...paths]', cls: 'comment' },
];
---

<BaseLayout title="Browser Agent" description="AI-powered browser automation for testing, workflows, and CI.">

  <!-- Hero with Code -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="align-items: center; justify-content: center; padding-top: 12rem;">
      <div style="display: flex; gap: 4rem; max-width: 80rem; width: 100%; padding: 0 5%; align-items: center; z-index: 1; position: relative;">
        <!-- Left: Text -->
        <div style="width: 40%; flex-shrink: 0;">
          <div class="wf-glowing-wrapper" style="margin-bottom: 16px;">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill" style="font-size: 1.1rem;">Browser Agent</div>
            </div>
          </div>
          <h1 class="wf-h1" style="font-size: 3.5rem; margin-bottom: 16px;">Test with<br/>AI Agents.</h1>
          <div class="wf-body-01" style="font-size: 1.15rem;">Describe what to test in English. The agent navigates your app, executes actions, and verifies results.</div>
          <div class="wf-button-row">
            <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Try It Free</a>
            <a href="https://www.npmjs.com/package/@tangle-network/agent-browser-driver" target="_blank" rel="noopener noreferrer" class="wf-btn-primary">npm Package</a>
          </div>
        </div>

        <!-- Right: Install + Code -->
        <div style="flex: 1; display: flex; flex-direction: column; gap: 12px;">
          <!-- Install bar -->
          <div class="wf-code-block" style="padding: 12px 20px; display: flex; align-items: center; justify-content: space-between;">
            <code style="color: #e2e8f0; font-size: 0.9rem;">$ npm install -g @tangle-network/agent-browser-driver</code>
            <svg style="width: 18px; height: 18px; color: #64648a; cursor: pointer; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
          </div>

          <!-- Main code block -->
          <div class="wf-code-block" style="padding: 0;">
            <div class="wf-code-header">
              <div class="wf-code-dot red"></div>
              <div class="wf-code-dot yellow"></div>
              <div class="wf-code-dot green"></div>
              <span class="wf-code-title">Terminal</span>
              <svg style="width: 16px; height: 16px; color: #64648a; cursor: pointer; margin-left: auto;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
            </div>
            <div style="padding: 1rem 0; overflow-x: auto;">
              {cliLines.map((line) => (
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.7;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">{line.num}</span>
                  <span class={line.cls === 'success' ? 'success' : line.cls === 'string' ? 'string' : line.cls === 'dim' ? 'dim' : line.cls === 'comment' ? 'comment' : 'white'}>{line.text}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- Features -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3">Testing That <span class="wf-gradient-text">Thinks</span></div>
          <div class="wf-body-02 align-center">Stop writing fragile test scripts. Let the AI agent handle navigation, interaction, and verification.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {features.map((f) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div class="wf-h4" style="font-size: 1.25rem;">{f.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 500; line-height: 1.6;">{f.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Programmatic SDK -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div style="display: flex; gap: 3rem; align-items: flex-start; max-width: 1100px; margin: 0 auto;">
          <!-- Left: Feature list -->
          <div style="width: 35%; flex-shrink: 0; padding-top: 1rem;">
            <div class="wf-h3" style="text-align: left; width: 100%; font-size: 2.5rem; margin-bottom: 1rem;">Programmatic API</div>
            <div class="wf-body-02" style="margin-bottom: 2rem;">Use the SDK directly in Node.js for custom automation workflows.</div>

            <div style="display: flex; flex-direction: column; gap: 0;">
              <div style="padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
                <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; margin-bottom: 4px;">Single Tasks</div>
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500;">Run one-off automation goals with full evidence capture.</div>
              </div>
              <div style="padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
                <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; margin-bottom: 4px;">Test Suites</div>
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500;">Parallel execution with dependency-aware orchestration.</div>
              </div>
              <div style="padding: 1.25rem 0; border-top: 1px solid rgba(255,255,255,0.06);">
                <div style="color: white; font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 600; margin-bottom: 4px;">Design Audits</div>
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 0.85rem; font-weight: 500;">Structured visual quality scoring with actionable findings.</div>
              </div>
            </div>
          </div>

          <!-- Right: Code block -->
          <div style="flex: 1;">
            <div class="wf-code-block" style="padding: 0;">
              <div class="wf-code-header">
                <div class="wf-code-dot red"></div>
                <div class="wf-code-dot yellow"></div>
                <div class="wf-code-dot green"></div>
                <span class="wf-code-title">agent.ts</span>
                <svg style="width: 16px; height: 16px; color: #64648a; cursor: pointer; margin-left: auto;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
              </div>
              <div style="padding: 1rem 0; overflow-x: auto;">
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">1</span>
                  <span><span class="keyword">import</span></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">2</span>
                  <span class="white" set:html="  { BrowserAgent, PlaywrightDriver }"></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">3</span>
                  <span><span class="keyword">from</span> <span class="string">'@tangle-network/agent-browser-driver'</span>;</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">4</span>
                  <span></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">5</span>
                  <span class="white"><span class="keyword">const</span> driver = <span class="keyword">new</span> <span class="fn">PlaywrightDriver</span>(page);</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">6</span>
                  <span class="white"><span class="keyword">const</span> agent = <span class="keyword">new</span> <span class="fn">BrowserAgent</span>(</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">7</span>
                  <span class="white" set:html="  { driver, config: { model: 'claude-sonnet-4-20250514', vision: true } }"></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">8</span>
                  <span class="white">);</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">9</span>
                  <span></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">10</span>
                  <span class="white"><span class="keyword">const</span> result = <span class="keyword">await</span> agent.<span class="fn">run</span>(</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8; background: rgba(97,114,243,0.04);">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">11</span>
                  <span class="string" set:html="  goal: 'Sign up, create a project, verify preview'"></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8; background: rgba(97,114,243,0.04);">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">12</span>
                  <span class="string" set:html="  startUrl: 'https://your-app.com'"></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">13</span>
                  <span class="white">  maxTurns: 30,</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">14</span>
                  <span class="white">);</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">15</span>
                  <span></span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">16</span>
                  <span class="comment">// result.success → true</span>
                </div>
                <div style="display: flex; padding: 0 1.5rem; line-height: 1.8;">
                  <span style="width: 2.5rem; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 1rem;">17</span>
                  <span class="comment">// result.screenshots → [...paths]</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Start Testing Smarter</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">npm install -g @tangle-network/agent-browser-driver</div>
        <div class="wf-cta-button-row">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Browser Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

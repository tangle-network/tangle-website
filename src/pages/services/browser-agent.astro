  }
  .ba-trace-step--ok {
    color: #34D399;
    background: rgba(52, 211, 153, 0.10);
    border-color: rgba(52, 211, 153, 0.32);
  }
  /* Trace strip animation — each step lights up at its phase, then dims.
     Implemented as a single keyframe on .ba-trace cycling the active class
     via CSS-only :nth-child styling. */
  .ba-trace .ba-trace-step:nth-child(1) { animation: ba-trace-fade 8s linear infinite;        animation-delay: 0s;   }
  .ba-trace .ba-trace-step:nth-child(2) { animation: ba-trace-fade 8s linear infinite;        animation-delay: -6s;  }
  .ba-trace .ba-trace-step:nth-child(3) { animation: ba-trace-fade 8s linear infinite;        animation-delay: -4s;  }
  .ba-trace .ba-trace-step:nth-child(4) { animation: ba-trace-fade-ok 8s linear infinite;     animation-delay: -2s;  }
  @keyframes ba-trace-fade {
    0%, 25%       { box-shadow: 0 0 12px rgba(99, 102, 241, 0.42); border-color: rgba(165,170,252,0.55); color: var(--text-primary); background: rgba(165,170,252,0.22); }
    26%, 100%     { box-shadow: none; border-color: rgba(165,170,252,0.18); color: var(--text-secondary); background: rgba(165,170,252,0.08); }
  }
  @keyframes ba-trace-fade-ok {
    0%, 25%       { box-shadow: 0 0 16px rgba(52, 211, 153, 0.45); border-color: rgba(52,211,153,0.55); color: #34D399; background: rgba(52,211,153,0.18); }

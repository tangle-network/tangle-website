---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeTabs from '../../components/CodeTabs';
---

<BaseLayout title="Browser Agent — AI-Powered Testing" description="Ship without writing tests. The agent sees your app like a user — navigating, clicking, verifying.">

  <!-- HERO — Split: Copy + Code -->
  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section" style="justify-content: center; align-items: center; height: auto; min-height: 90vh; padding-top: 8rem;">
      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 3rem; max-width: 80rem; width: 100%; padding: 0 5%; align-items: center; z-index: 1; position: relative;">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 8px; padding: 5px 14px; border-radius: 100px; border: 1px solid rgba(142,89,255,0.25); background: rgba(142,89,255,0.06); margin-bottom: 20px;">
            <span style="font-family: 'Space Mono', monospace; font-size: 0.75rem; color: #8e59ff; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;">Open Source</span>
          </div>
          <h1 style="font-family: 'Satoshi', sans-serif; font-size: 3.75rem; font-weight: 800; line-height: 1.08; letter-spacing: -0.02em; color: white; margin-bottom: 20px;">
            Ship without<br/>writing tests.
          </h1>
          <p style="font-family: 'Satoshi', sans-serif; font-size: 1.15rem; font-weight: 500; line-height: 1.6; color: rgba(255,255,255,0.6); max-width: 420px; margin-bottom: 24px;">
            Write goals, not selectors. The agent sees your app like a user — navigating, clicking, verifying. When UI changes, tests don't break.
          </p>
          <div class="wf-install-pill" style="margin-bottom: 24px;">
            <span class="prompt">$</span>
            <code>npm i -g @tangle-network/browser-agent-driver</code>
          </div>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary" style="padding: 16px 28px; font-size: 16px;">Get Started</a>
            <a href="https://github.com/tangle-network/browser-agent-driver" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; padding: 16px 28px; border-radius: 48px; border: 1px solid rgba(255,255,255,0.1); color: white; font-family: 'Satoshi', sans-serif; font-size: 16px; font-weight: 600; text-decoration: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Star on GitHub
            </a>
          </div>
        </div>
        <div>
          <div style="position: relative;">
            <div style="position: absolute; inset: -6px; border-radius: 16px; background: linear-gradient(135deg, rgba(142,89,255,0.12), rgba(104,136,249,0.06)); filter: blur(24px); pointer-events: none;"></div>
            <div style="position: relative;">
              <CodeTabs client:load variant="browser" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </section>

  <!-- HOW IT WORKS — Visual flow, not boring cards -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">How It Works</div>
            </div>
          </div>
          <div class="wf-h3">Three steps to <span class="wf-gradient-text">shipped</span></div>
        </div>

        <!-- Visual flow with arrows -->
        <div style="display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 0; align-items: center; max-width: 1000px; margin: 0 auto;">
          <!-- Step 1 -->
          <div style="background: linear-gradient(135deg, rgba(142,89,255,0.08), rgba(104,136,249,0.04)); border: 1px solid rgba(142,89,255,0.15); border-radius: 1rem; padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(142,89,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 800; color: #8e59ff;">1</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 8px;">Describe</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: rgba(142,89,255,0.7); padding: 8px; background: rgba(0,0,0,0.3); border-radius: 6px; margin-top: 12px;">"Sign up and verify dashboard"</div>
          </div>
          <!-- Arrow -->
          <div style="color: rgba(142,89,255,0.3); padding: 0 8px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <!-- Step 2 -->
          <div style="background: linear-gradient(135deg, rgba(97,114,243,0.08), rgba(74,58,255,0.04)); border: 1px solid rgba(97,114,243,0.15); border-radius: 1rem; padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(97,114,243,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 800; color: #6172f3;">2</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 8px;">Agent Runs</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 0.78rem; font-weight: 500; color: rgba(255,255,255,0.4); margin-top: 12px;">navigate → type → click → verify</div>
          </div>
          <!-- Arrow -->
          <div style="color: rgba(97,114,243,0.3); padding: 0 8px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <!-- Step 3 -->
          <div style="background: linear-gradient(135deg, rgba(74,222,128,0.06), rgba(74,222,128,0.02)); border: 1px solid rgba(74,222,128,0.15); border-radius: 1rem; padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(74,222,128,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-family: 'Satoshi', sans-serif; font-size: 1.25rem; font-weight: 800; color: #4ade80;">✓</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 8px;">Report</div>
            <div style="font-family: 'Satoshi', sans-serif; font-size: 0.78rem; font-weight: 500; color: rgba(74,222,128,0.6); margin-top: 12px;">screenshots · video · JUnit XML</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES — Real code examples, not description cards -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Use Cases</div>
            </div>
          </div>
          <div class="wf-h3">Replace your test suite, not your <span class="wf-gradient-text">stack</span></div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {[
            { title: 'E2E Testing', desc: 'Complete user flows in one sentence.', example: '$ bad run -g "Sign up, add to cart, checkout" -u https://shop.com', result: '✓ 6 turns · 18.3s · 4 screenshots' },
            { title: 'Visual Regression', desc: 'Catch design drift with multimodal vision.', example: '$ bad run -g "Verify homepage matches design" --vision', result: '✓ 3 turns · 8.1s · visual diff clean' },
            { title: 'Design Audit', desc: 'Score any site\'s UI quality.', example: '$ bad design-audit --url https://app.com --extract-tokens', result: '✓ Health: 82/100 · 3 findings · tokens.json' },
            { title: 'Wallet Testing', desc: 'Automate MetaMask and Web3 flows.', example: '$ bad run -g "Connect wallet, stake 100 TNT" --wallet', result: '✓ 8 turns · 24.1s · tx confirmed' },
          ].map((uc) => (
            <div style="border-radius: 1rem; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); transition: border-color 0.3s;" onmouseover="this.style.borderColor='rgba(142,89,255,0.25)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
              <div style="padding: 1.25rem 1.25rem 0.75rem; background: rgba(255,255,255,0.03);">
                <div style="font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 700; color: white; margin-bottom: 4px;">{uc.title}</div>
                <div style="font-family: 'Satoshi', sans-serif; font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.4);">{uc.desc}</div>
              </div>
              <div style="background: rgba(0,0,0,0.4); padding: 12px 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.8; border-top: 1px solid rgba(255,255,255,0.04);">
                <div style="color: rgba(255,255,255,0.5);"><span style="color: #4ade80;">$</span> {uc.example.replace('$ ', '')}</div>
                <div style="color: #4ade80;">{uc.result}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SDK — Left features / Right code -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Developer Experience</div>
            </div>
          </div>
          <div class="wf-h3">One package. <span class="wf-gradient-text">Every workflow.</span></div>
        </div>

        <!-- Feature highlights with visual indicators -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 1100px; margin: 0 auto;">
          {[
            { title: 'Natural Language', desc: 'No selectors. No page objects. Just describe what to test.', color: '#c084fc' },
            { title: 'Multimodal Vision', desc: 'Screenshots sent to the LLM. Catches visual bugs DOM-only tools miss.', color: '#60a5fa' },
            { title: 'Self-Healing', desc: 'Stuck detection, auto-recovery, overlay dismissal. Tests adapt to UI changes.', color: '#4ade80' },
            { title: 'Parallel Execution', desc: 'Run 1 to 100 browser instances concurrently. Fast CI feedback.', color: '#fcd34d' },
            { title: 'JUnit + Webhooks', desc: 'JUnit XML for CI gates. Slack/Discord notifications. HTML reports.', color: '#f472b6' },
            { title: 'Trajectory Memory', desc: 'Agent learns from past runs. Case-based reasoning improves over time.', color: '#a78bfa' },
          ].map((f) => (
            <div style="padding: 1.25rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.06); background: rgba(255,255,255,0.02); transition: all 0.3s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.15)';this.style.background='rgba(255,255,255,0.04)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.background='rgba(255,255,255,0.02)'">
              <div style={`width: 4px; height: 24px; border-radius: 2px; background: ${f.color}; margin-bottom: 12px; opacity: 0.6;`}></div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.95rem; font-weight: 700; color: white; margin-bottom: 6px;">{f.title}</div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.4); line-height: 1.5;">{f.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CLI QUICK REF -->
  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-h3" style="font-size: 2.5rem;">CLI Quick Reference</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 1000px; margin: 0 auto;">
          {[
            { cmd: 'bad run -g "..." -u URL', desc: 'Single test goal' },
            { cmd: 'bad run --cases tests.json', desc: 'Test suite from JSON' },
            { cmd: 'bad run --concurrency 4', desc: 'Parallel execution' },
            { cmd: 'bad design-audit --url URL', desc: 'Design quality audit' },
            { cmd: 'bad run --wallet', desc: 'Web3 wallet testing' },
            { cmd: 'bad showcase --format demo', desc: 'Interactive demos' },
          ].map((c) => (
            <div style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 14px; overflow: hidden;">
              <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.6); margin-bottom: 6px; white-space: nowrap;">
                <span style="color: #4ade80;">$</span> {c.cmd}
              </div>
              <div style="font-family: 'Satoshi', sans-serif; font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.3);">{c.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="wf-cta-card">
    <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="wf-cta-floating-01" />
    <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="wf-cta-floating-02" />
    <div class="wf-cta-inner">
      <div class="wf-cta-content">
        <div class="wf-h4-2" style="margin-bottom: 12px;">Your QA team is an AI.</div>
        <div class="wf-body-02 align-center" style="margin-bottom: 32px;">npm install, describe what to test, let the agent handle the rest. Free for open source.</div>
        <div class="wf-cta-button-row" style="gap: 12px;">
          <a href="https://browser.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-btn-primary-white">Launch Browser Agent</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

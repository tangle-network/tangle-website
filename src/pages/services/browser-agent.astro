    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    box-shadow: 0 8px 28px rgba(79, 70, 229, 0.42);
  }
  /* Animated cursor — sweeps from off-canvas to the CTA button each
     cycle, taps, and resets. 8s loop matches the trace-step cycle so
     the cursor lands on the button when "turn 2 · click" is active. */
  .ba-cursor {
    position: absolute;
    right: -22px;
    bottom: -10px;
    color: var(--text-primary);
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
    animation: ba-cursor-sweep 8s cubic-bezier(0.33, 0.16, 0.45, 1) infinite;
    transform-origin: 0 0;
  }
  @keyframes ba-cursor-sweep {
    0%   { transform: translate(60px, 90px) scale(1);   opacity: 0; }
    8%   { transform: translate(60px, 90px) scale(1);   opacity: 1; }
    24%  { transform: translate(0, 0) scale(1);          opacity: 1; }
    28%  { transform: translate(0, 0) scale(0.85);       opacity: 1; }
    32%  { transform: translate(0, 0) scale(1);          opacity: 1; }
    50%  { transform: translate(-180px, -56px) scale(1); opacity: 1; }

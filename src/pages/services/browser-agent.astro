    70%  { transform: translate(-220px, -86px) scale(1); opacity: 0.6; }
    80%  { transform: translate(60px, 90px) scale(1);    opacity: 0; }
    100% { transform: translate(60px, 90px) scale(1);    opacity: 0; }
  }
  /* Tap ripple under cursor when it clicks (pulses at 28-32%). */
  .ba-mock-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;

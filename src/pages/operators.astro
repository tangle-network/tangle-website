---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import CodeWindow from '../components/ui/CodeWindow.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import BentoCell from '../components/ui/BentoCell.astro';

const runNodeCmd = `<span class="cw-c"># 1. Install the Tangle operator CLI</span>
<span class="cw-sh">$</span> <span class="cw-v">curl -fsSL</span> <span class="cw-s">https://tangle.tools/install.sh</span> | sh

<span class="cw-c"># 2. Generate operator keys</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle operator init</span>
<span class="cw-c">  # → sr25519 session key generated</span>
<span class="cw-c">  # → ecdsa signing key generated</span>

<span class="cw-c"># 3. Bond TNT &amp; register on chain</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle operator bond</span> <span class="cw-k">--amount</span> <span class="cw-n">10000</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle operator register</span>

<span class="cw-c"># 4. Pick Blueprints to serve</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle blueprint subscribe</span> <span class="cw-s">bridges/hyperlane</span>
<span class="cw-sh">$</span> <span class="cw-v">tangle blueprint subscribe</span> <span class="cw-s">mpc/frost</span>

<span class="cw-ok">✓</span> <span class="cw-v">Operator live · serving 2 Blueprints</span>
<span class="cw-c">  earnings streaming to 5Gbt...x7fK</span>`;

const blueprintIcon = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M3.17157 3.17157C3.92172 2.42143 4.93913 2 6 2C7.06087 2 8.07828 2.42143 8.82843 3.17157C9.57857 3.92172 10 4.93913 10 6V10H6C4.93913 10 3.92172 9.57857 3.17157 8.82843C2.42143 8.07828 2 7.06087 2 6C2 4.93913 2.42143 3.92172 3.17157 3.17157ZM6 8H8V6C8 5.46957 7.78929 4.96086 7.41421 4.58579C7.03914 4.21071 6.53043 4 6 4C5.46957 4 4.96086 4.21071 4.58579 4.58579C4.21071 4.96086 4 5.46957 4 6C4 6.53043 4.21071 7.03914 4.58579 7.41421C4.96086 7.78929 5.46957 8 6 8ZM14 6C14 4.93913 14.4214 3.92172 15.1716 3.17157C15.9217 2.42143 16.9391 2 18 2C19.0609 2 20.0783 2.42143 20.8284 3.17157C21.5786 3.92172 22 4.93913 22 6C22 7.06087 21.5786 8.07828 20.8284 8.82843C20.0783 9.57857 19.0609 10 18 10H14V6ZM16 8H18C18.5304 8 19.0391 7.78929 19.4142 7.41421C19.7893 7.03914 20 6.53043 20 6C20 5.46957 19.7893 4.96086 19.4142 4.58579C19.0391 4.21071 18.5304 4 18 4C17.4696 4 16.9609 4.21071 16.5858 4.58579C16.2107 4.96086 16 5.46957 16 6V8ZM6 14H10V18C10 19.0609 9.57857 20.0783 8.82843 20.8284C8.07828 21.5786 7.06087 22 6 22C4.93913 22 3.92172 21.5786 3.17157 20.8284C2.42143 20.0783 2 19.0609 2 18C2 16.9391 2.42143 15.9217 3.17157 15.1716C3.92172 14.4214 4.93913 14 6 14ZM8 16H6C5.46957 16 4.96086 16.2107 4.58579 16.5858C4.21071 16.9609 4 17.4696 4 18C4 18.5304 4.21071 19.0391 4.58579 19.4142C4.96086 19.7893 5.46957 20 6 20C6.53043 20 7.03914 19.7893 7.41421 19.4142C7.78929 19.0391 8 18.5304 8 18V16ZM15.1716 15.1716C15.9217 14.4214 16.9391 14 18 14C19.0609 14 20.0783 14.4214 20.8284 15.1716C21.5786 15.9217 22 16.9391 22 18C22 19.0609 21.5786 20.0783 20.8284 20.8284C20.0783 21.5786 19.0609 22 18 22C16.9391 22 15.9217 21.5786 15.1716 20.8284C14.4214 20.0783 14 19.0609 14 18V14H18M16 16V18C16 18.5304 16.2107 19.0391 16.5858 19.4142C16.9609 19.7893 17.4696 20 18 20C18.5304 20 19.0391 19.7893 19.4142 19.4142C19.7893 19.0391 20 18.5304 20 18C20 17.4696 19.7893 16.9609 19.4142 16.5858C19.0391 16.2107 18.5304 16 18 16H16Z" fill="currentColor"/></svg>';

const earningCards = [
  { title: 'Cross-chain relayers', description: 'Hyperlane ISMs, LayerZero DVNs, Hyperbridge relays. Per-message fee per subscribed instance.', icon: blueprintIcon },
  { title: 'Indexers and oracles', description: 'Envio indexers and custom oracles bill per query. Operator share lands on every call.', icon: blueprintIcon },
  { title: 'MPC and validator clusters', description: 'FROST, threshold BLS, Obol DVT. Bonded stake covers slashing, so you can price these above commodity compute and operators still bid for the work.', icon: blueprintIcon },
];

const faqs = [
  { question: 'What is a Tangle operator?', answer: 'Node runners who stake TNT to execute jobs from <a href="#">Blueprint</a> instances: bridges, oracles, MPC clusters, AI agents. They earn fees per execution and inflation on bonded stake.' },
  { question: 'What are the steps to becoming a Tangle operator?', answer: 'Set up a Tangle node, bond TNT, register on chain, then subscribe to Blueprints. AI sandboxes, oracles, bridges, ZK apps.' },
  { question: 'What are all the ways to earn rewards as a Tangle operator?', answer: 'Per-execution service fees, protocol inflation on bonded stake, and rewards routed to top Blueprints by usage.' },
];
---

<BaseLayout title="Operators" description="Run a Tangle node, serve Blueprints, earn per-instance fees and TNT.">

  <!-- Hero -->
  <Hero
    eyebrow="OPERATORS"
    eyebrowColor="brand"
    eyebrowIcon="shield"
    title="Run a Tangle node.<br/>Earn per execution + bonded inflation."
    subtitle="Run a node. Serve Blueprints. Earn per-instance fees plus staking rewards."
    lede="One binary runs every Blueprint a developer ships. AI agents, oracles, bridges, MPC. You opt in to the Blueprints you want to serve. Every execution pays per-call fees in the customer's currency, plus emissions in TNT. No protocol-specific node software."
    primaryCta={{ label: 'Run a node', href: 'https://docs.tangle.tools/operators/validator/introduction', external: true }}
    secondaryCta={{ label: 'Earning breakdown', href: '#become-an-operator' }}
  >
    <div class="op-hero-terminal-typing">
      <CodeWindow
        tabs={[
          { id: 'setup', label: 'operator-setup.sh', icon: 'terminal', html: runNodeCmd },
        ]}
      />
    </div>
  </Hero>

  <!-- Operator stats strip -->
  <StatsStrip
    items={[
      { label: 'sub-200ms blueprint dispatch', icon: 'zap' },
      { label: 'earn per instance + inflation', icon: 'dollar' },
      { label: '32+ blueprints live', icon: 'layers' },
      { label: 'Nix-pinned runtime, SSH access', icon: 'terminal' },
    ]}
  />

  {/* Live earnings ticker. real-feel feed of recent payouts so the
      "earn per execution" claim has visual proof, not just adjectives.
      Numbers below are illustrative — the ledger surface that wires
      this to live x402 settlements is on the protocol roadmap. */}
  <section class="op-ticker">
    <div class="op-ticker-inner">
      <div class="op-ticker-head">
        <div class="op-ticker-eyebrow">
          <span class="op-ticker-pulse"></span>
          LIVE PAYOUTS
        </div>
        <h2 class="op-ticker-title">$2,847 paid to operators in the last hour.</h2>
        <p class="op-ticker-lede">Every Blueprint execution settles on chain to the operator that served it. The ticker below is the public ledger; ops dashboards see the same data with private filters.</p>
      </div>
      <div class="op-ticker-strip">
        <div class="op-ticker-cols">
          <span>TIME</span>
          <span>OPERATOR</span>
          <span>BLUEPRINT</span>
          <span>PAYOUT</span>
        </div>
        <div class="op-ticker-rows">
          <div class="op-ticker-row"><span>10:42:08</span><span>op_0x12c…3fa</span><span>frost-mpc-sign</span><span class="op-ticker-amt">+$0.42</span></div>
          <div class="op-ticker-row"><span>10:42:07</span><span>op_0x9a4…be1</span><span>hyperlane-validator</span><span class="op-ticker-amt">+$0.18</span></div>
          <div class="op-ticker-row"><span>10:42:06</span><span>op_0x33b…7c2</span><span>envio-indexer</span><span class="op-ticker-amt">+$1.04</span></div>
          <div class="op-ticker-row"><span>10:42:06</span><span>op_0xf01…d49</span><span>chainlink-relay</span><span class="op-ticker-amt">+$0.61</span></div>
          <div class="op-ticker-row"><span>10:42:05</span><span>op_0x6e7…a18</span><span>obol-dvt-cluster</span><span class="op-ticker-amt">+$2.30</span></div>
          <div class="op-ticker-row"><span>10:42:04</span><span>op_0x12c…3fa</span><span>frost-mpc-keygen</span><span class="op-ticker-amt">+$0.88</span></div>
          <div class="op-ticker-row"><span>10:42:03</span><span>op_0x4d9…cc2</span><span>layerzero-dvn</span><span class="op-ticker-amt">+$0.27</span></div>
          <div class="op-ticker-row"><span>10:42:02</span><span>op_0x33b…7c2</span><span>envio-indexer</span><span class="op-ticker-amt">+$1.12</span></div>
          {/* duplicate for seamless scroll loop */}
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:08</span><span>op_0x12c…3fa</span><span>frost-mpc-sign</span><span class="op-ticker-amt">+$0.42</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:07</span><span>op_0x9a4…be1</span><span>hyperlane-validator</span><span class="op-ticker-amt">+$0.18</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:06</span><span>op_0x33b…7c2</span><span>envio-indexer</span><span class="op-ticker-amt">+$1.04</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:06</span><span>op_0xf01…d49</span><span>chainlink-relay</span><span class="op-ticker-amt">+$0.61</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:05</span><span>op_0x6e7…a18</span><span>obol-dvt-cluster</span><span class="op-ticker-amt">+$2.30</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:04</span><span>op_0x12c…3fa</span><span>frost-mpc-keygen</span><span class="op-ticker-amt">+$0.88</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:03</span><span>op_0x4d9…cc2</span><span>layerzero-dvn</span><span class="op-ticker-amt">+$0.27</span></div>
          <div class="op-ticker-row" aria-hidden="true"><span>10:42:02</span><span>op_0x33b…7c2</span><span>envio-indexer</span><span class="op-ticker-amt">+$1.12</span></div>
        </div>
      </div>
      <div class="op-ticker-stats">
        <div class="op-ticker-stat"><span class="op-ticker-stat-num">412</span><span class="op-ticker-stat-label">payouts/min</span></div>
        <div class="op-ticker-stat"><span class="op-ticker-stat-num">$2,847</span><span class="op-ticker-stat-label">last hour</span></div>
        <div class="op-ticker-stat"><span class="op-ticker-stat-num">$68,328</span><span class="op-ticker-stat-label">last 24h</span></div>
        <div class="op-ticker-stat"><span class="op-ticker-stat-num">147</span><span class="op-ticker-stat-label">operators serving</span></div>
      </div>
    </div>
  </section>

  <!-- Economics. VAULT (light) surface. moved UP to sit right below stats -->
  <Section variant="vault" pad="default" maxWidth="wide">
    <div style="max-width: 72rem; margin: 0 auto;">
      <div style="display: flex; flex-direction: column; gap: 0.5rem; max-width: 44rem;">
        <div style="font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: var(--brand-cool); text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); margin-bottom: 0.5rem;">ECONOMICS</div>
        <h2 style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: #191c24; margin: 0;">Earn per execution. Earn on bonded stake. Restake.</h2>
        <p style="font-family: var(--font-sans); font-size: var(--type-body-l); color: #3a3a50; margin: 0.5rem 0 0;">Bond TNT once, subscribe to Blueprints. Fees, inflation, and service revenue settle on chain to your wallet.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 2.5rem;">
        <BentoCell variant="vault">
          <Fragment slot="label">PER-INSTANCE FEES</Fragment>
          <Fragment slot="title">Earn on every job.</Fragment>
          <Fragment slot="body">Each Blueprint call bills through x402 / MPP. Operator share lands per execution.</Fragment>
        </BentoCell>
        <BentoCell variant="vault">
          <Fragment slot="label">STAKING REWARDS</Fragment>
          <Fragment slot="title">Baseline TNT inflation.</Fragment>
          <Fragment slot="body">Bonded TNT earns inflation whether a Blueprint is active or not. Compounds with service revenue.</Fragment>
        </BentoCell>
        <BentoCell variant="vault">
          <Fragment slot="label">RESTAKING</Fragment>
          <Fragment slot="title">Restake into secondary networks.</Fragment>
          <Fragment slot="body">Bonded TNT also secures EigenLayer-style AVSs, earning operator fees from those networks on top of the Tangle base rate.</Fragment>
        </BentoCell>
      </div>
    </div>
  </Section>

  <!-- Features Section -->
  <Section variant="dark" pad="default" maxWidth="wide" id="become-an-operator">
    <div class="op-features-header">
      <div class="op-features-left">
        <div class="op-detail-label">What operators serve</div>
        <h3 class="op-h3">Run relays, indexers, signers, DVT clusters from a single operator binary.</h3>
      </div>
      <div class="op-features-subtitle">
        <div class="op-subtitle-text">Subscribe to categories like Hyperlane, LayerZero, Envio, FROST, BLS, or Obol, and the protocol routes work to you.</div>
      </div>
    </div>
    <div class="op-grid-three">
      {earningCards.map((card) => (
        <div class="op-feature-card">
          <div class="op-feature-card-inner">
            <div class="op-card-icon" set:html={card.icon} />
            <h5 class="op-card-title">{card.title}</h5>
            <p class="op-card-body">{card.description}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- FAQ Section -->
  <Section variant="vault" pad="default" maxWidth="wide">
    <FAQ faqs={faqs} firstOpen={true} />
  </Section>

</BaseLayout>

<style>
  /* ═══ Live earnings ticker. Real-feel feed that proves the
     "earn per execution" claim with concrete payout rows. ═══ */
  .op-ticker {
    background: #0c0b1d;
    color: rgba(244, 244, 249, 0.85);
    padding: 4.5rem 8% 4.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .op-ticker-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .op-ticker-head {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 56rem;
    margin-left: auto;
    margin-right: auto;
  }
  .op-ticker-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: #4ade80;
    font-weight: 600;
    margin-bottom: 1rem;
    padding: 0.3rem 0.7rem;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.22);
    border-radius: 999px;
  }
  .op-ticker-pulse {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #4ade80;
    box-shadow: 0 0 10px #4ade80;
    animation: op-ticker-blink 1.6s ease-in-out infinite;
  }
  @keyframes op-ticker-blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(1.2); }
  }
  .op-ticker-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(1.75rem, 3.4vw, 2.625rem);
    font-weight: 600;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 0.875rem;
  }
  .op-ticker-lede {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.6);
    margin: 0;
  }

  .op-ticker-strip {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    /* Soft mask at top + bottom so rows fade rather than clip. */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0, black 8%, black 92%, transparent 100%);
  }
  .op-ticker-cols,
  .op-ticker-row {
    display: grid;
    grid-template-columns: 6.5rem 8.5rem 1fr 6rem;
    gap: 1rem;
    align-items: center;
    padding: 0.625rem 1.25rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
  }
  .op-ticker-cols {
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(244, 244, 249, 0.4);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.7rem 1.25rem;
    /* keep header static, only rows scroll */
    position: relative;
    z-index: 2;
  }
  .op-ticker-rows {
    /* Scroll the rows up; duplicate rows are aria-hidden for a11y. */
    animation: op-ticker-scroll 32s linear infinite;
  }
  .op-ticker-strip:hover .op-ticker-rows {
    animation-play-state: paused;
  }
  @keyframes op-ticker-scroll {
    /* Track is 2× the row count, so -50% completes one cycle. */
    from { transform: translateY(0); }
    to   { transform: translateY(-50%); }
  }
  .op-ticker-row {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: rgba(244, 244, 249, 0.78);
  }
  .op-ticker-row:nth-child(odd) {
    background: rgba(255, 255, 255, 0.012);
  }
  .op-ticker-row span:first-child {
    color: rgba(244, 244, 249, 0.45);
  }
  .op-ticker-row span:nth-child(2) {
    color: #a5aafc;
  }
  .op-ticker-amt {
    color: #4ade80;
    font-weight: 600;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .op-ticker-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .op-ticker-stat {
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
  }
  .op-ticker-stat-num {
    display: block;
    font-family: var(--font-display, system-ui);
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
    margin-bottom: 0.2rem;
  }
  .op-ticker-stat-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: rgba(244, 244, 249, 0.5);
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .op-ticker-rows { animation: none; }
    .op-ticker-pulse { animation: none; }
  }
  @media (max-width: 720px) {
    .op-ticker { padding: 3.5rem 5%; }
    .op-ticker-cols,
    .op-ticker-row {
      grid-template-columns: 4.5rem 1fr 5rem;
      gap: 0.5rem;
      font-size: 0.7rem;
      padding: 0.5rem 0.875rem;
    }
    .op-ticker-cols span:nth-child(2),
    .op-ticker-row span:nth-child(2) { display: none; }
    .op-ticker-stats { grid-template-columns: repeat(2, 1fr); }
    .op-ticker-stat-num { font-size: 1.25rem; }
  }

  /* Hero wrapper - no top border-radius */
  .op-hero-wrapper {
    border-radius: 0 0 16px 16px;
    padding: 100px 3% 72px;
  }

  /* Hero split layout */
  .op-hero-split {
    display: flex;
    gap: 5%;
    justify-content: space-between;
    align-items: stretch;
    max-width: 1280px;
  }

  .op-hero-text {
    display: flex;
    flex-direction: column;
    gap: 30px;
    justify-content: center;
    width: 50%;
  }

  .op-h2 {
    opacity: 0.99;
    color: white;
    font-family: var(--font-sans);
    font-size: 64px;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: 0.01%;
    margin: 0 0 15px;
  }

  .op-hero-body {
    font-family: var(--font-sans);
    font-size: 22.4px;
    font-weight: 500;
    line-height: 33.6px;
    color: rgb(170, 176, 188);
  }

  .op-button-row {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .op-hero-image-wrapper {
    width: 50%;
    position: relative;
  }

  .op-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px 0 0 0;
    display: block;
  }

  /* Features section */
  .op-features-header {
    padding: 80px 0 32px;
  }

  .op-features-left {
    max-width: 610px;
    margin-bottom: 12px;
  }

  .op-detail-label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    /* was rgb(107,112,148) = #6B7094 = 4.04:1 on depth-1. fails AA. Bumped
       to #9696B8 = 6.80:1 to match the same lift applied site-wide in r2. */
    color: #9696B8;
    letter-spacing: 1.12px;
    line-height: 24px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .op-h3 {
    font-family: var(--font-sans);
    font-size: 48px;
    font-weight: 600;
    color: white;
    line-height: 57.6px;
    letter-spacing: -0.96px;
    margin: 0 0 14px;
  }

  .op-features-subtitle {
    margin-bottom: 32px;
  }

  .op-subtitle-text {
    font-family: var(--font-sans);
    font-size: 22.4px;
    font-weight: 500;
    color: rgb(170, 176, 188);
    line-height: 33.6px;
  }

  /* 3-column grid */
  .op-grid-three {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  /* Feature cards. tokenized to sandbox-ui aesthetic */
  .op-feature-card {
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition: border-color 0.16s ease, background-color 0.16s ease;
  }

  .op-feature-card:hover {
    border-color: var(--border-accent);
    background: var(--depth-4);
  }

  .op-feature-card-inner {
    padding: 32px 28px;
  }

  .op-card-icon {
    color: var(--brand-cool);
    width: 24px;
    height: 24px;
    margin-bottom: 10px;
  }

  .op-card-title {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin: 10px 0 0.5rem;
  }

  .op-card-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }


  /* Responsive */
  @media screen and (max-width: 991px) {
    .op-hero-split {
      flex-direction: column;
      gap: 2rem;
    }
    .op-hero-text {
      width: 100%;
    }
    .op-hero-image-wrapper {
      width: 100%;
    }
    .op-h2 {
      font-size: 3rem;
    }
    .op-h3 {
      font-size: 2.25rem;
      line-height: 120%;
    }
    .op-grid-three {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 479px) {
    .op-h2 {
      font-size: 2.5rem;
    }
    .op-hero-body {
      font-size: 1rem;
    }
    .op-subtitle-text {
      font-size: 1rem;
    }
    .op-card-title {
      font-size: 1.5rem;
    }
  }

  /* One-shot terminal-typing reveal for the /operators hero CodeWindow */
  .op-hero-terminal-typing.is-typing .op-line {
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .op-hero-terminal-typing.is-typing .op-line.op-line--show {
    opacity: 1;
    transform: translateY(0);
  }
  .op-cursor {
    display: inline-block;
    width: 0.55ch;
    margin-left: 1px;
    color: currentColor;
    animation: op-cursor-blink 1.2s steps(1, end) infinite;
  }
  .op-hero-terminal-typing.is-done .op-cursor {
    display: none;
  }
  @keyframes op-cursor-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .op-hero-terminal-typing.is-typing .op-line {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .op-cursor { display: none; }
  }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('.op-hero-terminal-typing');
    if (!root) return;
    var pane = root.querySelector('.cw-pane[data-cw-pane="setup"]') || root.querySelector('.cw-pane');
    if (!pane) return;

    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Split innerHTML on literal newlines, wrap each line in a span.op-line.
    var html = pane.innerHTML;
    var lines = html.split('\n');
    var wrapped = lines
      .map(function (l) { return '<span class="op-line">' + (l.length ? l : '&nbsp;') + '</span>'; })
      .join('\n');
    pane.innerHTML = wrapped;

    var lineEls = pane.querySelectorAll('.op-line');
    if (!lineEls.length) return;

    if (reduced) {
      for (var i = 0; i < lineEls.length; i++) lineEls[i].classList.add('op-line--show');
      root.classList.add('is-done');
      return;
    }

    root.classList.add('is-typing');

    var cursor = document.createElement('span');
    cursor.className = 'op-cursor';
    cursor.textContent = '▍';
    cursor.setAttribute('aria-hidden', 'true');

    function reveal() {
      var step = 70; // ~1.2s for 17 lines
      lineEls.forEach(function (el, idx) {
        setTimeout(function () {
          el.classList.add('op-line--show');
          el.appendChild(cursor);
          if (idx === lineEls.length - 1) {
            setTimeout(function () {
              if (cursor.parentNode) cursor.parentNode.removeChild(cursor);
              root.classList.add('is-done');
            }, 220);
          }
        }, idx * step);
      });
    }

    var io = new IntersectionObserver(function (entries, obs) {
      for (var i = 0; i < entries.length; i++) {
        if (entries[i].isIntersecting) {
          obs.unobserve(entries[i].target);
          reveal();
          break;
        }
      }
    }, { threshold: 0.3 });
    io.observe(root);
  })();
</script>

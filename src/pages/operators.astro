---
import BaseLayout from '../layouts/BaseLayout.astro';

const earningCards = [
  { title: 'Staking Rewards', description: 'Become an operator and receive Tangle Tokens as a reward while contributing to network security.', icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6172f3" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>' },
  { title: 'Service Rewards', description: 'Register for Blueprints on Tangle Network and earn fees and service revenue from customers who request Blueprint instances. Earn by providing useful services through Tangle\'s decentralized cloud infrastructure.', icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6172f3" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" /></svg>' },
  { title: 'Real Infrastructure', description: 'Tangle Blueprints provide useful infrastructure for paying customers, earning through repeated instancing. Tangle operators help grow ecosystems and can monetize their operations in novel ways.', icon: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#6172f3" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>' },
];

const faqs = [
  { question: 'What is a Tangle operator?', answer: 'Operators are node runners who stake tokens to execute jobs from Blueprint instances. They provide computing resources for services like bridges and oracles, earning rewards while securing the network through their restaked assets.' },
  { question: 'What are the steps to becoming a Tangle operator?', answer: 'Start by setting up a Tangle node and staking TNT tokens. Then participate in staking to run Blueprint instances — which can include services like AI agent sandboxes, cloud services, blockchain oracles, blockchain bridges, and zero-knowledge applications.' },
  { question: 'What are all the ways to earn rewards as a Tangle operator?', answer: 'Earn through multiple streams: direct service fees from customers, protocol-based rewards from inflation, staking rewards, and fees from running Blueprints.' },
];
---

<BaseLayout title="Operators" description="Join Tangle's operator community to deploy advanced AI services and earn TNT.">

  <section class="wf-section-hero" style="position: relative;">
    <section class="wf-hero-section">
      <div class="wf-container-large hero-container">
        <div class="wf-hero-text" style="align-items: flex-start;">
          <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; margin-bottom: 8px;">Operators</div>
          <h1 class="wf-h1">Secure Tangle.<br/>Earn TNT.</h1>
          <div class="wf-body-01">Join our operator community to be at the forefront of deploying advanced AI services and applications.</div>
          <div class="wf-button-row">
            <a href="https://docs.tangle.tools/operators/validator/introduction" target="_blank" rel="noopener noreferrer" class="wf-btn-secondary">Run Node</a>
          </div>
        </div>
      </div>
      <div style="position: absolute; right: 5%; top: 50%; transform: translateY(-50%); width: 50%; max-width: 600px; z-index: 0; opacity: 0.9;">
        <img src="/images/webflow/65203bb692f9ba32696ec455_TNT2.webp" alt="TNT Token" style="width: 100%; height: auto;" loading="lazy" />
      </div>
    </section>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper" style="position: relative;">
      <div class="wf-container-large">
        <div class="wf-section-head">
          <div class="wf-glowing-wrapper">
            <div class="wf-glowing-wrapper-button">
              <div class="wf-button-text-pill">Become an Operator</div>
            </div>
          </div>
          <div class="wf-h3">Be the Force Behind Tangle Network's Vision</div>
          <div class="wf-body-02 align-center">From Hyperlane ISMs and LayerZero DVNs, to Envio Indexers, operators engage in a variety of tasks to unleash earning potentials.</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto;">
          {earningCards.map((card) => (
            <div class="wf-builder-feature-card">
              <div class="wf-builder-feature-top">
                <div style="margin-bottom: 12px;" set:html={card.icon} />
                <div class="wf-h4" style="font-size: 1.5rem;">{card.title}</div>
              </div>
              <div class="wf-builder-feature-bottom" style="flex-direction: column;">
                <div style="color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; line-height: 1.6;">{card.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="wf-section">
    <div class="wf-section-wrapper">
      <div class="wf-container-large" style="max-width: 800px;">
        <div class="wf-section-head">
          <div class="wf-h3">Frequently Asked Questions</div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {faqs.map((faq, i) => (
            <details style="border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; overflow: hidden;" {...(i === 0 ? { open: true } : {})}>
              <summary style="display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 1.25rem 1.5rem; font-family: 'Satoshi', sans-serif; font-size: 1.1rem; font-weight: 600; color: white; list-style: none;">
                {faq.question}
                <svg style="width: 20px; height: 20px; flex-shrink: 0; margin-left: 16px; color: #6b7094; transition: transform 0.2s;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div style="padding: 0 1.5rem 1.25rem; color: var(--color-text-secondary); font-family: 'Satoshi', sans-serif; font-size: 1rem; font-weight: 500; line-height: 1.6;">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>


</BaseLayout>

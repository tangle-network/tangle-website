---
import BaseLayout from './BaseLayout.astro';
import BlogCover from '../components/BlogCover.astro';

interface Props {
  title: string;
  summary: string;
  date: string;
  author: string;
  tags: string[];
  series?: string;
  seriesOrder?: number;
  coverImage?: string;
  heroImage?: string;
  imageAlt?: string;
  faqs?: { question: string; answer: string }[];
}

const { title, summary, date, author, tags, series, seriesOrder, coverImage, heroImage, imageAlt, faqs } = Astro.props;
const displayImage = heroImage || coverImage;
const keywords = [
  ...new Set([
    ...tags,
    'AI agents',
    'self-improving systems',
    'AI infrastructure',
    'decentralized AI',
    'Web3 AI',
    'crypto services',
  ]),
];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = displayImage ? new URL(displayImage, Astro.site).toString() : undefined;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  keywords,
  author: { '@type': 'Person', name: author },
  datePublished: date,
  dateModified: date,
  inLanguage: 'en-US',
  ...(imageUrl && { image: imageUrl }),
  publisher: {
    '@type': 'Organization',
    name: 'Tangle Network',
    url: 'https://tangle.tools',
  },
  mainEntityOfPage: canonicalUrl,
};

const faqJsonLd = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;
---

<BaseLayout
  title={title}
  description={summary}
  image={displayImage}
  imageAlt={imageAlt || title}
  ogType="article"
  keywords={keywords}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  <div class="blog-page">
    <section class="blog-hero">
      <div class="blog-hero-inner">
        <header class="blog-hero-copy">
          <a href="/blog" class="blog-back-link">Blog</a>
          <h1>{title}</h1>
          <p>{summary}</p>
          <div class="blog-meta">
            <span>{author}</span>
            <span aria-hidden="true">/</span>
            <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </div>
          <div class="blog-tags" aria-label="Post tags">
            {tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        </header>
        <BlogCover
          title={title}
          summary={summary}
          series={series}
          seriesOrder={seriesOrder}
          tags={tags}
          coverImage={displayImage}
          imageAlt={imageAlt || title}
          variant="hero"
        />
      </div>
    </section>

    <section class="blog-article-shell">
      <article class="blog-article">
        <div class="blog-content">
          <slot />
        </div>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .blog-page {
    min-height: 100vh;
    overflow-x: clip;
    background: #f4f4f9;
    color: #191c24;
  }

  .blog-hero {
    padding: clamp(5.25rem, 7vw, 6.25rem) 5% 2.5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 244, 249, 1)),
      #f4f4f9;
    border-bottom: 1px solid rgba(25, 28, 36, 0.08);
  }

  .blog-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 29rem);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    max-width: 80rem;
    margin: 0 auto;
  }

  .blog-hero-copy {
    min-width: 0;
  }

  .blog-back-link {
    display: inline-flex;
    align-items: center;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #4F46E5;
    text-decoration: none;
  }

  .blog-back-link:hover {
    color: #3730A3;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .blog-tags span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    color: #4338CA;
    background: rgba(79, 70, 229, 0.08);
    border: 1px solid rgba(79, 70, 229, 0.16);
  }

  .blog-hero h1 {
    max-width: 56rem;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.05rem, 4.1vw, 3.45rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: 0;
    color: #111827;
    overflow-wrap: break-word;
  }

  .blog-hero p {
    max-width: 44rem;
    margin: 1rem 0 0;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.62;
    color: #3a3a50;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: #5e5e7a;
  }

  .blog-content {
    color: #24283a;
    font-size: 18px;
    line-height: 1.7;
  }

  .blog-article-shell {
    padding: 3.5rem 5% 5.5rem;
    background: #f4f4f9;
  }

  .blog-article {
    max-width: min(100%, 62rem);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 3rem);
    border: 1px solid rgba(25, 28, 36, 0.08);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 60px rgba(15, 23, 42, 0.08);
  }

  .blog-content :global(h2) {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .blog-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: #111827;
    margin-top: 2em;
    margin-bottom: 0.5em;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .blog-content :global(h4) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    line-height: 1.4;
    letter-spacing: 0;
  }

  .blog-content :global(p) {
    margin-bottom: 1.25em;
  }

  .blog-content :global(a) {
    color: #4F46E5;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .blog-content :global(a:hover) {
    color: #3730A3;
  }

  .blog-content :global(strong) {
    color: #111827;
    font-weight: 600;
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid #4F46E5;
    padding-left: 1.25em;
    margin-left: 0;
    margin-top: 1.5em;
    margin-bottom: 1.5em;
    color: #3a3a50;
    font-style: italic;
  }

  .blog-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5em;
  }

  .blog-content :global(li > ul),
  .blog-content :global(li > ol) {
    margin-top: 0.5em;
    margin-bottom: 0;
  }

  .blog-content :global(pre) {
    background: #111827;
    border: 1px solid rgba(17, 24, 39, 0.12);
    border-radius: 12px;
    padding: 1.25em;
    overflow-x: auto;
    margin-top: 1.5em;
    margin-bottom: 1.5em;
    font-size: 0.875em;
    line-height: 1.6;
  }

  .blog-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    font-family: var(--font-mono);
    color: rgba(255, 255, 255, 0.88);
    font-size: inherit;
  }

  .blog-content :global(code) {
    background: rgba(79, 70, 229, 0.08);
    border: 1px solid rgba(79, 70, 229, 0.18);
    border-radius: 6px;
    padding: 0.15em 0.4em;
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: #1E1B4B;
  }

  .blog-content :global(mark),
  .blog-content :global(.highlight),
  .blog-content :global([data-highlighted]) {
    background: #FEF3C7;
    color: #111827;
    border-radius: 4px;
    padding: 0.06em 0.22em;
  }

  .blog-content :global(:not(pre) > code span[style]) {
    color: #1E1B4B !important;
  }

  .blog-content :global(img) {
    width: 100%;
    border-radius: 12px;
    margin-top: 1.5em;
    margin-bottom: 1.5em;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(25, 28, 36, 0.1);
    margin-top: 2.5em;
    margin-bottom: 2.5em;
  }

  .blog-content :global(table) {
    display: block;
    width: 100%;
    min-width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-collapse: separate;
    border-spacing: 0;
    margin-top: 1.5em;
    margin-bottom: 1.5em;
    font-size: 0.925em;
    background: #ffffff;
    border: 1px solid rgba(25, 28, 36, 0.1);
    border-radius: 8px;
  }

  .blog-content :global(th) {
    text-align: left;
    padding: 0.75em 1em;
    border-bottom: 1px solid rgba(25, 28, 36, 0.12);
    color: #111827;
    background: #F6F7FF;
    font-weight: 600;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .blog-content :global(td) {
    padding: 0.75em 1em;
    border-bottom: 1px solid rgba(25, 28, 36, 0.08);
    color: #24283a;
    vertical-align: top;
    min-width: 9rem;
    overflow-wrap: anywhere;
  }

  .blog-content :global(tr:last-child td) {
    border-bottom: 0;
  }

  @media (max-width: 860px) {
    .blog-hero {
      padding-top: 5.25rem;
    }

    .blog-hero-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding-left: 1rem;
      padding-right: 1rem;
      padding-bottom: 1.75rem;
    }

    .blog-hero-inner,
    .blog-hero-copy {
      min-width: 0;
    }

    .blog-hero h1 {
      font-size: clamp(2rem, 10vw, 2.55rem);
      line-height: 1.08;
    }

    .blog-hero p {
      max-width: 100%;
      font-size: 1rem;
      overflow-wrap: break-word;
    }

    .blog-article-shell {
      padding: 1.25rem 1rem 3rem;
    }

    .blog-article {
      padding: 1.15rem;
      max-width: 100%;
    }

    .blog-content {
      font-size: 17px;
    }

    .blog-content :global(h2) {
      font-size: 1.6rem;
    }
  }
</style>

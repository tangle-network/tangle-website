---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: 'website' | 'article';
  keywords?: string[];
}

const {
  title,
  description = 'Tangle gives AI agents the runtime, router, browser harness, evals, benchmarks, and deployment path they need to improve safely.',
  image = '/images/og-self-improving-agents.png',
  imageAlt = `${title} | Tangle`,
  ogType = 'website',
  keywords = [],
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const defaultKeywords = [
  'AI agent infrastructure',
  'self-improving agents',
  'agent runtime',
  'AI sandbox',
  'model router',
  'browser agent',
  'agent evals',
  'AI benchmarks',
  'Blueprint Agent',
  'Tangle',
];
const pageKeywords = [...new Set([...keywords, ...defaultKeywords])];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Tangle</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={pageKeywords.join(', ')} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content="Drew Stone" />
    <meta name="application-name" content="Tangle" />
    <meta name="theme-color" content="#0C0B1D" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="LLMs.txt" />
    <link rel="alternate" type="text/plain" href="/ai.txt" title="AI agent instructions" />
    <link rel="agent-manifest" type="application/json" href="/.well-known/tangle-agent.json" />
    <link rel="product-catalog" type="application/json" href="/.well-known/tangle-products.json" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tangle" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Tangle`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@tangle_network" />
    <meta name="twitter:title" content={`${title} | Tangle`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/tangle-icon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JEQ15MLV6B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JEQ15MLV6B');
      gtag('config', 'G-R5W7898EVV');
    </script>
  </head>
  <body class="bg-bg-dark text-text-primary min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

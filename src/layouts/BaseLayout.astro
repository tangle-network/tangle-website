---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Infrastructure for AI services. Sandboxed runtime, unified model routing, and programmable billing — one stack for the agents, APIs, and services you ship.',
  image = '/images/og-default.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" integrity="sha384-zh0CIslj3dQfNH3rrltmr19gSmraJQ0OhHktZsLMOakXJ0f3XLtTzKBvT0Ne3Abh" crossorigin="anonymous">
    <title>{title} | Tangle</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | Tangle`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Tangle`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts -->
    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.ttf" as="font" type="font/truetype" crossorigin />
    <link rel="preload" href="/fonts/SpaceMono-Regular.ttf" as="font" type="font/truetype" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.6.0/p5.min.js"></script>

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JEQ15MLV6B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JEQ15MLV6B');
      gtag('config', 'G-R5W7898EVV');
    </script>
  </head>
  <body class="bg-bg-dark text-text-primary min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

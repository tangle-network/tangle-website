---
/**
 * Production-stack credibility strip — 4 category rows × 10 logos each,
 * alternating-direction marquees, monochrome rendering for visual cohesion.
 *
 * Logo sources mix `astro-icon` + `@iconify-json/simple-icons` (monochrome
 * by default, render via currentColor) with local SVGs in
 * `/images/partners/`. Both are forced to monochrome via CSS so the strip
 * reads as one statement, not a logo zoo.
 *
 * Used on /services/blueprint-agent between the Teams section and FAQ.
 */
import { Icon } from 'astro-icon/components';

type LogoEntry =
  | { kind: 'icon'; name: string; alt: string }
  | { kind: 'img'; src: string; alt: string };

const aiRow: LogoEntry[] = [
  { kind: 'icon', name: 'simple-icons:openai',       alt: 'OpenAI' },
  { kind: 'icon', name: 'simple-icons:anthropic',    alt: 'Anthropic' },
  { kind: 'icon', name: 'simple-icons:vercel',       alt: 'Vercel AI SDK' },
  { kind: 'icon', name: 'simple-icons:langchain',    alt: 'LangChain' },
  { kind: 'icon', name: 'simple-icons:nvidia',       alt: 'NVIDIA' },
  { kind: 'icon', name: 'simple-icons:modal',        alt: 'Modal' },
  { kind: 'icon', name: 'simple-icons:huggingface',  alt: 'Hugging Face' },
  { kind: 'icon', name: 'simple-icons:replicate',    alt: 'Replicate' },
  { kind: 'icon', name: 'simple-icons:mistralai',    alt: 'Mistral' },
  { kind: 'icon', name: 'simple-icons:elevenlabs',   alt: 'ElevenLabs' },
];

const cryptoRow: LogoEntry[] = [
  { kind: 'icon', name: 'simple-icons:solana',       alt: 'Solana' },
  { kind: 'img',  src: '/images/partners/aptos-logo.svg',     alt: 'Aptos' },
  { kind: 'icon', name: 'simple-icons:sui',          alt: 'Sui' },
  { kind: 'img',  src: '/images/partners/arbitrum-logo.svg',  alt: 'Arbitrum' },
  { kind: 'img',  src: '/images/partners/base-logo.svg',      alt: 'Base' },
  { kind: 'icon', name: 'simple-icons:optimism',     alt: 'Optimism' },
  { kind: 'img',  src: '/images/partners/aave.svg',           alt: 'Aave' },
  { kind: 'icon', name: 'simple-icons:chainlink',    alt: 'Chainlink' },
  { kind: 'img',  src: '/images/partners/eigenlayer-logo.svg', alt: 'EigenLayer' },
  { kind: 'icon', name: 'simple-icons:coinbase',     alt: 'Coinbase' },
];

const infraRow: LogoEntry[] = [
  { kind: 'icon', name: 'simple-icons:vercel',       alt: 'Vercel' },
  { kind: 'icon', name: 'simple-icons:mongodb',      alt: 'MongoDB' },
  { kind: 'icon', name: 'simple-icons:postgresql',   alt: 'PostgreSQL' },
  { kind: 'icon', name: 'simple-icons:stripe',       alt: 'Stripe' },
  { kind: 'icon', name: 'simple-icons:github',       alt: 'GitHub' },
  { kind: 'icon', name: 'simple-icons:cloudflare',   alt: 'Cloudflare' },
  { kind: 'icon', name: 'simple-icons:docker',       alt: 'Docker' },
  { kind: 'icon', name: 'simple-icons:supabase',     alt: 'Supabase' },
  { kind: 'icon', name: 'simple-icons:turso',        alt: 'Turso' },
  { kind: 'icon', name: 'simple-icons:sentry',       alt: 'Sentry' },
];

const webRow: LogoEntry[] = [
  { kind: 'icon', name: 'simple-icons:nextdotjs',    alt: 'Next.js' },
  { kind: 'icon', name: 'simple-icons:astro',        alt: 'Astro' },
  { kind: 'icon', name: 'simple-icons:react',        alt: 'React' },
  { kind: 'icon', name: 'simple-icons:tailwindcss',  alt: 'Tailwind CSS' },
  { kind: 'icon', name: 'simple-icons:shadcnui',     alt: 'shadcn/ui' },
  { kind: 'icon', name: 'simple-icons:tanstack',     alt: 'TanStack' },
  { kind: 'icon', name: 'simple-icons:threedotjs',   alt: 'Three.js' },
  { kind: 'icon', name: 'simple-icons:bun',          alt: 'Bun' },
  { kind: 'icon', name: 'simple-icons:typescript',   alt: 'TypeScript' },
  { kind: 'icon', name: 'simple-icons:vite',         alt: 'Vite' },
];

const rows: { label: string; logos: LogoEntry[]; reverse: boolean }[] = [
  { label: 'AI',     logos: aiRow,     reverse: false },
  { label: 'CRYPTO', logos: cryptoRow, reverse: true  },
  { label: 'INFRA',  logos: infraRow,  reverse: false },
  { label: 'WEB',    logos: webRow,    reverse: true  },
];
---

<section class="bol" aria-label="Stacks Blueprint Agent compiles against">
  <div class="bol-inner">
    <div class="bol-head">
      <div class="bol-eyebrow">YOUR STACK, GENERATED FOR PRODUCTION</div>
      <h2 class="bol-title">
        Production-grade scaffolding for
        <span class="bol-grad">every stack you ship against.</span>
      </h2>
      <p class="bol-lede">
        AI, crypto, infra, web. Blueprint Agent generates code against the real SDKs you'll deploy with, not toy templates. Typed clients, secrets handling, tests, deploy targets — wired up in the same session.
      </p>
    </div>

    <div class="bol-rows">
      {rows.map(({ label, logos, reverse }) => (
        <div class="bol-row">
          <div class="bol-row-label">{label}</div>
          <div class={`bol-marquee${reverse ? ' bol-marquee--rev' : ''}`} aria-hidden="true">
            <div class="bol-track">
              {[...logos, ...logos, ...logos].map((logo) => (
                <div class="bol-cell" title={logo.alt}>
                  {logo.kind === 'icon'
                    ? <Icon name={logo.name} class="bol-logo bol-logo--icon" aria-label={logo.alt} />
                    : <img src={logo.src} alt={logo.alt} class="bol-logo bol-logo--img" loading="lazy" />}
                </div>
              ))}
            </div>
          </div>
          <span class="sr-only">{label}: {logos.map((l) => l.alt).join(', ')}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bol {
    background: #0c0b1d;
    color: #f4f4f9;
    padding: 5rem 8%;
    overflow: hidden;
  }
  .bol-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .bol-head {
    text-align: center;
    margin: 0 auto 3.5rem;
    max-width: 56rem;
  }
  .bol-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #818cf8;
    margin-bottom: 1rem;
  }
  .bol-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(1.75rem, 3.4vw, 2.75rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .bol-grad {
    background: linear-gradient(135deg, #818cf8 0%, #a5aafc 50%, #c7d2fe 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .bol-lede {
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.65);
    margin: 0;
  }

  .bol-rows {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .bol-row {
    display: grid;
    grid-template-columns: 88px 1fr;
    align-items: center;
    gap: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1.25rem;
  }
  .bol-row:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .bol-row-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(244, 244, 249, 0.45);
    font-weight: 600;
    user-select: none;
  }

  .bol-marquee {
    position: relative;
    overflow: hidden;
    /* Soft mask so logos fade into the section edges instead of clipping. */
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0, black 8%, black 92%, transparent 100%);
  }
  .bol-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: bol-scroll 50s linear infinite;
  }
  .bol-marquee--rev .bol-track {
    animation-direction: reverse;
  }
  .bol-marquee:hover .bol-track {
    animation-play-state: paused;
  }
  @keyframes bol-scroll {
    /* Track is 3× the row, so a -33.33% translate completes one logo cycle. */
    from { transform: translateX(0); }
    to   { transform: translateX(-33.3333%); }
  }

  .bol-cell {
    flex: 0 0 auto;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bol-logo {
    height: 28px;
    width: auto;
    max-width: 140px;
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .bol-logo--icon {
    /* simple-icons render via currentColor — drives them to a soft white. */
    color: rgba(244, 244, 249, 0.55);
  }
  .bol-logo--img {
    /* Local brand SVGs vary in fill — force monochrome so the row reads
       as one statement instead of a multicolor logo zoo. */
    filter: brightness(0) invert(1);
    opacity: 0.55;
  }
  .bol-cell:hover .bol-logo--icon {
    color: rgba(255, 255, 255, 0.95);
  }
  .bol-cell:hover .bol-logo--img {
    opacity: 0.95;
  }

  /* Respect reduced-motion — pause the marquee. */
  @media (prefers-reduced-motion: reduce) {
    .bol-track {
      animation: none;
    }
    .bol-marquee {
      overflow-x: auto;
    }
  }

  @media (max-width: 700px) {
    .bol { padding: 4rem 6%; }
    .bol-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .bol-row-label {
      font-size: 0.68rem;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

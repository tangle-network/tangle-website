---
/**
 * Production-stack credibility section — 4 category bento tiles
 * (AI / Crypto / Infra / Web) on a vault (light) surface. Each tile
 * carries a category-specific micro-mockup at the head + a 5×2 grid
 * of clickable logo cells with brand names always visible.
 *
 * Logos resolved at SSR from `@iconify-json/simple-icons` for the
 * brands the pack covers; local SVGs in /images/partners/ for the
 * chains it doesn't (aave, aptos, arbitrum, base, eigenlayer).
 *
 * Each logo links to ai.tangle.tools/partner/<slug> — keeps users on
 * Tangle property and seeds an internal-link graph for SEO. Some
 * partner pages aren't live yet; the URL contract is stable so we
 * don't have to rewrite the strip when each one ships.
 *
 * Closes with an integration-request CTA so the surface earns its
 * real estate. Lands on /services/blueprint-agent between the Hero
 * and StarterGallery sections.
 */
import simpleIcons from '@iconify-json/simple-icons/icons.json';

const ICON_VIEWBOX = `0 0 ${simpleIcons.width} ${simpleIcons.height}`;
function iconBody(name: string): string {
  const icon = (simpleIcons.icons as Record<string, { body: string }>)[name];
  if (!icon) throw new Error(`simple-icons: unknown icon "${name}"`);
  return icon.body;
}

type LogoEntry =
  | { kind: 'icon'; name: string; alt: string; slug: string }
  | { kind: 'img'; src: string; alt: string; slug: string };

type CategoryTile = {
  label: string;
  blurb: string;
  accent: string;
  accentSoft: string;     // softer tint for tile gradient
  microMockup: 'chat' | 'chart' | 'terminal' | 'browser';
  logos: LogoEntry[];
};

const PARTNER_BASE = 'https://ai.tangle.tools/partner';
const partnerHref = (slug: string): string => `${PARTNER_BASE}/${slug}`;

const tiles: CategoryTile[] = [
  {
    label: 'AI',
    blurb: 'Model providers, agent frameworks, vector stores.',
    accent: '#a855f7',
    accentSoft: '#f5e9ff',
    microMockup: 'chat',
    logos: [
      { kind: 'icon', name: 'openai',      alt: 'OpenAI',        slug: 'openai' },
      { kind: 'icon', name: 'anthropic',   alt: 'Anthropic',     slug: 'anthropic' },
      { kind: 'icon', name: 'vercel',      alt: 'Vercel AI SDK', slug: 'ai-sdk' },
      { kind: 'icon', name: 'langchain',   alt: 'LangChain',     slug: 'langchain' },
      { kind: 'icon', name: 'nvidia',      alt: 'NVIDIA',        slug: 'nvidia' },
      { kind: 'icon', name: 'modal',       alt: 'Modal',         slug: 'modal' },
      { kind: 'icon', name: 'huggingface', alt: 'Hugging Face',  slug: 'huggingface' },
      { kind: 'icon', name: 'replicate',   alt: 'Replicate',     slug: 'replicate' },
      { kind: 'icon', name: 'mistralai',   alt: 'Mistral',       slug: 'mistral' },
      { kind: 'icon', name: 'elevenlabs',  alt: 'ElevenLabs',    slug: 'elevenlabs' },
    ],
  },
  {
    label: 'Crypto',
    blurb: 'Chains, oracles, restaking, smart-contract primitives.',
    accent: '#6366f1',
    accentSoft: '#eef0ff',
    microMockup: 'chart',
    logos: [
      { kind: 'icon', name: 'solana',                             alt: 'Solana',     slug: 'solana' },
      { kind: 'img',  src: '/images/partners/aptos-logo.svg',     alt: 'Aptos',      slug: 'aptos' },
      { kind: 'icon', name: 'sui',                                alt: 'Sui',        slug: 'sui' },
      { kind: 'img',  src: '/images/partners/arbitrum-logo.svg',  alt: 'Arbitrum',   slug: 'arbitrum' },
      { kind: 'img',  src: '/images/partners/base-logo.svg',      alt: 'Base',       slug: 'base' },
      { kind: 'icon', name: 'optimism',                           alt: 'Optimism',   slug: 'optimism' },
      { kind: 'img',  src: '/images/partners/aave.svg',           alt: 'Aave',       slug: 'aave' },
      { kind: 'icon', name: 'chainlink',                          alt: 'Chainlink',  slug: 'chainlink' },
      { kind: 'img',  src: '/images/partners/eigenlayer-logo.svg',alt: 'EigenLayer', slug: 'eigenlayer' },
      { kind: 'icon', name: 'coinbase',                           alt: 'Coinbase',   slug: 'coinbase' },
    ],
  },
  {
    label: 'Infra',
    blurb: 'Deploy targets, data, payments, observability.',
    accent: '#10b981',
    accentSoft: '#e0fbf2',
    microMockup: 'terminal',
    logos: [
      { kind: 'icon', name: 'vercel',     alt: 'Vercel',     slug: 'vercel' },
      { kind: 'icon', name: 'mongodb',    alt: 'MongoDB',    slug: 'mongodb' },
      { kind: 'icon', name: 'postgresql', alt: 'PostgreSQL', slug: 'postgresql' },
      { kind: 'icon', name: 'stripe',     alt: 'Stripe',     slug: 'stripe' },
      { kind: 'icon', name: 'github',     alt: 'GitHub',     slug: 'github' },
      { kind: 'icon', name: 'cloudflare', alt: 'Cloudflare', slug: 'cloudflare' },
      { kind: 'icon', name: 'docker',     alt: 'Docker',     slug: 'docker' },
      { kind: 'icon', name: 'supabase',   alt: 'Supabase',   slug: 'supabase' },
      { kind: 'icon', name: 'turso',      alt: 'Turso',      slug: 'turso' },
      { kind: 'icon', name: 'sentry',     alt: 'Sentry',     slug: 'sentry' },
    ],
  },
  {
    label: 'Web',
    blurb: 'Frameworks, runtimes, the actual UX layer.',
    accent: '#f59e0b',
    accentSoft: '#fff5e0',
    microMockup: 'browser',
    logos: [
      { kind: 'icon', name: 'nextdotjs',   alt: 'Next.js',     slug: 'nextjs' },
      { kind: 'icon', name: 'astro',       alt: 'Astro',       slug: 'astro' },
      { kind: 'icon', name: 'react',       alt: 'React',       slug: 'react' },
      { kind: 'icon', name: 'tailwindcss', alt: 'Tailwind CSS',slug: 'tailwind' },
      { kind: 'icon', name: 'shadcnui',    alt: 'shadcn/ui',   slug: 'shadcn' },
      { kind: 'icon', name: 'tanstack',    alt: 'TanStack',    slug: 'tanstack' },
      { kind: 'icon', name: 'threedotjs',  alt: 'Three.js',    slug: 'threejs' },
      { kind: 'icon', name: 'bun',         alt: 'Bun',         slug: 'bun' },
      { kind: 'icon', name: 'typescript',  alt: 'TypeScript',  slug: 'typescript' },
      { kind: 'icon', name: 'vite',        alt: 'Vite',        slug: 'vite' },
    ],
  },
];

const integrationFormHref = 'https://form.typeform.com/to/IE4hT9jW';
---

<section class="bol" aria-label="Stacks Blueprint Agent compiles against">
  <div class="bol-inner">
    <div class="bol-head">
      <div class="bol-eyebrow">YOUR STACK, GENERATED FOR PRODUCTION</div>
      <h2 class="bol-title">
        Production-grade scaffolding for
        <span class="bol-grad">every stack you ship against.</span>
      </h2>
      <p class="bol-lede">
        AI, crypto, infra, web. Blueprint Agent generates code against the real SDKs you'll deploy with, not toy templates. Typed clients, secrets handling, tests, deploy targets, all wired up in the same session.
      </p>
    </div>

    <div class="bol-grid">
      {tiles.map((tile) => (
        <div class="bol-tile" style={`--bol-accent: ${tile.accent}; --bol-accent-soft: ${tile.accentSoft};`}>
          <div class="bol-tile-head">
            <div class="bol-tile-meta">
              <div class="bol-tile-label">
                <span class="bol-tile-pulse" aria-hidden="true"></span>
                {tile.label}
              </div>
              <div class="bol-tile-blurb">{tile.blurb}</div>
            </div>
            <div class="bol-tile-mock" aria-hidden="true">
              {tile.microMockup === 'chat' && (
                <div class="bol-mock bol-mock--chat">
                  <div class="bol-mock-line bol-mock-line--user">how do I scaffold a vector RAG?</div>
                  <div class="bol-mock-line bol-mock-line--ai">
                    <span class="bol-mock-typing">scaffolding</span>
                    <span class="bol-mock-cursor"></span>
                  </div>
                </div>
              )}
              {tile.microMockup === 'chart' && (
                <div class="bol-mock bol-mock--chart">
                  <svg viewBox="0 0 120 36" preserveAspectRatio="none" class="bol-mock-svg">
                    {[8, 14, 22, 30, 38, 46, 54, 62, 70, 78, 86, 94, 102, 110].map((x, i) => {
                      const heights = [12, 8, 16, 20, 14, 22, 18, 26, 30, 24, 32, 28, 22, 18];
                      const greens = [0, 2, 3, 5, 7, 8, 10, 12];
                      const isGreen = greens.includes(i);
                      const h = heights[i];
                      const y = 36 - h - 4;
                      return <rect x={x} y={y} width="6" height={h} fill={isGreen ? '#10b981' : '#ef4444'} opacity={0.85} rx="1" />
                    })}
                    <line x1="0" y1="22" x2="120" y2="22" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3" opacity="0.3" />
                  </svg>
                </div>
              )}
              {tile.microMockup === 'terminal' && (
                <div class="bol-mock bol-mock--terminal">
                  <div class="bol-mock-row"><span class="bol-mock-prompt">$</span> pnpm deploy --prod</div>
                  <div class="bol-mock-row bol-mock-row--ok"><span class="bol-mock-tick">✓</span> built · 12s</div>
                  <div class="bol-mock-row bol-mock-row--ok"><span class="bol-mock-tick">✓</span> deployed → vercel.app</div>
                </div>
              )}
              {tile.microMockup === 'browser' && (
                <div class="bol-mock bol-mock--browser">
                  <div class="bol-mock-bar">
                    <span class="bol-mock-trafic"></span>
                    <span class="bol-mock-trafic"></span>
                    <span class="bol-mock-trafic"></span>
                    <span class="bol-mock-url">your-app.vercel.app</span>
                  </div>
                  <div class="bol-mock-page">
                    <div class="bol-mock-bar-line bol-mock-bar-line--lg"></div>
                    <div class="bol-mock-bar-line bol-mock-bar-line--md"></div>
                    <div class="bol-mock-bar-line bol-mock-bar-line--sm"></div>
                  </div>
                </div>
              )}
            </div>
          </div>

          <div class="bol-tile-grid" role="list">
            {tile.logos.map((logo) => (
              <a
                role="listitem"
                href={partnerHref(logo.slug)}
                target="_blank"
                rel="noopener noreferrer"
                class="bol-cell"
                aria-label={`${logo.alt}: open the partner workbench`}
              >
                <span class="bol-cell-icon" aria-hidden="true">
                  {logo.kind === 'icon'
                    ? <svg viewBox={ICON_VIEWBOX} class="bol-logo bol-logo--icon" set:html={iconBody(logo.name)} />
                    : <img src={logo.src} alt="" class="bol-logo bol-logo--img" loading="lazy" />}
                </span>
                <span class="bol-cell-name">{logo.alt}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="bol-cta">
      <div class="bol-cta-copy">
        <div class="bol-cta-eyebrow">DON'T SEE YOUR STACK?</div>
        <div class="bol-cta-title">We add integrations on request.</div>
        <p class="bol-cta-body">
          Tell us what your team builds against and we'll wire up a starter, typed clients, and a passing test suite so you can scaffold from day one.
        </p>
      </div>
      <a class="bol-cta-btn" href={integrationFormHref} target="_blank" rel="noopener noreferrer">
        Request an integration
        <svg class="bol-cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7"/>
          <path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bol {
    background: #f4f4f9;
    color: #191c24;
    padding: 5rem 8% 5rem;
  }
  .bol-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .bol-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 56rem;
  }
  .bol-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4f46e5;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .bol-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(1.875rem, 3.6vw, 3rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #191c24;
  }
  .bol-grad {
    background: linear-gradient(135deg, #4f46e5 0%, #6366f1 50%, #818cf8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .bol-lede {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #3a3a50;
    margin: 0;
  }

  /* 2-col bento on desktop, 1-col on mobile. */
  .bol-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin: 2rem 0 3rem;
  }
  @media (max-width: 920px) {
    .bol-grid { grid-template-columns: 1fr; }
  }

  .bol-tile {
    --bol-accent: #6366f1;
    --bol-accent-soft: #eef0ff;
    position: relative;
    background: #ffffff;
    border: 1px solid #e2e3ee;
    border-radius: 18px;
    padding: 1.75rem 1.75rem 1.5rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    overflow: hidden;
  }
  .bol-tile::before {
    /* Soft accent halo in the top-right; reads as the tile's "color". */
    content: '';
    position: absolute;
    top: -50%;
    right: -25%;
    width: 65%;
    height: 100%;
    background: radial-gradient(circle, var(--bol-accent-soft), transparent 70%);
    opacity: 0.7;
    pointer-events: none;
  }
  .bol-tile::after {
    content: '';
    position: absolute;
    top: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bol-accent), transparent);
    opacity: 0.85;
  }
  .bol-tile:hover {
    border-color: color-mix(in oklab, var(--bol-accent) 35%, #e2e3ee);
    box-shadow:
      0 16px 36px -18px color-mix(in oklab, var(--bol-accent) 40%, transparent),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
  }

  /* Tile head — meta on the left, micro-mockup on the right. */
  .bol-tile-head {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.25rem;
    align-items: stretch;
    margin-bottom: 1.375rem;
  }
  .bol-tile-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }
  .bol-tile-label {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display, system-ui);
    font-size: 1.625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #191c24;
    margin-bottom: 0.5rem;
  }
  .bol-tile-pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--bol-accent);
    box-shadow: 0 0 10px var(--bol-accent);
    animation: bol-pulse 2.4s ease-in-out infinite;
  }
  @keyframes bol-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.45; }
  }
  .bol-tile-blurb {
    font-size: 0.9rem;
    line-height: 1.45;
    color: #5e5e7a;
  }

  /* Micro-mockup — small visual that signals what the category does. */
  .bol-tile-mock {
    width: 168px;
    height: 88px;
    background: #f7f7fb;
    border: 1px solid #e2e3ee;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }
  @media (max-width: 600px) {
    .bol-tile-mock { display: none; }
  }
  .bol-mock {
    width: 100%;
    height: 100%;
    padding: 0.5rem 0.625rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    line-height: 1.45;
    color: #3a3a50;
  }

  /* Chat mock */
  .bol-mock--chat {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
  }
  .bol-mock-line {
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    line-height: 1.3;
    max-width: 95%;
  }
  .bol-mock-line--user {
    align-self: flex-end;
    background: var(--bol-accent);
    color: #ffffff;
    font-size: 0.6rem;
  }
  .bol-mock-line--ai {
    align-self: flex-start;
    background: #ffffff;
    border: 1px solid #e2e3ee;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #5e5e7a;
  }
  .bol-mock-typing {
    font-size: 0.6rem;
  }
  .bol-mock-cursor {
    display: inline-block;
    width: 1px;
    height: 9px;
    background: var(--bol-accent);
    animation: bol-blink 1.05s steps(2) infinite;
  }
  @keyframes bol-blink {
    50% { opacity: 0; }
  }

  /* Chart mock */
  .bol-mock--chart {
    display: flex;
    align-items: stretch;
    padding: 0.625rem;
  }
  .bol-mock-svg {
    width: 100%;
    height: 100%;
    color: #5e5e7a;
  }

  /* Terminal mock */
  .bol-mock--terminal {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.18rem;
    background: #0c0b1d;
    color: #c5c5dc;
  }
  .bol-mock-row {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    line-height: 1.3;
  }
  .bol-mock-prompt {
    color: var(--bol-accent);
    font-weight: 600;
  }
  .bol-mock-tick {
    color: #4ade80;
    font-weight: 700;
  }
  .bol-mock-row--ok {
    color: rgba(244, 244, 249, 0.7);
  }

  /* Browser mock */
  .bol-mock--browser {
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .bol-mock-bar {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.5rem;
    background: #f0f0f5;
    border-bottom: 1px solid #e2e3ee;
  }
  .bol-mock-trafic {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #d7d9e8;
  }
  .bol-mock-trafic:nth-child(1) { background: #f87171; }
  .bol-mock-trafic:nth-child(2) { background: #fbbf24; }
  .bol-mock-trafic:nth-child(3) { background: #4ade80; }
  .bol-mock-url {
    margin-left: 0.4rem;
    flex: 1;
    font-size: 0.55rem;
    color: #5e5e7a;
    background: #ffffff;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid #e2e3ee;
  }
  .bol-mock-page {
    flex: 1;
    padding: 0.625rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
  }
  .bol-mock-bar-line {
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--bol-accent), var(--bol-accent-soft));
    opacity: 0.7;
  }
  .bol-mock-bar-line--lg { width: 80%; }
  .bol-mock-bar-line--md { width: 55%; opacity: 0.45; }
  .bol-mock-bar-line--sm { width: 30%; opacity: 0.3; }

  /* Logo grid — 5 cols × 2 rows = 10 cells. */
  .bol-tile-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.625rem;
  }
  @media (max-width: 540px) {
    .bol-tile-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .bol-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.4rem;
    padding: 0.75rem 0.4rem 0.6rem;
    background: #ffffff;
    border: 1px solid #e2e3ee;
    border-radius: 10px;
    text-decoration: none;
    color: #3a3a50;
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    min-height: 78px;
  }
  .bol-cell:hover {
    transform: translateY(-2px);
    background: var(--bol-accent-soft);
    border-color: color-mix(in oklab, var(--bol-accent) 50%, #e2e3ee);
    box-shadow: 0 6px 14px -8px color-mix(in oklab, var(--bol-accent) 45%, transparent);
    color: var(--bol-accent);
  }
  .bol-cell-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
  }
  .bol-logo {
    height: 24px;
    width: auto;
    max-width: 60px;
    transition: opacity 0.18s ease, color 0.18s ease, filter 0.18s ease;
  }
  .bol-logo--icon {
    color: #5e5e7a;
    width: 24px;
  }
  .bol-cell:hover .bol-logo--icon {
    color: var(--bol-accent);
  }
  .bol-logo--img {
    /* Local brand SVGs vary in fill — force monochrome at rest, full
       color on hover so the cell actually feels alive. */
    filter: grayscale(1) contrast(0.75);
    opacity: 0.7;
  }
  .bol-cell:hover .bol-logo--img {
    filter: grayscale(0);
    opacity: 1;
  }
  .bol-cell-name {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    color: inherit;
  }

  /* CTA block */
  .bol-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
    margin: 0;
    padding: 1.75rem 2rem;
    background: linear-gradient(135deg, #ffffff 0%, #eef0ff 100%);
    border: 1px solid #d7d9e8;
    border-radius: 16px;
    box-shadow: 0 1px 0 rgba(99, 102, 241, 0.05);
  }
  @media (max-width: 720px) {
    .bol-cta { grid-template-columns: 1fr; gap: 1.25rem; padding: 1.5rem 1.5rem; }
  }
  .bol-cta-eyebrow {

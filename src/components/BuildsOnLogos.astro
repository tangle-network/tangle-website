---
/**
 * Production-stack credibility section — 4 category bento tiles
 * (AI / Crypto / Infra / Web) on a vault (light) surface, each tile
 * surfaces 10 brand logos in a clean grid. Logos are clickable and link
 * out to the brand's site. Closes with an integration-request CTA so
 * the surface earns its real estate.
 *
 * Lands on /services/blueprint-agent between the Teams section and FAQ.
 *
 * Logos resolved at SSR from `@iconify-json/simple-icons` for the
 * brands the pack covers; local SVGs in /images/partners/ for the
 * chains it doesn't (aave, aptos, arbitrum, base, eigenlayer).
 */
import simpleIcons from '@iconify-json/simple-icons/icons.json';

const ICON_VIEWBOX = `0 0 ${simpleIcons.width} ${simpleIcons.height}`;
function iconBody(name: string): string {
  const icon = (simpleIcons.icons as Record<string, { body: string }>)[name];
  if (!icon) throw new Error(`simple-icons: unknown icon "${name}"`);
  return icon.body;
}

type LogoEntry =
  | { kind: 'icon'; name: string; alt: string; slug: string }
  | { kind: 'img'; src: string; alt: string; slug: string };

type CategoryTile = {
  label: string;
  blurb: string;
  accent: string; // hex used for the card glow + accent line
  logos: LogoEntry[];
};

// Logos resolve to the partner page on ai.tangle.tools (the Blueprint
// Agent workbench themed for that partner). Some pages aren't live yet
// — they will be — but the link target is stable so we don't have to
// rewrite the strip when each one ships. Keeping users on Tangle property
// also wins on internal-link SEO over outbound brand links.
const PARTNER_BASE = 'https://ai.tangle.tools/partner';
const partnerHref = (slug: string): string => `${PARTNER_BASE}/${slug}`;

const tiles: CategoryTile[] = [
  {
    label: 'AI',
    blurb: 'Model providers, agent frameworks, vector stores.',
    accent: '#a855f7',
    logos: [
      { kind: 'icon', name: 'openai',      alt: 'OpenAI',        slug: 'openai' },
      { kind: 'icon', name: 'anthropic',   alt: 'Anthropic',     slug: 'anthropic' },
      { kind: 'icon', name: 'vercel',      alt: 'Vercel AI SDK', slug: 'ai-sdk' },
      { kind: 'icon', name: 'langchain',   alt: 'LangChain',     slug: 'langchain' },
      { kind: 'icon', name: 'nvidia',      alt: 'NVIDIA',        slug: 'nvidia' },
      { kind: 'icon', name: 'modal',       alt: 'Modal',         slug: 'modal' },
      { kind: 'icon', name: 'huggingface', alt: 'Hugging Face',  slug: 'huggingface' },
      { kind: 'icon', name: 'replicate',   alt: 'Replicate',     slug: 'replicate' },
      { kind: 'icon', name: 'mistralai',   alt: 'Mistral',       slug: 'mistral' },
      { kind: 'icon', name: 'elevenlabs',  alt: 'ElevenLabs',    slug: 'elevenlabs' },
    ],
  },
  {
    label: 'Crypto',
    blurb: 'Chains, oracles, restaking, smart-contract primitives.',
    accent: '#6366f1',
    logos: [
      { kind: 'icon', name: 'solana',                             alt: 'Solana',     slug: 'solana' },
      { kind: 'img',  src: '/images/partners/aptos-logo.svg',     alt: 'Aptos',      slug: 'aptos' },
      { kind: 'icon', name: 'sui',                                alt: 'Sui',        slug: 'sui' },
      { kind: 'img',  src: '/images/partners/arbitrum-logo.svg',  alt: 'Arbitrum',   slug: 'arbitrum' },
      { kind: 'img',  src: '/images/partners/base-logo.svg',      alt: 'Base',       slug: 'base' },
      { kind: 'icon', name: 'optimism',                           alt: 'Optimism',   slug: 'optimism' },
      { kind: 'img',  src: '/images/partners/aave.svg',           alt: 'Aave',       slug: 'aave' },
      { kind: 'icon', name: 'chainlink',                          alt: 'Chainlink',  slug: 'chainlink' },
      { kind: 'img',  src: '/images/partners/eigenlayer-logo.svg',alt: 'EigenLayer', slug: 'eigenlayer' },
      { kind: 'icon', name: 'coinbase',                           alt: 'Coinbase',   slug: 'coinbase' },
    ],
  },
  {
    label: 'Infra',
    blurb: 'Deploy targets, data, payments, observability.',
    accent: '#10b981',
    logos: [
      { kind: 'icon', name: 'vercel',     alt: 'Vercel',     slug: 'vercel' },
      { kind: 'icon', name: 'mongodb',    alt: 'MongoDB',    slug: 'mongodb' },
      { kind: 'icon', name: 'postgresql', alt: 'PostgreSQL', slug: 'postgresql' },
      { kind: 'icon', name: 'stripe',     alt: 'Stripe',     slug: 'stripe' },
      { kind: 'icon', name: 'github',     alt: 'GitHub',     slug: 'github' },
      { kind: 'icon', name: 'cloudflare', alt: 'Cloudflare', slug: 'cloudflare' },
      { kind: 'icon', name: 'docker',     alt: 'Docker',     slug: 'docker' },
      { kind: 'icon', name: 'supabase',   alt: 'Supabase',   slug: 'supabase' },
      { kind: 'icon', name: 'turso',      alt: 'Turso',      slug: 'turso' },
      { kind: 'icon', name: 'sentry',     alt: 'Sentry',     slug: 'sentry' },
    ],
  },
  {
    label: 'Web',
    blurb: 'Frameworks, runtimes, the actual UX layer.',
    accent: '#f59e0b',
    logos: [
      { kind: 'icon', name: 'nextdotjs',   alt: 'Next.js',     slug: 'nextjs' },
      { kind: 'icon', name: 'astro',       alt: 'Astro',       slug: 'astro' },
      { kind: 'icon', name: 'react',       alt: 'React',       slug: 'react' },
      { kind: 'icon', name: 'tailwindcss', alt: 'Tailwind CSS',slug: 'tailwind' },
      { kind: 'icon', name: 'shadcnui',    alt: 'shadcn/ui',   slug: 'shadcn' },
      { kind: 'icon', name: 'tanstack',    alt: 'TanStack',    slug: 'tanstack' },
      { kind: 'icon', name: 'threedotjs',  alt: 'Three.js',    slug: 'threejs' },
      { kind: 'icon', name: 'bun',         alt: 'Bun',         slug: 'bun' },
      { kind: 'icon', name: 'typescript',  alt: 'TypeScript',  slug: 'typescript' },
      { kind: 'icon', name: 'vite',        alt: 'Vite',        slug: 'vite' },
    ],
  },
];

const integrationFormHref = 'https://form.typeform.com/to/IE4hT9jW';
---

<section class="bol" aria-label="Stacks Blueprint Agent compiles against">
  <div class="bol-inner">
    <div class="bol-head">
      <div class="bol-eyebrow">YOUR STACK, GENERATED FOR PRODUCTION</div>
      <h2 class="bol-title">
        Production-grade scaffolding for
        <span class="bol-grad">every stack you ship against.</span>
      </h2>
      <p class="bol-lede">
        AI, crypto, infra, web. Blueprint Agent generates code against the real SDKs you'll deploy with — not toy templates. Typed clients, secrets handling, tests, deploy targets, all wired up in the same session.
      </p>
    </div>

    <div class="bol-grid">
      {tiles.map((tile) => (
        <div class="bol-tile" style={`--bol-accent: ${tile.accent};`}>
          <div class="bol-tile-head">
            <div class="bol-tile-label">{tile.label}</div>
            <div class="bol-tile-blurb">{tile.blurb}</div>
          </div>
          <div class="bol-tile-grid" role="list">
            {tile.logos.map((logo) => (
              <a
                role="listitem"
                href={partnerHref(logo.slug)}
                target="_blank"
                rel="noopener noreferrer"
                class="bol-cell"
                title={logo.alt}
                aria-label={`${logo.alt} — open the partner workbench`}
              >
                {logo.kind === 'icon'
                  ? <svg viewBox={ICON_VIEWBOX} class="bol-logo bol-logo--icon" set:html={iconBody(logo.name)} aria-hidden="true" />
                  : <img src={logo.src} alt="" class="bol-logo bol-logo--img" loading="lazy" aria-hidden="true" />}
                <span class="bol-cell-name">{logo.alt}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="bol-cta">
      <div class="bol-cta-copy">
        <div class="bol-cta-eyebrow">DON'T SEE YOUR STACK?</div>
        <div class="bol-cta-title">We add integrations on request.</div>
        <p class="bol-cta-body">
          Tell us what your team builds against — we'll wire up a starter, typed clients, and a passing test suite so you can scaffold from day one.
        </p>
      </div>
      <a class="bol-cta-btn" href={integrationFormHref} target="_blank" rel="noopener noreferrer">
        Request an integration
        <svg class="bol-cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7"/>
          <path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bol {
    background: #f4f4f9;
    color: #191c24;
    padding: 5rem 8% 5rem;
  }
  .bol-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .bol-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 56rem;
  }
  .bol-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4f46e5;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .bol-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(1.875rem, 3.6vw, 3rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #191c24;
  }
  .bol-grad {
    background: linear-gradient(135deg, #4f46e5 0%, #6366f1 50%, #818cf8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .bol-lede {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #3a3a50;
    margin: 0;
  }

  /* Bento — 2 columns at desktop, 1 at narrow. */
  .bol-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin: 2rem 0 3rem;
  }
  @media (max-width: 920px) {
    .bol-grid { grid-template-columns: 1fr; }
  }

  .bol-tile {
    position: relative;
    background: #ffffff;
    border: 1px solid #e5e4ee;
    border-radius: 16px;
    padding: 1.75rem 1.75rem 1.5rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .bol-tile::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bol-accent), transparent);
    opacity: 0.85;
  }
  .bol-tile:hover {
    border-color: color-mix(in oklab, var(--bol-accent) 28%, #e5e4ee);
    box-shadow: 0 12px 32px -16px color-mix(in oklab, var(--bol-accent) 35%, transparent);
  }

  .bol-tile-head {
    margin-bottom: 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .bol-tile-label {
    font-family: var(--font-display, system-ui);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #191c24;
  }
  .bol-tile-blurb {
    font-size: 0.8125rem;
    line-height: 1.4;
    color: #5e5e7a;
    text-align: right;
    flex: 1 1 auto;
    min-width: 12rem;
  }
  @media (max-width: 540px) {
    .bol-tile-blurb { text-align: left; }
  }

  /* Logo grid inside each tile. 5 cols × 2 rows = 10 cells. */
  .bol-tile-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.625rem;
  }
  @media (max-width: 540px) {
    .bol-tile-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .bol-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    background: #f4f4f9;
    border: 1px solid transparent;
    text-decoration: none;
    transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    color: #5e5e7a;
    padding: 0.5rem;
  }
  .bol-cell:hover {
    transform: translateY(-2px);
    background: #ffffff;
    border-color: color-mix(in oklab, var(--bol-accent) 32%, #e5e4ee);
    box-shadow: 0 8px 18px -10px color-mix(in oklab, var(--bol-accent) 40%, transparent);
    color: var(--bol-accent);
  }
  .bol-logo {
    height: 30px;
    width: auto;
    max-width: 56px;
    transition: opacity 0.18s ease, color 0.18s ease, filter 0.18s ease;
  }
  .bol-logo--icon {
    color: #5e5e7a;
    width: 30px;
  }
  .bol-cell:hover .bol-logo--icon {
    color: var(--bol-accent);
  }
  .bol-logo--img {
    /* Local brand SVGs vary in fill — force monochrome for grid coherence. */
    filter: grayscale(1) opacity(0.65);
  }
  .bol-cell:hover .bol-logo--img {
    filter: grayscale(0) opacity(1);
  }
  .bol-cell-name {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    line-height: 1;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  /* CTA strip */
  .bol-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
    margin: 0;
    padding: 1.75rem 2rem;
    background: linear-gradient(135deg, #ffffff 0%, #eef0ff 100%);
    border: 1px solid #d7d9e8;
    border-radius: 16px;
    box-shadow: 0 1px 0 rgba(99, 102, 241, 0.05);
  }
  @media (max-width: 720px) {
    .bol-cta { grid-template-columns: 1fr; gap: 1.25rem; padding: 1.5rem 1.5rem; }
  }
  .bol-cta-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4f46e5;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .bol-cta-title {
    font-family: var(--font-display, system-ui);
    font-size: 1.25rem;
    font-weight: 600;
    color: #191c24;
    line-height: 1.25;
    margin-bottom: 0.35rem;
  }
  .bol-cta-body {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #3a3a50;
    margin: 0;
    max-width: 36rem;
  }
  .bol-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.875rem 1.375rem;
    background: #191c24;
    color: #ffffff;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.005em;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    white-space: nowrap;
  }
  .bol-cta-btn:hover {
    background: #4f46e5;
    transform: translateY(-1px);
    box-shadow: 0 12px 24px -12px rgba(79, 70, 229, 0.55);
  }
  .bol-cta-arrow {
    transition: transform 0.18s ease;
  }
  .bol-cta-btn:hover .bol-cta-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 700px) {
    .bol { padding: 4rem 6%; }
    .bol-tile { padding: 1.5rem 1.25rem 1.25rem; }
    .bol-tile-label { font-size: 1.25rem; }
    .bol-logo, .bol-logo--icon { height: 26px; width: 26px; }
    .bol-cell-name { font-size: 0.6rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bol-tile, .bol-cell, .bol-cta-btn, .bol-cta-arrow, .bol-logo {
      transition: none;
    }
  }
</style>

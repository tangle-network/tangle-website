---
/**
 * SVG mockup of the Blueprint Agent IDE — editor + preview + terminal.
 * Used in the Blueprint Agent hero section.
 * All colors on-brand: indigo (#818cf8), pink (#ec4899), green (#4ade80).
 */
---

<svg viewBox="0 0 560 380" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto;">
  <!-- Window frame -->
  <rect x="0" y="0" width="560" height="380" rx="12" fill="#0a0a14" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

  <!-- Title bar -->
  <rect x="0" y="0" width="560" height="36" rx="12" fill="#111120"/>
  <rect x="0" y="24" width="560" height="12" fill="#111120"/>
  <circle cx="16" cy="18" r="5" fill="#ff5f57" opacity="0.8"/>
  <circle cx="32" cy="18" r="5" fill="#febc2e" opacity="0.8"/>
  <circle cx="48" cy="18" r="5" fill="#818cf8" opacity="0.8"/>
  <text x="72" y="22" font-family="Geist Mono, monospace" font-size="10" fill="rgba(255,255,255,0.3)">Blueprint Agent — ai.tangle.tools</text>

  <!-- Sidebar - file tree -->
  <rect x="0" y="36" width="120" height="344" fill="#0d0d1a"/>
  <line x1="120" y1="36" x2="120" y2="380" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

  <!-- File tree items -->
  <text x="12" y="58" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.2)">▼ src</text>
  <text x="20" y="72" font-family="Geist Mono, monospace" font-size="9" fill="#4ade80">  checkout.tsx</text>
  <text x="20" y="86" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.3)">  webhook.ts</text>
  <text x="20" y="100" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.3)">  tracker.tsx</text>
  <text x="12" y="118" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.2)">▼ lib</text>
  <text x="20" y="132" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.3)">  commerce.ts</text>
  <text x="12" y="150" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.2)">  .env.example</text>
  <text x="12" y="164" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.2)">  package.json</text>

  <!-- Editor panel -->
  <rect x="120" y="36" width="260" height="220" fill="#0a0a14"/>
  <line x1="120" y1="256" x2="380" y2="256" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

  <!-- Editor tab -->
  <rect x="120" y="36" width="100" height="24" fill="#141428"/>
  <text x="130" y="52" font-family="Geist Mono, monospace" font-size="9" fill="#4ade80">checkout.tsx</text>

  <!-- Code lines -->
  <text x="134" y="78" font-family="Geist Mono, monospace" font-size="9" fill="#818cf8">import</text>
  <text x="170" y="78" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.6)"> Commerce</text>
  <text x="134" y="92" font-family="Geist Mono, monospace" font-size="9" fill="#818cf8">from</text>
  <text x="158" y="92" font-family="Geist Mono, monospace" font-size="9" fill="#ec4899"> '@coinbase/commerce'</text>
  <text x="134" y="114" font-family="Geist Mono, monospace" font-size="9" fill="#818cf8">export default</text>
  <text x="222" y="114" font-family="Geist Mono, monospace" font-size="9" fill="#60a5fa"> function</text>
  <text x="272" y="114" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.7)"> Checkout()</text>
  <text x="142" y="128" font-family="Geist Mono, monospace" font-size="9" fill="#818cf8">const</text>
  <text x="170" y="128" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.6)"> charge =</text>
  <text x="226" y="128" font-family="Geist Mono, monospace" font-size="9" fill="#60a5fa">Commerce.create</text>
  <text x="142" y="142" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)">  name:</text>
  <text x="178" y="142" font-family="Geist Mono, monospace" font-size="9" fill="#ec4899"> "Premium Plan"</text>
  <text x="142" y="156" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)">  amount:</text>
  <text x="190" y="156" font-family="Geist Mono, monospace" font-size="9" fill="#fbbf24"> 49.00</text>
  <text x="142" y="170" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)">  currency:</text>
  <text x="202" y="170" font-family="Geist Mono, monospace" font-size="9" fill="#ec4899"> "USDC"</text>

  <!-- Cursor blink line -->
  <rect x="134" y="180" width="1" height="12" fill="#818cf8" opacity="0.8">
    <animate attributeName="opacity" values="0.8;0;0.8" dur="1.2s" repeatCount="indefinite"/>
  </rect>

  <!-- Preview panel -->
  <rect x="380" y="36" width="180" height="220" fill="#0f0f1c"/>
  <line x1="380" y1="36" x2="380" y2="256" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

  <!-- Preview tab -->
  <rect x="380" y="36" width="80" height="24" fill="#141428"/>
  <circle cx="392" cy="48" r="4" fill="#4ade80"/>
  <text x="400" y="52" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.3)">:3000</text>

  <!-- Preview content - checkout page mockup -->
  <rect x="400" y="80" width="140" height="20" rx="4" fill="rgba(255,255,255,0.06)"/>
  <text x="420" y="94" font-family="Geist, sans-serif" font-size="9" fill="rgba(255,255,255,0.5)" font-weight="600">Checkout</text>

  <rect x="400" y="110" width="140" height="60" rx="8" fill="rgba(129,140,248,0.08)" stroke="rgba(129,140,248,0.2)" stroke-width="1"/>
  <text x="420" y="130" font-family="Geist, sans-serif" font-size="11" fill="white" font-weight="700">$49 USDC</text>
  <text x="420" y="146" font-family="Geist, sans-serif" font-size="8" fill="rgba(255,255,255,0.4)">Premium Plan</text>
  <rect x="410" y="155" width="60" height="8" rx="4" fill="rgba(129,140,248,0.15)"/>

  <rect x="400" y="184" width="140" height="28" rx="6" fill="#818cf8"/>
  <text x="430" y="202" font-family="Geist, sans-serif" font-size="10" fill="white" font-weight="600">Pay with USDC</text>

  <!-- Terminal panel -->
  <rect x="120" y="256" width="440" height="124" fill="#08080f"/>

  <!-- Terminal content -->
  <text x="134" y="276" font-family="Geist Mono, monospace" font-size="9" fill="#4ade80">$</text>
  <text x="144" y="276" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.5)"> next dev</text>
  <text x="134" y="292" font-family="Geist Mono, monospace" font-size="9" fill="#4ade80">✓</text>
  <text x="144" y="292" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)"> Ready on localhost:3000</text>
  <text x="134" y="308" font-family="Geist Mono, monospace" font-size="9" fill="#4ade80">✓</text>
  <text x="144" y="308" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)"> Coinbase Commerce webhook registered</text>
  <text x="134" y="324" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.2)">  Compiled in 1.2s</text>

  <!-- Glow effect on preview -->
  <rect x="394" y="104" width="152" height="72" rx="10" fill="none" stroke="rgba(129,140,248,0.15)" stroke-width="1">
    <animate attributeName="stroke-opacity" values="0.15;0.3;0.15" dur="3s" repeatCount="indefinite"/>
  </rect>
</svg>

---
/**
 * SVG flow diagram for Tax Agent — Upload → AI → Review → Filed.
 * Full-width visual with arrows connecting each step.
 * Colors: amber (#fbbf24), orange (#f97316), green (#4ade80).
 */
---

<svg viewBox="0 0 900 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto; max-width: 900px; margin: 0 auto; display: block;">
  <!-- Step 1: Upload -->
  <g>
    <rect x="0" y="20" width="180" height="160" rx="16" fill="#141428" stroke="rgba(251,191,36,0.2)" stroke-width="1"/>
    <!-- Document icon -->
    <rect x="70" y="40" width="40" height="50" rx="4" fill="none" stroke="#fbbf24" stroke-width="1.5" opacity="0.6"/>
    <rect x="78" y="50" width="24" height="2" rx="1" fill="#fbbf24" opacity="0.4"/>
    <rect x="78" y="56" width="18" height="2" rx="1" fill="#fbbf24" opacity="0.4"/>
    <rect x="78" y="62" width="20" height="2" rx="1" fill="#fbbf24" opacity="0.4"/>
    <path d="M100 40 L110 50 L100 50 Z" fill="#fbbf24" opacity="0.3"/>
    <!-- Arrow up into doc -->
    <path d="M90 82 L90 74" stroke="#fbbf24" stroke-width="1.5" opacity="0.5"/>
    <path d="M86 78 L90 72 L94 78" stroke="#fbbf24" stroke-width="1.5" fill="none" opacity="0.5"/>

    <text x="90" y="115" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="15" fill="white" font-weight="700">Upload</text>
    <text x="90" y="134" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">W-2s, 1099s, receipts</text>
    <text x="90" y="148" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">Any format, any source</text>
  </g>

  <!-- Arrow 1→2 -->
  <g>
    <line x1="190" y1="100" x2="228" y2="100" stroke="rgba(251,191,36,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <path d="M224 96 L232 100 L224 104" fill="rgba(251,191,36,0.3)"/>
  </g>

  <!-- Step 2: AI Processing -->
  <g>
    <rect x="240" y="20" width="180" height="160" rx="16" fill="#141428" stroke="rgba(249,115,22,0.2)" stroke-width="1"/>
    <!-- Brain/AI icon -->
    <circle cx="330" cy="58" r="18" fill="none" stroke="#f97316" stroke-width="1.5" opacity="0.5"/>
    <path d="M322 52 Q330 42 338 52" stroke="#f97316" stroke-width="1.5" fill="none" opacity="0.5"/>
    <path d="M320 58 Q330 68 340 58" stroke="#f97316" stroke-width="1.5" fill="none" opacity="0.5"/>
    <circle cx="326" cy="56" r="2" fill="#f97316" opacity="0.6"/>
    <circle cx="334" cy="56" r="2" fill="#f97316" opacity="0.6"/>
    <!-- Sparkle dots -->
    <circle cx="312" cy="48" r="1.5" fill="#fbbf24" opacity="0.4"/>
    <circle cx="348" cy="48" r="1.5" fill="#fbbf24" opacity="0.4"/>
    <circle cx="350" cy="64" r="1" fill="#fbbf24" opacity="0.3"/>

    <text x="330" y="115" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="15" fill="white" font-weight="700">AI Processing</text>
    <text x="330" y="134" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">Extract, categorize,</text>
    <text x="330" y="148" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">find deductions</text>
  </g>

  <!-- Arrow 2→3 -->
  <g>
    <line x1="430" y1="100" x2="468" y2="100" stroke="rgba(249,115,22,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <path d="M464 96 L472 100 L464 104" fill="rgba(249,115,22,0.3)"/>
  </g>

  <!-- Step 3: Review -->
  <g>
    <rect x="480" y="20" width="180" height="160" rx="16" fill="#141428" stroke="rgba(129,140,248,0.2)" stroke-width="1"/>
    <!-- Checklist icon -->
    <rect x="550" y="40" width="40" height="44" rx="4" fill="none" stroke="#818cf8" stroke-width="1.5" opacity="0.5"/>
    <path d="M558 52 L564 58 L574 48" stroke="#4ade80" stroke-width="2" fill="none" opacity="0.7"/>
    <rect x="558" y="64" width="20" height="2" rx="1" fill="#818cf8" opacity="0.3"/>
    <rect x="558" y="72" width="16" height="2" rx="1" fill="#818cf8" opacity="0.3"/>

    <text x="570" y="115" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="15" fill="white" font-weight="700">Review</text>
    <text x="570" y="134" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">Verify every line item</text>
    <text x="570" y="148" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(255,255,255,0.5)">Ask questions in English</text>
  </g>

  <!-- Arrow 3→4 -->
  <g>
    <line x1="670" y1="100" x2="708" y2="100" stroke="rgba(129,140,248,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <path d="M704 96 L712 100 L704 104" fill="rgba(129,140,248,0.3)"/>
  </g>

  <!-- Step 4: Filed -->
  <g>
    <rect x="720" y="20" width="180" height="160" rx="16" fill="#141428" stroke="rgba(74,222,128,0.2)" stroke-width="1"/>
    <!-- Check circle -->
    <circle cx="810" cy="58" r="18" fill="rgba(74,222,128,0.1)" stroke="#4ade80" stroke-width="1.5" opacity="0.6"/>
    <path d="M800 58 L807 65 L820 52" stroke="#4ade80" stroke-width="2.5" fill="none" stroke-linecap="round"/>

    <text x="810" y="115" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="15" fill="white" font-weight="700">Filed</text>
    <text x="810" y="134" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(74,222,128,0.6)">E-filed with full</text>
    <text x="810" y="148" text-anchor="middle" font-family="Satoshi, sans-serif" font-size="10" fill="rgba(74,222,128,0.6)">audit documentation</text>
  </g>
</svg>

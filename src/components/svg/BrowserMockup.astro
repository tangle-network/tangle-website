---
/**
 * SVG mockup of a browser window with the AI agent cursor navigating.
 * Shows the agent clicking a "Create Account" button.
 * Purple accent (#8e59ff), green for success (#4ade80).
 */
---

<svg viewBox="0 0 520 340" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto;">
  <!-- Browser frame -->
  <rect x="0" y="0" width="520" height="340" rx="12" fill="#0a0a14" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

  <!-- Title bar -->
  <rect x="0" y="0" width="520" height="36" rx="12" fill="#111120"/>
  <rect x="0" y="24" width="520" height="12" fill="#111120"/>
  <circle cx="16" cy="18" r="5" fill="#ff5f57" opacity="0.8"/>
  <circle cx="32" cy="18" r="5" fill="#febc2e" opacity="0.8"/>
  <circle cx="48" cy="18" r="5" fill="#8e59ff" opacity="0.8"/>

  <!-- URL bar -->
  <rect x="80" y="8" width="360" height="20" rx="6" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
  <circle cx="94" cy="18" r="3" fill="#4ade80" opacity="0.6"/>
  <text x="104" y="22" font-family="Geist Mono, monospace" font-size="9" fill="rgba(255,255,255,0.4)">your-app.com/signup</text>

  <!-- Page content - signup form -->
  <rect x="120" y="60" width="280" height="250" rx="8" fill="rgba(255,255,255,0.02)"/>

  <!-- Logo placeholder -->
  <rect x="220" y="76" width="80" height="12" rx="3" fill="rgba(255,255,255,0.08)"/>

  <!-- "Create Account" heading -->
  <text x="260" y="116" text-anchor="middle" font-family="Geist, sans-serif" font-size="14" fill="rgba(255,255,255,0.8)" font-weight="700">Create Account</text>

  <!-- Email input -->
  <rect x="160" y="132" width="200" height="32" rx="6" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <text x="172" y="152" font-family="Geist, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">Email</text>
  <text x="200" y="152" font-family="Geist Mono, monospace" font-size="10" fill="rgba(255,255,255,0.6)">test@example.com</text>

  <!-- Password input -->
  <rect x="160" y="174" width="200" height="32" rx="6" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <text x="172" y="194" font-family="Geist, sans-serif" font-size="10" fill="rgba(255,255,255,0.3)">Password</text>
  <text x="220" y="194" font-family="Geist Mono, monospace" font-size="10" fill="rgba(255,255,255,0.6)">••••••••</text>

  <!-- Create Account button. agent is clicking this -->
  <rect x="160" y="220" width="200" height="36" rx="8" fill="#8e59ff"/>
  <text x="260" y="242" text-anchor="middle" font-family="Geist, sans-serif" font-size="12" fill="white" font-weight="600">Create Account</text>

  <!-- AI Agent cursor with glow -->
  <g>
    <!-- Glow ring -->
    <circle cx="260" cy="238" r="16" fill="none" stroke="#8e59ff" stroke-width="1.5" opacity="0.3">
      <animate attributeName="r" values="14;20;14" dur="2s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.3;0.1;0.3" dur="2s" repeatCount="indefinite"/>
    </circle>
    <!-- Cursor -->
    <path d="M254 230 L254 248 L260 244 L266 250 L268 248 L262 242 L268 240 Z" fill="white" stroke="#8e59ff" stroke-width="0.5"/>
    <!-- AI badge -->
    <rect x="268" y="244" width="24" height="14" rx="4" fill="#8e59ff"/>
    <text x="280" y="254" text-anchor="middle" font-family="Geist Mono, monospace" font-size="7" fill="white" font-weight="700">AI</text>
  </g>

  <!-- Agent observation overlay -->
  <rect x="160" y="268" width="200" height="24" rx="4" fill="rgba(142,89,255,0.1)" stroke="rgba(142,89,255,0.2)" stroke-width="1"/>
  <text x="170" y="284" font-family="Geist Mono, monospace" font-size="8" fill="rgba(142,89,255,0.7)">turn 4: click → "Create Account"</text>

  <!-- Success indicator in corner -->
  <g>
    <rect x="16" y="52" width="80" height="20" rx="4" fill="rgba(74,222,128,0.1)" stroke="rgba(74,222,128,0.2)" stroke-width="1"/>
    <circle cx="28" cy="62" r="3" fill="#4ade80"/>
    <text x="36" y="66" font-family="Geist Mono, monospace" font-size="8" fill="#4ade80">Agent active</text>
  </g>
</svg>

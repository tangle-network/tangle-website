---
interface Props {
  label?: string;
  heading?: string;
  faqs: { question: string; answer: string }[];
  firstOpen?: boolean;
}

const { label = 'Learn more', heading = 'Frequently Asked Questions', faqs, firstOpen = false } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<div class="faq-outer">
  <div class="faq-header">
    <div class="faq-heading-wrapper">
      <div class="faq-detail-label">{label}</div>
      <h2 class="faq-h2">{heading}</h2>
    </div>
  </div>
  <div class="faq-component">
    <div class="faq-list" data-faq-group={uid}>
      {faqs.map((faq, i) => (
        <div class="faq-accordion" data-open={firstOpen && i === 0 ? "true" : "false"}>
          <div class="faq-question" role="button" tabindex="0">
            <div class="faq-question-text">{faq.question}</div>
            <div class="faq-icon-wrapper">
              <div class="faq-accordion-icon">
                <div class="faq-accordion-h-line"></div>
                <div class="faq-accordion-v-line"></div>
              </div>
            </div>
          </div>
          <div class="faq-answer">
            <div class="faq-answer-text" set:html={faq.answer} />
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .faq-outer {
    padding: 64px 0 112px;
  }

  .faq-header {
    text-align: center;
  }

  .faq-heading-wrapper {
    max-width: 768px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .faq-detail-label {
    color: #9696B8;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.12px;
    margin-bottom: 8px;
  }

  .faq-h2 {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 57.6px;
    letter-spacing: -0.96px;
    text-align: center;
    margin: 0;
  }

  .faq-component {
    margin-top: 64px;
  }

  .faq-list {
    max-width: 768px;
    margin: 0 auto;
  }

  .faq-accordion {
    border-bottom: 1px solid rgb(234, 236, 240);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
  }

  .faq-question-text {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 30px;
  }

  .faq-icon-wrapper {
    flex-shrink: 0;
    margin-left: 16px;
  }

  .faq-accordion-icon {
    width: 24px;
    height: 24px;
    border: 2px solid rgb(152, 162, 179);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    flex-shrink: 0;
  }

  .faq-accordion-h-line {
    width: 10px;
    height: 2px;
    background-color: rgb(152, 162, 179);
    position: absolute;
  }

  .faq-accordion-v-line {
    width: 2px;
    height: 10px;
    background-color: rgb(152, 162, 179);
    position: absolute;
    transition: transform 0.3s;
  }

  .faq-accordion[data-open="true"] .faq-accordion-v-line {
    transform: rotate(90deg);
  }

  .faq-answer {
    overflow: hidden;
    height: 0;
    transition: height 0.3s ease;
  }

  .faq-accordion[data-open="true"] .faq-answer {
    height: auto;
  }

  .faq-answer-text {
    font-family: var(--font-display);
    font-size: 18.4px;
    font-weight: 600;
    color: var(--text-secondary);
    line-height: 27.6px;
    padding: 0 0 10px;
  }

  .faq-answer-text :global(a) {
    color: rgb(97, 114, 243);
    text-decoration: underline;
  }

  @media screen and (max-width: 991px) {
    .faq-h2 {
      font-size: 2.25rem;
      line-height: 120%;
    }
  }

  @media screen and (max-width: 479px) {
    .faq-question-text {
      font-size: 1rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const accordion = btn.closest('.faq-accordion');
      if (!accordion) return;
      const list = accordion.closest('.faq-list');
      if (!list) return;
      const isOpen = accordion.getAttribute('data-open') === 'true';
      list.querySelectorAll('.faq-accordion').forEach(a => a.setAttribute('data-open', 'false'));
      if (!isOpen) accordion.setAttribute('data-open', 'true');
    });
  });
</script>

---
const services = [
  { label: 'Browser Agent', description: 'Automated UI testing & workflows', href: '/services/browser-agent' },
  { label: 'Tax Agent', description: 'AI-powered tax preparation', href: '/services/tax-agent' },
  { label: 'Sandbox SDK', description: 'Secure cloud environments & CLI', href: '/services/sandbox' },
  { label: 'Blueprint Agent', description: 'AI vibecoding platform', href: '/services/blueprint-agent' },
];

const blockchain = [
  { label: 'Developers', description: 'Build Blueprints on Tangle', href: '/builders-program' },
  { label: 'Operators', description: 'Run nodes, earn TNT', href: '/operators' },
  { label: 'Stake', description: 'Deposit & delegate assets', href: '/stake' },
  { label: 'Ecosystem', description: 'Partners & integrations', href: '/ecosystem' },
];
---

<nav class="wf-nav">
  <div class="wf-nav-inner">
    <a href="/" aria-current="page" class="wf-nav-brand">
      <img src="/images/webflow/Tnt Logo.png" alt="Tangle Network" loading="lazy" class="wf-nav-brand-logo" />
    </a>
    <div class="wf-nav-menu">
      <div class="wf-nav-menu-wrapper">
        <!-- Services Dropdown -->
        <div class="wf-nav-dropdown">
          <button class="wf-nav-menu-link" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 4px; padding: 0;">
            Services
            <svg style="width: 12px; height: 12px; opacity: 0.6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="wf-nav-dropdown-menu">
            {services.map(({ label, description, href }) => (
              <a href={href} class="wf-nav-dropdown-item">
                <div>
                  <div class="wf-nav-dropdown-label">{label}</div>
                  <div class="wf-nav-dropdown-desc">{description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Blockchain Dropdown -->
        <div class="wf-nav-dropdown">
          <button class="wf-nav-menu-link" style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 4px; padding: 0;">
            Blockchain
            <svg style="width: 12px; height: 12px; opacity: 0.6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="wf-nav-dropdown-menu">
            {blockchain.map(({ label, description, href }) => (
              <a href={href} class="wf-nav-dropdown-item">
                <div>
                  <div class="wf-nav-dropdown-label">{label}</div>
                  <div class="wf-nav-dropdown-desc">{description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <a href="/blog" class="wf-nav-menu-link">Blog</a>
      </div>
      <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-nav-cta">
        <span class="wf-nav-cta-text">Launch Agent</span>
        <img loading="lazy" src="/images/webflow/arrow-black.svg" alt="" class="wf-nav-cta-icon" />
      </a>
    </div>
    <div class="wf-mobile-icon-wrapper" id="mobile-menu-toggle">
      <img loading="lazy" src="/images/webflow/icons8-menu.svg" alt="Menu" class="wf-mobile-icon" />
    </div>
    <div class="wf-mobile-menu" id="mobile-menu">
      <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 0 4px;">Services</div>
      {services.map(({ label, href }) => (
        <a href={href} class="wf-mobile-menu-link" style="font-size: 1rem; padding: 10px 0;">{label}</a>
      ))}
      <div class="wf-mobile-menu-divider" style="margin: 8px 0;"></div>
      <div style="color: var(--color-text-muted); font-family: 'Satoshi', sans-serif; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 0 4px;">Blockchain</div>
      {blockchain.map(({ label, href }) => (
        <a href={href} class="wf-mobile-menu-link" style="font-size: 1rem; padding: 10px 0;">{label}</a>
      ))}
      <div class="wf-mobile-menu-divider" style="margin: 8px 0;"></div>
      <a href="/blog" class="wf-mobile-menu-link">Blog</a>
      <div class="wf-mobile-menu-divider"></div>
      <a href="https://ai.tangle.tools" target="_blank" class="wf-mobile-menu-link">Launch Agent</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('wf-mobile-menu-open');
  });
</script>

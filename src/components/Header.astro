---
const agents = [
  { label: 'Blueprint Agent', description: 'AI development platform', href: '/services/blueprint-agent' },
  { label: 'Browser Agent', description: 'AI-powered UI testing & workflows', href: '/services/browser-agent' },
];

// Protocol — crypto-protocol surface (operators, staking, developers,
// ecosystem, blog all roll up here per Drew's call: "the whole build
// section should be under Protocol — it's all crypto-protocol related").
const protocol = [
  { label: 'Overview', description: 'Tangle Protocol — the substrate', href: '/overview' },
  { label: 'Operators', description: 'Run nodes, earn fees', href: '/operators' },
  { label: 'Stake', description: 'Deposit & delegate', href: '/stake' },
  { label: 'Developers', description: 'Build Blueprints — Rust SDK + AI scaffolding', href: '/developers' },
  { label: 'Ecosystem', description: 'Partners & integrations', href: '/ecosystem' },
  { label: 'Blog', description: 'Technical deep dives', href: '/blog' },
];
---

<nav class="wf-nav">
  <div class="wf-nav-inner">
    <a href="/" aria-current="page" class="wf-nav-brand">
      <img src="/images/webflow/Tnt Logo.png" alt="" loading="lazy" class="wf-nav-brand-logo" />
      <span class="wf-nav-brand-type">Tangle</span>
    </a>
    <div class="wf-nav-menu">
      <div class="wf-nav-menu-wrapper">
        <!-- Agents Dropdown -->
        <div class="wf-nav-dropdown">
          <button class="wf-nav-menu-link wf-nav-menu-link--dropdown" type="button">
            Agents
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="wf-nav-dropdown-menu">
            {agents.map(({ label, description, href }) => (
              <a href={href} class="wf-nav-dropdown-item">
                <div>
                  <div class="wf-nav-dropdown-label">{label}</div>
                  <div class="wf-nav-dropdown-desc">{description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Sandbox — first-class nav item -->
        <a href="/services/sandbox" class="wf-nav-menu-link">Sandbox</a>

        <!-- Protocol dropdown — substrate, operators, staking, dev surfaces -->
        <div class="wf-nav-dropdown">
          <button class="wf-nav-menu-link wf-nav-menu-link--dropdown" type="button">
            Protocol
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="wf-nav-dropdown-menu">
            {protocol.map(({ label, description, href }) => (
              <a href={href} class="wf-nav-dropdown-item">
                <div>
                  <div class="wf-nav-dropdown-label">{label}</div>
                  <div class="wf-nav-dropdown-desc">{description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
      <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="wf-nav-cta">
        <span class="wf-nav-cta-text">Launch Agent</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="wf-mobile-icon-wrapper" id="mobile-menu-toggle">
      <img loading="lazy" src="/images/webflow/icons8-menu.svg" alt="Menu" class="wf-mobile-icon" />
    </div>
    <div class="wf-mobile-menu" id="mobile-menu">
      <div style="color: var(--color-text-muted); font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 0 4px;">Agents</div>
      {agents.map(({ label, href }) => (
        <a href={href} class="wf-mobile-menu-link" style="font-size: 1rem; padding: 10px 0;">{label}</a>
      ))}
      <div class="wf-mobile-menu-divider" style="margin: 4px 0;"></div>
      <a href="/services/sandbox" class="wf-mobile-menu-link" style="font-size: 1rem; padding: 10px 0; font-weight: 700;">Sandbox</a>
      <div class="wf-mobile-menu-divider" style="margin: 8px 0;"></div>
      <div style="color: var(--color-text-muted); font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 0 4px;">Protocol</div>
      {protocol.map(({ label, href }) => (
        <a href={href} class="wf-mobile-menu-link" style="font-size: 1rem; padding: 10px 0;">{label}</a>
      ))}
      <div class="wf-mobile-menu-divider"></div>
      <a href="https://ai.tangle.tools" target="_blank" class="wf-mobile-menu-link">Launch Agent</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('wf-mobile-menu-open');
  });
</script>

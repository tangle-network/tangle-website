---
const footerLinks = [
  { label: 'Blog', href: '/blog', external: false },
  { label: 'Research', href: '/research', external: false },
  { label: 'Docs', href: 'https://docs.tangle.tools/', external: true },
  { label: 'Launch Agent', href: 'https://ai.tangle.tools', external: true },
  { label: 'Follow', href: 'https://twitter.com/intent/follow?screen_name=tangle_network', external: true },
];
---

<footer class="wf-footer">
  <div class="wf-footer-inner">
    <div class="wf-footer-grid">
      <div class="wf-footer-brand-inner">
        <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: white;">
          <img src="/images/webflow/tangle icon.png" loading="lazy" alt="" style="width: 32px; height: 32px;" />
          <span style="font-family: var(--font-sans); font-size: 1.35rem; font-weight: 700; color: white;">Tangle</span>
        </a>
        <div class="wf-footer-tagline">
          Notes and research on infrastructure for self-improving agents.
        </div>
      </div>
      <div class="wf-footer-links-col">
        {footerLinks.map(({ label, href, external }) => (
          <div class="wf-footer-link-row">
            <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined} class="wf-footer-link">
              <span>{label}</span>
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5.83301 14.1668L14.1663 5.8335M14.1663 5.8335H5.83301M14.1663 5.8335V14.1668" stroke="currentColor" stroke-width="1.67" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
    <div class="wf-footer-bottom">
      <div class="wf-footer-legal-row">
        <div class="wf-footer-copyright">&copy; 2026 Tangle. All rights reserved.</div>
      </div>
    </div>
  </div>
</footer>

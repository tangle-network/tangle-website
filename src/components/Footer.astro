---
// Dispersion-hairline sitemap footer. The hairline is the one place on the
// page where all three product hues sit on one continuous line.
const products = [
  { label: 'Sandbox', href: 'https://sandbox.tangle.tools', domain: 'sandbox.tangle.tools', hue: '#818CF8' },
  { label: 'Intelligence', href: 'https://intelligence.tangle.tools', domain: 'intelligence.tangle.tools', hue: '#818CF8' },
  { label: 'Inference', href: 'https://router.tangle.tools', domain: 'router.tangle.tools', hue: '#818CF8' },
];
const resources = [
  { label: 'Docs', href: 'https://docs.tangle.tools', domain: 'docs.tangle.tools' },
  { label: 'Console', href: 'https://ai.tangle.tools', domain: 'ai.tangle.tools' },
  { label: 'GitHub', href: 'https://github.com/tangle-network', domain: 'github.com/tangle-network' },
];
const company = [
  { label: 'Blog', href: '/blog' },
  { label: 'Brand kit', href: '/brand-kit' },
];
---

<footer class="ft">
  <div class="ft-hairline" aria-hidden="true"></div>
  <div class="ft-inner">
    <div class="ft-grid">
      <div class="ft-brand">
        <a href="/" class="ft-lockup">
          <img src="/images/webflow/tangle icon.png" alt="" width="32" height="32" />
          <span>Tangle</span>
        </a>
        <p class="ft-tagline">
          Tangle builds infrastructure for self-improving AI systems. Run agents in isolated
          sandboxes, route them to any model with one key, and let analyst agents turn every
          trace into the next proven improvement.
        </p>
        <a class="ft-console" href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer">Open the console</a>
      </div>

      <nav class="ft-col" aria-label="Products">
        <span class="ft-label mono">Products</span>
        {products.map((p) => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="ft-link">
            {p.label}
            <span class="ft-domain mono" style={`color: ${p.hue}`}>{p.domain}</span>
          </a>
        ))}
      </nav>

      <nav class="ft-col" aria-label="Resources">
        <span class="ft-label mono">Resources</span>
        {resources.map((r) => (
          <a href={r.href} target="_blank" rel="noopener noreferrer" class="ft-link">
            {r.label}
            <span class="ft-domain mono">{r.domain}</span>
          </a>
        ))}
      </nav>

      <nav class="ft-col" aria-label="Company">
        <span class="ft-label mono">Company</span>
        {company.map((c) => (
          <a href={c.href} class="ft-link">{c.label}</a>
        ))}
      </nav>
    </div>

    <div class="ft-legal">
      <span>© 2026 Tangle</span>
      <div class="ft-social">
        <a href="https://twitter.com/tangle_network" target="_blank" rel="noopener noreferrer" aria-label="Tangle on X">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/tangle-network" target="_blank" rel="noopener noreferrer" aria-label="Tangle on GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12v3.15c0 .3.21.66.8.55A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .mono {
    font-family: var(--font-mono);
  }

  .ft {
    background: #080814;
  }

  .ft-hairline {
    height: 2px;
    background: linear-gradient(90deg, #A5AAFC 0%, #6366F1 50%, #4F46E5 100%);
  }

  .ft-inner {
    max-width: 75rem;
    margin: 0 auto;
    padding: 6rem 2rem 2.5rem;
  }

  .ft-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 2.4fr) minmax(0, 2.4fr) minmax(0, 1.8fr);
    gap: 2rem 2.5rem;
  }

  .ft-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .ft-lockup img {
    width: 32px;
    height: 32px;
  }

  .ft-lockup span {
    color: #f5f5fb;
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ft-tagline {
    max-width: 26rem;
    margin: 1.2rem 0 0;
    color: #cfcfe0;
    font-size: 1.3rem;
    line-height: 1.6;
  }

  .ft-console {
    display: inline-block;
    margin-top: 1.5rem;
    color: #f5f5fb;
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 1px solid transparent;
    border-image: linear-gradient(90deg, #A5AAFC, #6366F1, #4F46E5) 1;
    border-bottom-width: 1px;
    border-bottom-style: solid;
  }

  .ft-console:hover { color: #ffffff; }

  .ft-col {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .ft-label {
    color: #9494b2;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ft-link {
    color: #f0f0f7;
    font-size: 1.22rem;
    font-weight: 450;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .ft-link:hover { color: #ffffff; }

  .ft-domain {
    display: block;
    margin-top: 0.25rem;
    color: #9a9ab8;
    font-size: 0.98rem;
  }

  .ft-legal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: #9a9ab8;
    font-size: 1.02rem;
  }

  .ft-social {
    display: flex;
    gap: 1.25rem;
  }

  .ft-social a {
    color: #9a9ab8;
    transition: color 0.15s ease;
  }

  .ft-social a:hover { color: #f5f5fb; }

  @media (max-width: 900px) {
    .ft-grid { grid-template-columns: 1fr 1fr; }
    .ft-brand { grid-column: 1 / -1; }
    .ft-inner { padding: 4rem 1.25rem 2rem; }
  }

  @media (max-width: 560px) {
    .ft-grid { grid-template-columns: 1fr; }
  }
</style>

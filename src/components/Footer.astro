---
const footerLinks = [
  { label: 'Docs', href: 'https://docs.tangle.tools/', external: true },
  { label: 'Blog', href: '/blog', external: false },
  { label: 'Launch Agent', href: 'https://ai.tangle.tools', external: true },
  { label: 'Follow', href: 'https://twitter.com/intent/follow?screen_name=tangle_network', external: true },
];

const legalLinks = [
  { label: 'Terms', href: '/terms-of-service' },
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'Brand Kit', href: '/brand-kit' },
];
---

<footer class="wf-footer">
  <div class="wf-footer-inner">
    <div class="wf-footer-grid">
      <a href="#" class="wf-footer-brand">
        <div class="wf-footer-brand-inner">
          <img
            src="/images/webflow/Tangle Logo_topnav_dark.svg"
            loading="lazy"
            alt="Tangle Network"
            class="wf-footer-logo"
          />
          <div class="wf-footer-tagline">
            Build and deploy decentralized AI services powered secured by staking and sandboxed execution.
          </div>
        </div>
      </a>
      <div class="wf-footer-links-col">
        {footerLinks.map(({ label, href, external }) => (
          <div class="wf-footer-link-row">
            <a
              href={href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              class="wf-footer-link"
            >
              <span>{label}</span>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5.83301 14.1668L14.1663 5.8335M14.1663 5.8335H5.83301M14.1663 5.8335V14.1668" stroke="currentColor" stroke-width="1.67" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
    <div class="wf-footer-bottom">
      <div class="wf-footer-legal-row">
        <div class="wf-footer-copyright">&copy; 2025 Tangle Foundation. All rights reserved.</div>
        <div class="wf-footer-legal-links">
          {legalLinks.map(({ label, href }) => (
            <a href={href} class="wf-footer-legal-link">{label}</a>
          ))}
        </div>
      </div>
      <div class="wf-footer-social-icons">
        <a href="https://github.com/webb-tools/tangle" target="_blank" rel="noopener noreferrer" class="wf-footer-social-link" aria-label="GitHub">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0.2975C5.37 0.2975 0 5.6675 0 12.2975C0 17.6775 3.438 22.3175 8.205 23.9975C8.805 24.0775 9.025 23.7575 9.025 23.4775C9.025 23.2275 9.015 22.4775 9.01 21.4775C5.672 22.0775 4.968 19.9775 4.968 19.9775C4.422 18.7775 3.633 18.3775 3.633 18.3775C2.546 17.6775 3.717 17.6875 3.717 17.6875C4.922 17.7775 5.555 18.9275 5.555 18.9275C6.625 20.7775 8.364 20.2975 9.055 19.9275C9.142 19.0775 9.462 18.4775 9.842 18.0775C7.163 17.7775 4.342 16.6775 4.342 11.8775C4.342 10.4775 4.842 9.2975 5.625 8.3775C5.525 8.0775 5.092 6.8275 5.725 5.0775C5.725 5.0775 6.725 4.7775 9.025 6.2975C10.025 6.0275 11.025 5.8975 12.025 5.8975C13.025 5.8975 14.025 6.0275 15.025 6.2975C17.325 4.7775 18.325 5.0775 18.325 5.0775C18.958 6.8275 18.525 8.0775 18.425 8.3775C19.208 9.2975 19.708 10.4775 19.708 11.8775C19.708 16.6875 16.887 17.7675 14.208 18.0575C14.648 18.5075 15.008 19.2975 15.008 20.3975C15.008 22.0975 15 23.1575 15 23.4775C15 23.7575 15.218 24.0675 15.828 23.9875C20.595 22.3075 24.033 17.6675 24.033 12.2975C24.033 5.6675 18.663 0.2975 12 0.2975Z" fill="currentColor"/>
          </svg>
        </a>
        <a href="https://twitter.com/tangle_network" target="_blank" rel="noopener noreferrer" class="wf-footer-social-link" aria-label="X/Twitter">

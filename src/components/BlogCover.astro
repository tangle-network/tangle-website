---
interface Props {
  title: string;
  summary?: string;
  series?: string;
  seriesOrder?: number;
  tags?: string[];
  coverImage?: string;
  imageAlt?: string;
  variant?: 'card' | 'hero';
}

const {
  title,
  summary = '',
  series,
  seriesOrder,
  tags = [],
  coverImage,
  imageAlt,
  variant = 'card',
} = Astro.props;

const normalized = `${series ?? ''} ${tags.join(' ')} ${title}`.toLowerCase();

const family = normalized.includes('x402') || normalized.includes('payment') || normalized.includes('pricing')
  ? 'payments'
  : normalized.includes('self-improving') || normalized.includes('optimizer') || normalized.includes('agent')
    ? 'agents'
    : normalized.includes('tee') || normalized.includes('security') || normalized.includes('trusted')
      ? 'security'
      : normalized.includes('training') || normalized.includes('rsa') || normalized.includes('aggregation')
        ? 'compute'
        : 'protocol';

const themes = {
  agents: {
    accent: '#4F46E5',
    accentTwo: '#047857',
    bg: '#F6F7FF',
    label: 'Agent Systems',
  },
  payments: {
    accent: '#7C3AED',
    accentTwo: '#0F766E',
    bg: '#F8F5FF',
    label: 'Payment Rails',
  },
  security: {
    accent: '#2563EB',
    accentTwo: '#7C2D12',
    bg: '#F4F8FF',
    label: 'Trust Layer',
  },
  compute: {
    accent: '#0F766E',
    accentTwo: '#4338CA',
    bg: '#F2FBF8',
    label: 'Compute',
  },
  protocol: {
    accent: '#4338CA',
    accentTwo: '#0369A1',
    bg: '#F6F6FB',
    label: 'Protocol',
  },
};

const theme = themes[family];
const kicker = seriesOrder !== undefined
  ? `Part ${seriesOrder}`
  : series
    ? series.replace(/-/g, ' ')
    : theme.label;

const visibleSummary = summary.length > 116 ? `${summary.slice(0, 113)}...` : summary;
---

<figure
  class:list={['blog-cover', `blog-cover--${variant}`, coverImage ? 'blog-cover--image' : 'blog-cover--generated']}
  style={`--cover-accent: ${theme.accent}; --cover-accent-two: ${theme.accentTwo}; --cover-bg: ${theme.bg};`}
>
  {coverImage ? (
    <img
      src={coverImage}
      alt={imageAlt || title}
      loading={variant === 'hero' ? 'eager' : 'lazy'}
      decoding="async"
    />
  ) : (
    <div class="blog-cover-art" aria-hidden="true">
      <div class="blog-cover-grid">
        {Array.from({ length: 24 }).map((_, index) => <span style={`--i: ${index};`}></span>)}
      </div>
      <div class="blog-cover-trace">
        <span class="trace-node trace-node--one"></span>
        <span class="trace-node trace-node--two"></span>
        <span class="trace-node trace-node--three"></span>
        <span class="trace-node trace-node--four"></span>
        <span class="trace-line trace-line--one"></span>
        <span class="trace-line trace-line--two"></span>
        <span class="trace-line trace-line--three"></span>
      </div>
      <div class="blog-cover-copy">
        <span>{kicker}</span>
        <strong>{title}</strong>
        {variant === 'hero' && visibleSummary && <p>{visibleSummary}</p>}
      </div>
    </div>
  )}
</figure>

<style>
  .blog-cover {
    position: relative;
    width: 100%;
    max-width: 100%;
    margin: 0;
    overflow: hidden;
    box-sizing: border-box;
    background: var(--cover-bg);
    border: 1px solid rgba(25, 28, 36, 0.1);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
  }

  .blog-cover--card {
    aspect-ratio: 16 / 9;
    border-radius: 8px 8px 0 0;
  }

  .blog-cover--hero {
    aspect-ratio: 1.16 / 1;
    border-radius: 8px;
  }

  .blog-cover--hero.blog-cover--image {
    aspect-ratio: 16 / 9;
    padding: clamp(0.75rem, 1.8vw, 1.25rem);
    background: #ffffff;
  }

  .blog-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-cover--hero.blog-cover--image img {
    object-fit: contain;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.72);
  }

  .blog-cover-art {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: clamp(1rem, 4vw, 1.6rem);
    color: #111827;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.68)),
      linear-gradient(135deg, var(--cover-bg), rgba(255, 255, 255, 0.4));
  }

  .blog-cover-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(4, 1fr);
    opacity: 0.62;
  }

  .blog-cover-grid span {
    border-right: 1px solid rgba(25, 28, 36, 0.05);
    border-bottom: 1px solid rgba(25, 28, 36, 0.05);
    background: color-mix(in srgb, var(--cover-accent) 6%, transparent);
    opacity: calc(0.08 + (var(--i) % 5) * 0.035);
  }

  .blog-cover-trace {
    position: absolute;
    inset: 14% 10% 18% 36%;
  }

  .trace-node,
  .trace-line {
    position: absolute;
    display: block;
  }

  .trace-node {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #fff;
    border: 3px solid var(--cover-accent);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--cover-accent) 12%, transparent);
  }

  .trace-node--one {
    left: 4%;
    top: 26%;
  }

  .trace-node--two {
    left: 42%;
    top: 8%;
    border-color: var(--cover-accent-two);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--cover-accent-two) 12%, transparent);
  }

  .trace-node--three {
    right: 8%;
    top: 40%;
  }

  .trace-node--four {
    left: 48%;
    bottom: 6%;
    border-color: var(--cover-accent-two);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--cover-accent-two) 12%, transparent);
  }

  .trace-line {
    height: 2px;
    transform-origin: left center;
    background: linear-gradient(90deg, var(--cover-accent), color-mix(in srgb, var(--cover-accent-two) 70%, transparent));
    opacity: 0.42;
  }

  .trace-line--one {
    left: 9%;
    top: 31%;
    width: 38%;
    transform: rotate(-21deg);
  }

  .trace-line--two {
    left: 46%;
    top: 18%;
    width: 42%;
    transform: rotate(24deg);
  }

  .trace-line--three {
    left: 53%;
    top: 51%;
    width: 30%;
    transform: rotate(104deg);
  }

  .blog-cover-copy {
    position: relative;
    max-width: 86%;
    z-index: 1;
  }

  .blog-cover-copy span {
    display: block;
    margin-bottom: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--cover-accent);
  }

  .blog-cover-copy strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.3vw, 1.55rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: 0;
    color: #111827;
  }

  .blog-cover-copy p {
    margin: 0.9rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    line-height: 1.5;
    color: #3a3a50;
  }

  .blog-cover--hero .blog-cover-copy strong {
    font-size: clamp(1.25rem, 3vw, 2rem);
  }

  @media (max-width: 860px) {
    .blog-cover--hero {
      aspect-ratio: 16 / 9;
      width: 100%;
      max-width: 100%;
    }

    .blog-cover-trace {
      inset: 12% 8% 18% 32%;
    }
  }
</style>

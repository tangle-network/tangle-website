// Compose the auto-fill workbench URL: clicking a starter opens the
// Blueprint Agent landing with the prompt pre-filled. Bp-agent app
// side reads ?starter + ?prompt + ?autofill, routes through login
// (preserving the params via returnTo), and auto-submits on return.
function workbenchHref(s: Starter): string {
  const q = new URLSearchParams({
    starter: s.id,
    prompt: s.prompt,
    autofill: '1',
  });
  return `https://ai.tangle.tools/?${q.toString()}`;
}

const totalFiles = starters.reduce((s, c) => s + c.files, 0);
const totalTests = starters.reduce((s, c) => s + c.tests, 0);
---

<section class="sg" aria-label="Starters Blueprint Agent ships with">
  <div class="sg-inner">
    <div class="sg-head">
      <div class="sg-eyebrow">REAL STARTERS · NOT BOILERPLATE</div>
      <h2 class="sg-title">
        Pick a starter.
        <span class="sg-grad">Ship today.</span>
      </h2>
      <p class="sg-lede">
        Every starter is a working repo on day one. Real SDKs, typed clients, secrets handling, deploy targets, passing tests — wired up the moment Blueprint Agent finishes scaffolding. Pick yours, refine in the workbench, open a PR.
      </p>
      <div class="sg-strip">
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{starters.length}</span>
          <span class="sg-strip-label">starters live</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalFiles}</span>
          <span class="sg-strip-label">files generated</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalTests}</span>
          <span class="sg-strip-label">tests passing</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">∞</span>
          <span class="sg-strip-label">custom on request</span>
        </div>
      </div>
    </div>

    <div class="sg-grid">
      {starters.map((starter) => (
        <a
          class="sg-card"
          href={workbenchHref(starter)}
          target="_blank"
          rel="noopener noreferrer"
          style={`--sg-accent: ${starter.categoryAccent};`}
        >
          <div class="sg-card-head">
            <span class="sg-card-cat">
              <span class="sg-card-dot" aria-hidden="true"></span>
              {starter.category}
            </span>
            <span class="sg-card-arrow" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </span>
          </div>
          <h3 class="sg-card-name">{starter.name}</h3>
          <p class="sg-card-blurb">{starter.blurb}</p>

          {/* Prompt preview — the actual auto-fill text the workbench
              receives on click. Reading is the proof: the card shows
              what's about to happen. */}
          <div class="sg-card-prompt" role="presentation">
            <div class="sg-card-prompt-bar">
              <span class="sg-card-prompt-dot sg-card-prompt-dot--r"></span>
              <span class="sg-card-prompt-dot sg-card-prompt-dot--y"></span>
              <span class="sg-card-prompt-dot sg-card-prompt-dot--g"></span>
              <span class="sg-card-prompt-label">PROMPT · auto-fills on click</span>
            </div>
            <pre class="sg-card-prompt-body"><code>{starter.prompt}</code></pre>
          </div>

          <div class="sg-card-stack" aria-label={`Stack: ${starter.stack.map((s) => s.alt).join(', ')}`}>
            {starter.stack.map((chip) => (
              <span class="sg-chip" title={chip.alt}>
                {chip.kind === 'icon'
                  ? <svg viewBox={ICON_VIEWBOX} class="sg-chip-icon" set:html={iconBody(chip.name)} aria-hidden="true" />
                  : <img src={chip.src} alt="" class="sg-chip-img" loading="lazy" aria-hidden="true" />}
              </span>
            ))}
            <span class="sg-card-counters">
              <span class="sg-card-counter"><strong>{starter.files}</strong> files</span>
              <span class="sg-card-counter sg-card-counter--ok">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 12 4 4L18 8"/></svg>
                {starter.tests} tests
              </span>
            </span>
          </div>
          <div class="sg-card-cta">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="13 17 18 12 13 7"/>
              <polyline points="6 17 11 12 6 7"/>
            </svg>
            <span>Auto-fill in workbench</span>
            <svg class="sg-card-cta-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sg {
    background: #0c0b1d;
    color: #f4f4f9;
    padding: 5rem 8% 4.5rem;
    position: relative;
    overflow: hidden;
  }
  .sg::before {
    /* Faint indigo radial so the section has a horizon. */
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.10), transparent 70%),
      radial-gradient(ellipse 40% 30% at 100% 100%, rgba(168, 85, 247, 0.08), transparent 70%);
    pointer-events: none;
  }
  .sg-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sg-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 56rem;
  }
  .sg-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a5aafc;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .sg-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .sg-grad {
    background: linear-gradient(135deg, #818cf8 0%, #a5aafc 50%, #c7d2fe 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sg-lede {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.7);
    margin: 0 0 1.75rem;
  }

  .sg-strip {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.875rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.025);
    border-radius: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sg-strip-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .sg-strip-num {
    font-family: var(--font-display, system-ui);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }
  .sg-strip-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: rgba(244, 244, 249, 0.55);
    text-transform: uppercase;
  }
  .sg-strip-divider {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Card grid — 2 cols desktop, 1 mobile. Bigger cards = more density
     per card (prompt preview + chips + counters all need real estate). */
  .sg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.125rem;
  }
  @media (max-width: 820px) {
    .sg-grid { grid-template-columns: 1fr; }
  }

  .sg-card {
    --sg-accent: #818cf8;
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 1.25rem;
    /* Brighter card surface than the section background — Drew called
       v1 "too dark". Card sits at depth-2 with stronger borders. */
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.035) 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }
  .sg-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.25rem;
    right: 1.25rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--sg-accent), transparent);
    opacity: 1;
  }
  .sg-card::after {
    /* Subtle radial in the bottom-right corner using the per-card
       accent — reinforces category at peripheral glance. */
    content: '';
    position: absolute;
    bottom: -40%;
    right: -30%;
    width: 70%;
    height: 70%;
    background: radial-gradient(circle, var(--sg-accent), transparent 70%);
    opacity: 0.07;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .sg-card:hover {
    transform: translateY(-4px);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.085) 0%, rgba(255, 255, 255, 0.05) 100%);
    border-color: color-mix(in oklab, var(--sg-accent) 50%, rgba(255, 255, 255, 0.18));
    box-shadow:
      0 24px 48px -20px rgba(0, 0, 0, 0.55),
      0 0 0 1px color-mix(in oklab, var(--sg-accent) 35%, transparent) inset,
      0 0 36px -10px color-mix(in oklab, var(--sg-accent) 30%, transparent);
  }
  .sg-card:hover::after {
    opacity: 0.14;
  }

  .sg-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.875rem;
  }
  .sg-card-cat {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sg-accent);
    font-weight: 600;
  }
  .sg-card-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--sg-accent);
    box-shadow: 0 0 8px var(--sg-accent);
  }
  .sg-card-arrow {
    display: inline-flex;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(244, 244, 249, 0.55);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .sg-card:hover .sg-card-arrow {
    background: var(--sg-accent);
    color: #0c0b1d;
    transform: translate(2px, -2px);
  }

  .sg-card-name {
    font-family: var(--font-display, system-ui);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.22;
    letter-spacing: -0.015em;
    color: #ffffff;
    margin: 0 0 0.5rem;
  }
  .sg-card-blurb {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(244, 244, 249, 0.7);
    margin: 0 0 1rem;
  }

  /* Prompt-preview window — code-window style mock that shows the
     exact text auto-filled into the workbench input on click. */
  .sg-card-prompt {
    margin: 0 0 1.125rem;
    background: rgba(12, 11, 29, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .sg-card:hover .sg-card-prompt {
    border-color: color-mix(in oklab, var(--sg-accent) 28%, rgba(255, 255, 255, 0.12));
    background: rgba(12, 11, 29, 0.85);
  }
  .sg-card-prompt-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .sg-card-prompt-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
  }
  .sg-card-prompt-dot--r { background: #ef4444; opacity: 0.6; }
  .sg-card-prompt-dot--y { background: #f59e0b; opacity: 0.6; }
  .sg-card-prompt-dot--g { background: #22c55e; opacity: 0.6; }
  .sg-card-prompt-label {
    margin-left: 0.5rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(244, 244, 249, 0.4);
  }
  .sg-card-prompt-body {
    margin: 0;
    padding: 0.875rem 1rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.78);
    white-space: pre-wrap;
    word-break: normal;
    overflow-wrap: break-word;
    /* Cap the visible prompt height; the workbench gets the full text. */
    max-height: 6.5rem;
    overflow: hidden;
    position: relative;
  }
  .sg-card-prompt-body::after {
    /* Fade-out at the bottom so the truncation reads as 'more on click'. */
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 1.75rem;
    background: linear-gradient(to bottom, transparent, rgba(12, 11, 29, 0.85));
    pointer-events: none;
  }
  .sg-card-prompt-body code {
    background: none;
    padding: 0;
    font: inherit;
    color: inherit;
  }

  .sg-card-stack {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.625rem;
    margin-bottom: 1rem;
  }
  .sg-chip {
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 7px;
    color: rgba(244, 244, 249, 0.8);
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .sg-card:hover .sg-chip {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.1);
  }
  .sg-chip-icon {
    width: 17px;
    height: 17px;
  }
  .sg-chip-img {
    width: 17px;
    height: 17px;
    filter: brightness(0) invert(1);
    opacity: 0.8;
  }
  .sg-card:hover .sg-chip-img {
    opacity: 1;

---
/**
 * Starter gallery — replaces the generic "PRODUCT TEAMS / L1-L2 / SOLO"
 * persona cards with concrete named starters that show what Blueprint
 * Agent actually scaffolds. Each card carries:
 *   - a starter name + one-liner
 *   - a 4-icon stack badge row (real brand SVGs from simple-icons +
 *     local /images/partners/)
 *   - file/test counters as proof of "real repo on day one"
 *   - a hover-revealed "Scaffold this →" CTA into ai.tangle.tools
 *
 * The point: replace adjectives with proof. The visitor sees AI chatbot
 * + RAG + Vercel AI SDK + Pinecone + Stripe in one card, not "starter
 * that matches your stack."
 */
import simpleIcons from '@iconify-json/simple-icons/icons.json';

const ICON_VIEWBOX = `0 0 ${simpleIcons.width} ${simpleIcons.height}`;
function iconBody(name: string): string {
  const icon = (simpleIcons.icons as Record<string, { body: string }>)[name];
  if (!icon) throw new Error(`simple-icons: unknown icon "${name}"`);
  return icon.body;
}

type StackChip =
  | { kind: 'icon'; name: string; alt: string }
  | { kind: 'img'; src: string; alt: string };

type Starter = {
  id: string;
  category: string;
  categoryAccent: string;
  name: string;
  blurb: string;
  files: number;
  tests: number;
  stack: StackChip[];
};

const starters: Starter[] = [
  {
    id: 'ai-rag-chatbot',
    category: 'AI · RAG',
    categoryAccent: '#a855f7',
    name: 'AI chatbot with RAG',
    blurb: 'Streaming chat over your docs. Pinecone-indexed, OpenAI-served, billed per message via Stripe.',
    files: 47,
    tests: 12,
    stack: [
      { kind: 'icon', name: 'nextdotjs',  alt: 'Next.js' },
      { kind: 'icon', name: 'vercel',     alt: 'Vercel AI SDK' },
      { kind: 'icon', name: 'openai',     alt: 'OpenAI' },
      { kind: 'icon', name: 'stripe',     alt: 'Stripe' },
    ],
  },
  {
    id: 'solana-dex-ui',
    category: 'Crypto · DEX',
    categoryAccent: '#6366f1',
    name: 'Solana DEX trading UI',
    blurb: 'Jupiter-routed swaps with wallet connection, slippage controls, real-time quotes, and a price chart.',
    files: 62,
    tests: 18,
    stack: [
      { kind: 'icon', name: 'solana',      alt: 'Solana' },
      { kind: 'icon', name: 'nextdotjs',   alt: 'Next.js' },
      { kind: 'icon', name: 'shadcnui',    alt: 'shadcn/ui' },
      { kind: 'icon', name: 'tailwindcss', alt: 'Tailwind' },
    ],
  },
  {
    id: 'realtime-voice-agent',
    category: 'AI · Realtime',
    categoryAccent: '#ec4899',
    name: 'Realtime voice agent',
    blurb: 'Twilio-callable. Deepgram ASR streams in, ElevenLabs TTS streams out, barge-in handled, calls replayable.',
    files: 38,
    tests: 9,
    stack: [
      { kind: 'icon', name: 'anthropic',  alt: 'Anthropic' },
      { kind: 'icon', name: 'elevenlabs', alt: 'ElevenLabs' },
      { kind: 'icon', name: 'modal',      alt: 'Modal' },
      { kind: 'icon', name: 'postgresql', alt: 'PostgreSQL' },
    ],
  },
  {
    id: 'eigenlayer-avs',
    category: 'Crypto · Restaking',
    categoryAccent: '#4f46e5',
    name: 'EigenLayer AVS service',
    blurb: 'Operator registration, task dispatch, signature aggregation, slashing hooks. Anvil + foundry tests passing.',
    files: 54,
    tests: 22,
    stack: [
      { kind: 'img',  src: '/images/partners/eigenlayer-logo.svg', alt: 'EigenLayer' },
      { kind: 'icon', name: 'typescript', alt: 'TypeScript' },
      { kind: 'icon', name: 'docker',     alt: 'Docker' },
      { kind: 'icon', name: 'github',     alt: 'GitHub' },
    ],
  },
  {
    id: 'discord-mcp',
    category: 'Agents · MCP',
    categoryAccent: '#f59e0b',
    name: 'Discord MCP server',
    blurb: 'Tool-calling bot exposing Discord moderation, search, and analytics over MCP. Drops into Claude or Cursor.',
    files: 31,
    tests: 7,
    stack: [
      { kind: 'icon', name: 'bun',        alt: 'Bun' },
      { kind: 'icon', name: 'typescript', alt: 'TypeScript' },
      { kind: 'icon', name: 'turso',      alt: 'Turso' },
      { kind: 'icon', name: 'sentry',     alt: 'Sentry' },
    ],
  },
  {
    id: 'aave-yield-vault',
    category: 'Crypto · DeFi',
    categoryAccent: '#10b981',
    name: 'Aave yield vault',
    blurb: 'ERC-4626 wrapper that auto-compounds Aave V3 supply yield. UI shows APY history + per-position health factor.',
    files: 49,
    tests: 16,
    stack: [
      { kind: 'img',  src: '/images/partners/aave.svg',          alt: 'Aave' },
      { kind: 'img',  src: '/images/partners/arbitrum-logo.svg', alt: 'Arbitrum' },
      { kind: 'icon', name: 'react',      alt: 'React' },
      { kind: 'icon', name: 'vercel',     alt: 'Vercel' },
    ],
  },
  {
    id: 'vector-search-api',
    category: 'AI · Search',
    categoryAccent: '#0ea5e9',
    name: 'Vector search API',
    blurb: 'Embed-once-query-many endpoint over Turso libSQL. OpenAI embeddings, hybrid BM25+dense, Cloudflare-edge served.',
    files: 28,
    tests: 11,
    stack: [
      { kind: 'icon', name: 'astro',       alt: 'Astro' },
      { kind: 'icon', name: 'cloudflare',  alt: 'Cloudflare' },
      { kind: 'icon', name: 'turso',       alt: 'Turso' },
      { kind: 'icon', name: 'openai',      alt: 'OpenAI' },
    ],
  },
  {
    id: 'hyperlane-validator',
    category: 'Crypto · Bridges',
    categoryAccent: '#dc2626',
    name: 'Hyperlane validator service',
    blurb: 'Listens to source chains, signs interchain messages, posts to ISMs. Health endpoint + Grafana dashboard included.',
    files: 41,
    tests: 14,
    stack: [
      { kind: 'icon', name: 'docker',      alt: 'Docker' },
      { kind: 'icon', name: 'postgresql',  alt: 'PostgreSQL' },
      { kind: 'icon', name: 'github',      alt: 'GitHub' },
      { kind: 'icon', name: 'cloudflare',  alt: 'Cloudflare' },
    ],
  },
];

const totalFiles = starters.reduce((s, c) => s + c.files, 0);
const totalTests = starters.reduce((s, c) => s + c.tests, 0);
---

<section class="sg" aria-label="Starters Blueprint Agent ships with">
  <div class="sg-inner">
    <div class="sg-head">
      <div class="sg-eyebrow">REAL STARTERS · NOT BOILERPLATE</div>
      <h2 class="sg-title">
        Pick a starter.
        <span class="sg-grad">Ship today.</span>
      </h2>
      <p class="sg-lede">
        Every starter is a working repo on day one. Real SDKs, typed clients, secrets handling, deploy targets, passing tests — wired up the moment Blueprint Agent finishes scaffolding. Pick yours, refine in the workbench, open a PR.
      </p>
      <div class="sg-strip">
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{starters.length}</span>
          <span class="sg-strip-label">starters live</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalFiles}</span>
          <span class="sg-strip-label">files generated</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalTests}</span>
          <span class="sg-strip-label">tests passing</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">∞</span>
          <span class="sg-strip-label">custom on request</span>
        </div>
      </div>
    </div>

    <div class="sg-grid">
      {starters.map((starter) => (
        <a
          class="sg-card"
          href={`https://ai.tangle.tools/?starter=${starter.id}`}
          target="_blank"
          rel="noopener noreferrer"
          style={`--sg-accent: ${starter.categoryAccent};`}
        >
          <div class="sg-card-head">
            <span class="sg-card-cat">{starter.category}</span>
            <span class="sg-card-arrow" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </span>
          </div>
          <h3 class="sg-card-name">{starter.name}</h3>
          <p class="sg-card-blurb">{starter.blurb}</p>
          <div class="sg-card-stack" aria-label={`Stack: ${starter.stack.map((s) => s.alt).join(', ')}`}>
            {starter.stack.map((chip) => (
              <span class="sg-chip" title={chip.alt}>
                {chip.kind === 'icon'
                  ? <svg viewBox={ICON_VIEWBOX} class="sg-chip-icon" set:html={iconBody(chip.name)} aria-hidden="true" />
                  : <img src={chip.src} alt="" class="sg-chip-img" loading="lazy" aria-hidden="true" />}
              </span>
            ))}
            <span class="sg-card-counters">
              <span class="sg-card-counter"><strong>{starter.files}</strong> files</span>
              <span class="sg-card-counter sg-card-counter--ok">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 12 4 4L18 8"/></svg>
                {starter.tests} tests
              </span>
            </span>
          </div>
          <div class="sg-card-cta">Scaffold this starter →</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sg {
    background: #0c0b1d;
    color: #f4f4f9;
    padding: 5rem 8% 4.5rem;
    position: relative;
    overflow: hidden;
  }
  .sg::before {
    /* Faint indigo radial so the section has a horizon. */
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.10), transparent 70%),
      radial-gradient(ellipse 40% 30% at 100% 100%, rgba(168, 85, 247, 0.08), transparent 70%);
    pointer-events: none;
  }
  .sg-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sg-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 56rem;
  }
  .sg-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a5aafc;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .sg-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .sg-grad {
    background: linear-gradient(135deg, #818cf8 0%, #a5aafc 50%, #c7d2fe 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sg-lede {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.7);
    margin: 0 0 1.75rem;
  }

  .sg-strip {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.875rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.025);
    border-radius: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sg-strip-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .sg-strip-num {
    font-family: var(--font-display, system-ui);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }
  .sg-strip-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: rgba(244, 244, 249, 0.55);
    text-transform: uppercase;
  }
  .sg-strip-divider {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Card grid — 4 cols desktop, 2 tablet, 1 mobile. */
  .sg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  @media (max-width: 1100px) {
    .sg-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .sg-grid { grid-template-columns: 1fr; }
  }

  .sg-card {
    --sg-accent: #6366f1;
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }
  .sg-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.25rem;
    right: 1.25rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--sg-accent), transparent);
    opacity: 0.85;
  }
  .sg-card:hover {
    transform: translateY(-3px);
    background: rgba(255, 255, 255, 0.045);
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 18px 36px -16px rgba(0, 0, 0, 0.5),
                0 0 0 1px var(--sg-accent) inset;
  }

  .sg-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.875rem;
  }
  .sg-card-cat {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sg-accent);
    font-weight: 600;
  }
  .sg-card-arrow {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(244, 244, 249, 0.5);
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .sg-card:hover .sg-card-arrow {
    background: var(--sg-accent);
    color: #ffffff;
    transform: translate(2px, -2px);
  }

  .sg-card-name {
    font-family: var(--font-display, system-ui);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #ffffff;
    margin: 0 0 0.5rem;
  }
  .sg-card-blurb {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(244, 244, 249, 0.65);
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .sg-card-stack {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.625rem;
    margin-bottom: 0.875rem;
  }
  .sg-chip {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    color: rgba(244, 244, 249, 0.7);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .sg-card:hover .sg-chip {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.95);
  }
  .sg-chip-icon {
    width: 16px;
    height: 16px;
  }
  .sg-chip-img {
    width: 16px;
    height: 16px;
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }
  .sg-card:hover .sg-chip-img {
    opacity: 0.95;
  }
  .sg-card-counters {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    color: rgba(244, 244, 249, 0.55);
  }
  .sg-card-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .sg-card-counter strong {
    color: rgba(244, 244, 249, 0.85);
    font-weight: 600;
  }
  .sg-card-counter--ok {
    color: #4ade80;
  }

  .sg-card-cta {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(244, 244, 249, 0.4);
    padding-top: 0.875rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .sg-card:hover .sg-card-cta {
    color: var(--sg-accent);
    border-top-color: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 700px) {
    .sg { padding: 4rem 6%; }
    .sg-card { padding: 1.25rem 1.25rem 1rem; }
    .sg-strip { gap: 0.875rem; padding: 0.75rem 1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sg-card, .sg-chip, .sg-card-arrow, .sg-card-cta { transition: none; }
  }
</style>

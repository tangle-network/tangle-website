// Compose the auto-fill workbench URL: clicking a starter opens the
// Blueprint Agent landing with the prompt pre-filled. Bp-agent app
// side reads ?starter + ?prompt + ?autofill, routes through login
// (preserving the params via returnTo), and auto-submits on return.
function workbenchHref(s: Starter): string {
  const q = new URLSearchParams({
    starter: s.id,
    prompt: s.prompt,
    autofill: '1',
  });
  return `https://ai.tangle.tools/?${q.toString()}`;
}

const totalFiles = starters.reduce((s, c) => s + c.files, 0);
const totalTests = starters.reduce((s, c) => s + c.tests, 0);
---

<section class="sg" aria-label="Starters Blueprint Agent ships with">
  <div class="sg-inner">
    <div class="sg-head">
      <div class="sg-eyebrow">REAL STARTERS · NOT BOILERPLATE</div>
      <h2 class="sg-title">
        Pick a starter.
        <span class="sg-grad">Ship today.</span>
      </h2>
      <p class="sg-lede">
        Every starter is a working repo on day one. Real SDKs, typed clients, secrets handling, deploy targets, passing tests, all wired up the moment Blueprint Agent finishes scaffolding. Pick yours, refine in the workbench, open a PR.
      </p>
      <div class="sg-strip">
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{starters.length}</span>
          <span class="sg-strip-label">starters live</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalFiles}</span>
          <span class="sg-strip-label">files generated</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">{totalTests}</span>
          <span class="sg-strip-label">tests passing</span>
        </div>
        <div class="sg-strip-divider" aria-hidden="true"></div>
        <div class="sg-strip-stat">
          <span class="sg-strip-num">∞</span>
          <span class="sg-strip-label">custom on request</span>
        </div>
      </div>
    </div>

    <div class="sg-grid">
      {starters.map((starter) => (
        <a
          class="sg-card"
          href={workbenchHref(starter)}
          target="_blank"
          rel="noopener noreferrer"
          style={`--sg-accent: ${starter.categoryAccent};`}
          data-starter={starter.id}
        >
          {/* Prompt Deck card — reads as a chat message you'd send to the
              agent. Header line is the metadata (category + name);
              the body IS the prompt about to be auto-filled. No code-
              window chrome, no traffic lights — this is a message,
              not a snippet. */}
          <div class="sg-card-head">
            <span class="sg-card-cat">
              <span class="sg-card-dot" aria-hidden="true"></span>
              {starter.category}
            </span>
            <span class="sg-card-name-inline">{starter.name}</span>
          </div>

          <p class="sg-card-prompt-bubble">
            {starter.prompt}<span class="sg-card-cursor" aria-hidden="true"></span>
          </p>

          <div class="sg-card-foot">
            <div class="sg-card-stack" aria-label={`Stack: ${starter.stack.map((s) => s.alt).join(', ')}`}>
              {starter.stack.map((chip) => (
                <span class="sg-chip" title={chip.alt}>
                  {chip.kind === 'icon'
                    ? <svg viewBox={ICON_VIEWBOX} class="sg-chip-icon" set:html={iconBody(chip.name)} aria-hidden="true" />
                    : <img src={chip.src} alt="" class="sg-chip-img" loading="lazy" aria-hidden="true" />}
                </span>
              ))}
            </div>
            <button type="button" class="sg-card-copy" data-prompt={starter.prompt} aria-label="Copy prompt to clipboard">
              <svg class="sg-card-copy-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="sg-card-copy-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
            <span class="sg-card-cta">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 2 11 13"/>
                <path d="M22 2 15 22 11 13 2 9z"/>
              </svg>
              Send</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sg {
    background: #0c0b1d;
    color: #f4f4f9;
    padding: 5rem 8% 4.5rem;
    position: relative;
    overflow: hidden;
  }
  .sg::before {
    /* Faint indigo radial so the section has a horizon. */
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.10), transparent 70%),
      radial-gradient(ellipse 40% 30% at 100% 100%, rgba(168, 85, 247, 0.08), transparent 70%);
    pointer-events: none;
  }
  .sg-inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sg-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 56rem;
  }
  .sg-eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a5aafc;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .sg-title {
    font-family: var(--font-display, system-ui);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .sg-grad {
    background: linear-gradient(135deg, #818cf8 0%, #a5aafc 50%, #c7d2fe 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sg-lede {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: rgba(244, 244, 249, 0.7);
    margin: 0 0 1.75rem;
  }

  .sg-strip {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.875rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.025);
    border-radius: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sg-strip-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .sg-strip-num {
    font-family: var(--font-display, system-ui);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }
  .sg-strip-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: rgba(244, 244, 249, 0.55);
    text-transform: uppercase;
  }
  .sg-strip-divider {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Prompt Deck — each card is a chat message, not a code window. 2-col
     grid, ~half the height of the prior bento, no traffic-light chrome. */
  .sg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }
  @media (max-width: 820px) {
    .sg-grid { grid-template-columns: 1fr; }
  }

  .sg-card {
    --sg-accent: #818cf8;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.125rem 1.25rem 1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.025) 100%);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 14px;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }
  /* Top accent stripe in the per-card brand color. */
  .sg-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--sg-accent) 40%, var(--sg-accent) 60%, transparent);
    opacity: 0.85;
    transition: opacity 0.22s ease;
  }
  .sg-card:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.075) 0%, rgba(255, 255, 255, 0.04) 100%);
    border-color: color-mix(in oklab, var(--sg-accent) 50%, rgba(255, 255, 255, 0.18));
    box-shadow:
      0 18px 40px -22px rgba(0, 0, 0, 0.55),
      0 0 28px -12px color-mix(in oklab, var(--sg-accent) 32%, transparent);
  }
  .sg-card:hover::before { opacity: 1; }

  /* Header line: category chip + starter name inline, mono-typeset
     "you · 12:42"-style metadata read. */
  .sg-card-head {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 0.125rem;
  }
  .sg-card-cat {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sg-accent);
    font-weight: 700;
    flex-shrink: 0;
  }
  .sg-card-dot {
    width: 5px; height: 5px;
    border-radius: 999px;
    background: var(--sg-accent);
    box-shadow: 0 0 6px var(--sg-accent);
  }
  .sg-card-name-inline {
    font-family: var(--font-display, system-ui);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    line-height: 1.3;
    flex: 1;
    min-width: 0;
  }

  /* Prompt body — this IS the card. Reads as a chat bubble: the actual
     text the agent receives on click. Typewriter cursor blinks at end. */
  .sg-card-prompt-bubble {
    position: relative;
    margin: 0;
    padding: 0.875rem 1rem;
    background: rgba(12, 11, 29, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    font-family: var(--font-sans, system-ui);
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(244, 244, 249, 0.86);
    /* Cap visible height so cards stay symmetric. The full prompt
       still goes to the workbench on click. */
    max-height: 5.5rem;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease, max-height 0.2s ease;
  }
  .sg-card:hover .sg-card-prompt-bubble {
    border-color: color-mix(in oklab, var(--sg-accent) 28%, rgba(255, 255, 255, 0.10));
    background: rgba(12, 11, 29, 0.78);
  }
  .sg-card-prompt-bubble::after {
    /* Fade-out at the bottom — implies 'more on click'. */
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 1.5rem;
    background: linear-gradient(to bottom, transparent, rgba(12, 11, 29, 0.78));
    pointer-events: none;
  }
  .sg-card-cursor {
    display: inline-block;
    width: 2px;
    height: 0.95rem;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--sg-accent);
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .sg-card:hover .sg-card-cursor {
    opacity: 1;
    animation: sg-card-cursor-blink 0.95s steps(2, end) infinite;
  }
  @keyframes sg-card-cursor-blink { 0%, 60% { opacity: 1; } 61%, 100% { opacity: 0; } }

  /* Footer: stack chips + copy button + Send CTA in one row. */
  .sg-card-foot {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
  }
  .sg-card-stack {
    display: flex;
    align-items: center;
    gap: 0.32rem;
    flex: 1; min-width: 0;
  }
  .sg-chip {
    flex: 0 0 auto;
    width: 24px; height: 24px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    color: rgba(244, 244, 249, 0.88);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .sg-card:hover .sg-chip {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }
  .sg-chip-icon { width: 14px; height: 14px; }
  .sg-chip-img {
    width: 14px; height: 14px;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }
  .sg-card:hover .sg-chip-img { opacity: 1; }

  /* Copy button — separate affordance so the card-click != copy. */
  .sg-card-copy {
    flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    padding: 0;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    color: rgba(244, 244, 249, 0.62);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .sg-card-copy:hover {
    background: rgba(255, 255, 255, 0.10);
    color: #ffffff;
    border-color: color-mix(in oklab, var(--sg-accent) 38%, rgba(255, 255, 255, 0.12));
  }
  .sg-card-copy-check { display: none; color: #34D399; }
  .sg-card-copy.is-copied .sg-card-copy-icon { display: none; }
  .sg-card-copy.is-copied .sg-card-copy-check { display: inline-block; }

  /* Send CTA — paper-airplane icon, accent-tinted, pill shape. */
  .sg-card-cta {
    flex-shrink: 0;
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.42rem 0.875rem;
    background: color-mix(in oklab, var(--sg-accent) 15%, rgba(255, 255, 255, 0.04));
    border: 1px solid color-mix(in oklab, var(--sg-accent) 35%, transparent);
    border-radius: 999px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--sg-accent);
    transition: background 0.18s ease, transform 0.18s ease, border-color 0.18s ease;
  }
  .sg-card:hover .sg-card-cta {
    background: color-mix(in oklab, var(--sg-accent) 30%, rgba(255, 255, 255, 0.06));
    border-color: color-mix(in oklab, var(--sg-accent) 55%, transparent);
    transform: translateX(2px);
  }

  @media (max-width: 700px) {
    .sg { padding: 4rem 6%; }
    .sg-card { padding: 1.25rem 1.25rem 1rem; }
    .sg-strip { gap: 0.875rem; padding: 0.75rem 1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sg-card, .sg-chip, .sg-card-cta { transition: none; }
    .sg-card-cursor { animation: none; }
  }
</style>

<script>
  // Per-card copy button: copies the prompt to clipboard, swaps the
  // clipboard icon for a checkmark for ~1.6s. stopPropagation prevents
  // the parent <a> from firing the workbench navigation.
  document.querySelectorAll<HTMLButtonElement>('.sg-card-copy').forEach((btn) => {
    btn.addEventListener('click', async (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      const prompt = btn.dataset.prompt;
      if (!prompt) return;
      try { await navigator.clipboard.writeText(prompt); } catch { return; }
      btn.classList.add('is-copied');
      setTimeout(() => btn.classList.remove('is-copied'), 1600);
    });
  });
</script>

---
/**
 * Starter gallery — replaces the generic "PRODUCT TEAMS / L1-L2 / SOLO"
 * persona cards with concrete named starters that show what Blueprint
 * Agent actually scaffolds. Each card carries:
 *   - a starter name + one-liner
 *   - a 4-icon stack badge row (real brand SVGs from simple-icons +
 *     local /images/partners/)
 *   - file/test counters as proof of "real repo on day one"
 *   - a hover-revealed "Scaffold this →" CTA into ai.tangle.tools
 *
 * The point: replace adjectives with proof. The visitor sees AI chatbot
 * + RAG + Vercel AI SDK + Pinecone + Stripe in one card, not "starter
 * that matches your stack."
 */
import simpleIcons from '@iconify-json/simple-icons/icons.json';

const ICON_VIEWBOX = `0 0 ${simpleIcons.width} ${simpleIcons.height}`;
function iconBody(name: string): string {
  const icon = (simpleIcons.icons as Record<string, { body: string }>)[name];
  if (!icon) throw new Error(`simple-icons: unknown icon "${name}"`);
  return icon.body;
}

type StackChip =
  | { kind: 'icon'; name: string; alt: string }
  | { kind: 'img'; src: string; alt: string };

type Starter = {
  id: string;
  category: string;
  categoryAccent: string;
  name: string;
  blurb: string;
  prompt: string;     // Auto-fills the workbench input on landing.
  files: number;
  tests: number;
  stack: StackChip[];
};


---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200';

const variants = {
  primary: 'bg-brand-primary hover:bg-brand-strong text-white',
  secondary: 'bg-bg-elevated hover:bg-bg-card text-text-primary border border-white/10',
  ghost: 'text-text-secondary hover:text-text-primary hover:bg-white/5',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-8 py-3 text-base',
};

const Element = href ? 'a' : 'button';
---

<Element
  href={href}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
>
  <slot />
</Element>

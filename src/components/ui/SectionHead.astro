---
interface Props {
  eyebrow?: string;
  eyebrowColor?: 'emerald' | 'brand' | 'warn';
  title: string;
  description?: string;
  align?: 'left' | 'center';
  maxWidth?: string;
}

const {
  eyebrow,
  eyebrowColor = 'emerald',
  title,
  description,
  align = 'left',
  maxWidth = '52rem',
} = Astro.props;

const eyebrowColors: Record<string, string> = {
  emerald: 'color: #10B981;',
  brand: 'color: var(--brand-cool);',
  warn: 'color: #FFB800;',
};
---

<div class="wf-section-head" style={`align-items: ${align === 'center' ? 'center' : 'flex-start'}; text-align: ${align};`}>
  {eyebrow && (
    <span class="wf-eyebrow" style={eyebrowColors[eyebrowColor]}>{eyebrow}</span>
  )}
  <h2 class="wf-h3" style={`text-align: ${align}; max-width: ${maxWidth}; margin: 0;`} set:html={title} />
  {description && (
    <p class="wf-body-01" style={`text-align: ${align}; max-width: 44rem; margin: 0;`}>{description}</p>
  )}
</div>

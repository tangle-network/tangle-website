---
/**
 * BentoCell.astro. canonical card primitive.
 *
 * Replaces:
 *   - wf-builder-feature-card (14 callsites, dark variant)
 *   - bp-bento-cell (5 cells on /services/blueprint-agent)
 *   - 8 inline 'background: white; border: rgba(110,108,148,0.25); padding: 1.75rem;'
 *     vault-surface cards across operators/developers/stake/services pages
 *
 * One radius (16px), one hover state, one body type. Vault variant flips
 * to white surface for light sections.
 *
 * Slots:
 *   label . mono eyebrow above the title (optional)
 *   title . h3-sized card title (use plain text or HTML. slot accepts both)
 *   body  . paragraph body
 *   default. visual content rendered after body (charts, code, etc.)
 *   foot  . optional footer text (mono small)
 *
 * Props:
 *   variant: 'dark' (default) | 'vault'
 *   span:    1 | 2 | 3  . grid column span (caller wraps in a grid)
 *   sharp:   true (default. sandbox-app aesthetic) | false (12px radius)
 *   hover:   'lift' (default. translateY -2px + indigo glow) | 'border' (just border-color) | 'none'
 *   accent:  'indigo' | 'emerald' | 'amber' | 'blue' (label color)
 */

interface Props {
  variant?: 'dark' | 'vault';
  span?: 1 | 2 | 3;
  sharp?: boolean;
  hover?: 'lift' | 'border' | 'none';
  accent?: 'indigo' | 'emerald' | 'amber' | 'blue';
  class?: string;
}

const {
  variant = 'dark',
  span = 1,
  sharp = false,
  hover = 'lift',
  accent = 'indigo',
  class: className,
} = Astro.props;

const accentColors: Record<string, string> = {
  indigo:  '#A5AAFC',
  emerald: '#34D399',
  amber:   '#FFB800',
  blue:    '#4AABFF',
};
const labelColor = variant === 'vault' ? '#4F46E5' : accentColors[accent];

const radius = sharp ? '16px' : '12px';

const baseStyle = variant === 'vault'
  ? `background: #ffffff; border: 1px solid rgba(110, 108, 148, 0.25); color: #191c24;`
  : `background: var(--depth-2); border: 1px solid var(--border-default); color: var(--text-primary);`;
---

<div
  class:list={['t-bento', `t-bento--${variant}`, `t-bento--span-${span}`, `t-bento--hover-${hover}`, className]}
  style={`${baseStyle} border-radius: ${radius}; padding: 2.25rem 2.5rem; min-width: 0; display: flex; flex-direction: column; gap: 0.75rem; transition: border-color 0.18s ease, transform 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;`}
  data-accent={accent}
>
  {Astro.slots.has('label') && (
    <div class="t-bento-label" style={`font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); font-weight: 700; color: ${labelColor}; text-transform: uppercase; letter-spacing: var(--type-mono-eyebrow-track); line-height: 1; margin: 0 0 0.625rem;`}>
      <slot name="label" />
    </div>
  )}

  {Astro.slots.has('title') && (
    <h3 class="t-bento-title" style={`font-family: var(--font-display); font-size: var(--type-h3); font-weight: var(--type-h3-weight); line-height: var(--type-h3-line); letter-spacing: var(--type-h3-track); color: ${variant === 'vault' ? '#191c24' : 'var(--text-primary)'}; margin: 0;`}>
      <slot name="title" />
    </h3>
  )}

  {Astro.slots.has('body') && (
    <p class="t-bento-body" style={`font-family: var(--font-sans); font-size: var(--type-body); line-height: 1.55; color: ${variant === 'vault' ? '#3a3a50' : 'var(--text-secondary)'}; margin: 0;`}>
      <slot name="body" />
    </p>
  )}

  {Astro.slots.has('default') && (
    <div class="t-bento-visual" style="margin-top: 0.5rem;">
      <slot />
    </div>
  )}

  {Astro.slots.has('foot') && (
    <div class="t-bento-foot" style={`font-family: var(--font-mono); font-size: var(--type-mono-eyebrow); color: ${variant === 'vault' ? '#5e5e7a' : 'var(--text-muted)'}; letter-spacing: 0.04em; margin-top: auto; padding-top: 0.875rem; border-top: 1px solid ${variant === 'vault' ? 'rgba(0,0,0,0.06)' : 'var(--border-subtle)'};`}>
      <slot name="foot" />
    </div>
  )}
</div>

<style is:global>
  .t-bento--span-2 { grid-column: span 2; }
  .t-bento--span-3 { grid-column: span 3; }

  .t-bento--hover-lift:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }
  .t-bento--vault.t-bento--hover-lift:hover {
    border-color: rgba(99, 102, 241, 0.35);
    background: #fafbfc;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(99, 102, 241, 0.10);
  }

  .t-bento--hover-border:hover { border-color: var(--border-accent); }
  .t-bento--vault.t-bento--hover-border:hover { border-color: rgba(99, 102, 241, 0.35); }

  @media (max-width: 768px) {
    .t-bento { padding: 1.5rem !important; }
    .t-bento--span-2, .t-bento--span-3 { grid-column: span 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .t-bento { transition: none !important; }
    .t-bento--hover-lift:hover { transform: none !important; }
  }
</style>

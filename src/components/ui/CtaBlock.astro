---
/**
 * CtaBlock.astro. canonical bottom-of-page CTA card.
 *
 * Replaces the wf-cta-card / wf-cta-inner / wf-cta-content / wf-cta-floating
 * stack that's hand-rolled 7× across pages. One bright-indigo card,
 * geometric-pattern decoration, big headline, true-pill white button.
 *
 * Background uses --brand-dim (#4F46E5 = 5.42:1 with white = AA-safe; the
 * earlier brighter --brand-primary at 4.47:1 failed AA on white text).
 *
 * Slots:
 *   default. optional override of the rendered content. By default
 *   renders: title (h2), body (paragraph), and CTA buttons.
 *
 * Props:
 *   title:        string (HTML supported)
 *   body:         string (optional)
 *   primaryCta:   { label, href, external? }   (optional)
 *   secondaryCta: { label, href, external? }   (optional)
 *   pattern:      'webflow' (default. restored OG floating squares)
 *               | 'none'   (just the indigo card, no decoration)
 */

interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  title: string;
  body?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
  pattern?: 'webflow' | 'none';
}

const {
  title,
  body,
  primaryCta,
  secondaryCta,
  pattern = 'webflow',
} = Astro.props;
---

<div class="t-cta" style="background-color: var(--brand-dim); background-image: radial-gradient(ellipse at 18% 30%, rgba(165,170,252,0.32) 0%, transparent 55%), radial-gradient(ellipse at 82% 70%, rgba(60,47,200,0.45) 0%, transparent 60%), linear-gradient(135deg, #5651E8 0%, #4F46E5 60%, #4338CA 100%); border-radius: 20px; overflow: hidden; margin: 3rem 4%; position: relative; box-shadow: 0 32px 100px rgba(76, 60, 230, 0.32);">
  {pattern === 'webflow' && (
    <>
      <img src="/images/webflow/pattern-cta-v1-brix-templates-01.svg" alt="" class="t-cta-pattern t-cta-pattern--lt" loading="lazy" />
      <img src="/images/webflow/pattern-cta-v2-brix-templates-02.svg" alt="" class="t-cta-pattern t-cta-pattern--rb" loading="lazy" />
    </>
  )}

  <div class="t-cta-inner" style="padding: 6rem 6%; max-width: 64rem; margin: 0 auto; text-align: center; position: relative; z-index: 1;">
    {Astro.slots.has('default') ? (
      <slot />
    ) : (
      <>
        <h2 class="t-cta-title" style="font-family: var(--font-display); font-size: var(--type-h2); font-weight: var(--type-h2-weight); line-height: var(--type-h2-line); letter-spacing: var(--type-h2-track); color: #ffffff; margin: 0 0 1rem; text-wrap: balance;" set:html={title} />
        {body && (
          <p class="t-cta-body" style="font-family: var(--font-sans); font-size: var(--type-body-l); line-height: 1.55; color: rgba(255,255,255,0.88); max-width: 38rem; margin: 0 auto 2rem;" set:html={body} />
        )}
        {(primaryCta || secondaryCta) && (
          <div class="t-cta-buttons" style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
            {primaryCta && (
              <a
                href={primaryCta.href}
                target={primaryCta.external ? '_blank' : undefined}
                rel={primaryCta.external ? 'noopener noreferrer' : undefined}
                class="t-cta-btn t-cta-btn--primary"
                style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 16px 36px; background-color: #ffffff; border: 1px solid #ffffff; color: var(--brand-dim); border-radius: 999px; font-family: var(--font-sans); font-size: 1rem; font-weight: 700; line-height: 1.2; text-decoration: none; box-shadow: 0 8px 24px rgba(0,0,0,0.18); transition: transform 0.16s ease, box-shadow 0.16s ease, color 0.16s ease;"
              >
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                target={secondaryCta.external ? '_blank' : undefined}
                rel={secondaryCta.external ? 'noopener noreferrer' : undefined}
                class="t-cta-btn t-cta-btn--secondary"
                style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 16px 30px; background: transparent; border: 1px solid rgba(255,255,255,0.32); color: #ffffff; border-radius: 999px; font-family: var(--font-sans); font-size: 1rem; font-weight: 600; line-height: 1.2; text-decoration: none; transition: border-color 0.16s ease, background-color 0.16s ease;"
              >
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
      </>
    )}
  </div>
</div>

<style>
  /* Restored webflow geometric pattern. rotated translucent squares
     anchored to corners (negative offsets pull them out of the rounded
     box but inside the overflow:hidden boundary). */
  .t-cta-pattern {
    position: absolute;
    pointer-events: none;
    user-select: none;
    opacity: 0.9;
    z-index: 0;
  }
  .t-cta-pattern--lt {
    top: -40px;
    left: -56px;
    width: 380px;
    height: auto;
    transform: rotate(-8deg);
  }
  .t-cta-pattern--rb {
    bottom: -52px;
    right: -64px;
    width: 320px;
    height: auto;
    transform: rotate(12deg);
  }
  @media (max-width: 768px) {
    .t-cta-pattern--lt { width: 220px; top: -20px; left: -36px; }
    .t-cta-pattern--rb { width: 200px; bottom: -32px; right: -40px; }
    .t-cta-inner       { padding: 4rem 6% !important; }
  }

  .t-cta-btn--primary:hover {
    color: #3A35C8;
    transform: translateY(-1px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.24);
  }
  .t-cta-btn--secondary:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background-color: rgba(255, 255, 255, 0.06);
  }

  @media (prefers-reduced-motion: reduce) {
    .t-cta-btn--primary, .t-cta-btn--secondary { transition: none; }
    .t-cta-btn--primary:hover { transform: none; }
  }
</style>

---
// Sticky-scroll narrative section. Pinned on desktop, stacked on mobile.
// One stage is .is-active at a time, driven by scroll progress through the
// outer track. Pass a `stages` array and provide a slot per stage for the
// right-column visual:
//
//   <StoryScroller eyebrow="..." title="..." lede="..." stages={[
//     { id: 'spec',  num: '01', title: 'Spec.',  body: '...' },
//     ...
//   ]} />
//     <Fragment slot="visual-spec">  ...your visual...  </Fragment>
//     <Fragment slot="visual-build"> ...your visual...  </Fragment>
//
// Multiple instances on different pages are safe — each Astro page bundles
// its own scoped CSS + script, and the script scopes its DOM queries to
// the component's `<section>` element.

interface Stage {
  id: string;
  num: string;
  title: string;
  body: string;
}

interface Props {
  eyebrow: string;
  eyebrowColor?: string;
  title: string;
  titleAccent?: string;
  lede?: string;
  stages: Stage[];
  background?: string;
}

const {
  eyebrow,
  eyebrowColor,
  title,
  titleAccent,
  lede,
  stages,
  background,
} = Astro.props;

const sectionStyle = background ? `background: ${background};` : '';
---

<section class="story-scroller" aria-label={eyebrow} style={sectionStyle}>
  <div class="story-track">
    <div class="story-pin">
      <div class="story-grid">
        <div class="story-text">
          <span class="story-eyebrow" style={eyebrowColor ? `color: ${eyebrowColor};` : ''}>{eyebrow}</span>
          <h2 class="story-h2">
            {title}
            {titleAccent && <> <span class="wf-gradient-text">{titleAccent}</span></>}
          </h2>
          {lede && <p class="story-lede">{lede}</p>}

          {stages.map((s) => (
            <div class="story-stage" data-stage={s.id}>
              <div class="story-num">{s.num}</div>
              <h3 class="story-stage-title">{s.title}</h3>
              <p class="story-stage-body" set:html={s.body} />
            </div>
          ))}
        </div>

        <div class="story-visual">
          {/* Up to 6 stages supported. Slot names are indexed (visual-0..5)
              because Astro requires statically-known slot names. */}
          {stages[0] && (<div class="story-panel" data-stage={stages[0].id}><slot name="visual-0" /></div>)}
          {stages[1] && (<div class="story-panel" data-stage={stages[1].id}><slot name="visual-1" /></div>)}
          {stages[2] && (<div class="story-panel" data-stage={stages[2].id}><slot name="visual-2" /></div>)}
          {stages[3] && (<div class="story-panel" data-stage={stages[3].id}><slot name="visual-3" /></div>)}
          {stages[4] && (<div class="story-panel" data-stage={stages[4].id}><slot name="visual-4" /></div>)}
          {stages[5] && (<div class="story-panel" data-stage={stages[5].id}><slot name="visual-5" /></div>)}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .story-scroller {
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }
  .story-track { position: relative; }
  .story-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 6%;
    overflow: hidden;
  }
  .story-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: stretch;
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
  }
  .story-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .story-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--brand-cool);
    margin-bottom: 0.875rem;
    display: inline-block;
  }
  .story-h2 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.6vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .story-lede {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    max-width: 30rem;
  }
  .story-stage {
    padding: 1.25rem 0;
    border-top: 1px solid var(--border-subtle);
    opacity: 0.32;
    transition: opacity 0.3s ease;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1rem;
    align-items: baseline;
  }
  .story-stage.is-active { opacity: 1; }
  .story-stage:last-child { border-bottom: 1px solid var(--border-subtle); }
  .story-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--brand-cool);
    letter-spacing: 0.1em;
    grid-row: span 2;
    align-self: start;
    padding-top: 0.25rem;
  }
  .story-stage-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
  }
  .story-stage-body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }
  .story-stage-body :global(strong) { color: var(--text-primary); font-weight: 600; }

  .story-visual {
    position: relative;
    min-height: 28rem;
  }
  .story-panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.875rem;
    padding: 2rem 2.25rem;
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    border-radius: 16px;
    opacity: 0;
    transform: translateY(12px) scale(0.99);
    transition: opacity 0.42s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.42s cubic-bezier(0.22, 0.61, 0.36, 1),
                border-color 0.42s ease;
    pointer-events: none;
  }
  .story-panel.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
    border-color: var(--border-accent);
    pointer-events: auto;
    box-shadow: 0 24px 80px rgba(99, 102, 241, 0.16);
  }

  /* Track height controls scroll budget per stage. 4 stages × ~80vh each. */
  .story-track::before { content: ''; display: block; height: 320vh; }

  @media (max-width: 991px) {
    .story-track::before { display: none; }
    .story-pin { position: static; height: auto; padding: 4rem 6%; }
    .story-grid { grid-template-columns: 1fr; gap: 2rem; }
    .story-stage { opacity: 1; }
    .story-visual { min-height: 0; }
    .story-panel { position: static; opacity: 1; transform: none; pointer-events: auto; margin-top: 1rem; }
    .story-panel + .story-panel { margin-top: 1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .story-stage, .story-panel { transition: none !important; }
  }
</style>

<script>
  // Activate one stage + matching panel based on scroll progress through
  // the outer track. Scoped to each .story-scroller instance so multiple
  // instances on the same page won't fight each other.
  (() => {
    const scrollers = Array.from(document.querySelectorAll<HTMLElement>('.story-scroller'));
    if (scrollers.length === 0) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    scrollers.forEach((scroller) => {
      const track = scroller.querySelector<HTMLElement>('.story-track');
      const stages = Array.from(scroller.querySelectorAll<HTMLElement>('.story-stage'));
      const panels = Array.from(scroller.querySelectorAll<HTMLElement>('.story-panel'));
      if (!track || stages.length === 0 || panels.length === 0) return;

      const setActive = (idx: number) => {
        const i = Math.max(0, Math.min(stages.length - 1, idx));
        stages.forEach((s, k) => s.classList.toggle('is-active', k === i));
        panels.forEach((p, k) => p.classList.toggle('is-active', k === i));
      };

      if (reduced) {
        stages.forEach((s) => s.classList.add('is-active'));
        panels.forEach((p) => p.classList.add('is-active'));
        return;
      }

      setActive(0);

      let raf = 0;
      const onScroll = () => {
        const rect = track.getBoundingClientRect();
        const vh = window.innerHeight;
        const total = rect.height - vh;
        if (total <= 0) return;
        const progress = Math.max(0, Math.min(1, -rect.top / total));
        const idx = Math.min(stages.length - 1, Math.floor(progress * stages.length));
        setActive(idx);
      };
      const scheduled = () => {
        if (raf) return;
        raf = requestAnimationFrame(() => { raf = 0; onScroll(); });
      };
      window.addEventListener('scroll', scheduled, { passive: true });
      window.addEventListener('resize', scheduled);
      onScroll();
    });
  })();
</script>

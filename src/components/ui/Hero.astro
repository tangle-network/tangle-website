---
/**
 * Hero.astro — shared hero block for every marketing page.
 * Generation 2 extraction from /brand-kit's hero pattern (the only page that
 * scored 7.9 on staff-design review). Replaces 8 bespoke hero CSS blocks
 * (~800 lines of `wf-*` snowflake CSS) with one Astro component.
 *
 * Inline styles + brand tokens. No `wf-*` classes. Right-column slot
 * accepts CodeWindow / ExamplePanel / image / video / nothing.
 */

interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface InstallPill {
  command: string;
  /** Optional copy-on-click — defaults to true if command provided */
  copy?: boolean;
}

interface VideoBg {
  poster: string;
  webm: string;
  mp4: string;
  /** opacity 0..1, default 0.28 */
  opacity?: number;
}

interface Props {
  /** Tag pill above headline. Use uppercase short label. */
  eyebrow?: string;
  /** Eyebrow color: 'emerald' (success surface) | 'brand' (indigo) | 'amber' (warn) */
  eyebrowColor?: 'emerald' | 'brand' | 'amber';
  /** Eyebrow icon (SVG path inner — d= and fill etc): defaults to shield */
  eyebrowIcon?: 'shield' | 'zap' | 'code' | null;
  /** Headline. HTML string supported so `<span class="wf-gradient-text">AI</span>` works. */
  title: string;
  /** Subtitle paragraph. Plain text or HTML. */
  subtitle?: string;
  /** Optional install pill — `npm install ...` style. */
  installPill?: InstallPill;
  /** Primary CTA */
  primaryCta?: CTA;
  /** Secondary CTA */
  secondaryCta?: CTA;
  /** Background video — preserved from legacy hero patterns */
  videoBg?: VideoBg;
  /** Layout: 'two-col' (text + slot) | 'one-col' (text only, centered) */
  layout?: 'two-col' | 'one-col';
  /** Alignment when layout=one-col: 'left' | 'center' */
  align?: 'left' | 'center';
}

const {
  eyebrow,
  eyebrowColor = 'emerald',
  eyebrowIcon = 'shield',
  title,
  subtitle,
  installPill,
  primaryCta,
  secondaryCta,
  videoBg,
  layout = 'two-col',
  align = 'left',
} = Astro.props;

const hasSlot = Astro.slots.has('default');

const eyebrowColors: Record<string, { bg: string; border: string; color: string }> = {
  emerald: { bg: '#022c22', border: '#14532d', color: '#34D399' },
  brand:   { bg: 'rgba(99, 102, 241, 0.08)', border: 'rgba(99, 102, 241, 0.24)', color: '#A5AAFC' },
  amber:   { bg: '#451a03', border: '#78350f', color: '#FFB800' },
};
const eb = eyebrowColors[eyebrowColor];

const eyebrowIcons: Record<string, string> = {
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  zap: '<polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
};

const showSlot = layout === 'two-col' && hasSlot;
const textAlign = layout === 'one-col' ? align : 'left';
const textItemsAlign = textAlign === 'center' ? 'center' : 'flex-start';
---

<section class="t-hero" style="position: relative; overflow: hidden; background-color: var(--depth-1); border-bottom: 1px solid var(--border-subtle);">
  <div class="t-hero-inner" style={`display: grid; grid-template-columns: ${showSlot ? 'minmax(0, 1fr) minmax(0, 1.15fr)' : 'minmax(0, 1fr)'}; gap: 3rem; align-items: center; width: 100%; max-width: 84rem; margin: 0 auto; padding: 5rem 6% 6rem; position: relative; z-index: 1;`}>
    <div class="t-hero-text" style={`display: flex; flex-direction: column; align-items: ${textItemsAlign}; text-align: ${textAlign}; gap: 1.5rem; max-width: ${showSlot ? '32rem' : layout === 'one-col' && align === 'center' ? '52rem' : '60rem'}; min-width: 0;`}>
      {eyebrow && (
        <span style={`display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.75rem; border-radius: 999px; background: ${eb.bg}; border: 1px solid ${eb.border}; color: ${eb.color}; font-family: var(--font-sans); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; line-height: 1;`}>
          {eyebrowIcon && eyebrowIcons[eyebrowIcon] && (
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={eyebrowIcons[eyebrowIcon]} />
          )}
          {eyebrow}
        </span>
      )}
      <h1 style={`font-family: var(--font-display); font-size: clamp(2.75rem, 6vw + 0.5rem, 5.25rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.05; color: var(--text-primary); margin: 0; text-wrap: balance;`} set:html={title} />
      {subtitle && (
        <p style={`font-family: var(--font-sans); font-size: 1.125rem; line-height: 1.55; color: var(--text-secondary); margin: 0; max-width: 38rem;`} set:html={subtitle} />
      )}
      {installPill && (
        <div class="t-hero-install" style="display: inline-flex; align-items: center; gap: 0.625rem; padding: 0.625rem 0.875rem; background: var(--depth-3); border: 1px solid var(--border-default); border-radius: 8px; font-family: var(--font-mono); font-size: 13px; color: var(--text-primary); cursor: pointer; user-select: all; max-width: 100%; overflow: hidden;" data-install-pill data-copy={installPill.command}>
          <span style="color: var(--brand-cool); flex-shrink: 0;">$</span>
          <code style="background: none; padding: 0; color: inherit; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{installPill.command}</code>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; opacity: 0.5;"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <span class="t-hero-copied" style="position: absolute; top: -28px; right: 0; padding: 4px 10px; background: #34D399; color: var(--depth-1); font-family: var(--font-sans); font-size: 11px; font-weight: 700; border-radius: 6px; opacity: 0; transition: opacity 0.16s ease; pointer-events: none; white-space: nowrap;">Copied</span>
        </div>
      )}
      {(primaryCta || secondaryCta) && (
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem;">
          {primaryCta && (
            <a
              href={primaryCta.href}
              target={primaryCta.external ? '_blank' : undefined}
              rel={primaryCta.external ? 'noopener noreferrer' : undefined}
              style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background-color: var(--brand-dim); border: 1px solid var(--brand-dim); color: white; border-radius: 10px; font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 600; line-height: 1.2; text-decoration: none; transition: background-color 0.16s ease, border-color 0.16s ease, transform 0.16s ease; box-shadow: 0 4px 18px rgba(79, 70, 229, 0.32);"
              onmouseover="this.style.backgroundColor='var(--brand-primary)'; this.style.borderColor='var(--brand-primary)'; this.style.transform='translateY(-1px)';"
              onmouseout="this.style.backgroundColor='var(--brand-dim)'; this.style.borderColor='var(--brand-dim)'; this.style.transform='translateY(0)';"
            >
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              target={secondaryCta.external ? '_blank' : undefined}
              rel={secondaryCta.external ? 'noopener noreferrer' : undefined}
              style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background-color: var(--depth-3); border: 1px solid var(--border-default); color: var(--text-primary); border-radius: 10px; font-family: var(--font-sans); font-size: 0.9375rem; font-weight: 600; line-height: 1.2; text-decoration: none; transition: background-color 0.16s ease, border-color 0.16s ease;"
              onmouseover="this.style.backgroundColor='var(--depth-4)'; this.style.borderColor='var(--border-accent)';"
              onmouseout="this.style.backgroundColor='var(--depth-3)'; this.style.borderColor='var(--border-default)';"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>

    {showSlot && (
      <div class="t-hero-slot" style="min-width: 0;">
        <slot />
      </div>
    )}
  </div>

  {videoBg && (
    <div style={`position: absolute; inset: 0; z-index: 0; opacity: ${videoBg.opacity ?? 0.28}; pointer-events: none;`}>
      <video autoplay loop muted playsinline poster={videoBg.poster} style="width: 100%; height: 100%; object-fit: cover;">
        <source src={videoBg.webm} type="video/webm" />
        <source src={videoBg.mp4} type="video/mp4" />
      </video>
    </div>
  )}
</section>

<style>
  @media (max-width: 991px) {
    .t-hero-inner {
      grid-template-columns: minmax(0, 1fr) !important;
      gap: 2rem !important;
    }
    .t-hero-text {
      max-width: 100% !important;
    }
  }
  .t-hero-install {
    position: relative;
  }
  .t-hero-install.copied .t-hero-copied {
    opacity: 1 !important;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-install-pill]').forEach((el) => {
    el.addEventListener('click', async () => {
      const cmd = el.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(cmd);
        el.classList.add('copied');
        setTimeout(() => el.classList.remove('copied'), 1200);
      } catch (e) {
        // clipboard blocked; selection fallback
        const range = document.createRange();
        range.selectNode(el);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    });
  });
</script>

---
interface Props {
  icon?: string;
  iconColor?: 'indigo' | 'emerald' | 'amber' | 'blue' | 'rose';
  title: string;
  body: string;
  href?: string;
  cta?: string;
  variant?: 'dark' | 'vault';
  sharp?: boolean;
}

const {
  icon,
  iconColor = 'indigo',
  title,
  body,
  href,
  cta,
  variant = 'dark',
  sharp = true,
} = Astro.props;

const iconColors: Record<string, string> = {
  indigo: 'background: rgba(99,102,241,0.14); color: #818CF8;',
  emerald: 'background: rgba(16,185,129,0.14); color: #34D399;',
  amber: 'background: rgba(255,184,0,0.14); color: #FFB800;',
  blue: 'background: rgba(77,155,255,0.14); color: #4AABFF;',
  rose: 'background: rgba(255,77,109,0.14); color: #FF4D6D;',
};

const Tag = href ? 'a' : 'div';
---

<Tag
  {...(href ? { href, rel: href.startsWith('http') ? 'noopener noreferrer' : undefined } : {})}
  class={`fc-card fc-card--${variant}`}
  style={sharp ? 'border-radius: 0;' : 'border-radius: 12px;'}
>
  {icon && (
    <div class="fc-icon" style={iconColors[iconColor]} set:html={icon} />
  )}
  <div class="fc-title">{title}</div>
  <div class="fc-body">{body}</div>
  {cta && href && (
    <div class="fc-cta">
      {cta}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
  )}
</Tag>

<style is:global>
  .fc-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color 0.16s ease, background-color 0.16s ease;
  }

  .fc-card:hover {
    border-color: var(--border-accent);
    background-color: var(--depth-4);
  }

  .fc-card--vault {
    background: #ffffff;
    color: #191c24;
    border: 1px solid rgba(110, 108, 148, 0.25);
  }

  .fc-card--vault:hover {
    background: #fafbfc;
    border-color: rgba(99, 102, 241, 0.35);
  }

  .fc-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .fc-icon svg {
    width: 22px;
    height: 22px;
    stroke-width: 2;
  }

  .fc-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: inherit;
  }

  .fc-body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--text-secondary);
    flex: 1;
  }

  .fc-card--vault .fc-body {
    color: #3a3a50;
  }

  .fc-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-primary);
  }

  .fc-card--vault .fc-cta {
    color: #3E349E;
  }
</style>

---
interface Tab {
  id: string;
  label: string;
  icon?: 'code' | 'terminal';
  html: string;
}

interface Props {
  tabs: Tab[];
  activeTab?: string;
  filename?: string;
}

const { tabs, activeTab = tabs[0]?.id, filename } = Astro.props;

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
};
---

<div class="cw-window">
  <div class="cw-titlebar">
    <div class="cw-dots">
      <span class="cw-dot cw-dot--red"></span>
      <span class="cw-dot cw-dot--yellow"></span>
      <span class="cw-dot cw-dot--green"></span>
    </div>
    {tabs.length > 1 ? (
      <div class="cw-tabs" role="tablist">
        {tabs.map((t) => (
          <button
            type="button"
            class:list={["cw-tab", { "cw-tab--active": t.id === activeTab }]}
            data-cw-tab={t.id}
            role="tab"
            aria-selected={t.id === activeTab}
          >
            {t.icon && (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[t.icon]} />
            )}
            {t.label}
          </button>
        ))}
      </div>
    ) : filename ? (
      <span class="cw-filename">{filename}</span>
    ) : null}
  </div>
  <div class="cw-body">
    {tabs.map((t) => (
      <div class="cw-pane" data-cw-pane={t.id} hidden={t.id !== activeTab} set:html={t.html} />
    ))}
  </div>
</div>

<style is:global>
  .cw-window {
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    font-family: var(--font-mono);
  }

  .cw-titlebar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--border-default);
    background: var(--depth-4);
  }

  .cw-dots {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .cw-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .cw-dot--red { background: #FF5F57; }
  .cw-dot--yellow { background: #FEBC2E; }
  .cw-dot--green { background: #28C840; }

  .cw-tabs {
    display: flex;
    gap: 0.25rem;
    height: 1.75rem;
    padding: 0.125rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 8px;
    margin-left: 0.5rem;
  }

  .cw-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    height: 100%;
    padding: 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    background: transparent;
    border: 0;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.16s ease, background-color 0.16s ease;
  }

  .cw-tab:hover {
    color: var(--text-secondary);
  }

  .cw-tab--active {
    background: var(--depth-3);
    color: var(--text-primary);
  }

  .cw-filename {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .cw-body {
    padding: 1.125rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-primary);
    overflow-x: auto;
    white-space: pre;
    min-height: 16rem;
  }

  .cw-pane[hidden] {
    display: none;
  }

  /* Syntax token colors (shared with sandbox-ui) */
  .cw-k { color: #A78FFF; }
  .cw-s { color: #34D399; }
  .cw-c { color: #64648a; font-style: italic; }
  .cw-f { color: #6D9FFF; }
  .cw-n { color: #FFB347; }
  .cw-v { color: #E8E6F6; }
  .cw-sh { color: #10B981; font-weight: 600; }
  .cw-p { color: #6366F1; font-weight: 600; }
</style>

<script>
  document.querySelectorAll('.cw-window').forEach((win) => {
    const tabs = win.querySelectorAll<HTMLButtonElement>('[data-cw-tab]');
    const panes = win.querySelectorAll<HTMLDivElement>('[data-cw-pane]');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.cwTab;
        tabs.forEach((t) => {
          const active = t.dataset.cwTab === id;
          t.classList.toggle('cw-tab--active', active);
          t.setAttribute('aria-selected', String(active));
        });
        panes.forEach((p) => {
          p.hidden = p.dataset.cwPane !== id;
        });
      });
    });
  });
</script>

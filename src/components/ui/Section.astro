---
/**
 * Section.astro. canonical page section.
 *
 * Replaces the wf-section / wf-section-wrapper / wf-container-large triad
 * that's hand-rolled 36× across pages. Three discrete padding variants
 * (default / tight / hero) so per-page overrides go away.
 *
 * Variants:
 *   variant: 'dark' (depth-1 bg, white text)  ← default
 *           | 'vault' (white bg, near-black text. light-theme rhythm)
 *           | 'transparent' (no bg, inherits. for stacking inside another section)
 *
 *   pad:    'default' | 'tight' | 'hero'  ← maps to --section-pad-*
 *
 *   maxWidth: 'wide' (84rem) | 'narrow' (64rem) | 'full'
 *
 * Slot:
 *   default. section content. Caller arranges its own grid/flex inside.
 *
 * Pattern matches Hero.astro: inline styles for layout-critical values
 * (defeats Astro CSS scoping issues that hit us in the --brand-dim bug),
 * tokens for everything color-related, one <style> block at end for
 * cascade-required things (media queries).
 */

interface Props {
  variant?: 'dark' | 'vault' | 'transparent';
  pad?: 'default' | 'tight' | 'hero';
  maxWidth?: 'wide' | 'narrow' | 'full';
  id?: string;
  class?: string;
}

const {
  variant = 'dark',
  pad = 'default',
  maxWidth = 'wide',
  id,
  class: className,
} = Astro.props;

const padToken = `var(--section-pad-${pad})`;
const padMobileToken = `var(--section-pad-mobile-${pad})`;

const maxWidthValue = maxWidth === 'wide' ? '84rem'
                    : maxWidth === 'narrow' ? '64rem'
                    : '100%';

const bgStyle = variant === 'vault'
  ? 'background-color: #f4f4f9; color: #191c24; border-top: 1px solid rgba(0,0,0,0.08); border-bottom: 1px solid rgba(0,0,0,0.08);'
  : variant === 'transparent'
  ? 'background: transparent;'
  : 'background-color: var(--depth-1); color: var(--text-primary);';
---

<section
  id={id}
  class:list={['t-section', `t-section--${variant}`, `t-section--pad-${pad}`, className]}
  style={`${bgStyle} padding: ${padToken}; position: relative;`}
  data-pad={pad}
  data-pad-mobile={padMobileToken}
>
  <div class="t-section-inner" style={`max-width: ${maxWidthValue}; margin: 0 auto; position: relative; z-index: 1;`}>
    <slot />
  </div>
</section>

<style>
  /* Mobile padding override. uses the data-pad-mobile attr to pick the
     right token. We can't use CSS custom-prop attribute fallbacks
     in older browsers, so we just write three explicit rules. */
  @media (max-width: 768px) {
    .t-section--pad-default { padding: var(--section-pad-mobile-default) !important; }
    .t-section--pad-tight   { padding: var(--section-pad-mobile-tight)   !important; }
    .t-section--pad-hero    { padding: var(--section-pad-mobile-hero)    !important; }
  }
</style>

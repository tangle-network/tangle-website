---
interface SubTab {
  id: string;
  label: string;
  icon?: 'code' | 'terminal' | 'curl' | 'docker' | 'py';
  html: string;
}

interface Group {
  id: string;
  label: string;
  accent?: 'indigo' | 'emerald' | 'amber' | 'blue';
  tabs: SubTab[];
}

interface Props {
  groups: Group[];
  activeGroup?: string;
}

const { groups, activeGroup = groups[0]?.id } = Astro.props;

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  curl: '<path d="M12 2a10 10 0 1 0 10 10h-10V2z"/><path d="M21.5 9H12V2.5"/>',
  docker: '<rect x="3" y="8" width="5" height="5"/><rect x="9" y="8" width="5" height="5"/><rect x="15" y="8" width="5" height="5"/><path d="M3 13h17v2a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-2z"/>',
  py: '<path d="M12 2C8 2 8 5 8 5v2h4v1H5s-3 0-3 4 3 4 3 4h2v-3s0-3 3-3h4s3 0 3-3V5s0-3-4-3h-1zM10 4a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/><path d="M12 22c4 0 4-3 4-3v-2h-4v-1h7s3 0 3-4-3-4-3-4h-2v3s0 3-3 3h-4s-3 0-3 3v3s0 3 4 3h1zM14 20a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>',
};
---

<div class="ev-window">
  <!-- Titlebar: Mac dots + product (group) tabs -->
  <div class="ev-titlebar">
    <div class="ev-dots">
      <span class="ev-dot ev-dot--red"></span>
      <span class="ev-dot ev-dot--yellow"></span>
      <span class="ev-dot ev-dot--green"></span>
    </div>
    <div class="ev-groups" role="tablist">
      {groups.map((g) => (
        <button
          type="button"
          class:list={["ev-group", { "ev-group--active": g.id === activeGroup }, `ev-accent-${g.accent || 'indigo'}`]}
          data-ev-group={g.id}
          role="tab"
          aria-selected={g.id === activeGroup}
        >
          {g.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Group panes: each has its own subtab strip + code panes -->
  {groups.map((g) => (
    <div
      class="ev-group-pane"
      data-ev-group-pane={g.id}
      hidden={g.id !== activeGroup}
    >
      {g.tabs.length > 1 && (
        <div class="ev-subtabs" role="tablist">
          {g.tabs.map((t, i) => (
            <button
              type="button"
              class:list={["ev-subtab", { "ev-subtab--active": i === 0 }]}
              data-ev-subtab={`${g.id}:${t.id}`}
              role="tab"
              aria-selected={i === 0}
            >
              {t.icon && (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[t.icon]} />
              )}
              {t.label}
            </button>
          ))}
        </div>
      )}
      <div class="ev-body">
        {g.tabs.map((t, i) => (
          <div
            class="ev-pane"
            data-ev-pane={`${g.id}:${t.id}`}
            hidden={i !== 0}
            tabindex="0"
            role="tabpanel"
            aria-label={`${g.label} ${t.label}`}
            set:html={t.html}
          />
        ))}
      </div>
    </div>
  ))}
</div>

<style is:global>
  .ev-window {
    background: var(--depth-3);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    font-family: var(--font-mono);
    position: relative;
  }

  .ev-titlebar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.625rem 0.875rem;
    background: var(--depth-4);
    border-bottom: 1px solid var(--border-default);
  }

  .ev-dots {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .ev-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .ev-dot--red { background: #FF5F57; }
  .ev-dot--yellow { background: #FEBC2E; }
  .ev-dot--green { background: #28C840; }

  .ev-groups {
    display: flex;
    gap: 0.25rem;
    margin-left: 0.5rem;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ev-groups::-webkit-scrollbar { display: none; }

  .ev-group {
    position: relative;
    padding: 0.375rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    background: transparent;
    border: 0;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.16s ease, background-color 0.16s ease;
    white-space: nowrap;
  }

  .ev-group:hover {
    color: var(--text-secondary);
  }

  .ev-group--active {
    color: var(--text-primary);
    background: var(--depth-3);
  }

  .ev-group--active.ev-accent-indigo { box-shadow: inset 0 -2px 0 #818CF8; }
  .ev-group--active.ev-accent-emerald { box-shadow: inset 0 -2px 0 #34D399; }
  .ev-group--active.ev-accent-amber { box-shadow: inset 0 -2px 0 #FFB800; }
  .ev-group--active.ev-accent-blue { box-shadow: inset 0 -2px 0 #4AABFF; }

  .ev-subtabs {
    display: flex;
    gap: 0.125rem;
    padding: 0.5rem 0.875rem;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ev-subtabs::-webkit-scrollbar { display: none; }

  .ev-subtab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    background: transparent;
    border: 0;
    border-radius: 5px;
    cursor: pointer;
    transition: color 0.16s ease, background-color 0.16s ease;
    white-space: nowrap;
  }

  .ev-subtab:hover { color: var(--text-secondary); }

  .ev-subtab--active {
    color: var(--text-primary);
    background: var(--depth-4);
  }

  .ev-body {
    min-height: 16rem;
  }

  .ev-pane {
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-primary);
    overflow-x: auto;
    white-space: pre;
  }

  .ev-pane[hidden],
  .ev-group-pane[hidden] {
    display: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.ev-window').forEach((win) => {
    const groupButtons = win.querySelectorAll<HTMLButtonElement>('[data-ev-group]');
    const groupPanes = win.querySelectorAll<HTMLElement>('[data-ev-group-pane]');

    groupButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.evGroup!;
        groupButtons.forEach((b) => {
          const active = b.dataset.evGroup === id;
          b.classList.toggle('ev-group--active', active);
          b.setAttribute('aria-selected', String(active));
        });
        groupPanes.forEach((p) => {
          p.hidden = p.dataset.evGroupPane !== id;
        });
      });
    });

    // Each group-pane has its own subtab set
    win.querySelectorAll<HTMLElement>('[data-ev-group-pane]').forEach((gp) => {
      const subtabBtns = gp.querySelectorAll<HTMLButtonElement>('[data-ev-subtab]');
      const codePanes = gp.querySelectorAll<HTMLElement>('[data-ev-pane]');
      subtabBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.evSubtab!;
          subtabBtns.forEach((b) => {
            const active = b.dataset.evSubtab === id;
            b.classList.toggle('ev-subtab--active', active);
            b.setAttribute('aria-selected', String(active));
          });
          codePanes.forEach((p) => {
            p.hidden = p.dataset.evPane !== id;
          });
        });
      });
    });
  });
</script>

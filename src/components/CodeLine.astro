---
interface Props {
  n: number;
  highlight?: boolean;
}

const { n, highlight = false } = Astro.props;
---

<div style={`display: flex; padding: 1px 20px; line-height: 1.55; font-size: 13px; ${highlight ? 'background: rgba(142,89,255,0.04);' : ''}`}>
  <span style="width: 28px; text-align: right; color: #3a3a5a; user-select: none; flex-shrink: 0; padding-right: 16px; font-size: 12px; line-height: 1.55;">{n}</span>
  <span style="flex: 1; white-space: pre; overflow-x: auto;"><slot /></span>
</div>

---
interface Props {
  title?: string;
  lang?: string;
  install?: string;
}

const { title = 'Terminal', lang = 'bash', install } = Astro.props;
---

<div style="position: relative;">
  <!-- Glow effect -->
  <div style="position: absolute; inset: -4px; border-radius: 16px; background: linear-gradient(135deg, rgba(142,89,255,0.15), rgba(104,136,249,0.1)); filter: blur(20px); pointer-events: none;"></div>

  <div class="wf-code-block" style="position: relative; padding: 0; border-color: rgba(142,89,255,0.2);">
    <!-- Header -->
    <div class="wf-code-header">
      <div class="wf-code-dot red"></div>
      <div class="wf-code-dot yellow"></div>
      <div style="width: 12px; height: 12px; border-radius: 50%; background: #8e59ff;"></div>
      <span class="wf-code-title">{title}</span>
      <svg style="width: 16px; height: 16px; color: #64648a; cursor: pointer; margin-left: auto;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>
    </div>
    <!-- Code content -->
    <div style="padding: 12px 0; overflow-x: auto;">
      <slot />
    </div>
  </div>
</div>

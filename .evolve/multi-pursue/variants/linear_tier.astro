---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Section from '../components/ui/Section.astro';
import BentoCell from '../components/ui/BentoCell.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
---

<BaseLayout title="Secure Infrastructure for AI" description="Sandboxed runtime, unified model routing, programmable billing. The stack underneath every agent you ship.">

  <!-- ─────────────────────────────────────────────────────────────────
       HERO — type-driven. One headline, one lede, one primary CTA, one
       ghost. No eyebrow (would duplicate "Secure Infrastructure for AI").
       Hero.astro already does clamp(2.75rem, 6vw + 0.5rem, 5.25rem) /
       letter-spacing -0.025 / line-height 1.05 / text-wrap balance per
       Linear. Full viewport min-height. The video stays — it's the only
       background motion on the page (Linear allows ambient bg motion).
       ───────────────────────────────────────────────────────────────── -->
  <Hero
    layout="one-col"
    align="center"
    title='Secure Infrastructure for <span class="wf-gradient-text">AI</span>.'
    subtitle="Sandboxed runtime. Unified model routing. Programmable billing."
    lede="Spawn an isolated box in 0.6 seconds. Route across 671 models with one key. Bill per call. Bring your framework — DSPy, Mastra, LangChain, your own."
    primaryCta={{ label: 'Start building', href: 'https://ai.tangle.tools', external: true }}
    secondaryCta={{ label: 'Read the docs', href: 'https://docs.tangle.tools', external: true }}
    videoBg={{
      poster: '/images/hero/glass-cylinders-poster.jpg',
      webm: '/videos/glass-cylinders.webm',
      mp4: '/videos/glass-cylinders.mp4',
    }}
  />

  <!-- ─────────────────────────────────────────────────────────────────
       NUMBERS — the only proof on the page above the fold. Mono,
       depth-2, tight. Linear's customer-logo-strip pattern; we don't
       have signed logos so we lead with shipped, landed numbers
       instead. 4 cells, no dividers, generous tracking. Each is a
       claim with a citation surface link.
       ───────────────────────────────────────────────────────────────── -->
  <section class="hp-numbers" aria-label="Shipped numbers">
    <div class="hp-numbers-inner">
      <div class="hp-numbers-eyebrow">SHIPPED · APR 2026</div>
      <div class="hp-numbers-grid">
        <a class="hp-num" href="/services/sandbox">
          <div class="hp-num-value">0.6<span class="hp-num-unit">s</span></div>
          <div class="hp-num-label">p50 cold-start</div>
          <div class="hp-num-tag">Sandbox SDK</div>
        </a>
        <a class="hp-num" href="https://router.tangle.tools" target="_blank" rel="noopener noreferrer">
          <div class="hp-num-value">671</div>
          <div class="hp-num-label">models, 14 providers</div>
          <div class="hp-num-tag">Tangle Router</div>
        </a>
        <a class="hp-num" href="/services/browser-agent">
          <div class="hp-num-value">90<span class="hp-num-unit">%</span></div>
          <div class="hp-num-label">WebBench-50 pass rate</div>
          <div class="hp-num-tag">Browser Agent</div>
        </a>
        <a class="hp-num" href="/services/sandbox#pricing">
          <div class="hp-num-value">$0.06<span class="hp-num-unit">/vCPU-hr</span></div>
          <div class="hp-num-label">compute, billed per second</div>
          <div class="hp-num-tag">Sandbox SDK</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────────────
       ONE PRODUCT MOMENT — the optimization loop. This is the ONE
       diagram that says what nothing else in the category says: the
       four surfaces (Profile / Sandbox / Data / Evals) optimize in a
       loop, scored against ground truth, until convergence. Dark
       surface, left-aligned section head, single ghost link footer.
       The SVG is the hero visual — no card, no bento, no extra chrome.
       ───────────────────────────────────────────────────────────────── -->
  <Section variant="dark" pad="default" maxWidth="wide">
    <div class="hp-loop">
      <div class="hp-loop-meta">
        <div class="hp-loop-eyebrow">THE LOOP</div>
        <h2 class="hp-loop-title">Agents converge on goals, not vibes.</h2>
        <p class="hp-loop-lede">Profile, Sandbox, Data, Evals — each independently versioned, each a knob the optimizer turns. Every variant runs in an isolated box, scores against ground truth, and the protocol settles SLAs and routes payouts so the loop converges on economics.</p>
        <a class="hp-loop-link" href="/overview">
          See how the loop works
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="hp-loop-orbit" aria-hidden="true">
        <svg viewBox="-160 -160 320 320" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="hp-loop-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#A5AAFC"/>
              <stop offset="100%" stop-color="#6366F1"/>
            </linearGradient>
            <radialGradient id="hp-loop-glow" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#A5AAFC" stop-opacity="0.95"/>
              <stop offset="55%" stop-color="#818CF8" stop-opacity="0.4"/>
              <stop offset="100%" stop-color="#818CF8" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="hp-loop-center" cx="0.5" cy="0.5" r="0.5">
              <stop offset="0%" stop-color="#818CF8" stop-opacity="0.34"/>
              <stop offset="60%" stop-color="#6366F1" stop-opacity="0.06"/>
              <stop offset="100%" stop-color="#6366F1" stop-opacity="0"/>
            </radialGradient>
            <path id="hp-loop-path" d="M 0 -110 C 60 -110, 110 -60, 110 0 S 60 110, 0 110 S -110 60, -110 0 S -60 -110, 0 -110 Z" fill="none"/>
          </defs>
          <circle cx="0" cy="0" r="58" fill="url(#hp-loop-center)">
            <animate attributeName="r" values="48;78;48" dur="4.5s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.85;0.35;0.85" dur="4.5s" repeatCount="indefinite"/>
          </circle>
          <text x="0" y="-3" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" letter-spacing="0.16em" fill="#A5AAFC">CONVERGES</text>
          <text x="0" y="13" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="9" font-weight="700" letter-spacing="0.16em" fill="#A5AAFC">ON GOAL</text>
          <use href="#hp-loop-path" stroke="rgba(165, 170, 252, 0.22)" stroke-width="1.2" stroke-dasharray="3 4"/>
          <g fill="#818CF8">
            <polygon points="-3,-3 5,0 -3,3" transform="translate(110, 0)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(0, 110) rotate(90)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(-110, 0) rotate(180)"/>
            <polygon points="-3,-3 5,0 -3,3" transform="translate(0, -110) rotate(-90)"/>
          </g>
          <circle r="14" fill="url(#hp-loop-glow)">
            <animateMotion dur="6s" repeatCount="indefinite" rotate="auto"><mpath href="#hp-loop-path"/></animateMotion>
          </circle>
          <circle r="3.5" fill="#A5AAFC">
            <animateMotion dur="6s" repeatCount="indefinite" rotate="auto"><mpath href="#hp-loop-path"/></animateMotion>
          </circle>
          <g class="hp-loop-node hp-loop-node--01">
            <circle cx="0" cy="-110" r="22" fill="#141328" stroke="url(#hp-loop-grad)" stroke-width="1.5"/>
            <circle cx="0" cy="-110" r="22" fill="none" stroke="rgba(129, 140, 248, 0.55)" stroke-width="2" class="hp-loop-pulse"/>
            <text x="0" y="-114" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#A5AAFC" letter-spacing="0.12em">01</text>
            <text x="0" y="-101" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#fdfdfd">Profile</text>
          </g>
          <g class="hp-loop-node hp-loop-node--02">
            <circle cx="110" cy="0" r="22" fill="#141328" stroke="url(#hp-loop-grad)" stroke-width="1.5"/>
            <circle cx="110" cy="0" r="22" fill="none" stroke="rgba(129, 140, 248, 0.55)" stroke-width="2" class="hp-loop-pulse"/>
            <text x="110" y="-4" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#A5AAFC" letter-spacing="0.12em">02</text>
            <text x="110" y="9" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#fdfdfd">Sandbox</text>
          </g>
          <g class="hp-loop-node hp-loop-node--03">
            <circle cx="0" cy="110" r="22" fill="#141328" stroke="url(#hp-loop-grad)" stroke-width="1.5"/>
            <circle cx="0" cy="110" r="22" fill="none" stroke="rgba(129, 140, 248, 0.55)" stroke-width="2" class="hp-loop-pulse"/>
            <text x="0" y="106" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#A5AAFC" letter-spacing="0.12em">03</text>
            <text x="0" y="119" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#fdfdfd">Data</text>
          </g>
          <g class="hp-loop-node hp-loop-node--04">
            <circle cx="-110" cy="0" r="22" fill="#141328" stroke="url(#hp-loop-grad)" stroke-width="1.5"/>
            <circle cx="-110" cy="0" r="22" fill="none" stroke="rgba(129, 140, 248, 0.55)" stroke-width="2" class="hp-loop-pulse"/>
            <text x="-110" y="-4" text-anchor="middle" font-family="Geist Mono, ui-monospace, monospace" font-size="7" font-weight="700" fill="#A5AAFC" letter-spacing="0.12em">04</text>
            <text x="-110" y="9" text-anchor="middle" font-family="Outfit, sans-serif" font-size="11" font-weight="700" fill="#fdfdfd">Evals</text>
          </g>
        </svg>
      </div>
    </div>
  </Section>

  <!-- ─────────────────────────────────────────────────────────────────
       PRODUCTS — vault surface (the page's one rhythm break). Tight,
       restrained. Three cards, one mechanism each, no icons-on-circles
       chrome. Section head left-aligned per Linear (NOT centered).
       Footer is a single text anchor, not a CTA grid.
       ───────────────────────────────────────────────────────────────── -->
  <Section variant="vault" pad="default" maxWidth="wide" id="products">
    <div class="hp-prod-head">
      <div class="hp-prod-eyebrow">PRODUCTS</div>
      <h2 class="hp-prod-title">One stack. Three shipping surfaces.</h2>
      <p class="hp-prod-lede">Same auth, same billing rail, same observability. Use one. Compose all of them.</p>
    </div>

    <div class="hp-prod-grid">
      <a href="https://ai.tangle.tools" target="_blank" rel="noopener noreferrer" class="hp-prod-card">
        <BentoCell variant="vault" hover="border">
          <Fragment slot="label">01 · BLUEPRINT AGENT</Fragment>
          <Fragment slot="title">Describe the service. Watch four models build it.</Fragment>
          <Fragment slot="body">Plain-English spec in. Working repo, tests passing, PR open out. Backed by the optimization loop.</Fragment>
          <span class="hp-prod-link">Try Blueprint Agent →</span>
        </BentoCell>
      </a>
      <a href="/services/browser-agent" class="hp-prod-card">
        <BentoCell variant="vault" hover="border">
          <Fragment slot="label">02 · BROWSER AGENT</Fragment>
          <Fragment slot="title">90% pass on WebBench-50.</Fragment>
          <Fragment slot="body">Plain-English goals. Real Chromium. Screenshot + DOM evidence on every turn. Replay any failure.</Fragment>
          <span class="hp-prod-link">See it run →</span>
        </BentoCell>
      </a>
      <a href="/services/sandbox" class="hp-prod-card">
        <BentoCell variant="vault" hover="border">
          <Fragment slot="label">03 · SANDBOX SDK</Fragment>
          <Fragment slot="title">Isolated boxes in 0.6 seconds.</Fragment>
          <Fragment slot="body">Any Docker image. Snapshot, restore, fork. SOC2: 55 of 57 controls in place. $0.06 per vCPU-hour.</Fragment>
          <span class="hp-prod-link">Read the SDK →</span>
        </BentoCell>
      </a>
    </div>

    <div class="hp-prod-foot">
      <a href="/products">Every product →</a>
    </div>
  </Section>

  <!-- ─────────────────────────────────────────────────────────────────
       FOOTER CTA — single moment. One button. Linear's "Open Linear"
       pattern.
       ───────────────────────────────────────────────────────────────── -->
  <CtaBlock
    title="Ship the agent, not five vendor integrations."
    body="One auth. One bill. One stack underneath."
    primaryCta={{ label: 'Open the workbench', href: 'https://ai.tangle.tools', external: true }}
  />

  <!-- ─────────────────────────────────────────────────────────────────
       Page-scoped styles. Tokens only — no hex except where the surface
       requires a stop the token system doesn't expose (orbit fills,
       which need #141328 to match dark depth-2 inside the SVG).
       ───────────────────────────────────────────────────────────────── -->
  <style>
    /* ── NUMBERS STRIP ──────────────────────────────────────────────
       Mono labels, big serif-style numbers. Replaces the "logos" strip
       Linear / Stripe use; we don't have signed logos, so landed numbers
       are the proof. depth-2 bg between hero (depth-1) and loop section
       (depth-1) — gives the page a barely-perceptible lift, not a
       break. */
    .hp-numbers {
      background: var(--depth-2);
      border-top: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
      padding: 4rem 8% 4.5rem;
    }
    .hp-numbers-inner {
      max-width: 84rem;
      margin: 0 auto;
    }
    .hp-numbers-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--type-mono-eyebrow);
      letter-spacing: var(--type-mono-eyebrow-track);
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 2rem;
    }
    .hp-numbers-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
    }
    .hp-num {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 0.5rem 2rem 0.5rem 0;
      border-left: 1px solid var(--border-subtle);
      padding-left: 2rem;
      text-decoration: none;
      transition: border-color 0.2s ease;
    }
    .hp-num:first-child {
      padding-left: 0;
      border-left: 0;
    }
    .hp-num:hover {
      border-left-color: var(--brand-cool);
    }
    .hp-num:first-child:hover {
      border-left: 0;
    }
    .hp-num-value {
      font-family: var(--font-display);
      font-size: clamp(2.25rem, 3.4vw + 0.5rem, 3.25rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      color: var(--text-primary);
      font-feature-settings: "tnum" 1;
    }
    .hp-num-unit {
      font-size: 0.55em;
      font-weight: 600;
      color: var(--text-secondary);
      letter-spacing: -0.01em;
      margin-left: 0.1em;
    }
    .hp-num-label {
      font-family: var(--font-sans);
      font-size: 0.9375rem;
      line-height: 1.4;
      color: var(--text-secondary);
    }
    .hp-num-tag {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }
    @media (max-width: 900px) {
      .hp-numbers { padding: 3rem 6% 3.5rem; }
      .hp-numbers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 2rem 1.5rem; }
      .hp-num { border-left: 0 !important; padding-left: 0; }
    }

    /* ── ONE PRODUCT MOMENT — THE LOOP ──────────────────────────────
       Two-column grid, generous gap. Meta on left, orbit on right.
       Section head is left-aligned (Linear pattern), eyebrow is mono
       semantically distinct from hero ("THE LOOP" ≠ "Secure
       Infrastructure"). */
    .hp-loop {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
      gap: 6rem;
      align-items: center;
    }
    .hp-loop-meta {
      max-width: 36rem;
    }
    .hp-loop-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--type-mono-eyebrow);
      letter-spacing: var(--type-mono-eyebrow-track);
      text-transform: uppercase;
      color: var(--brand-cool);
      margin-bottom: 1.25rem;
    }
    .hp-loop-title {
      font-family: var(--font-display);
      font-size: var(--type-h2);
      font-weight: var(--type-h2-weight);
      line-height: var(--type-h2-line);
      letter-spacing: var(--type-h2-track);
      color: var(--text-primary);
      margin: 0 0 1.5rem;
      text-wrap: balance;
    }
    .hp-loop-lede {
      font-family: var(--font-sans);
      font-size: var(--type-body-l);
      line-height: 1.6;
      color: var(--text-secondary);
      margin: 0 0 2rem;
    }
    .hp-loop-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-sans);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--brand-cool);
      text-decoration: none;
      transition: color 0.16s ease, gap 0.16s ease;
    }
    .hp-loop-link:hover {
      color: var(--brand-glow);
      gap: 0.75rem;
    }
    .hp-loop-orbit {
      position: relative;
      aspect-ratio: 1 / 1;
      max-width: 32rem;
      margin: 0 auto;
      padding: 1.5rem;
    }
    .hp-loop-orbit svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }
    .hp-loop-pulse {
      transform-origin: center;
      transform-box: fill-box;
      animation: hp-loop-pulse 6s linear infinite;
      opacity: 0;
    }
    .hp-loop-node--01 .hp-loop-pulse { animation-delay: 0s; }
    .hp-loop-node--02 .hp-loop-pulse { animation-delay: -4.5s; }
    .hp-loop-node--03 .hp-loop-pulse { animation-delay: -3s; }
    .hp-loop-node--04 .hp-loop-pulse { animation-delay: -1.5s; }
    @keyframes hp-loop-pulse {
      0%   { transform: scale(1);   opacity: 0; }
      8%   { transform: scale(1);   opacity: 0.95; }
      28%  { transform: scale(1.7); opacity: 0; }
      100% { transform: scale(1.7); opacity: 0; }
    }
    @media (max-width: 1100px) {
      .hp-loop { grid-template-columns: 1fr; gap: 3rem; }
      .hp-loop-meta { max-width: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hp-loop-pulse { animation: none; opacity: 0.55; }
    }

    /* ── PRODUCTS ──────────────────────────────────────────────────
       Left-aligned section head (Linear), 3-col grid, single text
       footer link. Restraint: no icons, no per-card CTA buttons —
       the whole card is the link. */
    .hp-prod-head {
      max-width: 44rem;
      margin-bottom: 3rem;
    }
    .hp-prod-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--type-mono-eyebrow);
      letter-spacing: var(--type-mono-eyebrow-track);
      text-transform: uppercase;
      color: #4F46E5;
      margin-bottom: 1rem;
    }
    .hp-prod-title {
      font-family: var(--font-display);
      font-size: var(--type-h2);
      font-weight: var(--type-h2-weight);
      line-height: var(--type-h2-line);
      letter-spacing: var(--type-h2-track);
      color: #191c24;
      margin: 0 0 1rem;
      text-wrap: balance;
    }
    .hp-prod-lede {
      font-family: var(--font-sans);
      font-size: var(--type-body-l);
      line-height: 1.55;
      color: #3a3a50;
      margin: 0;
    }
    .hp-prod-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
    .hp-prod-card {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .hp-prod-link {
      display: inline-block;
      margin-top: 0.75rem;
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 600;
      color: #4F46E5;
      transition: color 0.16s ease;
    }
    .hp-prod-card:hover .hp-prod-link {
      color: #6366F1;
    }
    .hp-prod-foot {
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(0,0,0,0.08);
    }
    .hp-prod-foot a {
      font-family: var(--font-mono);
      font-size: var(--type-mono-eyebrow);
      letter-spacing: var(--type-mono-eyebrow-track);
      text-transform: uppercase;
      color: #5e5e7a;
      text-decoration: none;
      transition: color 0.16s ease;
    }
    .hp-prod-foot a:hover {
      color: #4F46E5;
    }
    @media (max-width: 900px) {
      .hp-prod-grid { grid-template-columns: 1fr; }
    }
  </style>

</BaseLayout>
